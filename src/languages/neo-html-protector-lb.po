msgid "設定"
msgstr "Astellungen"

msgid "IPログリーダー"
msgstr "IP-Log-Lieser"

msgid "IPアドレスログ"
msgstr "IP-Adress-Log"

msgid "全クリア"
msgstr "Fäerdeg maachen all d'Niveauen"

msgid "IPログが全て削除されました"
msgstr "All IP-Logdateien goufen geläscht."

msgid "ID"
msgstr "Identifikatioun"

msgid "タイムスタンプ"
msgstr "Zäitstempel"

msgid "IPアドレス"
msgstr "IP-Adress"

msgid "ユーザーエージェント"
msgstr "Benotzeragent"

msgid "イベント"
msgstr "Evenement"

msgid "IPアドレスのデータはありません"
msgstr "Et ginn keng Donnéeën fir d'IP-Adress."

msgid "EU GDPR対応"
msgstr "Konformitéit mat der EU-DSGVO"

msgid "無効"
msgstr "Net gëlteg"

msgid "有効"
msgstr "Gëlteg"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Wann Dir WordPress an der EU benotzt oder wann Är Websäit op Benotzer an der EU ausgeriicht ass, suergt w.e.g. datt dëst aktivéiert ass."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "De Knäppchen 'Bestätegen' gëtt zu 'Zoustëmmen' oder 'Net averstan' geännert, an d'Verhalen ännert sech e bësse."

msgid "同意画面の色"
msgstr "Faarf vum Zoustëmmungsbildschierm"

msgid "自動"
msgstr "Automatesch"

msgid "ライトモード"
msgstr "Liichtmodus"

msgid "ダークモード"
msgstr "Däischter Modus"

msgid "同意画面表示中の配色を設定します"
msgstr "Setzt d'Faarferschema fir de Zoustëmmungsbildschierm."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Verwëschelung vum Inhalt um Zoustëmmungsbildschierm"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Setzt de Schärfegrad vum Inhalt, deen um Zoustëmmungsbildschierm ugewisen gëtt."

msgid "同意画面の透過"
msgstr "Transparenz vum Zoustëmmungsbildschierm"

msgid "透過なし"
msgstr "Keng Transparenz"

msgid "同意画面の透過具合を設定します"
msgstr "Setzt d'Transparenz vum Zoustëmmungsbildschierm."

msgid "お知らせの1行目"
msgstr "Éischt Zeil vun der Annonce"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Dës Noriicht gëtt ëmmer d'éischt Kéier ugewisen, wann d'Säit geluede gëtt."

msgid "お知らせの2行目"
msgstr "Déi zweet Zeil vun der Notiz"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Dës Noriicht erschéngt ëmmer nëmmen op dem éischte Display, wann d'EU-DSGVO a Kraaft ass."

msgid "お知らせの3行目"
msgstr "Déi drëtt Zeil vun der Notiz"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Et wäert riets vum Link op d'Datenschutzpolitik erschéngen."

msgid "非EU向け確認の文字列"
msgstr "Bestätegungstext fir net-EU-Länner"

msgid "EU GDPR向け同意するの文字列"
msgstr "Zoustëmmungstext fir d'EU-DSGVO"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Text fir 'Net zoustëmmen' ënner der EU-DSGVO"

msgid "プライバシーポリシーの文字列"
msgstr "Datenschutzerklärungstext"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Setzt w.e.g. hei d'URL fir d'Datenschutzerklärung."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Füügt w.e.g. d'Folgendes an d'Datenschutzrichtlinnen derbäi."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Fir betrügeresch Aktivitéiten z'entdecken, ginn Identifikateuren wéi IP-Adressen an Cookies an an der Datebank gespäichert. D'gespäichert Donnéeën ginn no Ermëttlung vum Administrator geläscht."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Fir sécherzestellen, datt Biller nëmmen dann korrekt geliwwert ginn, wann de Bilderschutz aktivéiert ass, späichere mir gehäschte Date, déi d'IP-Adress an den Numm vun der Bilddatei enthalen, fir bis zu 60 Minutten an der Datebank."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Wann Dir d'Benotzungsbedéngungen opstellt, suergt w.e.g. dofir, datt Dir e Link op si an Ärer Privatsphärpolitik enthält."

msgid "利用規約の文字列"
msgstr "Text vun de Benotzungsbedéngungen"

msgid "利用規約のページ"
msgstr "Säit mat de Bedéngungen a Bestëmmungen"

msgid "ページ選択なし"
msgstr "Keng Säit ausgewielt"

msgid "検索エンジン等のURL"
msgstr "URLen fir Sichmotoren, asw."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Setzt d'URL fir Sichmotoren an ähnlech Siten, déi d'Benotzer weiderleeden, wann keng Zoustëmmung gëtt."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Feeler-Modus, Warnungsmessagen vun der Konsole"

msgid "右クリックの警告メッセージ"
msgstr "Rechter-Klick-Warnungsbotschaft"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Warnungsmelltung betreffend d'Drockéierung an d'Späicheren als PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Warnungsnoriicht am Screenshot"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Warnungsnoriicht iwwer verdächteg Screenshots"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Warnungsnoriicht wann de ganze Text ausgewielt ass"

msgid "ページ保存の警告メッセージ"
msgstr "Warnungsbotschaft betreffend d'Späichere vun der Säit"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Noriicht, déi ugewisen gëtt, wann kopéiert oder ausgeschnidden gëtt"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Noriicht, déi ugewisen gëtt, wann d'HTML-Quell ugekuckt gëtt"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Noriicht, déi uewen am Quellcode ugewisen gëtt, wann HTML verschleiert oder geschützt gëtt."

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Noriicht fir unzeweisen, wann de Ee-mol-Authentifikatiounstoken wärend der HTML-Protektion ongëlteg ass"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Noriicht fir unzeweisen, wann Cookies oder JavaScript ausgeschalt sinn"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Tatsächlech gëtt dëst nëmmen ugewisen, wann JavaScript ausgeschalt ass."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Wann e Bild geschützt ass, gëtt et erofgeluede, an eng Noriicht gëtt op deem Bild ugewisen"

msgid "HTML難読化 (圧縮)"
msgstr "HTML-Obfuskatioun"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Dëst ass Standard-HTML-Kompressioun; et ginn och Websäiten, déi et dekodéiere kënnen."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Duerch d'Aktivéiere vun dëser Optioun kënnt Dir View-Source-Logs ofruffen."

msgid "HTML保護"
msgstr "HTML-Schutz"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Et gëtt nëmmen dat nackte Minimum u HTML eraus—sogar nach manner wéi bei der HTML-Kompressioun—an de Contenu bannent dem BODY-Tag gëtt iwwerhaapt net erausginn."

msgid "Firefoxに対しては無効です"
msgstr "Dëst gëllt net fir Firefox."

msgid "SEOに著しく影響があります"
msgstr "Dëst huet e wesentlechen Afloss op d'SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "HTML mat JavaScript rendéieren"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Fir ëm Firefox erëm ze kommen, renderen mir d'HTML mat JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "D'Erlaabung vum JavaScript-Rendering verlangsamt d'Luedgeschwindegkeet vun der Websäit wesentlech."

msgid "画像の保護"
msgstr "Bildschutz"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Beschützt d'Bild all Kéier wann de img-Tag geruff gëtt."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Schützt all Biller, déi an WordPress eropgeluede goufen, am ganzen HTML-Ausgab."

msgid "画像をダウンロードから保護します"
msgstr "Schützt Biller dorunner, erofgeluede ze ginn."

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Wann d'Bilddaten geschützt sinn, verhënneren mir bal all Downloads, generéieren eenzegaarteg eenmolig URLs, authentifizéieren mat Tokens, déi an der Sessioun gespäichert sinn, a weisen d'Biller iwwer PHP; dat verhënnert effektiv bal all Bilddiefstal."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Wann d'Bilddaten geschützt sinn, funktionéiert d'Caching net, wat dozou féiert, datt d'Websäit bei weideren Besich méi lues geluede gëtt, an domat d'SEO beaflosst."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "D'Sécherung vun Bilddaten kann d'Belaaschtung vun der Datebank erhéijen."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Wann Dir 'Biller schützen, wann ëmmer e ‹img›-Tag ugeruff gëtt' auswielt, benotzt de System add_filter fir d'Filtratioun unzewenden, wann de ‹img›-Tag generéiert gëtt; dëst kann awer mat e puer Themen net korrekt funktionéieren."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Wann Dir 'All Biller, déi an WordPress eropgeluede goufen, am ganzen HTML-Ausgab schützen' auswielt, erfaasst de Plugin bal all WordPress-Operatiounen a veraarbecht all ‑Tag am Inhalt. W.e.g. bemierkt, datt dëst mat e puer Themen net korrekt funktionéiere kann."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "W.e.g. bemierkt, datt Biller, déi als Featured Images markéiert sinn, als OGP-Daten gedeelt ginn a net geschützt kënne ginn. Wann Dir se absolut mussen schützen, ännert w.e.g. d'Astellung fir d'Ausgab vum HEAD-Tag an de fortgeschrattene Astellungen, wann Dir d'HTML-Schutzfunktioun aktivéiert."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "D'Screenshot-Funktioun, déi als Standard am Betribssystem abegraff ass, kann net geschützt ginn."

msgid "画像URLの保護"
msgstr "D'URLen vun Biller schützen"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Dëst soll am Zesummenhang mat dem Bildschutz benotzt ginn; eleng huet et kee Sënn."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Well et iwwer JavaScript geluede gëtt, beaflosst dat d'SEO."

msgid "画像のウォーターマーク"
msgstr "Bild-Wasserzeechen"

msgid "右下"
msgstr "ënnen riets"

msgid "ランダム位置"
msgstr "Zoufälleg Positioun"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Zesumme mat dem Bildschutz benotzt, weisen dynamesch Waassermarker kloer d'Urheberrechterbesëtz an dobäi gëtt de Betrachteren den Androck, iwwerwaacht ze ginn, wat als Abschreckung déngt."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Nëmmen JPG-, PNG- a WebP-Formate ginn ënnerstëtzt."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Dëst z'erméiglechen erhéicht d'Belaaschtung um Server."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ausgab vun ASCII-Konscht aus HTML-Quellcode während der Verwëschung an dem Schutz"

msgid "表示なし"
msgstr "Keng Display"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Weist ASCII-Konscht, déi eng Warnung ugëtt, wann een d'HTML-Quell mat 'view-source' ukuckt."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Weis d'Design wann d'Zilaktioun ausgefouert gëtt"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "E Basisdesign mat schwaarzem Text op engem gielen Hannergrond"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "En Horror-Stil-Design mat roude Text op engem schwaarzen Hannergrond"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "E Design mat glühendem roude Text op engem schwaarzen Hannergrond"

msgid "対象アクションを起こした時のBGM"
msgstr "Hannergrondsmusek, déi ofgespillt gëtt, wann d'Zilaktioun ausgefouert gëtt."

msgid "サウンドなし"
msgstr "Kee Toun"

