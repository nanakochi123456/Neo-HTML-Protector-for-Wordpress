msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare – 22,3 Sekonnen – 183.926 Bytes – 64 kbps – Lizenz: Public Domain"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Retro-Stil Fanfare – 2,2 Sekonnen – 10 536 Bytes – 32 kbps – Lizenz: Public Domain"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Retro-Stil-Intro – 42,1 Sekonnen – 179.138 Bytes – 32 kbps – Lizenz: Public Domain"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Warnung vum ChatGPT - 3,8 Sekonnen - 109 700 Bytes - 256 kbps - Lizenz: Public Domain"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "E héich dréngende Toun wéi eng Malware-Detektiouns-Alarm – Deel 1 vum ChatGPT – 3,3 Sekonnen – 102.850 Bytes – 256 kbps – Lizenz: Public Domain"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "E klang mat héijer drénglechkeet wéi eng malware-detektiouns-alarm, deel 2 vun ChatGPT - 3,3 sekonnen - 103.122 bytes - 256 kbps - lizenz: public domain"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "MRI-Stil-Sound vum ChatGPT – 1 Minutt 14,9 Sekonnen – 3.340.392 Bytes – 320 kbps – Lizenz: Public Domain"

msgid "警告表示中のBGMを選択します"
msgstr "Wielt d'Hannergrondsmusek, déi wärend enger Warnung ofgespillt gëtt."

msgid "びっくりするような雰囲気を作ります"
msgstr "Et schaaft eng iwwerraschend Atmosphär."

msgid "Firefoxでは音声ブロックされます"
msgstr "Audio ass am Firefox blockéiert."

msgid "対象アクションを起こした時のビープ音"
msgstr "E Piep, wann d'gespeichert Aktioun ausgefouert gëtt"

msgid "有効 音量小さ目"
msgstr "U, Lautstëmm niddereg"

msgid "有効 音量大き目"
msgstr "Aktiv, Lautstärk op héich gesat"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "E Piep kléngt fir all Tasten- a Maus-Ereignisser, während eng Warnung ugewisen gëtt."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Et erweckt den Androck, datt d'Gerät ausser Kontroll geroden ass, während d'Warnung ugewisen gëtt."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "De Mauscursor verstoppen, wann eng bestëmmte Aktioun ausgefouert gëtt."

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Verhüllt de Mauscursor am Browserberäich, während eng Warnung ugewisen gëtt."

msgid "デバッグモード"
msgstr "Feelermoossmodus"

msgid "妨害＋記録のみ"
msgstr "Interference + Records nëmmen"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Interferenz + Protokolléierung + Display + Ëmleitung"

msgid "メニューからは操作できてしまいます"
msgstr "Dir kënnt et nach ëmmer iwwer de Menü zougräifen."

msgid "Firefoxにおけるデバッグモード"
msgstr "Feeler-Modus am Firefox"

msgid "ブラウザーコンソール"
msgstr "Browser-Konsole"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Tatsächlech kënnt Dir et am Debug-Modus bedreiwen."

msgid "HTMLソース表示"
msgstr "Usiichteg HTML-Quell"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
