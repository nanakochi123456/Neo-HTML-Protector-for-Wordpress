msgstr "Maqanakuy & Atipay - 1 minuto 16.3 segundo - 630,056 byte - 64 kbps - Saqillay: CC 2.1 utaq qhipanmanta"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Tayta Short - 3.8 sigundukuna - 32,364 bytekuna - 64 kbps - Lisinsya: GPL 2.0 utaq qhipan"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23.5 sigundukuna - 195,578 bytekuna - 64 kbps - Lisinsya: GPL 2.0 utaq qhipan"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
