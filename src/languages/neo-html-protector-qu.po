msgid "設定"
msgstr "Allichaykuna"

msgid "IPログリーダー"
msgstr "IP Qillqa Ñawiriq"

msgid "IPアドレスログ"
msgstr "IP tiyay qillqasqa"

msgid "全クリア"
msgstr "Tukuy patakunata tukuy"

msgid "IPログが全て削除されました"
msgstr "Llapan IP qillqasqakuna pichasqañam kanku."

msgid "ID"
msgstr "Pichqa yupay"

msgid "タイムスタンプ"
msgstr "Pacha qillqa"

msgid "IPアドレス"
msgstr "Llika tiyanap tupuynin"

msgid "ユーザーエージェント"
msgstr "Ruraq apachikuq"

msgid "イベント"
msgstr "Ruway"

msgid "IPアドレスのデータはありません"
msgstr "Kay IP direccionpaqqa manam willakuy kanchu."

msgid "EU GDPR対応"
msgstr "UE GDPR nisqaman hunt'ay"

msgid "無効"
msgstr "Mana chanin"

msgid "有効"
msgstr "Chanin"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "WordPress nisqata UE ukhupi llamk'achichkanki chayqa, utaq web p'anqayki UE ukhupi kaqkunapaq kachkan chayqa, ama hina kaspa, kayta churay."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' ñit'inaqa 'Arí' utaq 'Manan' nisqamanmi t'ikrakunqa, hinaspataq ruwayninpas pisillata t'ikrakunqa."

msgid "同意画面の色"
msgstr "Arí ninapaq qhawanap llimp'in"

msgid "自動"
msgstr "Kikinmanta"

msgid "ライトモード"
msgstr "Hap'iqlla ñan"

msgid "ダークモード"
msgstr "Yana Rikch'ay"

msgid "同意画面表示中の配色を設定します"
msgstr "Arí ninapaq qhawanapaq llimp'ikunata churay"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Munasqayki qhawanapi imaymanakuna laqhayay"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Munasqayki qhawana p'anqapi rikuchisqa kaqkunapaq laqhayachiy sayayninta churay."

msgid "同意画面の透過"
msgstr "Arí ninapaq qhawanap ch'uyayaynin"

msgid "透過なし"
msgstr "Mana ch'uyanchay"

msgid "同意画面の透過具合を設定します"
msgstr "Aranway qhawanap ch'uyaynin churanakuy"

msgid "お知らせの1行目"
msgstr "Willakuypa ñawpaq siq'in"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Kay willakuyqa sapa kutin rikuchikun p'anqa ñawpaq kutita kargakusqanpi."

msgid "お知らせの2行目"
msgstr "Willakuypa iskay ñiqin siq'in"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Kay willakuyqa ñawpaq qhawanapim wiñaypaq rikurinqa, EU GDPR kamachikuy kallpachasqa kachkaptinlla."

msgid "お知らせの3行目"
msgstr "Willakuypa kinsa ñiqin siq'in"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Sapanchasqa Willaykunamanta Kamachikuypa t'inkininpa paña larunpi rikhurinqa."

msgid "非EU向け確認の文字列"
msgstr "Mana UE suyukunapaq takyachina qillqa"

msgid "EU GDPR向け同意するの文字列"
msgstr "UE GDPR nisqapaq ari ninapaq qillqa"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Ama ari ninachu, UE GDPR kamachikuypaq qillqa"

msgid "プライバシーポリシーの文字列"
msgstr "Sapanchasqa willakuykunamanta kamachikuy qillqa"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Ama hina kaspa, kaypi churaq chaski kamachikuypa URL nisqanta."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Ama hina kaspa, kay qatiqta Sapanchasqa Willakuykunamanta Kamachikuyman yapay."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Llulla ruwaykunata taripanapaq, IP direccionkuna hina riqsichinakunaqa cookies nisqapi hinallataq willay taqipi waqaychasqa kanku. Waqaychasqa willaykunaqa kamachiqpa munasqanman hina pichasqa kanku."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Rikch'a amachay llamk'achkasqan pachapi rikch'akuna allinta chaskisqa kanankuta qhawanapaq, IP tiyaywan rikch'a sutintawan hap'iq hashaqchasqa willakuykunata willay taqiykupi suqta chunka minutukama waqaychayku."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Sichus Llamk'achina Kamachikuykunata churashanki, ama qunqaychu Sapanchasqa Willaykunamanta Kamachikuyniykipi chayman t'inkita churanaykita."

msgid "利用規約の文字列"
msgstr "Llamk'achina Kamachikuykunaq Qillqan"

msgid "利用規約のページ"
msgstr "Kamachikuykuna hinaspa Rurana Kamachikuykuna p'anqa"

msgid "ページ選択なし"
msgstr "Mana p'anqa akllasqachu"

msgid "検索エンジン等のURL"
msgstr "Mask'ana makinakunapaq URLkuna, hukkunapas."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Mask'ana makinakunapaq URL nisqata churay, chaykunataq mana munaspa puriqkunata hukman kachan."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Pantay allichana, consola willaykuna"

msgid "右クリックの警告メッセージ"
msgstr "Paña ñit'iywan willakuy"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDFpi ch'ipachinamanta waqaychanamantawan yuyaychay willakuy"

msgid "スクリーンショットの警告メッセージ"
msgstr "Rikch'a hap'isqapi willay"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Rikch'asqa pantallakunamanta willay"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Llapan qillqasqa akllasqa kachkaptin willay"

msgid "ページ保存の警告メッセージ"
msgstr "P'anqata waqaychaymanta willakuy"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Kutichichkaspa utaq kuchuchkaspa rikuchisqa willakuy"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML pukyu qhawaspa rikuchinapaq willakuy"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML pukllayachispa utaq amachaspa, pukllayachina qillqaq qallariyninpa hawanpi rikuchinapaq willakuy"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML amachay pachapi huk kuti llamk'aq chiqaqchana mana chanin kaptin rikuchinapaq willakuy"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Cookiekunapas JavaScriptpas mana llamk'achisqa kaptin rikuchinapaq willakuy"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Chiqaqpuniqa, kayqa JavaScript wich'usqa kachkaptinlla rikuchikun."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Huk rikch'a hark'asqa kaptinqa, uraykachisqam, chay rikch'apitaq huk willakuy rikurin"

msgid "HTML難読化 (圧縮)"
msgstr "HTML laqhayachiy"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Kayqa sapsi HTML ñit'iyninmi; kantaqmi web p'anqakunapas chayta kutichinapaq."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Kay akllanata atichispaqa, qhawana pukyu qillqakamaykunata hurquyta atinki."

msgid "HTML保護"
msgstr "HTML amachay"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Aslla HTML nisqallatam lluqsichin—HTML ñit'iywan llamk'asqamantapas aswan pisi—chaymantapas BODY unanchap ukhunpi kaqqa manam imaynallapas lluqsimunqachu."

msgid "Firefoxに対しては無効です"
msgstr "Kayqa manam Firefoxpaqchu."

msgid "SEOに著しく影響があります"
msgstr "Kayqa SEO nisqapi ancha hatun kallpayuqmi."

msgid "HTMLをJavaScriptで描画"
msgstr "JavaScriptwan HTML ruway"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox-ta muyunapaq, HTML nisqata JavaScript nisqawan rikuchiyku."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScript rikuchiyta saqiyqa web p'anqap kargakuy usqhayninta anchatapuni allillamanta kachinqa."

msgid "画像の保護"
msgstr "Rikch'ay amachay"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Sapa kuti img unancha waqyasqa kaqtin, rikch'ata amachay."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "WordPressman wichachisqa llapan rikch'akunata llapan HTML lluqsimuynin ukhupi amachay."

msgid "画像をダウンロードから保護します"
msgstr "Rikch'akunata uraykachinamanta hark'an"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Rikch'a willaykuna amachasqa kaptinqa, yaqa llapan uraykachiykunata hark'ayku, sapan kuti llamk'aq URL nisqakunata qoyku, sesión nisqapi waqaychasqa tokenkunawan chiqanchayku, hinaspa rikch'akunata PHP nisqawan rikuchiyku; kayqa allintam yaqa llapan rikch'a suwakuyta hark'an."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Rikch'a willaykuna hark'asqa kaptinqa, cache nisqa mana llamk'anchu, chayrayku web p'anqa qhipa kutikunapi aswan allillamanta kargakunqa, chaywantaq SEO nisqatapas llakichinqa."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Rikch'a willaykunata amachayqa willaykuna taqipa llasayninta yapaykunman."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "'Rikch'akunata amachay sapa kuti img unancha waqyasqa kaptin' nisqata akllanki chayqa, llikachaqa add_filter nisqawanmi suysuyta churaykun img unancha paqarichisqa kaptin; ichaqa, kayqa wakin rikch'aykunawanqa manachá allintachu llamk'anman."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "'WordPressman churasqa llapan rikch'akunata llapan HTML lluqsimuyninpi amachay' nisqata akllaptiykiqa, kay pluginqa yaqa llapan WordPress ruraykunata hap'inqa, hinaspataq qillqasqapi sapa img unanchata ruranqa. Yuyariy, kayqa wakin rikch'aykunawan mana allintachu llamk'anman."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Yuyariy, akllasqa rikch'akunaqa OGP willay hina rak'isqa kanqa, manataqmi amachay atinachu. Sichus chiqamanta amachanayki kaptinqa, HTML amachayta kichaspa, ñawpaqman risqa kamachiykunapi HEAD unanchap lluqsinanpaq kamachiyta t'ikray."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Llamk'achina llikap kikinmanta churasqa pantallamanta siq'i hap'ina ruwayninqa mana amachay atinachu."

msgid "画像URLの保護"
msgstr "Rikch'a t'inkikunata amachay"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Kayqa rikch'a amachaywan kuska llamk'achisqa kanan; sapallanqa, mana imapaqpas valenchu."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "JavaScriptwan churakusqanrayku, kayqa SEO nisqata hukmanyachin."

msgid "画像のウォーターマーク"
msgstr "Rikch'ap unanchan"

msgid "右下"
msgstr "Paña urapi"

msgid "ランダム位置"
msgstr "Mayqin sayaypas"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Rikch'a amachaywan kuska llamk'achisqa, kuyuriq unancha qillqakunaqa sut'ita rikuchinku kamachiqpa hayñin kapuqninta, chayllapitaq qhawaqkunaman qhawasqa kasqankuta yuyachispa, chaynapitaq hark'anapaq hina llamk'anku."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "JPG, PNG, WebP rikch'a rikch'aykunallam chaskisqa kanku."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Kayta saqiyqa sirwiqpa llamk'ayninta yapaykunqa."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "HTML pukyu qillqamanta ASCII kapchiyta lluqsichiy, pakaqchaypi hinallataq amachaypi."

msgid "表示なし"
msgstr "Mana rikuchinachu"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "'view-source' nisqawan HTML qallariy qillqata qhawaspa, huk willayta rikuchiq ASCII siq'ikunata rikuchin."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Munasqa ruway hunt'akuptin rikuchiyta rikuchiy"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Q'illu qhipapi yana qillqayuq sapsi siq'i."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Manchay rikch'aq ruway, yana qhipapi puka qillqayuq."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Yana qhipapi k'anchaq puka qillqayuq siq'i"

msgid "対象アクションを起こした時のBGM"
msgstr "Rurana hunt'akuptin waqariq qhipa takiy"

msgid "サウンドなし"
msgstr "Mana uyarikunchu"

