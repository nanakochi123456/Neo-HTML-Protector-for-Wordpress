msgid "ショパン スケルツォ 変ロ短調 Op2 打ち込み版 高速短縮版 - 1分48.0秒 - 665,369bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin: Scherzo B bemol menorpi, Op. 2 – Antañiqiqpa rurasqan, utqhaylla pisiyachisqa – 1 minuto 48.0 segundo – 665,369 byte – 48 kbps – Lisinsya: CC BY-ND 4.0 utaq qhipanmanta"

msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Sutina: Étude d'Exécution No. 4 'Mazeppa'"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare – 22.3 sigundukuna – 183,926 bytekuna – 64 kbps – Lisinsya: Lliwpaq kaq"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Ñawpaq pachamanta hina phukuy – 2.2 sigundukuna – 10,536 bytekuna – 32 kbps – Saqillay: Lliwpaq kaq"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Ñawpaq rikch'ay qallariy – 42.1 sigundukuna – 179,138 baytukuna – 32 kbps – Saqillay: Lliwpaq"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "ChatGPT-pa willaynin - 3.8 sigundukuna - 109,700 bytekuna - 256 kbps - Lisinsya: Lliwpaq kaq"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Hatun usqhaylla, malware tarisqa willakuy hina – Huk ñiqin raki, ChatGPT-pa ruwasqan – 3.3 sigundukuna – 102,850 bytekuna – 256 kbps – Saqillay: Lliwpaq kachkan"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Hatun usqhaylla, malware tarisqa willakuy hina uyarikun, Iskay ñiqin raki, ChatGPT-pa ruwasqan - 3.3 sigundukuna - 103,122 byte - 256 kbps - Lisinsya: Lliwpaq kachkan"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "MRI hina kunkata ChatGPT-pa rurasqan – 1 minuto 14.9 sigundu – 3,340,392 byte – 320 kbps – Saqillay: Lliwpaq kachkan"

msgid "警告表示中のBGMを選択します"
msgstr "Willay pachapi waqachinapaq qhipa takita akllay."

msgid "びっくりするような雰囲気を作ります"
msgstr "Musphachikuq pachata paqarichin"

msgid "Firefoxでは音声ブロックされます"
msgstr "Firefox nisqapi uyarina hark'asqa kachkan."

msgid "対象アクションを起こした時のビープ音"
msgstr "Akllasqa ruway hunt'akuptin huk bip"

msgid "有効 音量小さ目"
msgstr "Pukllasqa, k'allaylla"

msgid "有効 音量大き目"
msgstr "K'uchisqa, kallpan hatunpi churasqa"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Llapan tekladomanta ukuchamantawan ruwaykunapaq huk bip uyarikunqa, huk willariy rikuchikuchkaptin."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Willay rikuchikuchkaptin, aparikunaqa mana kamachiy atina hina rikch'akun."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Huk sapaq ruway hunt'akuptin ukucha t'upsinata pakay"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Llika wamp'uqpa p'anqanpi ukhu-ukhu t'upsita pakay, huk willakuy rikuchikuchkaptin."

msgid "デバッグモード"
msgstr "Pantay allichana ñan"

msgid "妨害＋記録のみ"
msgstr "Ch'aqway + Qillqasqakuna"

