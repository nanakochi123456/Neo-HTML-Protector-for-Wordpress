msgid "設定"
msgstr "Gosodiadau"

msgid "IPログリーダー"
msgstr "Darllenydd Log IP"

msgid "IPアドレスログ"
msgstr "Log cyfeiriad IP"

msgid "全クリア"
msgstr "Cwblhewch yr holl lefelau"

msgid "IPログが全て削除されました"
msgstr "Mae'r holl logiau IP wedi'u dileu."

msgid "ID"
msgstr "Adnabod"

msgid "タイムスタンプ"
msgstr "Nod amser"

msgid "IPアドレス"
msgstr "Cyfeiriad IP"

msgid "ユーザーエージェント"
msgstr "Asiant Defnyddiwr"

msgid "イベント"
msgstr "Digwyddiad"

msgid "IPアドレスのデータはありません"
msgstr "Nid oes data ar gyfer y cyfeiriad IP hwn."

msgid "EU GDPR対応"
msgstr "Cydymffurfiaeth â GDPR yr UE"

msgid "無効"
msgstr "Annilys"

msgid "有効"
msgstr "Dilys"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Os ydych chi'n defnyddio WordPress o fewn yr UE, neu os yw'ch gwefan yn targedu defnyddwyr o fewn yr UE, sicrhewch fod hyn wedi'i alluogi."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Bydd y botwm 'Cadarnhau' yn newid i 'Cytuno' neu 'Anghytuno', a bydd yr ymddygiad yn newid ychydig."

msgid "同意画面の色"
msgstr "Lliw'r sgrin cydsyniad"

msgid "自動"
msgstr "Awtomatig"

msgid "ライトモード"
msgstr "Modd golau"

msgid "ダークモード"
msgstr "Modd Tywyll"

msgid "同意画面表示中の配色を設定します"
msgstr "Gosodwch y cynllun lliwiau ar gyfer y sgrin cydsyniad"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Cymylu cynnwys ar y sgrin gydsyniad"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Gosodwch lefel y cymylu ar gyfer cynnwys a ddangosir ar y sgrin cydsyniad."

msgid "同意画面の透過"
msgstr "Tryloywder y sgrin gydsyniad"

msgid "透過なし"
msgstr "Dim tryloywder"

msgid "同意画面の透過具合を設定します"
msgstr "Gosod tryloywder y sgrin cydsyniad"

msgid "お知らせの1行目"
msgstr "Llinell gyntaf y cyhoeddiad"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Caiff y neges hon ei harddangos bob amser y tro cyntaf y llwythir y dudalen."

msgid "お知らせの2行目"
msgstr "Ail linell y hysbysiad"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Bydd y neges hon bob amser yn ymddangos ar y sgrin gyntaf yn unig pan fydd GDPR yr UE mewn grym."

msgid "お知らせの3行目"
msgstr "Trydedd llinell y hysbysiad"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Bydd yn ymddangos i'r dde o'r ddolen i'r Polisi Preifatrwydd."

msgid "非EU向け確認の文字列"
msgstr "Testun cadarnhau ar gyfer gwledydd y tu allan i'r UE"

msgid "EU GDPR向け同意するの文字列"
msgstr "Testun cydsyniad ar gyfer GDPR yr UE"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Testun ar gyfer 'Peidio â chydsynio' o dan GDPR yr UE"

msgid "プライバシーポリシーの文字列"
msgstr "Testun y polisi preifatrwydd"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Os gwelwch yn dda, gosodwch yr URL ar gyfer y polisi preifatrwydd yma."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Ychwanegwch y canlynol at y Polisi Preifatrwydd."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Er mwyn canfod gweithgarwch twyllodrus, caiff adnabyddwyr fel cyfeiriadau IP eu storio mewn cwcis a'r gronfa ddata. Caiff y data a storir ei ddileu yn ôl disgresiwn y gweinyddwr."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Er mwyn sicrhau bod delweddau'n cael eu danfon yn gywir dim ond pan fydd amddiffyn delweddau wedi'i alluogi, rydym yn storio data wedi'i hasio sy'n cynnwys y cyfeiriad IP ac enw ffeil y ddelwedd yn y gronfa ddata am hyd at 60 munud."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Os ydych chi'n sefydlu Telerau Defnyddio, sicrhewch eich bod yn cynnwys dolen iddynt yn eich Polisi Preifatrwydd."

msgid "利用規約の文字列"
msgstr "Testun y Telerau Defnyddio"

msgid "利用規約のページ"
msgstr "Tudalennau Telerau ac Amodau"

msgid "ページ選択なし"
msgstr "Dim tudalen wedi'i dewis"

msgid "検索エンジン等のURL"
msgstr "URLau ar gyfer peiriannau chwilio, ac ati."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Gosodwch yr URL ar gyfer peiriannau chwilio a gwefannau tebyg sy'n ailgyfeirio defnyddwyr pan na roddir cydsyniad."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Modd dadfygio, negeseuon rhybudd y consol"

msgid "右クリックの警告メッセージ"
msgstr "Neges rybudd clicio-de"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Neges rybuddio ynglŷn â argraffu a chadw fel PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Neges rybudd yn y sgrinlun"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Neges rybudd ynghylch sgrinluniau a amheuir"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Neges rybudd pan fydd yr holl destun wedi'i ddewis"

msgid "ページ保存の警告メッセージ"
msgstr "Neges rybudd ynglŷn â chadw'r dudalen"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Neges a ddangosir wrth gopïo neu dorri"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Neges i'w dangos wrth weld ffynhonnell HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Neges i'w harddangos ar frig y cod ffynhonnell wrth amwysáu neu amddiffyn HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Neges i'w harddangos os yw'r tocyn dilysu untro yn annilys yn ystod amddiffyniad HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Neges i'w dangos os yw cwcis neu JavaScript wedi'u hanalluogi"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Mewn gwirionedd, dim ond pan fydd JavaScript wedi'i analluogi y caiff hyn ei arddangos."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Pan amddiffynnir delwedd, caiff ei lawrlwytho, a dangosir neges ar y ddelwedd honno"

msgid "HTML難読化 (圧縮)"
msgstr "Cymylu"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Dyma gywasgu HTML safonol; mae yna hefyd wefannau sy'n gallu ei ddatgodio."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Mae galluogi'r opsiwn hwn yn caniatáu i chi adfer log ffynhonnell y golwg."

msgid "HTML保護"
msgstr "Amddiffyniad HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Mae'n allbwnio'r isafswm llwyr o HTML—hyd yn oed llai na wrth ddefnyddio cywasgu HTML—ac nid yw'r cynnwys o fewn y tag BODY yn cael ei allbwnio o gwbl."

msgid "Firefoxに対しては無効です"
msgstr "Nid yw hyn yn berthnasol i Firefox."

msgid "SEOに著しく影響があります"
msgstr "Mae hyn yn cael effaith sylweddol ar SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Renderio HTML gan ddefnyddio JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "I weithio o amgylch Firefox, rydym yn rendro'r HTML gan ddefnyddio JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Bydd galluogi rendro JavaScript yn arafu cyflymder llwytho'r wefan yn sylweddol."

msgid "画像の保護"
msgstr "Amddiffyn delwedd"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Amddiffyn y ddelwedd bob tro y gelwir y tag img."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Diogelu'r holl ddelweddau a uwchlwythir i WordPress o fewn yr allbwn HTML cyfan."

msgid "画像をダウンロードから保護します"
msgstr "Yn amddiffyn delweddau rhag cael eu lawrlwytho"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Pan amddiffynnir data delweddau, rydym yn atal bron pob lawrlwythiad, yn cyhoeddi URLau untro unigryw, yn dilysu gan ddefnyddio tocynnau a storir yn y sesiwn, ac yn arddangos y delweddau drwy PHP; mae hyn yn atal bron pob achos o ladrata delweddau yn effeithiol."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Pan amddiffynnir data delweddau, nid yw'r storfa'n gweithio, sy'n golygu y bydd y wefan yn llwytho'n arafach ar ymweliadau dilynol, a thrwy hynny'n effeithio ar SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Gall diogelu data delweddau gynyddu'r llwyth ar y gronfa ddata."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Os dewiswch 'Diogelu delweddau pryd bynnag y gelwir tag img', mae'r system yn defnyddio add_filter i gymhwyso hidlo pan fydd y tag img yn cael ei gynhyrchu; fodd bynnag, efallai na fydd hyn yn gweithio'n gywir gyda rhai themâu."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Os dewiswch 'Diogelu pob delwedd a lwythir i WordPress o fewn yr allbwn HTML cyfan', bydd yr ategyn yn dal bron pob gweithrediad WordPress ac yn prosesu pob tag img o fewn y cynnwys. Noder efallai na fydd hyn yn gweithio'n gywir gyda rhai themâu."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Noder y bydd delweddau a ddynodir fel delweddau dan sylw yn cael eu rhannu fel data OGP ac na ellir eu diogelu. Os oes rhaid i chi eu diogelu, newidiwch y gosodiad ar gyfer allbwn tag HEAD yn y gosodiadau uwch wrth alluogi diogelwch HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Ni ellir diogelu'r swyddogaeth sgrinlun sydd wedi'i hymgorffori yn y system weithredu."

msgid "画像URLの保護"
msgstr "Diogelu URLau delweddau"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Dylid defnyddio hwn ar y cyd â diogelu delweddau; ar ei ben ei hun, nid yw'n gwasanaethu unrhyw bwrpas."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Gan ei fod yn llwytho'n ddiog drwy JavaScript, mae hyn yn effeithio ar SEO."

msgid "画像のウォーターマーク"
msgstr "Dŵrnod delwedd"

msgid "右下"
msgstr "Gwaelod dde"

msgid "ランダム位置"
msgstr "Safle ar hap"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Wedi'u defnyddio ar y cyd â diogelu delweddau, mae dyfrnodau deinamig yn nodi perchnogaeth hawlfraint yn glir, gan roi'r argraff i wylwyr eu bod yn cael eu monitro, a thrwy hynny'n gweithredu fel ataliad."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Dim ond fformatau JPG, PNG a WebP sy'n cael eu cefnogi."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Bydd galluogi hyn yn cynyddu'r llwyth ar y gweinydd."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Allbwnu celf ASCII o god ffynhonnell HTML yn ystod cymylu a diogelu HTML"

msgid "表示なし"
msgstr "Dim arddangosfa"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Arddangos celf ASCII sy'n dangos rhybudd wrth edrych ar ffynhonnell yr HTML gan ddefnyddio 'view-source'."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Dangos y dyluniad pan gyflawnir y weithred darged"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Dyluniad sylfaenol yn cynnwys testun du ar gefndir melyn."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Dyluniad arswyd-arddull yn cynnwys testun coch ar gefndir du"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Dyluniad yn cynnwys testun coch llachar ar gefndir du"

msgid "対象アクションを起こした時のBGM"
msgstr "Cerddoriaeth gefndir sy'n chwarae pan gyflawnir y weithred darged."

msgid "サウンドなし"
msgstr "Dim sain"

