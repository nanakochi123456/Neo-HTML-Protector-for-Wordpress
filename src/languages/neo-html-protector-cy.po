msgstr "Gorymdeithfaner arddull retro – 2.2 eiliad – 10,536 bait – 32 kbps – Trwydded: Parth Cyhoeddus"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Cyflwyniad arddull retro – 42.1 eiliad – 179,138 bait – 32 kbps – Trwydded: Parth Cyhoeddus"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Rhybudd gan ChatGPT - 3.8 eiliad - 109,700 bait - 256 kbps - Trwydded: Parth Cyhoeddus"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sain brys uchel fel rhybudd canfod meddalwedd faleisus – Rhan 1 gan ChatGPT – 3.3 eiliad – 102,850 bait – 256 kbps – Trwydded: Parth Cyhoeddus"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sain brys uchel fel rhybudd canfod meddalwedd faleisus, Rhan 2 gan ChatGPT - 3.3 eiliad - 103,122 bait - 256 kbps - Trwydded: Parth Cyhoeddus"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Sain arddull MRI gan ChatGPT – 1 munud 14.9 eiliad – 3,340,392 bait – 320 kbps – Trwydded: Parth Cyhoeddus"

msgid "警告表示中のBGMを選択します"
msgstr "Dewiswch y gerddoriaeth gefndir i'w chwarae yn ystod rhybudd."

msgid "びっくりするような雰囲気を作ります"
msgstr "Mae'n creu awyrgylch syfrdanol"

msgid "Firefoxでは音声ブロックされます"
msgstr "Mae sain wedi'i rhwystro yn Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Bîp pan gyflawnir y weithred benodol"

msgid "有効 音量小さ目"
msgstr "Ymlaen, sain isel"

msgid "有効 音量大き目"
msgstr "Gweithredol, sain uchel"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Bydd bip yn seinio mewn ymateb i bob digwyddiad bysell a llygoden tra bydd rhybudd yn cael ei arddangos."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Mae'n creu'r argraff bod y ddyfais wedi mynd o reolaeth tra bod y rhybudd yn cael ei arddangos."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Cuddio cyrchwr y llygoden pan gyflawnir gweithred benodol"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Cuddio cyrchwr y llygoden yn ardal y porwr tra bod rhybudd yn cael ei arddangos."

msgid "デバッグモード"
msgstr "Modd dadfygio"

msgid "妨害＋記録のみ"
msgstr "Ymyrraeth + Cofnodion yn unig"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Ymyriad + Cofnodi + Arddangos + Ailgyfeirio"

msgid "メニューからは操作できてしまいます"
msgstr "Gallwch chi ddal i gael mynediad ato drwy'r ddewislen."

