msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare – 22.3 saniye – 183,926 bayt – 64 kbps – Lîsans: Qada Giştî"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Fanfareya bi şêwaza retro – 2.2 saniye – 10,536 bayt – 32 kbps – Lîsans: Qada Giştî"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Pêşgotina bi şêwaza retro – 42.1 saniye – 179,138 bayt – 32 kbps – Lîsans: Qada Giştî"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Hişyarî ji aliyê ChatGPT - 3.8 saniye - 109,700 bayt - 256 kbps - Lîsans: Qada Giştî"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Dengê lezgîn ê bilind wekî hişyariyek tespîtkirina malwareyê – Beş 1 ji aliyê ChatGPT – 3.3 saniye – 102,850 bayt – 256 kbps – Lîsans: Qada Giştî"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Dengê lezgîn ê bilind wekî hişyariyek tespîtkirina malwareyê, Beş 2 ji aliyê ChatGPT - 3.3 saniye - 103,122 bayt - 256 kbps - Lîsans: Qada Giştî"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Dengê bi şêwazê MRI ji aliyê ChatGPT ve – 1 deqe 14.9 saniye – 3,340,392 bayt – 320 kbps – Lîsans: Qada Giştî"

msgid "警告表示中のBGMを選択します"
msgstr "Muzîka paşxanê ya ji bo dema hişyariyê hilbijêre."

msgid "びっくりするような雰囲気を作ります"
msgstr "Ew atmosfereke sosret diafirîne."

msgid "Firefoxでは音声ブロックされます"
msgstr "Deng di Firefoxê de hatiye astengkirin."

msgid "対象アクションを起こした時のビープ音"
msgstr "Dengê bipêkê dema ku çalakiya diyarkirî tê kirin"

msgid "有効 音量小さ目"
msgstr "Vekirî, deng nizm"

msgid "有効 音量大き目"
msgstr "Çalak, deng bilind e"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Dengê bîpê dê ji bo hemû çalakiyên klavye û mişkê lê bide, dema ku hişyariyek tê nîşandan."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Wisa xuya dike ku amûr ji kontrolê derketiye dema ku hişyarî tê nîşandan."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Veşartina kursora mişkê dema ku kiryareke taybet tê kirin"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Dema ku hişyariyek tê nîşandan, kursora mişkê di qada gerokê de vedişêre."

