msgid "設定"
msgstr "Mîheng"

msgid "IPログリーダー"
msgstr "Xwendevanê Logên IP'yê"

msgid "IPアドレスログ"
msgstr "Tomara navnîşana IP'yê"

msgid "全クリア"
msgstr "Hemû astan temam bike"

msgid "IPログが全て削除されました"
msgstr "Hemû tomarên IP'yê hatin jêbirin."

msgid "ID"
msgstr "Nasname"

msgid "タイムスタンプ"
msgstr "Mora demê"

msgid "IPアドレス"
msgstr "Navnîşana IPyê"

msgid "ユーザーエージェント"
msgstr "Nûnerê Bikarhêner"

msgid "イベント"
msgstr "Bûyer"

msgid "IPアドレスのデータはありません"
msgstr "Ji bo vê navnîşana IP'yê ti daneyek tune."

msgid "EU GDPR対応"
msgstr "Lihevhatina bi GDPR a YE re"

msgid "無効"
msgstr "Ne derbasdar"

msgid "有効"
msgstr "Derbasdar"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Heke hûn WordPressê di nav Yekîtiya Ewropayê de bi kar tînin, an jî heke malpera we ji bo bikarhênerên di nav Yekîtiya Ewropayê de ye, ji kerema xwe piştrast bikin ku ev çalak e."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Bişkoka 'Piştrast bike' dê bibe 'Li hev bike' an 'Li hev neke', û tevger dê hinekî biguhere."

msgid "同意画面の色"
msgstr "Rengê ekrana razîbûnê"

msgid "自動"
msgstr "Otomatîk"

msgid "ライトモード"
msgstr "Modê sivik"

msgid "ダークモード"
msgstr "Modê Tarî"

msgid "同意画面表示中の配色を設定します"
msgstr "Şemaya rengê ji bo ekrana razîbûnê saz bike."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Tevlihevkirina naverokê li ser ekrana razîbûnê"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Asta matkirinê ji bo naveroka ku li ser ekrana razîbûnê tê nîşandan eyar bike."

msgid "同意画面の透過"
msgstr "Şefafiya ekrana razîbûnê"

msgid "透過なし"
msgstr "Bê şefafî"

msgid "同意画面の透過具合を設定します"
msgstr "Şefafiya ekrana razîbûnê saz bike"

msgid "お知らせの1行目"
msgstr "Rêza yekem a ragihandinê"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ev peyam her tim tê nîşandan gava ku rûpel cara yekem tê barkirin."

msgid "お知らせの2行目"
msgstr "Rêza duyemîn a agahdariyê"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ev peyam dê her tim tenê li ser dîmendera yekem xuya bibe dema ku GDPR ya YE di meriyetê de be."

msgid "お知らせの3行目"
msgstr "Xeta sêyem a agahdariyê"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ew ê li rastê ya lînka Polîtîkaya Nepenîtiyê xuya bibe."

msgid "非EU向け確認の文字列"
msgstr "Nivîsa piştrastkirinê ji bo welatên ne-YE"

msgid "EU GDPR向け同意するの文字列"
msgstr "Teksta razîbûnê ji bo GDPR ya YE"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Nivîsa ji bo 'Riza nede' di bin GDPR ya YE de"

msgid "プライバシーポリシーの文字列"
msgstr "Nivîsa polîtîkaya nepenîtiyê"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Ji kerema xwe URL-a polîtîkaya nepenîtiyê li vir saz bikin."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Ji kerema xwe van tiştan li Polîtîkaya Nepenîtiyê zêde bikin."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Ji bo tespîtkirina çalakiyên sextekarî, nasnameyên wekî navnîşanên IP'yê di cookieyan û databasê de tên tomarkirin. Daneyên tomarkirî li gorî biryara rêveber tên jêbirin."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Ji bo ku em piştrast bikin ku wêne rast tên radestkirin dema ku parastina wêneyan çalak be, em daneyên heşkirî yên ku navnîşana IPyê û navê pelê wêneyê di nav xwe de dihewînin, heta 60 deqeyan di databasa xwe de tomar dikin."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Heke hûn Mercên Bikaranînê saz dikin, ji kerema xwe piştrast bibin ku hûn di Polîtîkaya xwe ya Nepenîtiyê de lînkeke ber bi wan ve bi cih dikin."

msgid "利用規約の文字列"
msgstr "Nivîsa Mercên Bikaranînê"

msgid "利用規約のページ"
msgstr "Rûpela Şert û Mercan"

msgid "ページ選択なし"
msgstr "Rûpel nehatiye hilbijartin"

msgid "検索エンジン等のURL"
msgstr "URL ji bo motorên lêgerînê, hwd."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "URL'ê ji bo motorên lêgerînê û malperên wekhev ên ku dema destûr neyê dayîn bikarhêneran vedigerînin, saz bike."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Modêya debugê, peyamên hişyariyê yên konsolê"

msgid "右クリックの警告メッセージ"
msgstr "Peymana klîka-rastê ya peyama hişyariyê"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Peyama hişyariyê derbarê çapkirin û tomarkirina wekî PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Peyama hişyariyê di dîmenê de"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Peyama hişyariyê ya derbarê dîmenên ekranê yên gumanbar"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Peyama hişyariyê dema ku hemû nivîs hatiye hilbijartin"

msgid "ページ保存の警告メッセージ"
msgstr "Peyama hişyariyê derbarê tomarkirina rûpelê"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Peyama ku dema kopîkirin an jêbirinê tê nîşandan"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Peyama ku dema temaşekirina çavkaniya HTMLê were nîşandan"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Peyama ku li serê koda çavkaniyê were nîşandan dema ku HTML tê tevlihevkirin an parastin"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Peyama ku were nîşandan heke tokana rastkirina yekcarî di dema parastina HTMLê de ne derbasdar be"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Peyama ji bo nîşandanê heke cookies an JavaScript hatibin neçalakirin"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Bi rastî, ev tenê dema ku JavaScript neçalak be tê nîşandan."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Dema ku wêneyek tê parastin, ew tê daxistin û peyamek li ser wê wêneyê tê nîşandan"

msgid "HTML難読化 (圧縮)"
msgstr "Tevlihevkirina HTMLê"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Ev kompresyona standard a HTMLê ye; her wiha malperên ku dikarin wê deşîfre bikin jî hene."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Aktîvkirina vê vebijarkê rê dide we ku hûn qeydên çavkaniya-dîtinê bistînin."

msgid "HTML保護"
msgstr "Parastina HTMLê"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ew ji mîhenga pêlêkirina HTMLê jî kêmtir HTMLê derdixe, ev tê wê wateyê ku naveroka di nav etîketa BODY de dê qet neyê nîşandan."

msgid "Firefoxに対しては無効です"
msgstr "Ev ji bo Firefoxê derbas nabe."

msgid "SEOに著しく影響があります"
msgstr "Ev bandoreke girîng li ser SEOyê dike."

msgid "HTMLをJavaScriptで描画"
msgstr "Renderkirina HTMLê bi JavaScriptê"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Ji bo ku li dora Firefoxê bixebitin, em HTMLê bi rêya JavaScriptê render dikin."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Çalakkirina rindreya JavaScriptê dê leza barkirina malperê bi awayekî berbiçav hêdî bike."

msgid "画像の保護"
msgstr "Parastina wêneyan"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Her carê ku etîketa img tê gazîkirin, wêneyê biparêze."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Hemû wêneyên ku li WordPressê hatine barkirin di nav tevahiya derketina HTMLê de biparêze."

msgid "画像をダウンロードから保護します"
msgstr "Wêneyan ji daxistinê diparêze"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Dema ku daneyên wêneyan tên parastin, em hema hema bi temamî pêşî li daxistinan digirin, URLên yekcarî û yekta çêdikin, bi bikaranîna tokenên di danişînê"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Dema ku daneyên wêneyan tên parastin, keşkirin naxebite, ku ev tê wê wateyê ku malper di serdanên paşîn de dê hêdîtir vebe, û bi vî awayî bandorê li SEOyê dike."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Parastina daneyên wêneyê dibe ku barê li ser databasê zêde bike."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Heke hûn 'Wêneyan biparêze her gava ku etîketa img tê gazîkirin' hilbijêrin, sîstem add_filter bi kar tîne da ku dema etîketa img tê çêkirin parzûnkirinê pêk bîne; lêbelê, dibe ku ev bi hin temayan re rast nexebite."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Heke hûn 'Hemû wêneyên ku di nav tevahiya derketina HTMLê de li WordPressê hatine barkirin biparêze' hilbijêrin, pêvek dê hema hema hemû operasyonên WordPressê bigire û her etîketa img a di nav naverokê de bişixulîne. Ji kerema xwe bala xwe bidinê ku dibe ev bi hin temayan re rast nexebite."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Ji kerema xwe bala xwe bidinê ku wêneyên wekî wêneyên taybet hatine destnîşankirin, dê wekî daneyên OGP werin parvekirin û nikarin werin parastin. Heke hûn bi teqezî dixwazin wan biparêzin, dema ku hûn parastina HTML'ê çalak dikin, ji kerema xwe di mîhengên pêşketî de mîhenga derketina etîketa HEAD biguherînin."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Fonksiyona girtina dîmenê ya ku wekî standard di pergala xebitandinê de heye, nayê parastin."

msgid "画像URLの保護"
msgstr "Parastina URLyên wêneyan"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Divê ev bi parastina wêneyan re were bikaranîn; bi serê xwe, tu armancek wê nîne."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Ji ber ku ew bi awayekî tembelane bi rêya JavaScript tê barkirin, ev yek bandorê li SEOyê dike."

msgid "画像のウォーターマーク"
msgstr "Nîşana avê ya wêneyê"

msgid "右下"
msgstr "Rastê jêrîn"

msgid "ランダム位置"
msgstr "Pozîsyona tesadufî"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Di heman demê de bi parastina wêneyan re tên bikaranîn, nîşanên avê yên dînamîk bi awayekî zelal xwedîtiya mafê telîfê nîşan didin û di heman demê de hesta şopandinê didin temaşevanan, û bi vî awayî wekî handerekê kar dikin."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Tenê formatên JPG, PNG û WebP tên piştgirîkirin."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Vekirina vê dê barê ser serverê zêde bike."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Derxistina hunera ASCII ji koda çavkaniyê ya HTMLê di dema tevlihevkirin û parastinê de"

msgid "表示なし"
msgstr "Tiştek nayê nîşandan"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Dema ku çavkaniya HTMLê bi rêya 'view-source' tê dîtin, hunera ASCII ya ku hişyariyekê nîşan dide."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Dîzayna pêşandanê dema ku çalakiya armanc pêk tê"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Sêwiraneke bingehîn ku nivîsa reş li ser paşxaneyeke zer e."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Sêwiraneke bi şêwazê tirsê ku nivîsa sor li ser paşxaneyeke reş e."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Sêwiranek bi nivîsa sor a geş li ser paşxaneyeke reş."

msgid "対象アクションを起こした時のBGM"
msgstr "Muzîka paşxanê ya ku dema çalakiya armanc pêk tê lê dide"

msgid "サウンドなし"
msgstr "Deng tune"

