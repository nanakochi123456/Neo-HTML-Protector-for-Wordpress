msgid "設定"
msgstr "Ezarpenak"

msgid "IPログリーダー"
msgstr "IP Log Irakurgailua"

msgid "IPアドレスログ"
msgstr "IP helbideen erregistroa"

msgid "全クリア"
msgstr "Bukatu maila guztiak"

msgid "IPログが全て削除されました"
msgstr "IP erregistro guztiak ezabatu dira."

msgid "ID"
msgstr "Identifikatzailea"

msgid "タイムスタンプ"
msgstr "Denbora-marka"

msgid "IPアドレス"
msgstr "IP helbidea"

msgid "ユーザーエージェント"
msgstr "Erabiltzaile-agentzia"

msgid "イベント"
msgstr "Ekitaldia"

msgid "IPアドレスのデータはありません"
msgstr "IP helbiderako ez dago daturik."

msgid "EU GDPR対応"
msgstr "EBko GDPRari betetzea"

msgid "無効"
msgstr "Baliozkoa ez den"

msgid "有効"
msgstr "Baliozkoa"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Europako Batasunean WordPress erabiltzen ari bazara, edo zure webguneak EBko erabiltzaileei zuzenduta badago, mesedez ziurtatu hau gaituta dagoela."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Berretsi' botoia 'Ados' edo 'Ez ados' bihurtuko da, eta portaera pixka bat aldatuko da."

msgid "同意画面の色"
msgstr "Onarpen pantailaren kolorea"

msgid "自動"
msgstr "Automatikoa"

msgid "ライトモード"
msgstr "Argi modua"

msgid "ダークモード"
msgstr "Modu iluna"

msgid "同意画面表示中の配色を設定します"
msgstr "Onarpen pantailaren kolore-eskema ezarri"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Onarpen-pantailako edukiaren lausotzea"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Onarpen pantailan bistaratzen den edukirako lausotze-maila ezarri"

msgid "同意画面の透過"
msgstr "Onarpen-pantailaren gardentasuna"

msgid "透過なし"
msgstr "Ez dago gardentasunik"

msgid "同意画面の透過具合を設定します"
msgstr "Onarpen-pantailaren gardentasun-maila ezarri"

msgid "お知らせの1行目"
msgstr "Iragarkiaren lehen lerroa"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Mezu hau beti bistaratzen da orria lehen aldiz kargatzen denean."

msgid "お知らせの2行目"
msgstr "Oharraren bigarren lerroa"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Mezu hau beti lehen bistaratzean bakarrik agertuko da EBko GDPR indarrean dagoenean."

msgid "お知らせの3行目"
msgstr "Oharraren hirugarren lerroa"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Pribatutasun Politikarako estekaren eskuinean agertuko da."

msgid "非EU向け確認の文字列"
msgstr "EBkoak ez diren herrialdeentzako baieztapen-testua"

msgid "EU GDPR向け同意するの文字列"
msgstr "EBko GDPRrako baimen-testua"

msgid "EU GDPR向け同意しないの文字列"
msgstr "EBko GDPRaren arabera 'Ez eman baimena' testua"

msgid "プライバシーポリシーの文字列"
msgstr "Pribatutasun-politikaren testua"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Mesedez, ezarri hemen pribatutasun-politikarako URL-a."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Mesedez, gehitu honako hau Pribatutasun Politikara."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Jarduera iruzurrezkoak antzemateko, IP helbideak bezalako identifikatzaileak cookieetan eta datu-basean gordetzen dira. Gordetako datuak administratzailearen erabakiz ezabatzen dira."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Irudiak babesteko neurriak gaituta daudenean bakarrik behar bezala bidaltzen direla ziurtatzeko, IP helbidea eta irudiaren fitxategi-izena barne hartzen dituzten hash-datuak 60 minutuz gorde ditugu datu-basean."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Erabilera Baldintzak ezartzen ari bazara, ziurtatu zure Pribatutasun Politikaren barruan haien esteka sartzen duzula."

msgid "利用規約の文字列"
msgstr "Erabilera-baldintzen testua"

msgid "利用規約のページ"
msgstr "Baldintzak eta Kondizioak orria"

msgid "ページ選択なし"
msgstr "Ez dago aukeratutako orrialderik"

msgid "検索エンジン等のURL"
msgstr "Bilatzaileentzako URLak, etab."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Ezarri bilatzaileentzako eta antzeko webguneetarako URL-a, baimenik eman ez denean erabiltzaileak birbideratzen dituztenak."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Akatsak konpontzeko modua, kontsolako ohartarazpen-mezuak"

msgid "右クリックの警告メッセージ"
msgstr "Eskumako klikeko ohartarazpen-mezu"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDF formatuan inprimatu eta gordeari buruzko ohartarazpen-mezu"

msgid "スクリーンショットの警告メッセージ"
msgstr "Pantaila-argazkian ohartarazpen-mezu bat"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Susmagarri diren pantaila-argazkiei buruzko ohartarazpen-mezu"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Testu guztia hautatuta dagoenean ohartarazpen-mezu"

msgid "ページ保存の警告メッセージ"
msgstr "Orrialdea gordetzearekin lotutako ohartarazpen-mezu"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Kopiatzean edo moztean bistaratzen den mezua"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML iturburu-kodea ikusten denean erakutsi beharreko mezua"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML-a obskuratzean edo babestzean iturri-kodearen goialdean erakutsiko den mezua"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML babesaldian behin-behineko autentifikazio-tokena baliogabea bada, erakutsiko den mezua"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Cookieak edo JavaScript desgaituta badaude, erakutsi beharreko mezua"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Egiazki, hau soilik agertzen da JavaScript desgaituta dagoenean."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Irudi bat babestuta dagoenean, deskargatu egiten da eta mezua agertzen da irudi horretan"

msgid "HTML難読化 (圧縮)"
msgstr "HTML iluntzea"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Hau HTMLaren konpresio estandarra da; deskonpon dezakeen webguneak ere badaude."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Aukera hau gaitzeak ikus-iturriaren erregistroa berreskuratzeko aukera ematen dizu."

msgid "HTML保護"
msgstr "HTML babesa"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "HTMLaren oinarrizko minimoa bakarrik irteten du—HTML konpresioa erabiltzean baino gutxiago ere—eta BODY etiketako edukia batere ez da irteten."

msgid "Firefoxに対しては無効です"
msgstr "Hau ez da Firefox-i aplikagarria."

msgid "SEOに著しく影響があります"
msgstr "Honek SEOan eragin handia du."

msgid "HTMLをJavaScriptで描画"
msgstr "JavaScript erabiliz HTML renderizatzea"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox saihesteko, HTML-a JavaScript erabiliz bistaratzen dugu."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScript-en errendatzea gaitzeak nabarmen motelduko du webgunearen karga-abiadura."

msgid "画像の保護"
msgstr "Irudiaren babesa"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Babestu irudia img etiketa deitzen den bakoitzean"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Babestu WordPress-era igo diren irudi guztiak HTML irteera osoan zehar."

msgid "画像をダウンロードから保護します"
msgstr "Irudiak deskargatzeaz babesten ditu"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Irudi-datuak babestuta daudenean, ia deskarga guztiak saihesten ditugu, behin bakarreko URL bereziak ematen ditugu, saioan gordetako tokenak erabiliz egiaztatzen dugu eta irudiak PHP bidez bistaratzen ditugu; horrek irudi-lapurreta ia guztiak eraginkortasunez saihesten ditu."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Irudi-datuak babestuta daudenean, cacheak ez du funtzionatzen, eta horrek esan nahi du gunea hurrengo bisitaldietan motelago kargatuko dela, SEOari eraginez."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Irudi-datuak babesteak datu-basearen karga handitu dezake."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "'Irudiak babestu img etiketa deitzen den bakoitzean' hautatzen baduzu, sistemak add_filter erabiltzen du iragazketa aplikatzeko img etiketa sortzen denean; hala ere, honek ez du behar bezala funtzionatuko zenbait gaiekin."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "'WordPress-era igotako irudi guztiak HTML irteera osoan babestu' hautatzen baduzu, pluginak WordPress-eko ia eragiketa guztiak harrapatuko ditu eta edukian dauden img etiketa guztiak prozesatuko ditu. Kontuan izan honek zenbait gaiekin ez duela behar bezala funtzionatuko."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Mesedez, kontuan izan nabarmendutako irudi gisa izendatutako irudiak OGP datu gisa partekatuko direla eta ezin direla babestu. Haiek babestu behar badituzu, mesedez, aldatu HEAD etiketa irteerarako ezarpenak ezarpen aurreratuetan HTML babesa gaitzean."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Ezin da babestu sistema eragilean integratutako pantaila-argazki funtzioa."

msgid "画像URLの保護"
msgstr "Irudi-URLak babestea"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Hau irudiaren babesarekin batera erabili behar da; bere kabuz ez du inolako helbururik betetzen."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "JavaScriptez alferrik kargatzen denez, honek SEOari eragiten dio."

msgid "画像のウォーターマーク"
msgstr "Irudiaren ur-marka"

msgid "右下"
msgstr "Beheko eskuinean"

msgid "ランダム位置"
msgstr "Posizio ausazkoa"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Irudiaren babesarekin batera erabilita, ur-marka dinamikoek egile-eskubideen jabegoa argi adierazten dute, aldi berean ikusleei jarraipena jasotzen ari direla irudipena emanez, eta horrela eragozle gisa jarduten dute."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "JPG, PNG eta WebP formatuak soilik onartzen dira."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Honek zerbitzariaren karga handituko du."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "HTML iturburu-kodetik ASCII artea irteten HTML iluntze eta babes prozesuan"

msgid "表示なし"
msgstr "Ez dago pantailarik"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "'view-source' erabiliz HTML iturburu-kodea ikusten denean ohartarazpen bat adierazten duen ASCII artea bistaratzen du."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Helburu-ekintza gauzatzen denean diseinua erakutsi"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Hondo horia duen testu beltzezko oinarrizko diseinua"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Beldurrezko estiloko diseinu bat, atzeko plano beltz batean testu gorria duena"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Atzeko plano beltz batean testu gorri distiratsua duen diseinua"

msgid "対象アクションを起こした時のBGM"
msgstr "Helburu-ekintza gauzatzen denean jotzen den atzeko musika"

msgid "サウンドなし"
msgstr "Ez dago soinurik"

