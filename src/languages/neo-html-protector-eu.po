msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfara – 22,3 segundo – 183.926 byte – 64 kbps – Lizentzia: Domeinu Publikoa"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Retro estiloko fanfara – 2,2 segundo – 10.536 byte – 32 kbps – Lizentzia: Domeinu Publikoa"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Retro estiloko sarrera – 42,1 segundo – 179.138 byte – 32 kbps – Lizentzia: Domeinu Publikoa"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "ChatGPT-ren ohartarazpena - 3,8 segundo - 109.700 byte - 256 kbps - Lizentzia: Domeinu Publikoa"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Larrialdi handiko soinua, malware-detekzio alerta baten antzekoa – 1. zatia ChatGPT-k – 3,3 segundo – 102.850 byte – 256 kbps – Lizentzia: Domeinu publikoa"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Malware-detekzio-alerta baten antzeko premiazko soinua, 2. zatia ChatGPT-k - 3,3 segundo - 103.122 byte - 256 kbps - Lizentzia: Domeinu publikoa"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "MRI estiloko soinua ChatGPT-k sortua – 1 minutu 14,9 segundo – 3.340.392 byte – 320 kbps – Lizentzia: Domeinu Publikoa"

msgid "警告表示中のBGMを選択します"
msgstr "Hautatu abisu baten bitartean erreproduzituko den atzeko musika."

msgid "びっくりするような雰囲気を作ります"
msgstr "Harritzekoa den giro bat sortzen du."

msgid "Firefoxでは音声ブロックされます"
msgstr "Firefoxen audioa blokeatuta dago"

msgid "対象アクションを起こした時のビープ音"
msgstr "Ezarritako ekintza gauzatzen denean bip bat"

msgid "有効 音量小さ目"
msgstr "Piztuta, bolumena baxua"

msgid "有効 音量大き目"
msgstr "Aktiboa, bolumena altu ezarrita"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Abisu bat bistaratzen den bitartean, teklatu eta saguaren ekitaldi guztiei erantzunez bip bat entzun ahal izango da."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Abisua bistaratuta dagoen bitartean, gailuak kontrolik gabe dabilen moduko inpresioa sortzen du."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Ekintza zehatz bat gauzatzen denean saguaren kurtsorea ezkutatzea"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Abisua bistaratzen den bitartean nabigatzailearen eremuan saguaren kurtsorea ezkutatzen du."

msgid "デバッグモード"
msgstr "Akatsak konpontzeko modua"

msgid "妨害＋記録のみ"
msgstr "Interferentzia + Erregistroak bakarrik"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Interferentzia + Erregistroa + Erakustea + Bideratzea"

msgid "メニューからは操作できてしまいます"
msgstr "Oraindik ere menutik sar zaitezke."

msgid "Firefoxにおけるデバッグモード"
msgstr "Firefoxen akatsak konpontzeko modua"

msgid "ブラウザーコンソール"
msgstr "Arakatzaile-kontsola"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Egiazki, debug modutik eragiki dezakezu."

msgid "HTMLソース表示"
msgstr "Ikusi HTML iturburu-kodea"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Eragiketa 'view-source:' hasierako URL bat sartuta soilik egin dezakezu."

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
