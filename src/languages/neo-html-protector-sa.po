msgid "設定"
msgstr "विन्यासाः"

msgid "IPログリーダー"
msgstr "आईपी-पञ्जी-पठकः"

msgid "IPアドレスログ"
msgstr "आईपी-पत्त्र-लेखः"

msgid "全クリア"
msgstr "सर्वाणि स्तराणि पूर्णयतु।"

msgid "IPログが全て削除されました"
msgstr "सर्वे आईपी अभिलेखाः मेटिताः।"

msgid "ID"
msgstr "परिचयः"

msgid "タイムスタンプ"
msgstr "कालचिह्नम्"

msgid "IPアドレス"
msgstr "अद्वितीय-पत्ता"

msgid "ユーザーエージェント"
msgstr "उपयोक्ता-प्रतिनिधि"

msgid "イベント"
msgstr "कार्यक्रमः"

msgid "IPアドレスのデータはありません"
msgstr "अस्य IP-पत्तेः दत्ताङ्काः नास्ति।"

msgid "EU GDPR対応"
msgstr "यूरोपीय संघस्य सामान्य दत्तसंरक्षणनियमस्य अनुपालनम्"

msgid "無効"
msgstr "अमान्यम्"

msgid "有効"
msgstr "मान्यः"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "यदि यूरोपीयसंघे वर्डप्रेस् उपयुज्यते अथवा तव जालपुटं यूरोपीयसंघस्य अन्तर्जालप्रयोगकर्तॄन् लक्ष्यति, तर्हि कृपया एतत् सक्षमं भवेत् इति सुनिश्चितं कुरु।"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'पुष्टिकरण' बटनम् 'सममति' अथवा 'विरोधः' इति परिवर्तयिष्यते, तथा आचरणम् किंचित् परिवर्तयिष्यते।"

msgid "同意画面の色"
msgstr "अनुमतिपटलस्य वर्णः"

msgid "自動"
msgstr "स्वयंचालितम्"

msgid "ライトモード"
msgstr "हल्का विन्यासः"

msgid "ダークモード"
msgstr "तमो-पद्धतिः"

msgid "同意画面表示中の配色を設定します"
msgstr "अनुमतिपटलस्य वर्णविन्यासं स्थापय।"

msgid "同意画面中のコンテンツのぼかし"
msgstr "अनुमतिपटलस्य विषयवस्तु अस्पष्टीकरणम्"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "अनुमतिपटलिकायां प्रदर्शिताय विषयवस्तूनां धूसरतास्तरं निश्चितयतु।"

msgid "同意画面の透過"
msgstr "अनुमतिपटलस्य पारदर्शिता"

msgid "透過なし"
msgstr "पारदर्शिता नास्ति"

msgid "同意画面の透過具合を設定します"
msgstr "अनुमतिपटलस्य पारदर्शितां नियोजयतु।"

msgid "お知らせの1行目"
msgstr "घोषणायाः प्रथमपङ्क्तिः"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "यदा पृष्ठं प्रथमवारं लोड् भवति तदा एषः संदेशः सर्वदा दृश्यते।"

msgid "お知らせの2行目"
msgstr "सूचनायाः द्वितीयं पङ्क्तिः"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "यदा ईयू जीडीपीआर प्रवर्तते तदा एव एषः संदेशः प्रथमदर्शने एव सर्वदा दृश्यते।"

msgid "お知らせの3行目"
msgstr "सूचनायाः तृतीयं पङ्क्तिः"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "गोपनीयता-नीति-सूत्रस्य दक्षिणपार्श्वे दृश्यते।"

msgid "非EU向け確認の文字列"
msgstr "यूरोपीयसंघबाह्यदेशानां पुष्टिपठ्यम्"

msgid "EU GDPR向け同意するの文字列"
msgstr "यूरोपीय संघस्य सामान्य दत्तसंरक्षणनियमस्य"

msgid "EU GDPR向け同意しないの文字列"
msgstr "यूरोपीय संघस्य सामान्य दत्तसंरक्षणनियमस्य अन्तर्गत 'अनुमतिं मा ददातु' इत्यस्य पाठः"

msgid "プライバシーポリシーの文字列"
msgstr "गोपनीयता-नीति-पाठः"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "कृपया अत्र गोपनीयता-नीति-URL स्थापयतु।"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "कृपया निम्नलिखितं गोपनीयता-नीतिमध्ये योजयतु।"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "छद्मक्रियायाः अन्वेषणार्थम् IP-पत्तेषु इत्यादि परिचयचिह्नानि कुकीज् मध्ये च दत्तसङ्ग्रहणे च सञ्चितानि भवन्ति। सञ्चितदत्तानि प्रशासकस्य विवेकानुसारं विलोप्यन्ते।"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "यदा चित्ररक्षणं सक्रियं भवति तदा चित्राणां सम्यक् प्रेषणं सुनिश्चितुं वयं आईपी-पत्त्रं च चित्रस्य फाइल्-नामं च समाविष्टं हैश्-कृतं दत्तं अस्माकं दत्तसंग्रहणे षष्टिमिनिटपर्यन्तं सञ्चयामः।"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "यदि भवन्तः उपयोगशर्ताः स्थापयन्ति तर्हि कृपया सुनिश्चितं कुर्वन्तु यत् भवन्तः तेषां लिङ्कं स्वगोपनीयतानीतिपत्रे समावेशयन्ति।"

msgid "利用規約の文字列"
msgstr "उपयोगशर्त्सुपाठः"

msgid "利用規約のページ"
msgstr "शर्ताः च नियमाः पृष्ठम्"

msgid "ページ選択なし"
msgstr "पृष्ठं न निर्दिष्टम्"

msgid "検索エンジン等のURL"
msgstr "अन्वेषणयन्त्राणां इत्यादीनां यूआरएल्-सूचयः"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "यदा उपयोगकर्तारः अनुमतिं न ददन्ति तदा तान् पुनर्निर्देशयन्ति यन्त्राणि अन्वेषणयन्त्राणि च समानानि जालस्थलानि; तेषां URL निर्दिष्टयतु।"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "दोषशोधनप्रकारः, कन्सोल् चेतावनीसन्देशाः"

msgid "右クリックの警告メッセージ"
msgstr "दक्षिणक्लिक-चेतावनी-सन्देशः"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "पीडीएफ् रूपे मुद्रणं च संरक्षणं च विषये चेतावनी सन्देशः"

msgid "スクリーンショットの警告メッセージ"
msgstr "दृश्यचित्रे चेतावनी-सन्देशः"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "संशयित-स्क्रीनशॉट् विषये चेतावनी-सन्देशः"

msgid "テキスト全選択時の警告メッセージ"
msgstr "यदा सर्वं पाठ्यं चयनितम् तदा चेतावनी-सन्देशः"

msgid "ページ保存の警告メッセージ"
msgstr "पृष्ठरक्षणसम्बन्धी चेतावनीसन्देशः"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "प्रतिलिपिं कुर्वन् वा छिद्रयन् प्रदर्शितः सन्देशः"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML-स्रोतदर्शनकाले प्रदर्शयितुं संदेशः"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML-स्य अस्पष्टीकरणे वा संरक्षणे स्रोतकोडस्य शीर्षे प्रदर्शयितुं संदेशः"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML-संरक्षणकाले यदि एकवारप्रमाणिकरणप्रतीकः अमान्यः भवति तर्हि प्रदर्शयितुं संदेशः।"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "यदि कुकीज़् वा जावास्क्रिप्ट् निष्क्रियं कृतम् अस्ति तर्हि प्रदर्शयितुं संदेशः"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "वास्तवतः एतत् केवलं तदा प्रदर्श्यते यदा जावास्क्रिप्ट् निष्क्रियं भवति।"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "यदा चित्रम् संरक्षितम् भवति तदा तत् डाउनलोड् क्रियते च तस्मिन्चित्रे सन्देशः प्रदर्श्यते"

msgid "HTML難読化 (圧縮)"
msgstr "HTML अस्पष्टीकरणम्"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "एतत् सामान्यं एच् टी एम् एल् संपीडनम् अस्ति। तत्र अपि जालस्थलानि सन्ति यानि तस्य विसंकोडनं कर्तुं शक्नुवन्ति।"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "एतत् विकल्पं सक्रियं कृत्वा त्वं दृश्यस्रोत-पञ्जिकाः प्राप्तुं शक्नोषि।"

msgid "HTML保護"
msgstr "HTML संरक्षणम्"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "एषः HTML-संपीडनविकल्पात् अपि न्यूनतरं HTML उत्पद्यति, यत् BODY-टैगस्य अन्तर्गतं विषयवस्तु सर्वथा न प्रकाशितम्।"

msgid "Firefoxに対しては無効です"
msgstr "एतत् फायरफ़ॉक्स् विषये न प्रयुज्यते।"

msgid "SEOに著しく影響があります"
msgstr "एतत् एसईओ-परिष्करणे महत्त्वपूर्णं प्रभावं करोति।"

msgid "HTMLをJavaScriptで描画"
msgstr "जावास्क्रिप्टेन एचटीएमएल् प्रस्तुतीकरणम्"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "फायरफ़ॉक्स् परिहारार्थं वयं जावास्क्रिप्ट् उपयोगेन एचटीएमएल् प्रतिरूपयामः।"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "जावास्क्रिप्ट्-प्रदर्शनस्य सक्रियणं जालस्थलस्य लोड्-गतिम् विशेषतया मन्दयिष्यति।"

msgid "画像の保護"
msgstr "चित्ररक्षणम्"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "यदा यदा इम्‍ज्-टैग् आह्व्यते तदा तदा चित्रं रक्षतु।"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "सम्पूर्ण एचटीएमएल्-निष्पत्तौ वर्डप्रेस् मध्ये अपलोडितानि सर्वाणि चित्राणि रक्षतु।"

msgid "画像をダウンロードから保護します"
msgstr "चित्राणां डाउनलोड् भवनात् रक्षणम्"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "यदा चित्रदत्तानि संरक्ष्यन्ते, तदा वयं प्रायः सर्वे डाउनलोड् निरोधयामः, एकवारोपयोगी विशिष्ट-URLs निर्गमयामः, सत्रे सञ्चितानां टोकनानां साहाय्येन प्रमाणीकरणं कुर्मः, चित्राणि च PHP मार्गेण प्रदर्शयामः; एतत् प्रभावतः प्रायः सर्वे चित्रचोर्यम् निरोधयति।"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "यदा चित्रदत्तानि संरक्षितानि भवन्ति, तदा कैशिंग् न कार्यं करोति, यतः साइट् पुनरागमनेषु मन्दतरं लोड् भवति, एवं एसईओ प्रभावितम् भवति।"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "चित्रदत्तांशस्य संरक्षणं दत्तसङ्ग्रहस्य भारं वर्धयितुं शक्नोति।"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "यदि भवन्तः 'यदा कदाचित् img-टैग् आह्व्यते तदा चित्राणि संरक्षितानि भवन्तु' इति विकल्पं चयनं कुर्वन्ति, तदा प्रणाली img-टैग् सृज्यते तस्मिन् छन्नकरणं कर्तुं add_filter इति क्रियाम् उपयुज्यते; तथापि केषुचित् थीमेषु एतत् सम्यक् न कार्यं भवति।"

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "यदि भवन्तः 'सम्पूर्ण HTML-उत्पादनस्य अन्तर्गतं WordPress-उपरि आरोहितानां सर्वेषां छायाचित्राणां संरक्षणम्' इति विकल्पं चयनं कुर्वन्ति, तर्हि प्लगइनः प्रायः सर्वे WordPress-क्रियाः आहृत्य सामग्रीमध्ये प्रत्येकं img-टैगं प्रक्रिया करिष्यति। कृपया मन्यताम् यत् कतिपयेषु थीमेषु एतत् सम्यक् न कार्यं भवेत्।"

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "कृपया अवगच्छत यत् विशेषचित्ररूपेण निर्दिष्टाः चित्राः OGP-दत्तांशरूपेण वितरिताः स्युः, न च रक्षितुं शक्यन्ते। यदि त्वम् तान् अनिवार्यरूपेण रक्षितुम् इच्छसि, तर्हि HTML-संरक्षणं सक्रिययित्वा उन्नतविन्यासेषु HEAD-टैग्-उत्पादनस्य विन्यासं परिवर्तय।"

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "सञ्चालनतन्त्रे मानकरूपेण अन्तर्भूतं स्क्रीनचित्रग्रहणकार्यं रक्षितुं न शक्यते।"

msgid "画像URLの保護"
msgstr "चित्र-यूआरएल्-रक्षणम्"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "एतत् चित्ररक्षया सहैव प्रयुज्यते; स्वयमेव तद् निरर्थकम्।"

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "यतः जावास्क्रिप्ट् द्वारा आलस्येन लोड् क्रियते, अतः एतत् एसईओ प्रभावितयति।"

msgid "画像のウォーターマーク"
