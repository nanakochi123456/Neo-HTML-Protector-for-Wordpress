msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Intro gaya retro – 42,1 detik – 179.138 bait – 32 kbps – Lisénsi: Domain Umum"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Peringatan ku ChatGPT - 3,8 detik - 109.700 bait - 256 kbps - Lisénsi: Domain Umum"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sora darurat luhur siga béwara deteksi malware – Bagéan 1 ku ChatGPT – 3,3 detik – 102.850 bait – 256 kbps – Lisénsi: Domain Umum"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sora darurat luhur siga béwara deteksi malware, Bagéan 2 ku ChatGPT - 3,3 detik - 103.122 bait - 256 kbps - Lisénsi: Domain Umum"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Sora gaya MRI ku ChatGPT – 1 menit 14,9 detik – 3.340.392 bait – 320 kbps – Lisénsi: Domain Umum"

msgid "警告表示中のBGMを選択します"
msgstr "Pilih musik latar pikeun diputer nalika aya peringatan."

msgid "びっくりするような雰囲気を作ります"
msgstr "Éta nyiptakeun suasana anu matak héran"

msgid "Firefoxでは音声ブロックされます"
msgstr "Audio diblokir di Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "Beep nalika tindakan anu ditangtukeun dilakukeun"

msgid "有効 音量小さ目"
msgstr "Hurung, sora handap"

msgid "有効 音量大き目"
msgstr "Aktif, volume disetél ka luhur"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Sora bip bakal kadéngé pikeun sakabéh kajadian konci jeung beurit, bari peringatan dipidangkeun."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Éta nyieun kesan yén alatna geus teu karuan nalika peringatan éta dipidangkeun."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Nyumputkeun kursor beurit nalika hiji tindakan husus dilakukeun"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Nyumputkeun kursor beurit di wewengkon panyungsi nalika aya peringatan nu dipidangkeun"

msgid "デバッグモード"
msgstr "Mode debug"

msgid "妨害＋記録のみ"
msgstr "Gangguan + Rekaman wungkul"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Gangguan + Pencatetan + Tampilan + Pangalihan"

msgid "メニューからは操作できてしまいます"
msgstr "Anjeun masih tiasa ngaksésna ngaliwatan ménu."

msgid "Firefoxにおけるデバッグモード"
msgstr "Mode debug dina Firefox"

msgid "ブラウザーコンソール"
msgstr "Konsol panyungsi"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Sabenerna, anjeun tiasa ngajalankeunana tina mode debug."

msgid "HTMLソース表示"
msgstr "Tingali sumber HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Anjeun tiasa ngalaksanakeun operasi éta sacara basajan ku ngetik URL anu dimimitian ku 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Anjeun tiasa ngajagi eusi anjeun ku ngagabungkeun ieu jeung panyalindungan HTML."

msgid "印刷"
msgstr "Cétak"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Sanajan nyegah nyitak, éta bisa jadi henteu jalan leres dina sababaraha panyungsi wéb."

msgid "スクリーンショット"
msgstr "Tangkapan layar"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Gumantung kana sistem operasi, panyungsi wéb, atawa métode anu dianggo, bisa jadi teu mungkin pikeun ngahalangan ieu, atawa bisa jadi teu kadeteksi."

