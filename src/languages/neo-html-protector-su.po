msgid "設定"
msgstr "Setélan"

msgid "IPログリーダー"
msgstr "Pembaca Log IP"

msgid "IPアドレスログ"
msgstr "Catetan alamat IP"

msgid "全クリア"
msgstr "Rengsekeun sadaya tingkat"

msgid "IPログが全て削除されました"
msgstr "Sadaya log IP parantos dihapus"

msgid "ID"
msgstr "Identifikasi"

msgid "タイムスタンプ"
msgstr "Cap waktos"

msgid "IPアドレス"
msgstr "Alamat IP"

msgid "ユーザーエージェント"
msgstr "Agén Pamaké"

msgid "イベント"
msgstr "Acara"

msgid "IPアドレスのデータはありません"
msgstr "Teu aya data pikeun alamat IP ieu"

msgid "EU GDPR対応"
msgstr "Patuh kana GDPR EU"

msgid "無効"
msgstr "Henteu sah"

msgid "有効"
msgstr "Sah"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Lamun anjeun ngagunakeun WordPress di EU, atawa lamun situs wéb anjeun nargétkeun pangguna di EU, mangga pastikeun ieu diaktipkeun."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Tombol 'Konfirmasi' bakal robah jadi 'Satuju' atawa 'Henteu Satuju', sarta paripolahna bakal rada robah."

msgid "同意画面の色"
msgstr "Warna layar idin"

msgid "自動"
msgstr "Otomatis"

msgid "ライトモード"
msgstr "Mode hampang"

msgid "ダークモード"
msgstr "Mode Poék"

msgid "同意画面表示中の配色を設定します"
msgstr "Atur skéma warna pikeun layar idin"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Kabur eusi dina layar idin"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Atur tingkat kabur pikeun eusi anu dipidangkeun dina layar idin"

msgid "同意画面の透過"
msgstr "Kajelasan layar idin"

msgid "透過なし"
msgstr "Teu aya transparansi"

msgid "同意画面の透過具合を設定します"
msgstr "Atur opasitas layar idin"

msgid "お知らせの1行目"
msgstr "Baris kahiji tina pangumuman"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Pesen ieu sok dipidangkeun nalika halaman dimuat pikeun kahiji kalina."

msgid "お知らせの2行目"
msgstr "Baris kadua tina béwara"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Pesen ieu bakal salawasna muncul dina tampilan kahiji ngan nalika EU GDPR lumaku."

msgid "お知らせの3行目"
msgstr "Baris katilu tina béwara"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Éta bakal muncul di katuhu tautan kana Kabijakan Privasi."

msgid "非EU向け確認の文字列"
msgstr "Téks konfirmasi pikeun nagara non-Uni Éropa"

msgid "EU GDPR向け同意するの文字列"
msgstr "Téks idin pikeun GDPR EU"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Téks pikeun 'Ulah masihan idin' dina EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Téks kabijakan privasi"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Mangga pasang URL pikeun kabijakan privasi di dieu."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Mangga tambahkeun ieu di handap kana Kabijakan Privasi."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Pikeun ngadeteksi kagiatan panipuan, idéntifikasi sapertos alamat IP disimpen dina cookie jeung basis data. Data anu disimpen dihapus nurutkeun kaputusan administratur."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Pikeun mastikeun yén gambar dikirimkeun kalayan leres ngan nalika panyalindungan gambar diaktipkeun, kami nyimpen data anu geus di-hash anu ngawengku alamat IP jeung ngaran file gambar dina basis data salila nepi ka 60 menit."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Lamun anjeun nyetél Sarat Pamakéan, mangga pastikeun anjeun nyertakeun tautan ka éta dina Kabijakan Privasi anjeun."

msgid "利用規約の文字列"
msgstr "Téks Sarat Pamakéan"

msgid "利用規約のページ"
msgstr "Halaman Istilah jeung Kaayaan"

msgid "ページ選択なし"
msgstr "Henteu aya kaca anu dipilih"

msgid "検索エンジン等のURL"
msgstr "URL pikeun mesin pencari, jsb."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Atur URL pikeun mesin pencari jeung situs sarupa anu ngarahkeun pangguna nalika idin henteu dipasihan."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mode debug, pesen peringatan konsol"

msgid "右クリックの警告メッセージ"
msgstr "Pesen peringatan klik katuhu"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Pesen peringatan ngeunaan nyitak jeung nyimpen salaku PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Pesen peringatan dina tangkapan layar"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Pesen peringatan ngeunaan screenshot anu dicurigai"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Pesen peringatan nalika sadaya téks dipilih"

msgid "ページ保存の警告メッセージ"
msgstr "Pesen peringatan ngeunaan nyimpen kaca"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Pesen anu ditampilkeun nalika nyalin atawa motong"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Pesen anu bakal dipidangkeun nalika ningali sumber HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Pesen pikeun dipidangkeun di luhur kode sumber nalika ngaburukkeun atawa ngajagi HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Pesen anu bakal dipidangkeun lamun token oténtikasi sakali paké teu sah salila panyalindungan HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Pesen pikeun dipidangkeun lamun cookies atawa JavaScript dinonaktipkeun"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Saéstuna, ieu ngan dipidangkeun nalika JavaScript dinonaktipkeun."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Lamun hiji gambar dilindungi, éta bakal diunduh, sarta pesen bakal dipintonkeun dina gambar éta"

msgid "HTML難読化 (圧縮)"
msgstr "Obfuskasi HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Ieu komprési HTML standar; aya ogé situs wéb anu bisa ngadekodena."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ngaktipkeun pilihan ieu ngamungkinkeun anjeun ngaksés log view-source."

msgid "HTML保護"
msgstr "Panglindungan HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Éta ngahasilkeun HTML anu leuwih saeutik tibatan setélan komprési HTML, hartina eusi dina tag BODY moal kaluar pisan."

msgid "Firefoxに対しては無効です"
msgstr "Ieu henteu lumaku pikeun Firefox"

msgid "SEOに著しく影響があります"
msgstr "Ieu boga pangaruh anu signifikan kana SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Ngahasilkeun HTML ngagunakeun JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Pikeun ngungkulan Firefox, urang ngagambarkeun HTML ngagunakeun JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Ngaktipkeun rendering JavaScript bakal sacara signifikan ngalambatkeun laju muat situs wéb."

msgid "画像の保護"
msgstr "Panglindungan gambar"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Lindungi gambar unggal waktos tag img dipanggil"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Ngajagi sakabéh gambar anu diunggah ka WordPress dina sakabéh kaluaran HTML."

msgid "画像をダウンロードから保護します"
msgstr "Ngajaga gambar supaya teu bisa diunduh"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Nalika data gambar dilindungi, kami nyegah ampir sakabéh unduhan, ngaluarkeun URL sakali paké anu unik, ngautentikasi ngagunakeun token anu disimpen dina sesi, sarta nembongkeun gambar ngaliwatan PHP; ieu sacara efektif nyegah ampir sakabéh kasus maling gambar."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Lamun data gambar dilindungi, caching moal jalan, nu hartina situs bakal muat leuwih lalaunan dina kunjungan salajengna, sahingga mangaruhan SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ngajagi data gambar tiasa ningkatkeun beban dina basis data."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Lamun anjeun milih 'Ngajagi gambar iraha waé tag img dipanggil', sistem bakal ngagunakeun add_filter pikeun nerapkeun saringan nalika tag img dijieun; sanajan kitu, ieu bisa jadi teu jalan leres dina sababaraha téma."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Lamun anjeun milih 'Ngajagi sakabéh gambar anu diunggah ka WordPress dina sakabéh kaluaran HTML', plugin ieu bakal nyekel ampir sakabéh operasi WordPress jeung ngolah unggal tag img dina eusi. Punten dicatet yén ieu bisa jadi henteu jalan leres dina sababaraha téma."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Mangga diperhatikeun yén gambar anu ditunjuk salaku gambar unggulan bakal dibagikeun salaku data OGP sareng teu tiasa dilindungi. Upami anjeun mutlak kedah ngajagi éta, mangga robah setélan pikeun kaluaran tag HEAD dina setélan canggih nalika ngaktipkeun panyalindungan HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Fungsi screenshot anu aya dina sistem operasi teu tiasa dilindungi"

msgid "画像URLの保護"
msgstr "Ngajagi URL gambar"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Ieu kedah dianggo babarengan jeung panyalindungan gambar; mun nyalira, éta teu aya gunana."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Kusabab dimuat ngaliwatan JavaScript, ieu mangaruhan SEO."

msgid "画像のウォーターマーク"
msgstr "Watermark gambar"

msgid "右下"
msgstr "Handap katuhu"

msgid "ランダム位置"
msgstr "Posisi acak"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Dina kombinasi jeung panyalindungan gambar, watermark dinamis sacara jelas nunjukkeun kapamilikan hak cipta bari méré kesan ka panempo yén maranéhna keur diawasan, sahingga jadi panghalang."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Ngan format JPG, PNG, jeung WebP anu didukung."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Ngaktipkeun ieu bakal ningkatkeun beban dina sérver."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ngahasilkeun seni ASCII tina kode sumber HTML nalika ngaburamkeun jeung ngajaga"

msgid "表示なし"
msgstr "Teu aya tampilan"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Némbongkeun seni ASCII nu nandakeun peringatan nalika ningali sumber HTML maké 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Témbongkeun desain nalika tindakan sasaran dilakukeun"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Desain dasar anu nampilkeun téks hideung dina latar tukang konéng"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Desain gaya horor anu nembongkeun téks beureum dina latar hideung"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Desain anu nembongkeun téks beureum caang dina latar hideung"

msgid "対象アクションを起こした時のBGM"
msgstr "Musik latar anu maén nalika tindakan sasaran dilakukeun"

msgid "サウンドなし"
msgstr "Teu aya sora"

