msgstr "માન્ય"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "જો તમે EUમાં WordPress નો ઉપયોગ કરી રહ્યા છો, અથવા તમારી વેબસાઇટ EUમાં વપરાશકર્તાઓને લક્ષ્ય બનાવે છે, તો કૃપા કરીને ખાતરી કરો કે આ સક્રિય છે."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' બટન 'Agree' અથવા 'Disagree' માં બદલાશે, અને વર્તન થોડીક બદલાશે."

msgid "同意画面の色"
msgstr "સંમતિ સ્ક્રીનનો રંગ"

msgid "自動"
msgstr "સ્વચાલિત"

msgid "ライトモード"
msgstr "હળવો મોડ"

msgid "ダークモード"
msgstr "ડાર્ક મોડ"

msgid "同意画面表示中の配色を設定します"
msgstr "સંમતિ સ્ક્રીન માટે રંગ યોજના સેટ કરો"

msgid "同意画面中のコンテンツのぼかし"
msgstr "સંમતિ સ્ક્રીન પર સામગ્રીનું ધૂંધળું થવું"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "સંમતિ સ્ક્રીન પર પ્રદર્શિત સામગ્રી માટે ધૂંધળાશનું સ્તર સેટ કરો"

msgid "同意画面の透過"
msgstr "સંમતિ સ્ક્રીનની પારદર્શિતા"

msgid "透過なし"
msgstr "કોઈ પારદર્શિતા નથી"

msgid "同意画面の透過具合を設定します"
msgstr "સંમતિ સ્ક્રીનની પારદર્શિતા સેટ કરો"

msgid "お知らせの1行目"
msgstr "ઘોષણાની પ્રથમ પંક્તિ"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "પૃષ્ઠ પ્રથમવાર લોડ થતા આ સંદેશ હંમેશા પ્રદર્શિત થાય છે."

msgid "お知らせの2行目"
msgstr "સૂચનાની બીજી પંક્તિ"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "આ સંદેશા ફક્ત ત્યારે જ પ્રથમ ડિસ્પ્લે પર હંમેશા દેખાશે જ્યારે EU GDPR અમલમાં હોય."

msgid "お知らせの3行目"
msgstr "સૂચનાની ત્રીજી પંક્તિ"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "તે ગોપનીયતા નીતિની લિંકની જમણી બાજુએ દેખાશે."

msgid "非EU向け確認の文字列"
msgstr "EU સિવાયના દેશો માટેની પુષ્ટિકરણ લખાણ"

msgid "EU GDPR向け同意するの文字列"
msgstr "EU GDPR માટે સંમતિનો લખાણ"

msgid "EU GDPR向け同意しないの文字列"
msgstr "EU GDPR હેઠળ 'સંમતિ ન આપો' માટેનો લખાણ"

msgid "プライバシーポリシーの文字列"
msgstr "ગોપનીયતા નીતિનો લખાણ"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "કૃપા કરીને અહીં ગોપનીયતા નીતિ માટે URL સેટ કરો"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "કૃપા કરીને નીચેની બાબતોને ગોપનીયતા નીતિમાં ઉમેરો."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "ઠગાઈ પ્રવૃત્તિ શોધવા માટે, IP સરનામા જેવા ઓળખકર્તા કૂકીઝ અને ડેટાબેઝમાં સંગ્રહિત કરવામાં આવે છે. સંગ્રહિત ડેટા એડમિનિસ્ટ્રેટરના વિવેક અનુસાર કાઢી નાખવામાં આવે છે."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "છબી સંરક્ષણ સક્રિય હોય ત્યારે છબીઓ યોગ્ય રીતે પહોંચાડવામાં આવે તે સુનિશ્ચિત કરવા માટે, અમે IP સરનામું અને છબી ફાઇલનામનો સમાવેશ કરતી હેશ કરેલી માહિતી 60 મિનિટ સુધી ડેટાબેસમાં સંગ્રહિત કરીએ છીએ."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "જો તમે ઉપયોગની શરતો તૈયાર કરી રહ્યા છો, તો કૃપા કરીને ખાતરી કરો કે તમે તેને તમારી ગોપનીયતા નીતિમાં લિંક કરો."

msgid "利用規約の文字列"
msgstr "ઉપયોગની શરતોનો લખાણ"

msgid "利用規約のページ"
msgstr "શરતો અને નિયમોનું પૃષ્ઠ"

msgid "ページ選択なし"
msgstr "કોઈ પૃષ્ઠ પસંદ કરવામાં આવ્યું નથી"

msgid "検索エンジン等のURL"
msgstr "શોધ એન્જિન્સ માટેના URL, વગેરે."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "જ્યારે વપરાશકર્તાઓ સંમતિ ન આપે ત્યારે તેમને રીડાયરેક્ટ કરતી સર્ચ એન્જિન્સ અને સમાન સાઇટ્સ માટે URL સેટ કરો"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "ડિબગ મોડ, કન્સોલ ચેતવણી સંદેશાઓ"

msgid "右クリックの警告メッセージ"
msgstr "જમણ-ક્લિક ચેતવણી સંદેશ"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "પ્રિન્ટિંગ અને PDF તરીકે સાચવવા અંગે ચેતવણી સંદેશ"

msgid "スクリーンショットの警告メッセージ"
msgstr "સ્ક્રીનશોટમાં ચેતવણી સંદેશ"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "શંકાસ્પદ સ્ક્રીનશોટ્સ અંગેની ચેતવણી સંદેશ"

msgid "テキスト全選択時の警告メッセージ"
msgstr "બધા લખાણ પસંદ થવા પર ચેતવણી સંદેશ"

msgid "ページ保存の警告メッセージ"
msgstr "પૃષ્ઠ સાચવવા અંગેની ચેતવણી સંદેશ"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "કોપી અથવા કટ કરતી વખતે પ્રદર્શિત સંદેશ"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML સ્ત્રોત જોતી વખતે પ્રદર્શિત કરવા માટેનો સંદેશ"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML ને અસ્પષ્ટ"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML સુરક્ષા દરમિયાન એકવાર ઉપયોગ માટેનો પ્રમાણપત્ર ટોકન અમાન્ય હોય તો પ્રદર્શિત કરવા માટેનો સંદેશ"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "જો કૂકીઝ અથવા જાવાસ્ક્રિપ્ટ નિષ્ક્રિય હોય તો પ્રદર્શિત કરવા માટેનો સંદેશ"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "વાસ્તવમાં, આ ત્યારે જ દેખાય છે જ્યારે જાવાસ્ક્રિપ્ટ નિષ્ક્રિય હોય."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "જ્યારે કોઈ છબી સુરક્ષિત હોય છે, ત્યારે તે ડાઉનલોડ થાય છે અને તે છબી પર સંદેશ"

msgid "HTML難読化 (圧縮)"
msgstr "HTML અસ્પષ્ટીકરણ"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "આ સ્ટાન્ડર્ડ HTML સંકોચન છે; તેને ડિકોડ કરી શકે એવી વેબસાઇટ્સ પણ છે."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "આ વિકલ્પને સક્રિય કરવાથી તમે વ્યૂ-સોર્સ લોગ મેળવી શકો છો."

msgid "HTML保護"
msgstr "HTML રક્ષણ"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "તે ફક્ત HTML નું સૌથી ઓછું જરૂરી સ્વરૂપ જ આઉટપુટ કરે છે—HTML સંકોચન કરતાં પણ ઓછું—અને BODY ટેગની અંદરની સામગ્રી એકદમ પણ આઉટપુટ થતી નથી."

msgid "Firefoxに対しては無効です"
msgstr "આ ફાયરફોક્સ પર લાગુ પડતું નથી"

msgid "SEOに著しく影響があります"
msgstr "આનો SEO પર નોંધપાત્ર પ્રભાવ છે."

msgid "HTMLをJavaScriptで描画"
msgstr "જાવાસ્ક્રિપ્ટનો ઉપયોગ કરીને HTML રેન્ડર કરવું"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox પર કામ ચલાવવા માટે, અમે JavaScript નો ઉપયોગ કરીને HTML રેન્ડર કરીએ છીએ."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "જાવાસ્ક્રિપ્ટ રેન્ડરિંગ સક્રિય કરવાથી વેબસાઇટની લોડિંગ ગતિ નોંધપાત્ર રીતે ધીમી પડી જશે."

msgid "画像の保護"
msgstr "છબી સંરક્ષણ"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img ટેગ દરેક વખતે બોલાવવામાં આવે ત્યારે છબીની સુરક્ષા કરો"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "સંપૂર્ણ HTML આઉટપુટમાં WordPress પર અપલોડ થયેલી તમામ છબીઓને સુરક્ષિત કરો"

msgid "画像をダウンロードから保護します"
msgstr "છબીઓને ડાઉનલોડ થવાથી સુરક્ષિત કરે છે"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "જ્યારે ઈમેજ ડેટા સુરક્ષિત હોય છે, ત્યારે અમે ડાઉનલોડ્સને લગભગ સંપૂર્ણપણે અટકાવે છીએ, અનન્ય એકવાર ઉપયોગ માટેના URL જારી કરીએ છીએ, સત્રમાં સંગ્રહિત ટોકન્સનો ઉપયોગ કરીને પ્રમાણિકરણ કરીએ છીએ, અને PHP દ્વારા છબીઓ પ્રદર્શિત કરીએ છીએ; આ અસરકારક રીતે છબી ચોરી અટકાવે છે."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "જ્યારે ઈમેજ ડેટા સુરક્ષિત હોય છે, ત્યારે કેશિંગ કામ કરતી નથી, જેના કારણે સાઇટ આગામી મુલાકાતોમાં ધીરે લોડ થાય છે અને તે SEO પર અસર કરે છે."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "છબીના ડેટાની સુરક્ષા કરવાથી ડેટાબેઝ પરનો ભાર વધી શકે છે."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
