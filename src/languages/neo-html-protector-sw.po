msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Onyo kutoka kwa ChatGPT - sekunde 3.8 - baiti 109,700 - 256 kbps - Leseni: Mali ya umma"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sauti ya dharura ya juu inayofanana na tahadhari ya ugunduzi wa programu hasidi – Sehemu ya 1 na ChatGPT – sekunde 3.3 – baiti 102,850 – 256 kbps – Leseni: Mali ya umma"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sauti ya dharura ya juu inayofanana na tahadhari ya ugunduzi wa programu hasidi, Sehemu ya 2 na ChatGPT - sekunde 3.3 - baiti 103,122 - 256 kbps - Leseni: Mali ya Umma"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Sauti ya mtindo wa MRI na ChatGPT – dakika 1 sekunde 14.9 – baiti 3,340,392 – 320 kbps – Leseni: Mali ya umma"

msgid "警告表示中のBGMを選択します"
msgstr "Chagua muziki wa mandharinyuma utakao cheza wakati wa onyo."

msgid "びっくりするような雰囲気を作ります"
msgstr "Huitengeneza hali ya kushangaza"

msgid "Firefoxでは音声ブロックされます"
msgstr "Sauti imezuiwa katika Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "Bip inapofanywa kitendo kilichobainishwa"

msgid "有効 音量小さ目"
msgstr "Imewashwa, sauti chini"

msgid "有効 音量大き目"
msgstr "Inaendelea, sauti imewekwa juu"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Sauti ya bip itasikika kwa matukio yote ya kitufe na kipanya wakati onyo linaonyeshwa."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Hii inaacha hisia kwamba kifaa kimepoteza udhibiti wakati onyo linaonyeshwa."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Kuficha kiashiria cha panya wakati kitendo maalum kinapotendeka"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Huficha kiashiria cha panya katika eneo la kivinjari wakati onyo linaonyeshwa"

msgid "デバッグモード"
msgstr "Hali ya kurekebisha hitilafu"

msgid "妨害＋記録のみ"
msgstr "Uingiliaji + Rekodi tu"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Uingiliaji + Urekodi + Onyesho + Uelekezaji upya"

msgid "メニューからは操作できてしまいます"
msgstr "Bado unaweza kuifikia kupitia menyu."

msgid "Firefoxにおけるデバッグモード"
msgstr "Hali ya kurekebisha hitilafu katika Firefox"

msgid "ブラウザーコンソール"
msgstr "Konsoli ya kivinjari"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Kwa hakika, unaweza kuiendesha kutoka kwenye hali ya kurekebisha hitilafu."

msgid "HTMLソース表示"
msgstr "Tazama chanzo cha HTML"

