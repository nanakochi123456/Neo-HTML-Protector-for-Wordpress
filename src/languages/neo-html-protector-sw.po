msgid "設定"
msgstr "Mipangilio"

msgid "IPログリーダー"
msgstr "Soma Kumbukumbu za IP"

msgid "IPアドレスログ"
msgstr "Kumbukumbu ya anwani za IP"

msgid "全クリア"
msgstr "Kamilisha ngazi zote"

msgid "IPログが全て削除されました"
msgstr "Kumbukumbu zote za IP zimefutwa"

msgid "ID"
msgstr "Kitambulisho"

msgid "タイムスタンプ"
msgstr "Alama ya muda"

msgid "IPアドレス"
msgstr "Anwani ya IP"

msgid "ユーザーエージェント"
msgstr "Wakala wa mtumiaji"

msgid "イベント"
msgstr "Tukio"

msgid "IPアドレスのデータはありません"
msgstr "Hakuna data kwa anwani hii ya IP."

msgid "EU GDPR対応"
msgstr "Uzingatiaji wa GDPR ya EU"

msgid "無効"
msgstr "Si halali"

msgid "有効"
msgstr "Halali"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Ikiwa unatumia WordPress ndani ya Umoja wa Ulaya, au ikiwa tovuti yako inalenga watumiaji ndani ya Umoja wa Ulaya, tafadhali hakikisha hii imewezeshwa."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Kitufe cha 'Thibitisha' kitabadilika kuwa 'Kubaliana' au 'Kutokubaliana', na tabia yake itabadilika kidogo."

msgid "同意画面の色"
msgstr "Rangi ya skrini ya idhini"

msgid "自動"
msgstr "Kiotomatiki"

msgid "ライトモード"
msgstr "Hali nyepesi"

msgid "ダークモード"
msgstr "Hali ya Giza"

msgid "同意画面表示中の配色を設定します"
msgstr "Weka mpangilio wa rangi kwa skrini ya idhini"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Kufifisha maudhui kwenye skrini ya idhini"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Weka kiwango cha kufifisha maudhui yanayoonekana kwenye skrini ya idhini"

msgid "同意画面の透過"
msgstr "Uwazi wa skrini ya idhini"

msgid "透過なし"
msgstr "Hakuna uwazi"

msgid "同意画面の透過具合を設定します"
msgstr "Weka uwazi wa skrini ya idhini"

msgid "お知らせの1行目"
msgstr "Mstari wa kwanza wa tangazo"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ujumbe huu huonyeshwa kila mara mara ya kwanza ukurasa unapopakiwa."

msgid "お知らせの2行目"
msgstr "Mstari wa pili wa taarifa"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ujumbe huu utaonekana kila mara kwenye onyesho la kwanza tu wakati GDPR ya EU iko katika nguvu."

msgid "お知らせの3行目"
msgstr "Mstari wa tatu wa taarifa"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Itatokea upande wa kulia wa kiungo cha Sera ya Faragha."

msgid "非EU向け確認の文字列"
msgstr "Uthibitisho wa maandishi kwa nchi zisizo za Umoja wa Ulaya"

msgid "EU GDPR向け同意するの文字列"
msgstr "Maelezo ya idhini kwa GDPR ya EU"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Maandishi ya 'Usiruhusu' chini ya GDPR ya Umoja wa Ulaya"

msgid "プライバシーポリシーの文字列"
msgstr "Maandishi ya sera ya faragha"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Tafadhali weka URL ya sera ya faragha hapa"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Tafadhali ongeza yafuatayo kwenye sera ya faragha."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Ili kugundua shughuli za udanganyifu, vitambulisho kama anwani za IP huhifadhiwa kwenye vidakuzi na hifadhidata. Data iliyohifadhiwa hufutwa kwa hiari ya msimamizi."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Ili kuhakikisha picha zinafikishwa kwa usahihi tu wakati ulinzi wa picha umewezeshwa, tunahifadhi data zilizohashwa zinazojumuisha anwani ya IP na jina la faili la picha kwenye hifadhidata kwa hadi dakika 60."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Ikiwa unaandaa Masharti ya Matumizi, tafadhali hakikisha unajumuisha kiungo chao katika Sera yako ya Faragha."

msgid "利用規約の文字列"
msgstr "Nakala ya Masharti ya Matumizi"

msgid "利用規約のページ"
msgstr "Ukurasa wa Masharti na Vigezo"

msgid "ページ選択なし"
msgstr "Hakuna ukurasa uliochaguliwa"

msgid "検索エンジン等のURL"
msgstr "URL za injini za utafutaji, n.k."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Weka URL kwa injini za utafutaji na tovuti zinazofanana zinazowaelekeza watumiaji wanapokosa ridhaa."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Hali ya kurekebisha hitilafu, ujumbe wa onyo kwenye konsole"

msgid "右クリックの警告メッセージ"
msgstr "Bofya kulia ujumbe wa onyo"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Ujumbe wa tahadhari kuhusu kuchapisha na kuhifadhi kama PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Ujumbe wa onyo kwenye picha ya skrini"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Ujumbe wa onyo kuhusu picha za skrini zinazoshukiwa"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Ujumbe wa onyo wakati maandishi yote yamechaguliwa"

msgid "ページ保存の警告メッセージ"
msgstr "Ujumbe wa onyo kuhusu uhifadhi wa ukurasa"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Ujumbe unaoonyeshwa wakati wa kunakili au kukata"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Ujumbe wa kuonyesha unapotazama chanzo cha HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Ujumbe wa kuonyeshwa juu ya msimbo chanzo unapoficha au kulinda HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Ujumbe wa kuonyesha ikiwa tokeni ya uthibitisho ya mara moja haiko halali wakati wa ulinzi wa HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Ujumbe wa kuonyesha ikiwa vidakuzi au JavaScript zimezimwa"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Kwa kweli, hii huonyeshwa tu wakati JavaScript imezimwa."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Picha inapokuwa imelindwa, hupakuliwa, na ujumbe huonyeshwa juu yake"

msgid "HTML難読化 (圧縮)"
msgstr "Ufichuzi wa HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Hii ni ukandamizaji wa kawaida wa HTML; pia kuna tovuti zinazoweza kuifumbua."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Kuwasha chaguo hili kunakuwezesha kupata kumbukumbu ya chanzo cha mtazamo."

msgid "HTML保護"
msgstr "Ulinzi wa HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Inatoa HTML kidogo zaidi kuliko mpangilio wa kubana HTML, ikimaanisha kuwa yaliyomo ndani ya lebo ya BODY hayatatolewa kabisa."

msgid "Firefoxに対しては無効です"
msgstr "Hii haitumiki kwa Firefox"

msgid "SEOに著しく影響があります"
msgstr "Hii ina athari kubwa kwa SEO"

msgid "HTMLをJavaScriptで描画"
msgstr "Kutengeneza HTML kwa kutumia JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Ili kukabiliana na Firefox, tunatengeneza muonekano wa HTML kwa kutumia JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Kuwasha uwasilishaji wa JavaScript kutasababisha kupungua kwa kasi ya upakiaji wa tovuti."

msgid "画像の保護"
msgstr "Ulinzi wa picha"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Linda picha kila wakati lebo ya img inapotajwa"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Linda picha zote zilizopakiwa kwenye WordPress ndani ya pato lote la HTML"

msgid "画像をダウンロードから保護します"
msgstr "Hulinda picha zisishushwe"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Wakati data za picha zinapohifadhiwa, tunazuia karibu upakuaji wote, tunatoa URL za kipekee za mara moja, tunathibitisha utambulisho kwa kutumia tokeni zilizohifadhiwa katika kipindi cha kikao, na tunaonyesha picha kupitia PHP; hii kwa ufanisi inazuia karibu wizi wote wa picha."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Wakati data ya picha inalindwa, kuhifadhi kwa muda mfupi hakifanyi kazi, jambo linalomaanisha kuwa tovuti itapakia polepole zaidi katika ziara zinazofuata, na hivyo kuathiri SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Kulinda data ya picha kunaweza kuongeza mzigo kwenye hifadhidata."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Ukichagua 'Linda picha kila wakati lebo ya img inapotajwa', mfumo utatumia add_filter kutekeleza uchujaji wakati lebo ya img inapotengenezwa; hata hivyo, hii inaweza kutofanya kazi ipasavyo na baadhi ya mandhari."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Ukichagua 'Linda picha zote zilizopakiwa kwenye WordPress ndani ya pato lote la HTML', programu-jalizi itarekodi karibu shughuli zote za WordPress na kuchakata kila lebo ya img katika maudhui. Tafadhali kumbuka kuwa hii inaweza isifanye kazi ipasavyo na baadhi ya mandhari."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Tafadhali kumbuka kuwa picha zinazotajwa kama picha kuu zitashirikiwa kama data ya OGP na haziwezi kulindwa. Ikiwa ni lazima kabisa kuzilinda, tafadhali badilisha mipangilio ya kutolewa kwa lebo ya HEAD katika mipangilio ya hali ya juu unapowezesha ulinzi wa HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Kazi ya kuchukua picha ya skrini iliyojumuishwa kama kipengele cha kawaida katika mfumo wa uendeshaji haiwezi kulindwa."

msgid "画像URLの保護"
msgstr "Kulinda URL za picha"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Hii inapaswa kutumika pamoja na ulinzi wa picha; yenyewe haifai kwa chochote."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Kwa kuwa inapakia kupitia JavaScript, hii inaathiri SEO."

msgid "画像のウォーターマーク"
msgstr "Alama ya maji ya picha"

msgid "右下"
msgstr "Chini kulia"

msgid "ランダム位置"
msgstr "Nafasi ya nasibu"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Zikitumika pamoja na ulinzi wa picha, alama za maji zinazobadilika zinaonyesha wazi umiliki wa hakimiliki huku zikitoa hisia kwa watazamaji kwamba wanachunguzwa, hivyo zikichukua jukumu la kuzuia ukiukaji."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Ni miundo ya JPG, PNG na WebP pekee inayotumika."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Kuwasha hii kutongeza mzigo kwenye seva."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Kutoa sanaa ya ASCII kutoka kwa msimbo chanzo wa HTML wakati wa kuficha na kulinda"

msgid "表示なし"
msgstr "Hakuna onyesho"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Huonyesha sanaa ya ASCII inayoonyesha onyo unapotazama chanzo cha HTML kwa kutumia 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Onyesha muundo wakati kitendo lengwa kinapotekelezwa"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Muundo wa msingi unaoonyesha maandishi meusi kwenye mandhari ya manjano"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Muundo wa mtindo wa kutisha wenye maandishi mekundu kwenye mandhari nyeusi"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Muundo unaoonyesha maandishi mekundu yanayong'aa kwenye mandhari nyeusi"

msgid "対象アクションを起こした時のBGM"
msgstr "Muziki wa mandhari unaopigwa wakati kitendo lengwa kinapotendeka"

msgid "サウンドなし"
msgstr "Hakuna sauti"

