msgid "設定"
msgstr "Ntọala"

msgid "IPログリーダー"
msgstr "Onye na-agụ ndekọ IP"

msgid "IPアドレスログ"
msgstr "Ndekọ adreesị IP"

msgid "全クリア"
msgstr "Meechaa ọkwa niile"

msgid "IPログが全て削除されました"
msgstr "E hichapụla ndekọ IP niile."

msgid "ID"
msgstr "Nọmba njirimara"

msgid "タイムスタンプ"
msgstr "Akara oge"

msgid "IPアドレス"
msgstr "Adreesị IP"

msgid "ユーザーエージェント"
msgstr "Onye nnọchi anya onye ọrụ"

msgid "イベント"
msgstr "Ihe omume"

msgid "IPアドレスのデータはありません"
msgstr "Enweghị data maka adreesị IP a."

msgid "EU GDPR対応"
msgstr "Ịgbaso EU GDPR"

msgid "無効"
msgstr "Ezighi ezi"

msgid "有効"
msgstr "Ziri ezi"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Ọ bụrụ na ị na-eji WordPress n'ime EU, ma ọ bụ ma weebụsaịtị gị na-elekwasị anya na ndị ọrụ n'ime EU, biko hụ na a kwadoro nke a."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Bọtịnụ 'Nkwenye' ga-agbanwe bụrụ 'Nkwenye' ma ọ bụ 'Mgbagha', na omume ga-agbanwe ntakịrị."

msgid "同意画面の色"
msgstr "Agba nke ihuenyo nkwenye"

msgid "自動"
msgstr "Na-akpaghị aka"

msgid "ライトモード"
msgstr "Ụdị ìhè"

msgid "ダークモード"
msgstr "Ụdị Ọchịchịrị"

msgid "同意画面表示中の配色を設定します"
msgstr "Tọọ usoro agba maka ihuenyo nkwenye"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Ịkụda ọdịnaya na ihuenyo nkwenye"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Tọọ ọkwa igbu anya maka ọdịnaya e gosipụtara na ihuenyo nkwenye"

msgid "同意画面の透過"
msgstr "Ihe doro anya nke ihuenyo nkwenye"

msgid "透過なし"
msgstr "Enweghị ìhè doro anya"

msgid "同意画面の透過具合を設定します"
msgstr "Tọọ ịdị doro anya nke ihuenyo nkwenye"

msgid "お知らせの1行目"
msgstr "Ahịrị mbụ nke nkwupụta"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "A na-egosi ozi a mgbe niile n'oge mbụ e bulitere ibe ahụ."

msgid "お知らせの2行目"
msgstr "Ahịrị nke abụọ nke ọkwa ahụ"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ozi a ga-apụta mgbe niile na ngosipụta mbụ naanị mgbe EU GDPR dị n'ọrụ."

msgid "お知らせの3行目"
msgstr "Ahịrị nke atọ nke ọkwa ahụ"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ọ ga-apụta n'aka nri nke njikọ na Usoro Nzuzo."

msgid "非EU向け確認の文字列"
msgstr "Ozi nkwenye maka mba ndị na-abụghị EU"

msgid "EU GDPR向け同意するの文字列"
msgstr "Ozi ederede nkwenye maka EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Ozi maka 'Ekwela ikwe' n'okpuru EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Nkwupụta nzuzo"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Biko tọọ URL maka iwu nzuzo ebe a."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Biko tinye ihe ndị a na Atụmatụ Nzuzo."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Iji chọpụta omume aghụghọ, a na-echekwa njirimara dịka adreesị IP na kuki na nchekwa data. A na-ehichapụ data echekwara ahụ dịka onye nchịkwa si kpebie."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Iji hụ na a na-ebuga onyonyo n'ụzọ ziri ezi naanị mgbe nchebe onyonyo kwụrụ, anyị na-echekwa data e kpara hash nke gụnyere adreesị IP na aha faịlụ onyonyo na nchekwa data ruo nkeji iri isii."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Ọ bụrụ na ị na-etolite Ụkpụrụ Ojiji, biko jide n'aka na ị tinye njikọ na ha na Atụmatụ Nzuzo gị."

msgid "利用規約の文字列"
msgstr "Ozi gbasara Ụkpụrụ Ojiji"

msgid "利用規約のページ"
msgstr "Peji nke Okwu na Ọnọdụ"

msgid "ページ選択なし"
msgstr "Enweghị ibe ahọpụtara"

msgid "検索エンジン等のURL"
msgstr "URLs maka igwe nchọta, wdg."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Tọọ URL maka igwe nchọta na saịtị yiri ya nke na-eziga ndị ọrụ n'ebe ọzọ mgbe a naghị enye nkwenye"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Ụdị ndozi njehie, ozi ịdọ aka ná ntị na kọnsọl"

msgid "右クリックの警告メッセージ"
msgstr "Mesaa ozi ịdọ aka ná ntị site na ịpị aka nri"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Ozi ịdọ aka ná ntị gbasara ibipụta na ịchekwa dị ka PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Ozi ịdọ aka ná ntị dị na onyonyo ihuenyo"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Ozi ịdọ aka ná ntị gbasara ihe onyonyo ihuenyo a na-enyo enyo"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Ozi ịdọ aka ná ntị mgbe ahọpụtara ederede niile"

msgid "ページ保存の警告メッセージ"
msgstr "Ozi ịdọ aka ná ntị gbasara ịchekwa ibe"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Ozi a na-egosi mgbe ị na-detuo ma ọ bụ ị na-ehichapụ"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Ozi ga-egosi mgbe a na-ele isi mmalite HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Ozi ga-egosi n'elu koodu isi mgbe a na-eme ka HTML sie ike ma ọ bụ na-echebe ya"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Ozi ga-egosi ma ọ bụrụ na token nnwale otu ugboro adịghị irè n'oge nchebe HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Ozi ga-egosi ma ọ bụrụ na a gbanyụrụ kuki ma ọ bụ JavaScript"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "N'eziokwu, a na-egosipụta nke a naanị mgbe e gbanyụrụ JavaScript."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Mgbe echekwara onyonyo, a na-ebudata ya ma egosipụta ozi n'elu ya"

msgid "HTML難読化 (圧縮)"
msgstr "Ịkpụchi koodu HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Nke a bụ nkwụnye nrụgharị HTML ọkọlọtọ; e nwekwara weebụsaịtị ndị nwere ike ịtụgharị ya."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ịgbatị nhọrọ a na-enye gị ohere iweta ndekọ view-source."

msgid "HTML保護"
msgstr "Nchebe HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ọ na-emepụta naanị HTML kacha nta—ọbụna obere karịa mgbe eji nkwụnye HTML—ma ọ naghị ebipụta ọdịnaya dị n'ime tag BODY n'ụzọ ọ bụla."

msgid "Firefoxに対しては無効です"
msgstr "Nke a adịghị metụta Firefox."

msgid "SEOに著しく影響があります"
msgstr "Nke a nwere mmetụta dị ukwuu na SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Ịmepụta HTML site na JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Iji gbanwee ụzọ ọrụ Firefox, anyị na-emepụta HTML site na JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Ịkwado igosipụta JavaScript ga-eme ka ọsọ ibu weebụsaịtị belata nke ukwuu."

msgid "画像の保護"
msgstr "Nchebe onyonyo"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Chebe onyonyo oge niile a na-akpọ tag img."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Chebe ihe onyonyo niile e bulitere na WordPress n'ime mmepụta HTML niile."

msgid "画像をダウンロードから保護します"
msgstr "Na-echebe onyonyo ka a ghara ibudata ha"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Mgbe a na-echekwa data onyonyo, anyị na-egbochi ihe fọrọ nke nta ka ọ bụrụ nbudata niile, na-enye URLs pụrụ iche maka otu oge, na-eme nnwale njirimara site na tokens echekwara na session, ma na-egosipụta onyonyo site na PHP; nke a na-egbochi ihe fọrọ nke nta ka ọ bụrụ izu ohi onyonyo niile."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Mgbe echekwara data onyonyo, nchekwa cache anaghị arụ ọrụ, nke pụtara na saịtị ahụ ga-ebudata nwayọ nwayọ mgbe a laghachiri ya ọzọ, si otú a na-emetụta SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ịchekwa data onyonyo nwere ike ime ka ibu ọrụ na nchekwa data bawanye."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Ọ bụrụ na ị họrọ 'Chebe onyonyo mgbe niile mgbe a na-akpọ tag img', sistemụ ahụ na-eji add_filter mee nzacha mgbe a na-emepụta tag img; otú ọ dị, nke a nwere ike ọ gaghị arụ ọrụ nke ọma na ụfọdụ isiokwu."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Ọ bụrụ na ị họrọ 'Chebe onyonyo niile e bulitere na WordPress n'ime mmepụta HTML niile', mgbakwunye ahụ ga-ejide ihe fọrọ nke nta ka ọ bụrụ ọrụ niile nke WordPress ma rụọ ọrụ na tag img ọ bụla dị n'ime ọdịnaya. Biko mara na nke a nwere ike ọ gaghị arụ ọrụ nke ọma na ụfọdụ isiokwu."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Biko mara na onyonyo ndị a họpụtara dị ka onyonyo pụrụ iche ga-ekerịta dị ka data OGP ma enweghị ike ichebe ha. Ọ bụrụ na ị ga-echebe ha n'ezie, biko gbanwee ntọala maka mmepụta tag HEAD na ntọala ndị ọkachamara mgbe ị na-enye nchebe HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "A pụghị ichebe ọrụ ịse ihe ngosi ihuenyo etinyere na sistemụ arụmọrụ."

msgid "画像URLの保護"
msgstr "Ịchebe URLs onyonyo"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "A ga-eji nke a na nchebe onyonyo; n'onwe ya, ọ n'enweghị uru ọ bụla."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "N'ihi na e buru ya site na JavaScript, nke a na-emetụta SEO."

msgid "画像のウォーターマーク"
msgstr "Akara mmiri onyonyo"

msgid "右下"
msgstr "N'okpuru aka nri"

msgid "ランダム位置"
msgstr "Ọnọdụ ọ bụla"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "A na-eji ya na nchebe onyonyo; akara mmiri na-agbanwe agbanwe na-egosi n'ụzọ doro anya onye nwe ikike edemede, ma na-enye ndị na-ekiri mmetụta na a na-enyocha ha, si otú a na-arụ ọrụ dị ka ihe na-egbochi mmebi."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "A na-akwado naanị usoro JPG, PNG na WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Ịgbatị nke a ga-abawanye ibu ọrụ na sava."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ịmepụta nka ASCII site na koodu isi HTML n'oge mgbagwoju anya na nchebe"

msgid "表示なし"
msgstr "Enweghị ngosipụta"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Na-egosi nka ASCII nke na-egosi ịdọ aka ná ntị mgbe ị na-ele isi mmalite HTML site na iji 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Gosi imewe mgbe e mere omume a na-atụ anya"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Nhazi dị mfe nke na-egosipụta ederede ojii n'azụ odo"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Imewe ụdị egwu nke na-egosipụta ederede uhie n'azụ ojii"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Nhazi nke na-egosipụta ederede uhie na-enwu na ndabere ojii"

msgid "対象アクションを起こした時のBGM"
msgstr "Egwu ndabere na-egwu mgbe e mere omume a na-achọ"

msgid "サウンドなし"
msgstr "Enweghị ụda"

