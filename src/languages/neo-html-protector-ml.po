msgid "設定"
msgstr "ക്രമീകരണങ്ങൾ"

msgid "IPログリーダー"
msgstr "ഐപി ലോഗ് റീഡർ"

msgid "IPアドレスログ"
msgstr "ഐപി വിലാസത്തിന്റെ രേഖ"

msgid "全クリア"
msgstr "എല്ലാ ലെവലുകളും പൂർത്തിയാക്കുക"

msgid "IPログが全て削除されました"
msgstr "എല്ലാ ഐപി ലോഗുകളും ഇല്ലാതാക്കിയിരിക്കുന്നു"

msgid "ID"
msgstr "ഐഡി"

msgid "タイムスタンプ"
msgstr "സമയമുദ്ര"

msgid "IPアドレス"
msgstr "ഐപി വിലാസം"

msgid "ユーザーエージェント"
msgstr "ഉപയോക്തൃ ഏജന്റ്"

msgid "イベント"
msgstr "പരിപാടി"

msgid "IPアドレスのデータはありません"
msgstr "ഈ ഐപി വിലാസത്തിന് വിവരങ്ങളൊന്നുമില്ല."

msgid "EU GDPR対応"
msgstr "യൂറോപ്യൻ യൂണിയൻ ജിഡിപിആറുമായുള്ള അനുവർത്തനം"

msgid "無効"
msgstr "അസാധു"

msgid "有効"
msgstr "സാധുവായ"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "നിങ്ങൾ യൂറോപ്യൻ യൂണിയനിൽ"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'കൺഫേം' ബട്ടൺ 'സമ്മതിക്കുന്നു' അല്ലെങ്കിൽ 'സമ്മതിക്കുന്നില്ല' എന്നായി മാറുകയും, പ്രവർത്തനരീതിയിൽ ചെറിയ മാറ്റം വരികയും ചെയ്യും."

msgid "同意画面の色"
msgstr "സമ്മതപത്രത്തിൻ്റെ നിറം"

msgid "自動"
msgstr "ഓട്ടോമാറ്റിക്"

msgid "ライトモード"
msgstr "ലഘു രീതി"

msgid "ダークモード"
msgstr "ഡാർക്ക് മോഡ്"

msgid "同意画面表示中の配色を設定します"
msgstr "സമ്മതം നൽകൽ സ്ക്രീനിൻ്റെ നിറങ്ങൾ ക്രമീകരിക്കുക"

msgid "同意画面中のコンテンツのぼかし"
msgstr "സമ്മതം നൽകുന്ന സ്ക്രീനിലെ ഉള്ളടക്കം മങ്ങുന്നത്"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "സമ്മതം ചോദിക്കുന്ന സ്ക്രീനിൽ പ്രദർശിപ്പിക്കുന്ന ഉള്ളടക്കത്തിൻ്റെ മങ്ങലിൻ്റെ അളവ് ക്രമീകരിക്കുക"

msgid "同意画面の透過"
msgstr "സമ്മതം നൽകുന്നതിനുള്ള സ്ക്രീനിന്റെ സുതാര്യത"

msgid "透過なし"
msgstr "പരിശോധനയില്ല"

msgid "同意画面の透過具合を設定します"
msgstr "സമ്മതം നൽകുന്നതിനുള്ള സ്ക്രീനിൻ്റെ അതാര്യത ക്രമീകരിക്കുക"

msgid "お知らせの1行目"
msgstr "അറിയിപ്പിന്റെ ആദ്യ വരി"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "പേജ് ആദ്യമായി ലോഡ് ചെയ്യുമ്പോൾ ഈ സന്ദേശം എപ്പോഴും പ്രദർശിപ്പിക്കും."

msgid "お知らせの2行目"
msgstr "അറിയിപ്പിന്റെ രണ്ടാമത്തെ വരി"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "EU GDPR പ്രാബല്യത്തിൽ ആയിരിക്കുമ്പോൾ മാത്രം ആദ്യത്തെ ഡിസ്‌പ്ലേയിൽ ഈ സന്ദേശം എപ്പോഴും ദൃശ്യമാകും."

msgid "お知らせの3行目"
msgstr "അറിയിപ്പിന്റെ മൂന്നാം വരി"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "ഇത് സ്വകാര്യതാ നയത്തിലേക്കുള്ള ലിങ്കിന്റെ വലതുവശത്ത് ദൃശ്യമാകും."

msgid "非EU向け確認の文字列"
msgstr "യൂറോപ്യൻ യൂണിയനിൽ അംഗമല്ലാത്ത രാജ്യങ്ങൾക്കുള്ള സ്ഥിരീകരണ സന്ദേശം"

msgid "EU GDPR向け同意するの文字列"
msgstr "EU ജിഡിപിആറിനുള്ള സമ്മതപരമായ ടെക്സ്റ്റ്"

msgid "EU GDPR向け同意しないの文字列"
msgstr "യൂറോപ്യൻ യൂണിയൻ ജിഡിപിആർ പ്രകാരം 'സമ്മതം നൽകരുത്' എന്നതിനുള്ള വിവരണം"

msgid "プライバシーポリシーの文字列"
msgstr "സ്വകാര്യതാ നയം"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "ദയവായി സ്വകാര്യതാ നയത്തിൻ്റെ URL ഇവിടെ നൽകുക"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "ദയവായി താഴെ പറയുന്നവ സ്വകാര്യതാ നയത്തിൽ ചേർക്കുക"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "തട്ടിപ്പ് പ്രവർത്തനങ്ങൾ കണ്ടെത്തുന്നതിനായി, ഐപി വിലാസങ്ങൾ പോലുള്ള ഐഡന്റിഫയറുകൾ കുക്കികളിലും ഡാറ്റാബേസിലും സംഭരിക്കുന്നു. സംഭരിച്ച ഡാറ്റ അഡ്മിനിസ്ട്രേറ്ററുടെ വിവേചനാധികാരപ്രകാരം ഇല്ലാതാക്കുന്നു."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "ചിത്ര സംരക്ഷണം പ്രവർത്തനക്ഷമമാക്കുമ്പോൾ ചിത്രങ്ങൾ ശരിയായി ലഭ്യമാകുന്നുവെന്ന് ഉറപ്പാക്കാൻ, ഐപി വിലാസവും ചിത്രത്തിന്റെ ഫയൽ നാമവും അടങ്ങുന്ന ഹാഷ് ചെയ്ത ഡാറ്റ 60 മിനിറ്റ് വരെ ഞങ്ങളുടെ ഡാറ്റാബേസിൽ സൂക്ഷിക്കുന്നു."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "നിങ്ങൾ ഉപയോഗ നിബന്ധനകൾ സജ്ജീകരിക്കുകയാണെങ്കിൽ, നിങ്ങളുടെ സ്വകാര്യതാ നയത്തിൽ അതിലേക്കുള്ള ഒരു ലിങ്ക് ഉൾപ്പെടുത്തിയിട്ടുണ്ടെന്ന് ഉറപ്പാക്കുക."

msgid "利用規約の文字列"
msgstr "ഉപയോഗ നിബന്ധനകളുടെ ഉള്ളടക്കം"

msgid "利用規約のページ"
msgstr "നിബന്ധനകളും വ്യവസ്ഥകളും പേജ്"

msgid "ページ選択なし"
msgstr "പേജ് തിരഞ്ഞെടുത്തിട്ടില്ല"

msgid "検索エンジン等のURL"
msgstr "സെർച്ച് എഞ്ചിനുകൾക്കുള്ള URL-കൾ, മുതലായവ."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "ഉപയോക്താക്കൾ സമ്മതം നൽകാത്തപ്പോൾ അവരെ മറ്റ് വെബ്സൈറ്റുകളിലേക്ക് തിരിച്ചുവിടുന്ന സെർച്ച് എഞ്ചിനുകൾക്കും സമാനമായ സൈറ്റുകൾക്കുമുള്ള URL സജ്ജീകരിക്കുക"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "ഡീബഗ് മോഡ്, കൺസോൾ മുന്നറിയിപ്പ് സന്ദേശങ്ങൾ"

msgid "右クリックの警告メッセージ"
msgstr "വലത്-ക്ലിക്ക് മുന്നറിയിപ്പ് സന്ദേശം"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "പിഡിഎഫ് ആയി പ്രിന്റ് ചെയ്യുന്നതിനും സേവ് ചെയ്യുന്നതിനും സംബന്ധിച്ച മുന്നറിയിപ്പ് സന്ദേശം"

msgid "スクリーンショットの警告メッセージ"
msgstr "സ്ക്രീൻഷോട്ടിലെ മുന്നറിയിപ്പ് സന്ദേശം"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "സംശയാസ്പദമായ സ്ക്രീൻഷോട്ടുകളെക്കുറിച്ചുള്ള മുന്നറിയിപ്പ് സന്ദേശം"

msgid "テキスト全選択時の警告メッセージ"
msgstr "എല്ലാ ടെക്സ്റ്റും തിരഞ്ഞെടുക്കുമ്പോൾ പ്രദർശിക്കുന്ന മുന്നറിയിപ്പ് സന്ദേശം"

msgid "ページ保存の警告メッセージ"
msgstr "പേജ് സേവിംഗിനെക്കുറിച്ചുള്ള മുന്നറിയിപ്പ് സന്ദേശം"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "പകർത്തുമ്പോഴോ മുറിക്കുമ്പോഴോ ദൃശ്യമാകുന്ന സന്ദേശം"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML സോഴ്സ് കാണുമ്പോൾ പ്രദർശിപ്പിക്കാനുള്ള സന്ദേശം"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML മങ്ങാക്കുകയോ സംരക്ഷിക്കുകയോ ചെയ്യുമ്പോൾ സോഴ്സ് കോഡിന്റെ മുകളിൽ പ്രദർശിപ്പിക്കാനുള്ള സന്ദേശം"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML സംരക്ഷണ സമയത്ത് ഏകതവണ ഉപയോഗിക്കാവുന്ന ഓതന്റിക്കേഷൻ ടോക്കൺ അസാധുവാണെങ്കിൽ പ്രദർശിപ്പിക്കാനുള്ള സന്ദേശം"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "കുക്കികളോ ജാവാസ്ക്രിപ്റ്റോ പ്രവർത്തനരഹിതമാക്കിയിട്ടുണ്ടെങ്കിൽ പ്രദർശിപ്പിക്കാനുള്ള സന്ദേശം"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "വാസ്തവത്തിൽ, ജാവാസ്ക്രിപ്റ്റ് പ്രവർത്തനരഹിതമാക്കിയിരിക്കുമ്പോൾ മാത്രമേ ഇത് ദൃശ്യമാകുകയുള്ളൂ."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "ഒരു ചിത്രം സംരക്ഷിക്കുമ്പോൾ, അത് ഡൗൺലോഡ് ചെയ്യുകയും, ആ ചിത്രത്തിൽ ഒരു സന്ദേശം"

msgid "HTML難読化 (圧縮)"
msgstr "HTML അവ്യക്തീകരണം"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "ഇതൊരു സാധാരണ എച്ച്‌ടിഎംഎൽ കംപ്രഷനാണ്; ഇത് ഡീകോഡ് ചെയ്യാൻ കഴിയുന്ന വെബ്സൈറ്റുകളുമുണ്ട്."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "ഈ ഓപ്ഷൻ പ്രവർത്തനക്ഷമമാക്കുന്നത്, വ്യൂ-സോഴ്‌സ് ലോഗ് വീണ്ടെടുക്കാൻ നിങ്ങളെ അനുവദിക്കുന്നു."

msgid "HTML保護"
msgstr "HTML സംരക്ഷണം"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "ഇത് HTML-ന്റെ ഏറ്റവും കുറഞ്ഞ അളവ് മാത്രമേ ഔട്ട്പുട്ട് ചെയ്യുന്നുള്ളൂ—HTML കംപ്രഷൻ ഉപയോഗിക്കുമ്പോൾ ലഭിക്കുന്നതിനേക്കാൾ കുറവ്—കൂടാതെ BODY ടാഗിനുള്ളിലെ ഉള്ളടക്കം ഒട്ടും ഔട്ട്പുട്ട് ചെയ്യുകയുമില്ല."

msgid "Firefoxに対しては無効です"
msgstr "ഇത് ഫയർഫോക്സിൽ ബാധകമല്ല"

msgid "SEOに著しく影響があります"
msgstr "ഇത് എസ്.ഇ.ഒ-യെ കാര്യമായി ബാധിക്കുന്നു."

msgid "HTMLをJavaScriptで描画"
msgstr "ജാവാസ്ക്രിപ്റ്റ് ഉപയോഗിച്ച് എച്ച്‌ടിഎംഎൽ റെൻഡർ ചെയ്യൽ"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "ഫയർഫോക്സിലെ പ്രശ്നം ഒഴിവാക്കാൻ, ഞങ്ങൾ ജാവാസ്ക്രിപ്റ്റ് ഉപയോഗിച്ച് HTML റെൻഡർ ചെയ്യുന്നു."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "ജാവാസ്ക്രിപ്റ്റ് റെൻഡറിംഗ് പ്രവർത്തനക്ഷമമാക്കുന്നത് വെബ്സൈറ്റിന്റെ ലോഡിംഗ് വേഗത ഗണ്യമായി കുറയ്ക്കും."

msgid "画像の保護"
msgstr "ചിത്ര സംരക്ഷണം"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "എല്ലാ തവണയും img ടാഗ് വിളിക്കുമ്പോൾ ചിത്രം സംരക്ഷിക്കുക"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "HTML ഔട്ട്പുട്ട് മുഴുവനായി, വേർഡ്പ്രസ്സിൽ അപ്‌ലോഡ് ചെയ്ത എല്ലാ ചിത്രങ്ങളും സംരക്ഷിക്കുക."

msgid "画像をダウンロードから保護します"
msgstr "ചിത്രങ്ങൾ ഡൗൺലോഡ് ചെയ്യപ്പെടുന്നത് തടയുന്നു"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "ചിത്രങ്ങളുടെ ഡാറ്റ സംരക്ഷിക്കപ്പെടുമ്പോൾ, ഞങ്ങൾ മിക്കവാറും എല്ലാ ഡൗൺലോഡുകളും തടയുകയും, സവിശേഷമായ ഒറ്റത്തവണ ഉപയോഗിക്കാവുന്ന URL-കൾ നൽകുകയും, സെഷനിൽ സൂക്ഷിച്ചിരിക്കുന്ന ടോക്കണുകൾ ഉപയോഗിച്ച് പ്രാമാണീകരിക്കുകയും, ചിത്രങ്ങൾ PHP വഴി പ്രദർശിപ്പിക്കുകയും ചെയ്യുന്നു; ഇത് ചിത്ര മോഷണത്തിന്റെ മിക്കവാറും എല്ലാ സാധ്യതകളെയും ഫലപ്രദമായി തടയുന്നു."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "ചിത്രങ്ങളുടെ ഡാറ്റ സംരക്ഷിക്കുമ്പോൾ കാഷിംഗ് പ്രവർത്തിക്കില്ല, ഇതിനർത്ഥം തുടർന്നുള്ള സന്ദർശനങ്ങളിൽ സൈറ്റ് കൂടുതൽ സാവധാനത്തിൽ ലോഡുചെയ്യുമെന്നും അതുവഴി എസ്.ഇ.ഒ-യെ"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "ചിത്രത്തിന്റെ ഡാറ്റ സംരക്ഷിക്കുന്നത് ഡാറ്റാബേസിലെ ലോഡ് വർദ്ധിപ്പിച്ചേക്കാം."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "നിങ്ങൾ 'ഓരോ തവണയും ഒരു img ടാഗ് ഉപയോഗിക്കുമ്പോൾ ചിത്രങ്ങൾ സംരക്ഷിക്കുക' തിരഞ്ഞെടുക്കുകയാണെങ്കിൽ, img ടാഗ് ഉണ്ടാക്കുമ്പോൾ ഫിൽട്ടറിംഗ് പ്രയോഗിക്കാൻ സിസ്റ്റം add_filter ഉപയോഗിക്കുന്നു; എന്നിരുന്നാലും, ചില തീമുകളിൽ ഇത് ശരിയായി പ്രവർത്തിച്ചേക്കില്ല."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "നിങ്ങൾ 'മുഴുവൻ HTML ഔട്ട്പുട്ടിലും വേർഡ്പ്രസ്സിലേക്ക് അപ്‌ലോഡ് ചെയ്ത എല്ലാ ചിത്രങ്ങളും സംരക്ഷിക്കുക' എന്നത് തിരഞ്ഞെടുക്കുകയാണെങ്കിൽ, പ്ലഗിൻ മിക്കവാറും എല്ലാ വേർഡ്പ്രസ്സ് പ്രവർത്തനങ്ങളെയും പിടിച്ചെടുക്കുകയും ഉള്ളടക്കത്തിലെ ഓരോ img ടാഗും പ്രോസസ്സ് ചെയ്യുകയും ചെയ്യും. ചില തീമുകളിൽ ഇത് ശരിയായി പ്രവർത്തിച്ചേക്കില്ലെന്ന് ദയവായി ശ്രദ്ധിക്കുക."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "ഫീച്ചേർഡ് ഇമേജുകളായി നിർദ്ദേശിച്ച ചിത്രങ്ങൾ OGP ഡാറ്റയായി പങ്കുവെക്കപ്പെടുമെന്നും അവയെ സംരക്ഷിക്കാൻ കഴിയില്ലെന്നും ദയവായി ശ്രദ്ധിക്കുക. അവയെ നിങ്ങൾക്ക് തീർച്ചയായും സംരക്ഷിക്കണമെന്നുണ്ടെങ്കിൽ, HTML പ്രൊട്ടക്ഷൻ പ്രവർത്തനക്ഷമമാക്കുമ്പോൾ, അഡ്വാൻസ്ഡ് ക്രമീകരണങ്ങളിലെ HEAD ടാഗ് ഔട്ട്പുട്ടിനായുള്ള സെറ്റിംഗ് മാറ്റുക."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "ഓപ്പറേറ്റിംഗ് സിസ്റ്റത്തിൽ സ്റ്റാൻഡേർഡായി ഉൾപ്പെടുത്തിയിട്ടുള്ള സ്ക്രീൻഷോട്ട് ഫംഗ്ഷന് സംരക്ഷണം നൽകാൻ കഴിയില്ല."

msgid "画像URLの保護"
msgstr "ചിത്രത്തിന്റെ URL-കൾ സംരക്ഷിക്കുക"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "ഇത് ചിത്ര സംരക്ഷണത്തോടൊപ്പം ഉപയോഗിക്കേണ്ടതാണ്; തനിയെ ഉപയോഗിച്ചാൽ ഇതിന് ഒരു പ്രയോജനവുമില്ല."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "ജാവാസ്ക്രിപ്റ്റ് വഴി ലോഡ് ചെയ്യുന്നതിനാൽ, ഇത് എസ്.ഇ.ഒ-യെ ബാധിക്കുന്നു."

msgid "画像のウォーターマーク"
msgstr "ചിത്രത്തിലെ വാട്ടർമാർക്ക്"

msgid "右下"
msgstr "വലതുവശത്ത് താഴെ"

msgid "ランダム位置"
msgstr "യദൃശ്ചികമായ സ്ഥാനം"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "ചിത്രങ്ങളുടെ സംരക്ഷണത്തോടൊപ്പം ഉപയോഗിക്കുമ്പോൾ, ഡൈനാമിക് വാട്ടർമാർക്കുകൾ പകർപ്പവകാശ ഉടമസ്ഥാവകാശം വ്യക്തമായി സൂചിപ്പിക്കുകയും, കാഴ്ചക്കാരെ നിരീക്ഷിക്കുന്നുണ്ടെന്ന തോന്നൽ നൽകി അവരെ പിന്തിരിപ്പിക്കുകയും ചെയ്യുന്നു."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "JPG, PNG, WebP ഫോർമാറ്റുകൾ മാത്രമേ പിന്തുണയ്ക്കുന്നുള്ളൂ."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "ഇത് പ്രവർത്തനക്ഷമമാക്കുന്നത് സെർവറിലെ ലോഡ് വർദ്ധിപ്പിക്കും."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "വ്യക്തത കുറയ്ക്കലും സംരക്ഷണവും നടത്തുമ്പോൾ HTML സോഴ്സ് കോഡിൽ നിന്ന് ASCII ആർട്ട് ഔട്ട്പുട്ട് ചെയ്യൽ"

