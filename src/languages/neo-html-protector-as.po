msgid "設定"
msgstr "ছেটিংছ"

msgid "IPログリーダー"
msgstr "আইপি লগ ৰিডাৰ"

msgid "IPアドレスログ"
msgstr "আইপি ঠিকনাৰ লগ"

msgid "全クリア"
msgstr "সকলো স্তৰ সম্পূৰ্ণ কৰক"

msgid "IPログが全て削除されました"
msgstr "সকলো আইপি লগ মচি পেলোৱা হৈছে"

msgid "ID"
msgstr "চিন"

msgid "タイムスタンプ"
msgstr "সময়চিহ্ন"

msgid "IPアドレス"
msgstr "আইপি ঠিকনা"

msgid "ユーザーエージェント"
msgstr "ব্যৱহাৰকাৰী এজেণ্ট"

msgid "イベント"
msgstr "অনুষ্ঠান"

msgid "IPアドレスのデータはありません"
msgstr "এই আইপি ঠিকনাৰ কোনো তথ্য নাই।"

msgid "EU GDPR対応"
msgstr "ইইউ জিডিপিআৰৰ অনুপালন"

msgid "無効"
msgstr "অসিদ্ধ"

msgid "有効"
msgstr "বৈধ"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "যদি আপুনি ইইউৰ ভিতৰত ৱৰ্ডপ্ৰেছ ব্যৱহাৰ কৰিছে, বা যদি আপোনাৰ ৱেবছাইটটোৱে ইইউৰ ব্যৱহাৰকাৰীসকলক লক্ষ্য কৰিছে, তেন্তে অনুগ্ৰহ কৰি নিশ্চিত কৰক যে এইটো সক্ষম কৰা আছে।"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' বুটামটো 'Agree' বা 'Disagree'লৈ সলনি হ'ব, আৰু আচৰণটো সামান্য সলনি হ'ব।"

msgid "同意画面の色"
msgstr "সন্মতিৰ স্ক্ৰীণৰ ৰং"

msgid "自動"
msgstr "স্বয়ংক্ৰিয়"

msgid "ライトモード"
msgstr "সহজ মোড"

msgid "ダークモード"
msgstr "ডাৰ্ক মোড"

msgid "同意画面表示中の配色を設定します"
msgstr "সন্মতি স্ক্ৰীণৰ বাবে ৰঙৰ আঁচনি নিৰ্ধাৰণ কৰক"

msgid "同意画面中のコンテンツのぼかし"
msgstr "সন্মতি স্ক্ৰীণত বিষয়বস্তুৰ অস্পষ্টতা"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "সন্মতি স্ক্ৰীণত প্ৰদৰ্শিত সমলৰ বাবে ধুঁৱলীকাৰ স্তৰ নিৰ্ধাৰণ কৰক"

msgid "同意画面の透過"
msgstr "সন্মতি স্ক্ৰীণৰ স্বচ্ছতা"

msgid "透過なし"
msgstr "স্বচ্ছতা নাই"

msgid "同意画面の透過具合を設定します"
msgstr "সন্মতি স্ক্ৰীণৰ স্বচ্ছতা নিৰ্ধাৰণ কৰক"

msgid "お知らせの1行目"
msgstr "ঘোষণাৰ প্ৰথম শাৰী"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "পৃষ্ঠাখন প্ৰথমবাৰ লোড হ'লে এই বাৰ্তাটো সদায় দেখুওৱা হয়।"

msgid "お知らせの2行目"
msgstr "অৱগতিপত্ৰখনৰ দ্বিতীয় শাৰী"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "এই বাৰ্তাটো কেৱল তেতিয়াহে প্ৰথম ডিছপ্লেত সদায় দেখা যাব, যেতিয়া EU GDPR বলবৎ হৈ থাকিব।"

msgid "お知らせの3行目"
msgstr "অৱগতিপত্ৰখনৰ তৃতীয় শাৰী"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "ই গোপনীয়তা নীতিৰ লিংকটোৰ সোঁফালে দেখা যাব।"

msgid "非EU向け確認の文字列"
msgstr "EU-ৰ বাহিৰৰ দেশসমূহৰ বাবে নিশ্চিতকৰণৰ পাঠ্য"

msgid "EU GDPR向け同意するの文字列"
msgstr "EU GDPR-ৰ বাবে সন্মতিৰ পাঠ্য"

msgid "EU GDPR向け同意しないの文字列"
msgstr "EU GDPR-ৰ অধীনত 'সন্মতি নিদিব'ৰ বাবে পাঠ্য"

msgid "プライバシーポリシーの文字列"
msgstr "গোপনীয়তা নীতিৰ পাঠ"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "অনুগ্ৰহ কৰি ইয়াত গোপনীয়তা নীতিৰ URLটো দিয়ক।"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "অনুগ্ৰহ কৰি গোপনীয়তা নীতিত নিম্নলিখিতখিনি যোগ কৰক"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "প্ৰতাৰণামূলক কাৰ্যকলাপ চিনাক্ত কৰিবলৈ, আইপি ঠিকনাৰ দৰে চিনাক্তকৰণকাৰীসমূহ কুকিজ আৰু ডাটাবেছত সংৰক্ষণ কৰা হয়। সংৰক্ষিত ডাটা প্ৰশাসকৰ বিবেচনা অনুসৰি মচি পেলোৱা হয়।"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "ইমেজ সুৰক্ষা সক্ষম কৰি থকাৰ সময়ত ছবিবোৰ সঠিকভাৱে ডেলিভাৰী হোৱাটো নিশ্চিত কৰিবলৈ, আমি IP ঠিকনা আৰু ছবিৰ ফাইলৰ নাম অন্তৰ্ভুক্ত থকা হেছ কৰা ডেটা আমাৰ ডাটাবেছত ৬০ মিনিটলৈকে সংৰক্ষণ কৰোঁ।"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "যদি আপুনি ব্যৱহাৰৰ চৰ্তাৱলী স্থাপন কৰিছে, তেন্তে অনুগ্ৰহ কৰি নিশ্চিত কৰিব যে আপুনি আপোনাৰ গোপনীয়তা নীতিত ইয়াৰ এটা লিংক অন্তৰ্ভুক্ত কৰিছে।"

msgid "利用規約の文字列"
msgstr "ব্যৱহাৰৰ চৰ্তাৱলীৰ পাঠ"

msgid "利用規約のページ"
msgstr "চৰ্তাৱলী আৰু নিয়মাবলী পৃষ্ঠা"

msgid "ページ選択なし"
msgstr "কোনো পৃষ্ঠা বাছনি কৰা হোৱা নাই"

msgid "検索エンジン等のURL"
msgstr "চাৰ্চ ইঞ্জিন আদিৰ বাবে URL"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "অনুমতি নিদিলে অন্য পৃষ্ঠালৈ পুনঃনিৰ্দেশিত কৰা চাৰ্চ ইঞ্জিন আৰু অনুৰূপ চাইটসমূহৰ বাবে URL ছেট কৰক"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "ডিবাগ মোড, কনছ'ল সতৰ্কবাৰ্তা"

msgid "右クリックの警告メッセージ"
msgstr "সোঁ-ক্লিক সতৰ্কবাণী বাৰ্তা"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "পিডিএফ হিচাপে প্ৰিণ্ট আৰু ছেভ কৰাৰ সন্দৰ্ভত সতৰ্কবাণী"

msgid "スクリーンショットの警告メッセージ"
msgstr "স্ক্ৰীণশ্বটত সতৰ্কবাৰ্তা"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "সন্দেহযুক্ত স্ক্ৰীণশ্বট সম্পৰ্কে সতৰ্কবাণী"

msgid "テキスト全選択時の警告メッセージ"
msgstr "সকলো পাঠ্য বাছনি কৰাৰ সময়ত সতৰ্কবাণী বাৰ্তা"

msgid "ページ保存の警告メッセージ"
msgstr "পৃষ্ঠা সংৰক্ষণ সম্পৰ্কে সতৰ্কবাৰ্তা"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "কপি বা কাট কৰাৰ সময়ত প্ৰদৰ্শিত বাৰ্তা"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML উৎস দৰ্শন কৰাৰ সময়ত প্ৰদৰ্শন কৰিবলগীয়া বাৰ্তা"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML অস্পষ্ট বা সুৰক্ষিত কৰাৰ সময়ত উৎস ক'ডৰ একেবাৰে ওপৰত প্ৰদৰ্শন কৰিবলগীয়া বাৰ্তা"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML সুৰক্ষাৰ সময়ত যদি এককালীন প্ৰমাণীকৰণ টোকেনটো অবৈধ হয়, তেন্তে প্ৰদৰ্শন কৰিবলৈ বাৰ্তা"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "কুকিজ বা জাভাস্ক্রিপ্ট নিষ্ক্ৰিয় কৰিলে প্ৰদৰ্শন কৰিবলগীয়া বাৰ্তা"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "প্ৰকৃততে, জাভাস্ক্রিপ্ট নিষ্ক্ৰিয় কৰিলেহে এইটো দেখুওৱা হয়।"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "যেতিয়া এখন ছবি সুৰক্ষিত কৰা হয়, ই ডাউনল'ড হয়, আৰু সেই ছবিখনত এটা বাৰ্তা প্ৰদৰ্শিত হয়"

msgid "HTML難読化 (圧縮)"
msgstr "HTML অস্পষ্টকৰণ"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "এইটো এটা সাধাৰণ HTML কম্প্ৰেছন; ইয়াক ডিকোড কৰিব পৰা ৱেবছাইটো আছে।"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "এই বিকল্পটো সক্ষম কৰিলে আপুনি ভিউ-চ'ৰ্চ লগটো পুনৰুদ্ধাৰ কৰিব পাৰিব।"

msgid "HTML保護"
msgstr "HTML সুৰক্ষা"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "ই কেৱল একেবাৰে ন্যূনতম HTML আউটপুট দিয়ে—HTML কম্প্ৰেছন ব্যৱহাৰ কৰাতকৈও কম—আৰু BODY টেগৰ ভিতৰৰ সমল একেবাৰেই আউটপুট নহয়।"

msgid "Firefoxに対しては無効です"
msgstr "এইটো ফায়াৰফক্সৰ বাবে প্ৰযোজ্য নহয়।"

msgid "SEOに著しく影響があります"
msgstr "ইয়াৰ SEO-ৰ ওপৰত এক গুৰুত্বপূৰ্ণ প্ৰভাৱ আছে।"

msgid "HTMLをJavaScriptで描画"
msgstr "জাভাস্ক্রিপ্ট ব্যৱহাৰ কৰি HTML ৰেন্ডাৰ কৰা"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "ফায়াৰফক্সৰ সমস্যাটো এৰাই চলিবলৈ, আমি জাভাস্ক্রিপ্ট ব্যৱহাৰ কৰি HTML ৰেণ্ডাৰ কৰোঁ।"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "জাভাস্ক্রিপ্ট ৰেণ্ডাৰিং সক্ষম কৰিলে ৱেবছাইটটোৰ লোডিং গতি যথেষ্ট লেহেমীয়া হ'ব।"

msgid "画像の保護"
msgstr "ছবি সুৰক্ষা"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img টেগ প্ৰতিবাৰ কল কৰাৰ সময়ত ছবিখনক সুৰক্ষিত কৰক"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "গোটেই HTML আউটপুটৰ ভিতৰত WordPress-ত আপলোড কৰা সকলো ছবি সুৰক্ষিত কৰক।"

msgid "画像をダウンロードから保護します"
msgstr "ছবিবোৰ ডাউনলোড হোৱাৰ পৰা ৰক্ষা কৰে"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "যেতিয়া ছবিৰ ডেটা সুৰক্ষিত কৰা হয়, আমি প্ৰায় সকলো ডাউনল'ড প্ৰতিৰোধ কৰোঁ, একক বাৰ ব্যৱহাৰ কৰিব পৰা বিশেষ URL জাৰি কৰোঁ, ছেচনত সংৰক্ষিত টোকেনৰ জৰিয়তে প্ৰমাণীকৰণ কৰোঁ, আৰু PHP-ৰ জৰিয়তে ছবিসমূহ প্ৰদৰ্শন কৰোঁ; ই ফলপ্ৰসূভাৱে ছবি চুৰিৰ প্ৰায় সকলো ঘটনাই প্ৰতিৰোধ কৰে।"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "যেতিয়া ছবিৰ ডেটা সুৰক্ষিত কৰা হয়, কেছিং কাম নকৰে, যাৰ অৰ্থ হ'ল পৰৱৰ্তী ভ্ৰমণবোৰত চাইটটো অধিক লাহে লাহে লোড হ'ব, যাৰ ফলত SEO-ৰ ওপৰত প্ৰভাৱ পৰে।"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "ছবিৰ ডাটা সুৰক্ষিত কৰিলে ডাটাবেছৰ ওপৰত বোজা বৃদ্ধি হ'ব পাৰে।"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "যদি আপুনি 'যেতিয়াই কোনো img টেগ কল কৰা হয়, তেতিয়া ছবিবোৰ সুৰক্ষিত কৰক' বাছনি কৰে, চিষ্টেমে img টেগটো সৃষ্টি হোৱাৰ সময়ত ফিল্টাৰিং প্ৰয়োগ কৰিবলৈ add_filter ব্যৱহাৰ কৰে; কিন্তু, কিছুমান থিমৰ সৈতে ই হয়তো সঠিকভাৱে কাম নকৰিব পাৰে।"

