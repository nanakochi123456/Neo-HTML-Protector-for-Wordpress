msgstr "Agordoj"

msgid "IPログリーダー"
msgstr "IP-Loga Legilo"

msgid "IPアドレスログ"
msgstr "Protokolo de IP-adresoj"

msgid "全クリア"
msgstr "Kompletigu ĉiujn nivelojn"

msgid "IPログが全て削除されました"
msgstr "Ĉiuj IP-registroj estis forigitaj."

msgid "ID"
msgstr "Identigilo"

msgid "タイムスタンプ"
msgstr "Tempostampo"

msgid "IPアドレス"
msgstr "IP-adreso"

msgid "ユーザーエージェント"
msgstr "Uzanto-agento"

msgid "イベント"
msgstr "Okazaĵo"

msgid "IPアドレスのデータはありません"
msgstr "Ne estas datumoj por ĉi tiu IP-adreso."

msgid "EU GDPR対応"
msgstr "Konformeco kun la EU-GDPR"

msgid "無効"
msgstr "Ne valida"

msgid "有効"
msgstr "Valida"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Se vi uzas WordPress ene de la EU, aŭ se via retejo celas uzantojn ene de la EU, bonvolu certigi, ke tio estas ebligita."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "La butono 'Konfirmi' ŝanĝiĝos al 'Konsenti' aŭ 'Malkonsenti', kaj la konduto iomete ŝanĝiĝos."

msgid "同意画面の色"
msgstr "Koloro de la konsenta ekrano"

msgid "自動"
msgstr "Aŭtomata"

msgid "ライトモード"
msgstr "Malpeza reĝimo"

msgid "ダークモード"
msgstr "Malhela reĝimo"

msgid "同意画面表示中の配色を設定します"
msgstr "Agordu la kolorskemon por la konsenta ekrano."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Malklarigo de enhavo sur la konsenta ekrano"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Agordu la nivelon de malklarigo por la enhavo montrata sur la konsenta ekrano."

msgid "同意画面の透過"
msgstr "Travidebleco de la konsenta ekrano"

msgid "透過なし"
msgstr "Neniu travidebleco"

msgid "同意画面の透過具合を設定します"
msgstr "Agordu la travideblecon de la konsenta ekrano."

msgid "お知らせの1行目"
msgstr "Unua linio de la anonco"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ĉi tiu mesaĝo ĉiam aperas la unuan fojon kiam la paĝo estas ŝarĝita."

msgid "お知らせの2行目"
msgstr "La dua linio de la avizo"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ĉi tiu mesaĝo ĉiam aperos sur la unua ekrano nur kiam la EU GDPR estos en forto."

msgid "お知らせの3行目"
msgstr "La tria linio de la avizo"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ĝi aperos dekstre de la ligilo al la Privateca Politiko."

msgid "非EU向け確認の文字列"
msgstr "Konfirma teksto por ne-EU-landoj"

msgid "EU GDPR向け同意するの文字列"
msgstr "Teksto pri konsento por la EU-GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Teksto por 'Ne konsenti' laŭ la EU-GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Teksto de privateca politiko"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Bonvolu agordi la URL-on por la privateca politiko ĉi tie."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Bonvolu aldoni la jenon al la Privateca Politiko."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Por detekti fraŭdajn agadojn, identigiloj kiel IP-adresoj estas konservataj en kuketoj kaj datumbazoj. La konservitaj datumoj estas forigitaj laŭ la diskrecia decido de la administranto."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Por certigi, ke bildoj estas liverataj ĝuste nur kiam bildprotekto estas aktivigita, ni konservas en la datumbazo, dum ĝis 60 minutoj, la haŝitajn datumojn, kiuj enhavas la IP-adreson kaj la dosiernomon de la bildo."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Se vi starigas Uzkondiĉojn, bonvolu certigi, ke vi inkluzivas ligilon al ili en via Privateca Politiko."

msgid "利用規約の文字列"
msgstr "Teksto de la Kondiĉoj de Uzo"

msgid "利用規約のページ"
msgstr "Paĝo de Kondiĉoj kaj Regularo"

msgid "ページ選択なし"
msgstr "Neniu paĝo elektita"

msgid "検索エンジン等のURL"
msgstr "URL-oj por serĉiloj, ktp."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Agordu la URL-on por serĉiloj kaj similaj retejoj, kiuj redirektas uzantojn kiam konsento ne estas donita."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Erar-detektada reĝimo, konzolaj avertaj mesaĝoj"

msgid "右クリックの警告メッセージ"
msgstr "Dekstre-klaka averta mesaĝo"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Averto pri presado kaj konservado kiel PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Averta mesaĝo en la ekrana bildo"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Averto pri suspektataj ekranfotoj"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Averta mesaĝo kiam la tuta teksto estas elektita"

msgid "ページ保存の警告メッセージ"
msgstr "Averto pri paĝa konservado"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Mesaĝo montrata dum kopiado aŭ eltondado"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Mesaĝo por montri kiam oni rigardas la HTML-fonton"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Mesaĝo por montriĝi ĉe la supro de la fontkodo kiam oni obskuras aŭ protektas HTML-on"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Mesaĝo por montri se la unufoja aŭtentiga ĵetono estas malvalida dum HTML-protektado"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Mesaĝo por montri se kuketoj aŭ JavaScript estas malŝaltitaj"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Fakte, ĉi tio montriĝas nur kiam JavaScript estas malŝaltita."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Kiam bildo estas protektita, ĝi estas elŝutita, kaj mesaĝo estas montrata sur tiu bildo"

msgid "HTML難読化 (圧縮)"
msgstr "HTML-obskurado"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Ĉi tio estas norma HTML-kompresio; ekzistas ankaŭ retejoj, kiuj povas malkodigi ĝin."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Aktivigo de ĉi tiu opcio permesas al vi akiri la fontkoda logon."

msgid "HTML保護"
msgstr "HTML-protekto"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ĝi eligas eĉ malpli da HTML ol la agordo por HTML-kunpremado, kio signifas, ke la enhavo ene de la etikedo BODY tute ne estos eldonita."

msgid "Firefoxに対しては無効です"
msgstr "Ĉi tio ne aplikiĝas al Firefox."

msgid "SEOに著しく影響があります"
msgstr "Ĉi tio havas signifan efikon sur SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Rendado de HTML per JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Por ĉirkaŭiri Firefox, ni redonas la HTML-on per JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Aktivigo de JavaScript-renderado signife malrapidigos la ŝarĝan rapidon de la retejo."

msgid "画像の保護"
msgstr "Bildoprotektado"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Protektu la bildon ĉiufoje kiam la etikedo img estas vokita."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Protektu ĉiujn bildojn alŝutitajn al WordPress en la tuta HTML-elsendo."

msgid "画像をダウンロードから保護します"
msgstr "Protektas bildojn kontraŭ elŝuto"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Kiam bildaj datumoj estas protektitaj, ni malhelpas preskaŭ ĉiujn elŝutojn, eldonas unikajn unufojajn URL-ojn, aŭtentigas per sesie stokitaj tokenoj, kaj montras la bildojn per PHP; tio efike malhelpas preskaŭ ĉiun bildŝtelon."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Kiam bildaj datumoj estas protektitaj, kaŝmemorado ne funkcias, kio signifas, ke la retejo ŝarĝiĝos pli malrapide dum postaj vizitoj, tiel influante SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Protekti bildajn datumojn povas pliigi la ŝarĝon sur la datumbazo."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Se vi elektas 'Protekti bildojn ĉiufoje kiam img-etikedo estas vokita', la sistemo uzas add_filter por apliki filtradon kiam la img-etikedo estas generita; tamen tio eble ne funkcios ĝuste kun iuj temoj."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Se vi elektas 'Protekti ĉiujn bildojn alŝutitajn al WordPress en la tuta HTML-elsendo', la kromprogramo kaptos preskaŭ ĉiujn WordPress-operaciojn kaj prilaboros ĉiun img-etikedon en la enhavo. Bonvolu noti, ke tio eble ne funkcios ĝuste kun iuj temoj."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Bonvolu noti, ke bildoj difinitaj kiel ĉefaj bildoj estos dividitaj kiel OGP-datumoj kaj ne povas esti protektitaj. Se vi absolute devas protekti ilin, bonvolu ŝanĝi la agordon por la eligo de la HEAD-etikedo en la altnivelaj agordoj kiam vi ebligas HTML-protekton."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "La ekrana kapta funkcio integrita en la operaciumo ne povas esti protektita."

msgid "画像URLの保護"
msgstr "Protektado de bildaj URL-oj"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Ĉi tion oni devas uzi kune kun bildprotekto; per si mem ĝi ne servas al iu ajn celo."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Ĉar ĝi estas pigre ŝarĝita per JavaScript, tio influas SEO."

msgid "画像のウォーターマーク"
msgstr "Bilda akvomarko"

msgid "右下"
msgstr "Malsupra dekstra"

msgid "ランダム位置"
msgstr "Hazarda pozicio"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Uzate kune kun bildprotekto, dinamikaj akvomarkoj klare indikas la kopirajtan posedon, dum ili donas al spektantoj la impreson, ke ili estas observataj, tiel agante kiel malkuraĝigo."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Nur JPG-, PNG- kaj WebP-formatoj estas subtenataj."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Aktivigo de ĉi tio pliigos la ŝarĝon sur la servilo."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Elprodukti ASCII-arton el HTML-fonkodo dum obskurado kaj protektado"

msgid "表示なし"
msgstr "Neniu ekrano"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Montras ASCII-arton, kiu indikas averton kiam oni rigardas la HTML-fonton per 'view-source'."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Montru la dezajnon kiam la celita ago estas plenumita."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Baza dezajno kun nigra teksto sur flava fono"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Terurstila dezajno kun ruĝa teksto sur nigra fono."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Dezajno kun brilruĝa teksto sur nigra fono"

msgid "対象アクションを起こした時のBGM"
msgstr "Fona muziko, kiu ludas kiam la celita ago estas plenumita."

