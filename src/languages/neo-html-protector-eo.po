msgid "警告表示中のBGMを選択します"
msgstr "Elektu la fonmuzikon por ludi dum averto."

msgid "びっくりするような雰囲気を作ります"
msgstr "Ĝi kreas surprizan etoson."

msgid "Firefoxでは音声ブロックされます"
msgstr "Aŭdio estas blokita en Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Bipo kiam la specifita ago estas plenumita"

msgid "有効 音量小さ目"
msgstr "Sur, volumo malalta"

msgid "有効 音量大き目"
msgstr "Aktiva, volumo agordita al alta"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Bipo sonos por ĉiuj klavaj kaj musaj eventoj dum averto estas montrata."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Ĝi kreas la impreson, ke la aparato freneziĝis dum la averto estas montrata."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Kaŝi la muskursoron kiam specifa ago estas farita"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Kaŝas la muskursoron en la retumila areo dum montriĝas averto."

msgid "デバッグモード"
msgstr "Erar-detekta reĝimo"

msgid "妨害＋記録のみ"
msgstr "Interfero + Diskoj nur"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Interfero + Registrado + Montraĵo + Redirektado"

msgid "メニューからは操作できてしまいます"
msgstr "Vi ankoraŭ povas aliri ĝin per la menuo."

msgid "Firefoxにおけるデバッグモード"
msgstr "Erar-detekta reĝimo en Firefox"

msgid "ブラウザーコンソール"
msgstr "Retumila konzolo"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Fakte, vi povas funkciigi ĝin en maldebuga reĝimo."

msgid "HTMLソース表示"
msgstr "Vidi la HTML-fonton"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Vi povas simple plenumi la operacion enigante URL-on, kiu komenciĝas per 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Vi povas protekti vian enhavon per kombino de ĉi tio kun HTML-protekto."

msgid "印刷"
msgstr "Presi"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Kvankam ĝi malhelpas presadon, ĝi eble ne funkcios ĝuste en iuj retumiloj."

