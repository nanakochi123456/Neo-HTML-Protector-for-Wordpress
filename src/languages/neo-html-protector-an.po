msgid "設定"
msgstr "Aconfiguracions"

msgid "IPログリーダー"
msgstr "Lector de rechistros IP"

msgid "IPアドレスログ"
msgstr "Rechistro d'adrezas IP"

msgid "全クリア"
msgstr "Completar toz os nivels"

msgid "IPログが全て削除されました"
msgstr "Toz os rechistros d'IP s'han eliminau."

msgid "ID"
msgstr "Identificador"

msgid "タイムスタンプ"
msgstr "Sello de tiempo"

msgid "IPアドレス"
msgstr "Adreza IP"

msgid "ユーザーエージェント"
msgstr "Achent d'usuario"

msgid "イベント"
msgstr "Acte"

msgid "IPアドレスのデータはありません"
msgstr "No i hai datos pa ista adreza IP."

msgid "EU GDPR対応"
msgstr "Cumplimiento d'o RGPD d'a UE"

msgid "無効"
msgstr "Invalid"

msgid "有効"
msgstr "Válido"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Si ye fendo servir WordPress en a UE, u si o suyo puesto web s'adreza a usuarios en a UE, por favor, asegure-se de que isto ye activau."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "O botón 'Confirmar' cambiará a 'D'alcuerdo' u 'En desacuerdo', y o comportamiento cambiará un poquet."

msgid "同意画面の色"
msgstr "Color d'a pantalla de consentimiento"

msgid "自動"
msgstr "Automático"

msgid "ライトモード"
msgstr "Modo claro"

msgid "ダークモード"
msgstr "Modo fosco"

msgid "同意画面表示中の配色を設定します"
msgstr "Establir l'esquema de colors pa la pantalla de consentimiento"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Emborrimiento d'o conteniu en a pantalla de consentimiento"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Achustar o livel de difuminau t'o conteniu amostrau en a pantalla de consentimiento"

msgid "同意画面の透過"
msgstr "Transparencia d'a pantalla de consentimiento"

msgid "透過なし"
msgstr "Garra transparencia"

msgid "同意画面の透過具合を設定します"
msgstr "Establir a transparencia d'a pantalla de consentimiento"

msgid "お知らせの1行目"
msgstr "Primera linia de l'anuncio"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Iste mensache s'amuestra siempre a primera vegada que se carga a pachina."

msgid "お知らせの2行目"
msgstr "A segunda linia d'o aviso"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Iste mensache amaneixerá siempre en a primera pantalla nomás quan o RGPD d'a UE siga en vigor."

msgid "お知らせの3行目"
msgstr "A tercera linia de l'aviso"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Aparixerá a la dreita de l'enlace a la Politica de privacidat."

msgid "非EU向け確認の文字列"
msgstr "Texto de confirmación pa países no perteneixients a la UE"

msgid "EU GDPR向け同意するの文字列"
msgstr "Texto de consentimiento pa o RGPD d'a UE"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Texto pa 'No consentir' baixo o RGPD d'a UE"

msgid "プライバシーポリシーの文字列"
msgstr "Texto d'a politica de privacidat"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Per favor, estableixca aquí a URL d'a politica de privacidat."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Per favor, adhiba o siguient a la Politica de Privacidat."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Pa detectar actividat fraudulenta, s'almagazenan identificadors como as adrezas IP en as cookies y en a base de datos. Os datos almagazenaus s'eliminan a criterio de l'administrador."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Pa asegurar que as imáchens se entreguen correctament nomás quan a protección d'imáchens ye activada, almagazenamos en a base de datos os datos hashizaus que incluyen l'adreza IP y o nombre de l'archiu d'a imachen durant un maximo de 60 minutos."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Si ye configurando os Termins d'Uso, por favor, asegure-se d'incluyir-ie un vinclo en a suya Politica de Privacidat."

msgid "利用規約の文字列"
msgstr "Texto d'as Condicions d'Uso"

msgid "利用規約のページ"
msgstr "Pachina de Termins y Condicions"

msgid "ページ選択なし"
msgstr "Garra pachina trigada"

msgid "検索エンジン等のURL"
msgstr "URLs pa motors de busca, etc."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Establir a URL pa motors de busca y puestos semellants que redirichan a os usuarios quan no se da o consentimiento."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Modo de depuración, mensaches d'alvertencia d'a consola"

msgid "右クリックの警告メッセージ"
msgstr "Mensache d'alvertencia con botón dreito"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Mensache d'alvertencia sobre l'impresión y l'almagazenache como PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Mensache d'alvertencia en a captura de pantalla"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Mensache d'alvertencia sobre capturas de pantalla sospeitosas"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Mensache d'alvertencia quan tot o texto ye seleccionau"

msgid "ページ保存の警告メッセージ"
msgstr "Mensache d'alvertencia sobre l'almagazenache d'a pachina"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Mensache que s'amuestra en copiar u retallar"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Mensache pa amostrar en veyer o codigo fuent d'HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Mensache que s'amuestra en a parte superior d'o codigo fuent cuan s'obscureix u se proteche l'HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Mensache que s'amostrará si o token d'autenticación d'un solo uso ye inválido durant a protección HTML."

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Mensache ta amostrar si as cookies u o JavaScript son desactivaus"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "De feito, isto nomás s'amuestra quan JavaScript ye desactivau."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Cuan una imachen ye protechida, se descarga y s'amuestra un mensache sobre ixa imachen"

msgid "HTML難読化 (圧縮)"
msgstr "Oficación"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Ista ye a compresión estandar d'HTML; tamién bi ha pachinas web que la pueden descodificar."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Activando ista opción se puede recuperar o rechistro d'a visualización d'o codigo fuent."

msgid "HTML保護"
msgstr "Protección d'HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Sólament chenera o minimo imprescindible d'HTML —mesiau encara que fendo servir a compresión d'HTML— y o conteniu adintro d'a etiqueta BODY no se chenera de garra traza."

msgid "Firefoxに対しては無効です"
msgstr "Isto no s'aplica a Firefox."

msgid "SEOに著しく影響があります"
msgstr "Isto tiene un impauto significativo en o SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Rendindo HTML con JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Pa fer o treballo arredol de Firefox, renderizamos l'HTML fendo servir JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Activando o renderizau de JavaScript se ralentizará significativament a velocidat de carga d'o puesto web."

msgid "画像の保護"
msgstr "Protección d'imachen"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Protecher a imachen cada vegada que se clama a etiqueta img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Protecher todas as imáchens puyadas a WordPress adintro de tot o codigo HTML chenerau."

msgid "画像をダウンロードから保護します"
msgstr "Proteche as imáchens pa que no se descarguen"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Cuan os datos d'as imáchens son protechius, privamos cuasi todas as descargas, emitimos URLs unicas d'un solo uso, autenticamos fendo servir tokens almagazenaus en a sesión y amostramos as imáchens a traviés de PHP; isto priva efectivament cuasi toz os casos de furto d'imáchens."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Cuan os datos d'as imáchens son protechius, o caché no funciona, o que significa que o puesto se cargará más lentament en as vesitas posteriors, afectando asinas a o SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Protecher os datos d'as imáchens puede augmentar a carga en a base de datos."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Si seleccionas 'Protecher imáchens cada vegada que se clama una etiqueta img', o sistema fa servir add_filter pa aplicar o filtrau cuan se chenera a etiqueta img; manimenos, puede que isto no funcione correctament con bels temas."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Si trías 'Protecher todas as imáchens puyadas a WordPress adintro de tot o resultau HTML', o complemento capturará cuasi todas as operacions de WordPress y procesará cada etiqueta img adintro d'o conteniu. Ten en cuenta que isto puede no funcionar correctament con bels temas."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Tenga en cuenta que as imáchens designadas como imáchens destacadas se compartirán como datos OGP y no se pueden protecher. Si de veras las ha de protecher, por favor, cambee a configuración d'a salida d'a etiqueta HEAD en a configuración abanzada en activar a protección HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "A función de captura de pantalla integrada en o sistema operativo no se puede protecher."

msgid "画像URLの保護"
msgstr "Protegindo as URLs d'as imáchens"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Isto s'ha de fer servir en conchunto con a protección d'imachens; por sí solo, no sirve de cosa."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Como se carga perezosament a traviés de JavaScript, isto afecta a o SEO."

msgid "画像のウォーターマーク"
msgstr "Filigrana d'imachen"

msgid "右下"
msgstr "Abaixo a la dreita"

msgid "ランダム位置"
msgstr "Posición aleatoria"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Usadas en conchunto con a protección d'imachen, as filigranas dinamicas indican clarament a propiedat d'o dreito d'autor, a o mesmo tiempo que dan a os espectadors a impresión de que son estando vichilaus, actuando asinas como un disuasivo."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Nomás se refirman os formatos JPG, PNG y WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Activar isto augmentará a carga d'o servidor."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Chenerar arte ASCII dende o codigo fuent HTML durant l'ofuscación y protección d'HTML"

msgid "表示なし"
msgstr "Garra visualización"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Muestra arte ASCII que indica un aviso en veyer o codigo fuent d'HTML fendo servir 'view-source'."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Amostrar o disenyo cuan se fa l'acción obchectivo."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Un disenyo basico con texto negro sobre un fundo amariello."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Un disenyo d'estilo terrorifico con texto royo sobre un fundo negro."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Un disenyo con texto royo brillant sobre un fundo negro"

msgid "対象アクションを起こした時のBGM"
msgstr "Musica de fundo que sona quan se fa l'acción obchectivo."

msgid "サウンドなし"
msgstr "Garra son"

