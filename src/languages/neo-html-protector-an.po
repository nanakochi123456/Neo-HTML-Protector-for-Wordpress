msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Sonido d'estilo MRI por ChatGPT – 1 minuto 14,9 segundos – 3.340.392 bytes – 320 kbps – Licencia: Dominio publico"

msgid "警告表示中のBGMを選択します"
msgstr "Tría la musica de fundo pa reproducir durant un aviso."

msgid "びっくりするような雰囲気を作ります"
msgstr "Crea una atmosfera sorprendent"

msgid "Firefoxでは音声ブロックされます"
msgstr "L'audio ye bloquiato en Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Un pitido quan se fa l'acción especificada"

msgid "有効 音量小さ目"
msgstr "Puesto, volumen baixo"

msgid "有効 音量大き目"
msgstr "Activo, volumen a lo maximo"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Sonará un pitido en respuesta a toz os eventos de teclau y ratet mientres se muestra un aviso."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Da la impresión de que l'aparato s'ha tornau barrenau mientres s'amuestra l'alvertencia."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Amagar o cursor d'o ratet cuan se fa una acción especifica"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Amaga o cursor d'o ratet en l'aria d'o navegador mientres s'amuestra un aviso."

msgid "デバッグモード"
msgstr "Modo de depuración"

msgid "妨害＋記録のみ"
msgstr "Interferencia + Discos nomás"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Interferencia + Registro + Pantalla + Redirección"

msgid "メニューからは操作できてしまいます"
msgstr "Encara se i puede acceder a traviés d'o menú."

msgid "Firefoxにおけるデバッグモード"
msgstr "Modo de depuración en Firefox"

msgid "ブラウザーコンソール"
msgstr "Consola d'o navegador"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "De feito, se puede fer-lo funcionar dende o modo de depuración."

msgid "HTMLソース表示"
msgstr "Veyer o codigo fuent d'HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Se puede fer l'operación simplament metendo una URL que prencipie con 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Puetz protecher o tuyo conteniu combinando isto con a protección HTML."

msgid "印刷"
msgstr "Imprimir"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Anque evita l'impresión, puede que no funcione correctament en bels navegadors."

msgid "スクリーンショット"
msgstr "Captura de pantalla"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Seguntes o sistema operativo, o navegador u o metodo emplegau, puede que no siga posible bloqueyar isto, u puede que no se detecte."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Captura de pantalla sospeitosa quan a finestra se mueve a o fundo."

msgid "あわせて、スクリーンショット以外の機能（タブ切り替え・ウィンドウ切り替え）にも反応してしまいます。"
msgstr "Tamién responde a funcions distintas d'as capturas de pantalla"

