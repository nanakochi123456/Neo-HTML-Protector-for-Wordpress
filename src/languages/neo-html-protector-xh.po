msgid "設定"
msgstr "Iisetingi"

msgid "IPログリーダー"
msgstr "Umfundi weelog ze-IP"

msgid "IPアドレスログ"
msgstr "Ilog yeedilesi ze-IP"

msgid "全クリア"
msgstr "Gqibezela onke amanqanaba"

msgid "IPログが全て削除されました"
msgstr "Zonke iilogi ze-IP zicinyiwe."

msgid "ID"
msgstr "Isazisi"

msgid "タイムスタンプ"
msgstr "Isalathisi sexesha"

msgid "IPアドレス"
msgstr "Idilesi ye-IP"

msgid "ユーザーエージェント"
msgstr "I-Arhente yomsebenzisi"

msgid "イベント"
msgstr "Isiganeko"

msgid "IPアドレスのデータはありません"
msgstr "Akukho datha yale dilesi ye-IP."

msgid "EU GDPR対応"
msgstr "Ukuthotyelwa kwe-EU GDPR"

msgid "無効"
msgstr "Akuchanekanga"

msgid "有効"
msgstr "Iyavunyelwa"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Ukuba usebenzisa i-WordPress ngaphakathi kwe-EU, okanye ukuba iwebhusayithi yakho ijolise kubasebenzisi abangaphakathi kwe-EU, nceda uqinisekise ukuba oku kuvuliwe."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Iqhosha elithi 'Qinisekisa' liza kutshintsha libe 'Vumelana' okanye 'Ungavumelani', kwaye indlela yokusebenza iza kutshintsha kancinci."

msgid "同意画面の色"
msgstr "Umbala wesikrini sokuvuma"

msgid "自動"
msgstr "Ngokuzenzekelayo"

msgid "ライトモード"
msgstr "Indlela ekhanyayo"

msgid "ダークモード"
msgstr "Imowudi eMnyama"

msgid "同意画面表示中の配色を設定します"
msgstr "Misa isicwangciso semibala sesikrini somvume"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Ukufiphala komxholo kwisikrini sokuvuma"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Lungisa inqanaba lokungacaci koku kuboniswayo kwiscreen somvume."

msgid "同意画面の透過"
msgstr "Ukucaca kwesikrini somvume"

msgid "透過なし"
msgstr "Akukho sobala"

msgid "同意画面の透過具合を設定します"
msgstr "Lungisa ukungafihli kwesikrini somvume"

msgid "お知らせの1行目"
msgstr "Umgca wokuqala wesaziso"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Lo myalezo uhlala ubonakala okokuqala iphepha liyilayishwa."

msgid "お知らせの2行目"
msgstr "Umgca wesibini wesaziso"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Lo myalezo uya kuhlala uvela kuphela kwisiboniso sokuqala xa i-EU GDPR isebenza."

msgid "お知らせの3行目"
msgstr "Umgca wesithathu wesaziso"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Iya kuvela ngasekunene kokhonkco lomgaqo-nkqubo wobumfihlo."

msgid "非EU向け確認の文字列"
msgstr "Umsi-memo wokuqinisekisa wamazwe angaphandle kwe-EU"

msgid "EU GDPR向け同意するの文字列"
msgstr "Umyalezo wemvume we-EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Umbhalo we-'Musa ukuvuma' phantsi kwe-EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Umbhalo womgaqo-nkqubo wobumfihlo"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Nceda ubeke i-URL yomgaqo-nkqubo wobumfihlo apha."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Nceda wongeze oku kulandelayo kuMgaqo-nkqubo waBucala."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Ukuze kufunyanwe iintshukumo zobuqhophololo, izinto ezizazisi ezifana nee-IP address zigcinwa kwii-cookies nakwisiseko sedatha. Idatha egciniweyo iyacinywa ngokokubona komlawuli."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Ukuqinisekisa ukuba imifanekiso ihanjiswa ngokuchanekileyo kuphela xa ukhuseleko lwemifanekiso luvuliwe, sigcina idatha eyi-hashed equka idilesi ye-IP negama lefayile yomfanekiso kwidatabase kangangemizuzu engama-60."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Ukuba umisela iMiqathango yokuSetyenziswa, nceda uqinisekise ukuba ufaka ikhonkco eliya kuyo kwiNkqubo yakho yobuXwayi."

msgid "利用規約の文字列"
msgstr "Umbhalo wemiqathango yokusebenzisa"

msgid "利用規約のページ"
msgstr "Imiqathango nemimiselo"

msgid "ページ選択なし"
msgstr "Akukho phepha likhethiweyo"

msgid "検索エンジン等のURL"
msgstr "Ii-URL ze-injini zokukhangela, njl."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Misa i-URL yee-injini zokukhangela kunye neesayithi ezifanayo ezibuyisela abasebenzisi emva kokuba ingqinelwano ingakhange inikwe."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Imowudi yokulungisa iimpazamo, imiyalezo yesilumkiso yekhonsoli"

msgid "右クリックの警告メッセージ"
msgstr "Cofa ekunene ukuze ubonise umyalezo wesilumkiso"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Isilumkiso malunga nokuprinta nokugcina njenge-PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Umyalezo lwesilumkiso kumfanekiso weskrini"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Isilumkiso ngemifanekiso esikrowe-skrin esirhanelwayo"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Umyalezo lwesilumkiso xa konke okubhaliweyo kukhethiwe"

msgid "ページ保存の警告メッセージ"
msgstr "Isilumkiso malunga nokugcinwa kwephepha"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Umyalezo oboniswayo xa ukopa okanye usika"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Umyalezo oza kuboniswa xa kujongwe umthombo we-HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Umyalezo oza kuboniswa phezulu kwikhowudi yomthombo xa kuyinqaku okanye kuyikhusela i-HTML."

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Umyalezo oza kuboniswa ukuba itokheni yokuqinisekisa yexesha elinye ayisebenzi ngexesha lokukhuselwa kwe-HTML."

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Umyalezo oza kuboniswa ukuba ii-cookies okanye i-JavaScript zivaliwe"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Enyanisweni, oku kuboniswa kuphela xa iJavaScript icinyiwe."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Xa umfanekiso ukhuselwe, uyakhutshelwa, kwaye kuboniswe umyalezo kuloo mfanekiso"

msgid "HTML難読化 (圧縮)"
msgstr "Ukungacacisi i-HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Oku kucutshungulwa kwe-HTML okuqhelekileyo; kukwakho neewebhusayithi ezinokuyicacisa."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ukwenza lolu khetho lukwazi ukusebenza kukuvumela ukuba ufumane ilog yombono womthombo."

msgid "HTML保護"
msgstr "Ukhuseleko lwe-HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ikhupha kuphela i-HTML esisiseko kakhulu—kwanancinci ngakumbi kunokuba kusetyenziswa i-HTML compression—kwaye umxholo ongaphakathi kwi-BODY tag awukhutshwa kwaphela."

msgid "Firefoxに対しては無効です"
msgstr "Oku akusebenzi kwiFirefox."

msgid "SEOに著しく影響があります"
msgstr "Oku kunempembelelo enkulu kwi-SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Ukwenziwa kwe-HTML kusetyenziswa iJavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Ukuze sisebenze ngaphandle kweFirefox, siyibonisa i-HTML sisebenzisa iJavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Ukwenza iJavaScript ikwazi ukubonisa amaphepha kuya kucothisa kakhulu isantya sokulayisha iwebhusayithi."

msgid "画像の保護"
msgstr "Ukhuseleko lomfanekiso"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Khusela umfanekiso ngalo lonke ixesha kubizwa ithegi ye-img."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Khusela zonke iifoto ezilayishiweyo kwi-WordPress ngaphakathi kuyo yonke imveliso ye-HTML."

msgid "画像をダウンロードから保護します"
msgstr "Ikhusela imifanekiso ekukhutshelweni"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Xa idatha yemifanekiso ikhuselwe, sithintela phantse zonke iindlela zokukhuphela, sikhupha ii-URL ezizodwa ezisebenza kanye kuphela, siqinisekisa ubuni basebenzisi sisebenzisa ii-token ezigcinwe kwiseshoni, kwaye sibonisa imifanekiso nge-PHP; oku kuthintela ngokuphumelelayo phantse zonke iimeko zokuba kwebiwa imifanekiso."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Xa idatha yemifanekiso ikhuselwe, i-caching ayisebenzi, nto leyo ethetha ukuba isayithi iya kulayisha kancinci kwiindwendwe ezilandelayo, ngaloo ndlela ichaphazela i-SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ukuvikela idatha yemifanekiso kunokunyusa umthwalo kwidathabheyisi."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Ukuba ukhetha 'Khusela imifanekiso nanini na xa kubizwa i-img tag', inkqubo isebenzisa i-add_filter ukusebenzisa ukuhluza xa i-img tag yenziwa; nangona kunjalo, oku kusenokungasebenzi kakuhle nezinye i-themes."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Ukuba ukhetha 'Khusela zonke iifoto ezilayishiweyo kwi-WordPress ngaphakathi kuyo yonke imveliso ye-HTML', i-plugin iza kubamba phantse zonke iinkqubo ze-WordPress kwaye icubungule yonke i-img tag ngaphakathi kumxholo. Nceda uqaphele ukuba oku kusenokungasebenzi kakuhle nezinye i-themes."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Nceda uqaphele ukuba imifanekiso echongwe njengeemifanekiso eziphambili iya kwabelwana ngayo njenge-OGP data kwaye ayinakukhuselwa. Ukuba kufuneka ngokupheleleyo ukuba uzikhusele, nceda utshintshe isethingi yokuveliswa kwe-HEAD tag kwiisetingi eziphucukileyo xa uvula ukhuselo lwe-HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Umsebenzi wokuthatha iskrini ofakwe kwi-operating system awunakukhuselwa."

msgid "画像URLの保護"
msgstr "Ukhuseleko lwee-URL zemifanekiso"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Oku kufanele kusetyenziswe kunye nokhuselo lomfanekiso; ngokwako, akunamsebenzi."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Njengoko ilayishwa ngokucothayo ngeJavaScript, oku kuyichaphazela i-SEO."

msgid "画像のウォーターマーク"
msgstr "I-watermark yomfanekiso"

msgid "右下"
msgstr "Ezantsi ngasekunene"

msgid "ランダム位置"
msgstr "Indawo engalindelekanga"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Zisetyenziswa kunye nokhuseleko lomfanekiso, ii-watermark eziguquguqukayo zibonisa ngokucacileyo ubunini belungelo lokushicilela ngelixa zinika ababukeli umbono wokuba bayajongwa, ngaloo ndlela zisebenza njengesithintelo."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Kuxhaswa kuphela iifomathi ze-JPG, PNG ne-WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Ukwenza oku kuya kwandisa umthwalo kwiseva."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ukukhupha imizobo ye-ASCII kwikhowudi yomthombo ye-HTML ngexesha lokuyifihla nokuyikhusela i-HTML"

msgid "表示なし"
msgstr "Akukho mboniso"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Ibonisa umzobo we-ASCII olumkisayo xa kujongwe umthombo we-HTML kusetyenziswa 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Bonisa uyilo xa isenzo ekujoliswe kuso senziwe"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Uyilo olusisiseko olunombhalo omnyama kumva omthubi."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Uyilo oluyindlela yothusayo olunombhalo obomvu kumva omnyama"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Uyilo olunombhalo obomvu oqaqambileyo kumva omnyama"

msgid "対象アクションを起こした時のBGM"
msgstr "Umculo ongumva odlalayo xa isenzo esijoliswe kuso senziwa"

msgid "サウンドなし"
msgstr "Akukho sandi"

