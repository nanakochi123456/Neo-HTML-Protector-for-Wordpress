msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Uluhlu: Étude d'Exécution Transcendante No. 4, 'Mazeppa' – Inguqulelo eyenziwe yikhompyutha, inguqulelo emfutshane esebenza ngesantya esiphezulu – umzuzu o-1 nemizuzwana engama-51.6 – iibytes ezingama-687,586 – 48 kbps – Ilayisensi: CC BY-ND 4.0 okanye kamva"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Umculo Wovuyo – imizuzwana engama-22.3 – iibytes ezili-183,926 – 64 kbps – Ilayisensi: YeyoLuntu"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Umsitho wesimbo sakudala – imizuzwana eyi-2.2 – iibytes ezili-10,536 – 32 kbps – Ilayisensi: YeyoLuntu"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Intro yesitayile se-retro – imizuzwana engama-42.1 – iibytes ezili-179,138 – 32 kbps – Ilayisensi: YeyoLuntu"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Isilumkiso sika-ChatGPT - iisekondi ezi-3.8 - iibhayithi ezili-109,700 - i-256 kbps - Ilayisensi: Ilungelo eliloluntu"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Isandi esingxamiseke kakhulu esifana nesilumkiso sokufunyanwa kwentsholongwane – Icandelo 1 ngu-ChatGPT – imizuzwana eyi-3.3 – iibytes eziyi-102,850 – i-256 kbps – Ilayisensi: Ilungelo eliluphela"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Isandi esingxamiseke kakhulu esivakala njengesiqabu sokufunyanwa kwentsholongwane, Icandelo lesi-2 ngu-ChatGPT - imizuzwana eyi-3.3 - iibytes eziyi-103,122 - 256 kbps - Ilayisensi: YeyoLuntu"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Isandi esifana ne-MRI esenziwe yi-ChatGPT – umzuzu o-1 nemizuzwana eyi-14.9 – iibytes eziyi-3,340,392 – i-320 kbps – Ilayisensi: YeyoLuntu"

msgid "警告表示中のBGMを選択します"
msgstr "Khetha umculo wangasemva oza kudlala ngexesha lesilumkiso."

msgid "びっくりするような雰囲気を作ります"
msgstr "Idala umoya omangalisayo"

msgid "Firefoxでは音声ブロックされます"
msgstr "I-audio ivaliwe kwiFirefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "I-beep xa isenzo esichaziweyo senziwe"

msgid "有効 音量小さ目"
msgstr "Vula, ivolyum iphantsi"

msgid "有効 音量大き目"
