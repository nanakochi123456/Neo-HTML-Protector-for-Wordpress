msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Retro-styl fanfare – 2,2 sekondes – 10 536 baitjies – 32 kbps – Lisensie: Publieke domein"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Retro-styl intro – 42,1 sekondes – 179 138 baitjies – 32 kbps – Lisensie: Publieke domein"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Waarskuwing deur ChatGPT - 3,8 sekondes - 109 700 bytes - 256 kbps - Lisensie: Publieke domein"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "'n klank met hoë dringendheid wat soos 'n malware-deteksiewaarskuwing klink – Deel 1 deur ChatGPT – 3,3 sekondes – 102 850 bytes – 256 kbps – Lisensie: Publieke domein"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "'n Hoogdringende klank soos 'n malware-opsporingswaarskuwing, Deel 2 deur ChatGPT - 3,3 sekondes - 103 122 baitjies - 256 kbps - Lisensie: Publieke domein"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "MRI-styl klank deur ChatGPT – 1 minuut 14,9 sekondes – 3 340 392 baitjies – 320 kbps – Lisensie: Publieke domein"

msgid "警告表示中のBGMを選択します"
msgstr "Kies die agtergrondmusiek om tydens 'n waarskuwing te speel."

msgid "びっくりするような雰囲気を作ります"
msgstr "Dit skep 'n verrassende atmosfeer."

msgid "Firefoxでは音声ブロックされます"
msgstr "Klank is in Firefox geblokkeer."

msgid "対象アクションを起こした時のビープ音"
msgstr "'n piep wanneer die gespesifiseerde aksie uitgevoer word"

msgid "有効 音量小さ目"
msgstr "Aan, klank laag"

msgid "有効 音量大き目"
msgstr "Aktief, volume op hoog"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "'n piep sal klink in reaksie op alle sleutelbord- en muisgebeurtenisse terwyl 'n waarskuwing vertoon word."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Dit skep die indruk dat die toestel dol geword het terwyl die waarskuwing vertoon word."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Verberg die muisaanwyser wanneer 'n spesifieke aksie uitgevoer word"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Verberg die muisaanwyser in die blaaierarea terwyl 'n waarskuwing vertoon word."

msgid "デバッグモード"
msgstr "Foutopsporingsmodus"

msgid "妨害＋記録のみ"
msgstr "Stooring + Rekords slegs"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Versteuring + Aantekeninghou + Vertoon + Herlei"

msgid "メニューからは操作できてしまいます"
msgstr "Jy kan dit steeds via die menu bereik."

msgid "Firefoxにおけるデバッグモード"
msgstr "Foutopsporingsmodus in Firefox"

msgid "ブラウザーコンソール"
msgstr "Blaaierkonsole"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "In werklikheid kan jy dit in foutopsporingsmodus laat werk."

msgid "HTMLソース表示"
msgstr "Beskou HTML-bron"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Jy kan die operasie eenvoudig uitvoer deur 'n URL in te voer wat met 'view-source:' begin."

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Jy kan jou inhoud beskerm deur dit met HTML-beskerming te kombineer."

msgid "印刷"
msgstr "Druk"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Alhoewel dit druk voorkom, werk dit dalk nie behoorlik in sommige blaaiers nie."

msgid "スクリーンショット"
msgstr "Skermkiekie"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Afhangende van die bedryfstelsel, blaaier of gebruikte metode, mag dit nie moontlik wees om dit te blokkeer nie, of mag dit nie opgespoor word nie."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Vermoedelike skermkiekie wanneer die venster na die agtergrond beweeg"

