msgid "設定"
msgstr "Instellings"

msgid "IPログリーダー"
msgstr "IP-logleser"

msgid "IPアドレスログ"
msgstr "IP-adreslog"

msgid "全クリア"
msgstr "Voltooi alle vlakke"

msgid "IPログが全て削除されました"
msgstr "Alle IP-loglêers is verwyder."

msgid "ID"
msgstr "Identiteit"

msgid "タイムスタンプ"
msgstr "Tydstempel"

msgid "IPアドレス"
msgstr "IP-adres"

msgid "ユーザーエージェント"
msgstr "Gebruikeragent"

msgid "イベント"
msgstr "Geleentheid"

msgid "IPアドレスのデータはありません"
msgstr "Daar is geen data vir hierdie IP-adres nie."

msgid "EU GDPR対応"
msgstr "Nakoming van die EU GDPR"

msgid "無効"
msgstr "Ongeldig"

msgid "有効"
msgstr "Geldig"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "As u WordPress binne die EU gebruik, of as u webwerf gebruikers binne die EU teiken, maak asseblief seker dat dit geaktiveer is."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Die 'Bevestig'-knoppie sal verander na 'Stem saam' of 'Stem nie saam nie', en die gedrag sal effens verander."

msgid "同意画面の色"
msgstr "Kleur van die toestemmingskerm"

msgid "自動"
msgstr "Outomaties"

msgid "ライトモード"
msgstr "Ligmodus"

msgid "ダークモード"
msgstr "Donker modus"

msgid "同意画面表示中の配色を設定します"
msgstr "Stel die kleurskema vir die toestemmingsskerm in."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Verwarring van inhoud op die toestemmingsskerm"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Stel die onscherpte-vlak in vir die inhoud wat op die toestemmingskerm vertoon word."

msgid "同意画面の透過"
msgstr "Deursigtigheid van die toestemmingskerm"

msgid "透過なし"
msgstr "Geen deursigtigheid"

msgid "同意画面の透過具合を設定します"
msgstr "Stel die deursigtigheid van die toestemmingsskerm in"

msgid "お知らせの1行目"
msgstr "Eerste reël van die aankondiging"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Hierdie boodskap word altyd vertoon die eerste keer dat die bladsy gelaai word."

msgid "お知らせの2行目"
msgstr "Die tweede reël van die kennisgewing"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Hierdie boodskap sal altyd slegs op die eerste vertoning verskyn wanneer die EU GDPR in werking is."

msgid "お知らせの3行目"
msgstr "Die derde reël van die kennisgewing"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Dit sal regs van die skakel na die privaatheidsbeleid verskyn."

msgid "非EU向け確認の文字列"
msgstr "Bevestigingsteks vir nie-EU-lande"

msgid "EU GDPR向け同意するの文字列"
msgstr "Tekst vir toestemming vir die EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Teks vir 'Moenie toestemming gee nie' kragtens die EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Privaatheidsbeleidsteks"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Stel asseblief die URL vir die privaatheidsbeleid hier in."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Voeg asseblief die volgende by die Privaatheidsbeleid."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Om bedrieglike aktiwiteit op te spoor, word identifikators soos IP-adresse in koekies en die databasis gestoor. Die gestoorde data word na goeddunke van die administrateur verwyder."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Om te verseker dat beelde korrek gelewer word slegs wanneer beeldbeskerming geaktiveer is, stoor ons gehasheerde data wat die IP-adres en die beeldlêernaam bevat in die databasis vir tot 60 minute."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "As u Gebruiksvoorwaardes opstel, verseker asseblief dat u 'n skakel na hulle in u Privaatheidsbeleid insluit."

msgid "利用規約の文字列"
msgstr "Teks van die Gebruiksvoorwaardes"

msgid "利用規約のページ"
msgstr "Bepalings en Voorwaardes-bladsy"

msgid "ページ選択なし"
msgstr "Geen bladsy gekies nie"

msgid "検索エンジン等のURL"
msgstr "URL's vir soekenjins, ens."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Stel die URL in vir soekenjins en soortgelyke webwerwe wat gebruikers omlei wanneer toestemming nie gegee word nie."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Foutopsporingsmodus, konsole-waarskuwingsboodskappe"

msgid "右クリックの警告メッセージ"
msgstr "Regskliek waarskuwingsboodskap"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Waarskuwingsboodskap rakende drukwerk en stoor as PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Waarskuwingsboodskap in die skermkiekie"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Waarskuwingsboodskap rakende vermoedelike skermskote"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Waarskuwingsboodskap wanneer alle teks geselekteer is"

msgid "ページ保存の警告メッセージ"
msgstr "Waarskuwingsboodskap rakende bladsy-opbewaring"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Boodskap wat vertoon word wanneer gekopieer of gesny word"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Boodskap om te vertoon wanneer HTML-bron besigtig word"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Boodskap om bo-aan die bronkode te vertoon wanneer HTML vervaag of beskerm word"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Boodskap om te vertoon as die eenmalige verifikasietoken ongeldig is tydens HTML-beskerming"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Boodskap om te vertoon as koekies of JavaScript gedeaktiveer is"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "In werklikheid word dit slegs vertoon wanneer JavaScript gedeaktiveer is."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Wanneer 'n beeld beskerm is, word dit afgelaai en word 'n boodskap op daardie beeld vertoon"

msgid "HTML難読化 (圧縮)"
msgstr "HTML-verduistering"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Dit is standaard HTML-kompressie; daar is ook webwerwe wat dit kan dekodeer."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Deur hierdie opsie te aktiveer, kan jy die view-source-log ophaal."

msgid "HTML保護"
msgstr "HTML-beskerming"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Dit lewer slegs die blote minimum aan HTML uit—selfs minder as wanneer HTML-kompressie gebruik word—en die inhoud binne die BODY-tag word glad nie uitgelewer nie."

msgid "Firefoxに対しては無効です"
msgstr "Dit geld nie vir Firefox nie."

msgid "SEOに著しく影響があります"
msgstr "Dit het 'n beduidende impak op SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Rendering van HTML met JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Om Firefox te omseil, render ons die HTML met JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Die inskakeling van JavaScript-rendering sal die webwerf se laaispoed aansienlik vertraag."

msgid "画像の保護"
msgstr "Beeldbeskerming"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Beskerm die beeld elke keer as die img-tag aangeroep word."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Beskerm alle beelde wat in WordPress opgelaai is binne die hele HTML-uitset."

msgid "画像をダウンロードから保護します"
msgstr "Beskerm beelde teen aflaai"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Wanneer beelddata beskerm word, verhoed ons byna alle aflaaie, verstrek ons unieke eenmalige URL's, verifieer ons met tokens wat in die sessie gestoor is, en vertoon ons die beelde via PHP; dit verhoed effektief byna alle gevalle van beelddiefstal."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Wanneer beelddata beskerm word, werk kasgeheue nie, wat beteken dat die webwerf by daaropvolgende besoeke stadiger sal laai en sodoende SEO beïnvloed."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Die beskerming van beelddata kan die las op die databasis verhoog."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "As jy 'Beskerm beelde elke keer wanneer 'n img-tag aangeroep word' kies, gebruik die stelsel add_filter om filtering toe te pas wanneer die img-tag gegenereer word; dit mag egter nie korrek werk met sommige temas nie."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "As jy 'Beskerm alle beelde wat in WordPress opgelaai is binne die hele HTML-uitset' kies, sal die inprop byna alle WordPress-operasies vasvang en elke img-tag in die inhoud verwerk. Neem asseblief kennis dat dit dalk nie korrek met sommige temas sal werk nie."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Neem asseblief kennis dat beelde wat as uitgeligte beelde aangewys is, as OGP-data gedeel sal word en nie beskerm kan word nie. As jy dit absoluut moet beskerm, verander asseblief die instelling vir HEAD-tag-uitset in die gevorderde instellings wanneer jy HTML-beskerming aktiveer."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Die skermkiekie-funksie wat in die bedryfstelsel ingebou is, kan nie beskerm word nie."

msgid "画像URLの保護"
msgstr "Die beskerming van beeld-URL's"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Dit moet in samewerking met beeldbeskerming gebruik word; op sigself dien dit geen doel nie."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Aangesien dit luiweg via JavaScript gelaai word, beïnvloed dit SEO."

msgid "画像のウォーターマーク"
msgstr "Beeldwatermerk"

msgid "右下"
msgstr "Onder regs"

msgid "ランダム位置"
msgstr "Willekeurige posisie"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Gebruik in samewerking met beeldbeskerming dui dinamiese watermerke duidelik die kopiereg-eienaarskap aan en gee kykers die indruk dat hulle gemonitor word, wat sodoende as 'n afskrikmiddel dien."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Slegs JPG-, PNG- en WebP-formate word ondersteun."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Deur dit moontlik te maak, sal die las op die bediener toeneem."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Uitvoer van ASCII-kuns uit HTML-bron kode tydens HTML-verduistering en beskerming"

msgid "表示なし"
msgstr "Geen vertoning"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Vertoon ASCII-kuns wat 'n waarskuwing aandui wanneer die HTML-bron met 'view-source' besigtig word."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Vertoon die ontwerp wanneer die teikenaksie uitgevoer word."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "'n basiese ontwerp met swart teks op 'n geel agtergrond"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "'n gruwelstyl-ontwerp met rooi teks op 'n swart agtergrond"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "'n ontwerp met gloedrooi teks op 'n swart agtergrond"

msgid "対象アクションを起こした時のBGM"
msgstr "Agtergrondmusiek wat gespeel word wanneer die teikenaksie uitgevoer word"

