msgstr "Paralajmërim nga ChatGPT - 3.8 sekonda - 109,700 bajtë - 256 kbps - Licenca: Domeni publik"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Një tingull me urgjencë të lartë si një alarm për zbulimin e softuerit keqdashës – Pjesa 1 nga ChatGPT – 3.3 sekonda – 102,850 bajtë – 256 kbps – Licenca: Domeni publik"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Një tingull me urgjencë të lartë si një alarm për zbulimin e softuerit keqdashës, Pjesa 2 nga ChatGPT - 3.3 sekonda - 103,122 bajtë - 256 kbps - Licenca: Domeni publik"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Zë në stilin MRI nga ChatGPT – 1 minutë 14.9 sekonda – 3,340,392 bajtë – 320 kbps – Licenca: Domeni publik"

msgid "警告表示中のBGMを選択します"
msgstr "Zgjidhni muzikën e sfondit që do të luhet gjatë një paralajmërimi."

msgid "びっくりするような雰囲気を作ります"
msgstr "Krijon një atmosferë befasuese"

msgid "Firefoxでは音声ブロックされます"
msgstr "Audioja është bllokuar në Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Një tingull kur kryhet veprimi i specifikuar"

msgid "有効 音量小さ目"
msgstr "Ndezur, volum i ulët"

msgid "有効 音量大き目"
