msgid "IPログリーダー"
msgstr "Lexuesi i regjistrave IP"

msgid "IPアドレスログ"
msgstr "Regjistri i adresave IP"

msgid "全クリア"
msgstr "Përfundo të gjitha nivelet"

msgid "IPログが全て削除されました"
msgstr "Të gjitha regjistrimet e IP-ve janë fshirë."

msgid "ID"
msgstr "Identifikimi"

msgid "タイムスタンプ"
msgstr "Stampa kohore"

msgid "IPアドレス"
msgstr "Adresa IP"

msgid "ユーザーエージェント"
msgstr "Agjenti i Përdoruesit"

msgid "イベント"
msgstr "Ngjarje"

msgid "IPアドレスのデータはありません"
msgstr "Nuk ka të dhëna për këtë adresë IP."

msgid "EU GDPR対応"
msgstr "Përputhshmëria me GDPR-n e BE-së"

msgid "無効"
msgstr "Jo i vlefshëm"

msgid "有効"
msgstr "Vlefshëm"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Nëse po përdorni WordPress brenda BE-së, ose nëse faqja juaj synon përdorues brenda BE-së, ju lutemi sigurohuni që kjo të jetë e aktivizuar."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Butoni 'Konfirmo' do të ndryshojë në 'Pajtohem' ose 'Nuk pajtohem', dhe sjellja do të ndryshojë pak."

msgid "同意画面の色"
msgstr "Ngjyra e ekranit të pëlqimit"

msgid "自動"
msgstr "Automatik"

msgid "ライトモード"
msgstr "Modi i lehtë"

msgid "ダークモード"
msgstr "Modi i errët"

msgid "同意画面表示中の配色を設定します"
msgstr "Caktoni skemën e ngjyrave për ekranin e pëlqimit"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Zbehja e përmbajtjes në ekranin e pëlqimit"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Caktoni nivelin e mjegullimit për përmbajtjen e shfaqur në ekranin e pëlqimit"

msgid "同意画面の透過"
msgstr "Transparenca e ekranit të pëlqimit"

msgid "透過なし"
msgstr "Asnjë transparencë"

msgid "同意画面の透過具合を設定します"
msgstr "Caktoni transparencën e ekranit të pëlqimit"

msgid "お知らせの1行目"
msgstr "Rreshti i parë i njoftimit"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ky mesazh shfaqet gjithmonë herën e parë që faqja ngarkohet."

msgid "お知らせの2行目"
msgstr "Rreshti i dytë i njoftimit"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ky mesazh do të shfaqet gjithmonë në ekranin e parë vetëm kur Rregullorja e Përgjithshme e Mbrojtjes së të Dhënave të BE-së"

msgid "お知らせの3行目"
msgstr "Rreshti i tretë i njoftimit"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Do të shfaqet në të djathtën e lidhjes për Politikën e Privatësisë."

msgid "非EU向け確認の文字列"
msgstr "Teksti i konfirmimit për vendet jo-anëtare të BE-së"

msgid "EU GDPR向け同意するの文字列"
msgstr "Teksti i pëlqimit për GDPR-në e BE-së"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Teksti për 'Mos pajtohuni' sipas Rregullores së Përgjithshme për Mbrojtjen e të Dhënave të BE-së"

msgid "プライバシーポリシーの文字列"
msgstr "Teksti i politikës së privatësisë"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Ju lutemi vendosni URL-në e politikës së privatësisë këtu"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Ju lutem shtoni të mëposhtmen në Politikën e Privatësisë."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Për të zbuluar aktivitet mashtrues, identifikues të tillë si adresat IP ruhen në cookie-t dhe në bazën e të dhënave. Të dhënat e ruajtura fshihen sipas diskrecionit të administratorit."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Për të siguruar që imazhet të dorëzohen si duhet vetëm kur mbrojtja e imazheve është e aktivizuar, ne ruajmë në bazën e të dhënave të dhëna të hashuara që përfshijnë adresën IP dhe emrin e skedarit të imazhit për deri në 60 minuta."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Nëse po përgatitni Kushtet e Përdorimit, sigurohuni që t'i përfshini ato me një lidhje në Politikën tuaj të Privatësisë."

msgid "利用規約の文字列"
msgstr "Teksti i Kushtet e Përdorimit"

msgid "利用規約のページ"
msgstr "Faqja e Kushteve dhe Rregullave"

msgid "ページ選択なし"
msgstr "Nuk është zgjedhur asnjë faqe"

msgid "検索エンジン等のURL"
msgstr "URL-të për motorët e kërkimit, etj."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Caktoni URL-në për motorët e kërkimit dhe faqet e ngjashme që ridrejtojnë përdoruesit kur nuk jepet pëlqimi."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Modi i debugimit, mesazhet paralajmëruese në konsolë"

msgid "右クリックの警告メッセージ"
msgstr "Mesazh paralajmërues me klik të djathtë"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Mesazh paralajmërues për shtypjen dhe ruajtjen si PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Mesazh paralajmërues në pamjen e ekranit"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Mesazh paralajmërues në lidhje me pamjet e ekranit të dyshuara"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Mesazh paralajmërues kur është zgjedhur i gjithë teksti"

msgid "ページ保存の警告メッセージ"
msgstr "Mesazh paralajmërues në lidhje me ruajtjen e faqes"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Mesazh i shfaqur kur kopjoni ose prisni"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Mesazh për t'u shfaqur kur shikohet kodi burimor i HTML-it"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Mesazh për t'u shfaqur në krye të kodit burimor kur obskurohet ose mbrohet HTML-ja"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Mesazh për t'u shfaqur nëse tokeni i autentifikimit njëpërdorimësh është i pavlefshëm gjatë mbrojtjes HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Mesazh për t'u shfaqur nëse cookie-t ose JavaScript janë çaktivizuar"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Në fakt, kjo shfaqet vetëm kur JavaScript është çaktivizuar."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Kur një imazh është i mbrojtur, ai shkarkohet dhe në të shfaqet një mesazh"

msgid "HTML難読化 (圧縮)"
msgstr "Obulskimi i HTML-it"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Kjo është kompresim standard i HTML-it; ka gjithashtu faqe interneti që mund ta dekriptojnë."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Aktivizimi i kësaj opsioni ju lejon të merrni logun e shikimit të burimit."

msgid "HTML保護"
msgstr "Mbrojtja e HTML-it"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ai prodhon vetëm minimumin e nevojshëm të HTML-it—madje edhe më pak se kur përdoret kompresimi i HTML-it—dhe përmbajtja brenda etiketës BODY nuk shfaqet fare."

msgid "Firefoxに対しては無効です"
msgstr "Kjo nuk zbatohet për Firefox."

msgid "SEOに著しく影響があります"
msgstr "Kjo ka një ndikim të rëndësishëm në SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Gjenerimi i HTML-së me JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Për të anashkaluar Firefox-in, ne e renderizojmë HTML-in duke përdorur JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Aktivizimi i renderimit të JavaScript-it do të ngadalësojë ndjeshëm shpejtësinë e ngarkimit të faqes së internetit."

msgid "画像の保護"
msgstr "Mbrojtja e imazhit"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Mbrojt imazhin sa herë që thirret etiketa img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Mbrojini të gjitha imazhet e ngarkuara në WordPress brenda të gjithë daljes HTML."

msgid "画像をダウンロードから保護します"
msgstr "Mbron imazhet nga shkarkimi"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Kur të dhënat e imazheve janë të mbrojtura, ne parandalojmë pothuajse të gjitha shkarkimet, lëshojmë URL-e unike njëpërdorimshe, autentifikojmë duke përdorur tokenë të ruajtura në sesion dhe shfaqim imazhet përmes PHP-së; kjo në mënyrë efektive parandalon pothuajse të gjitha rastet e vjedhjes së imazheve."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Kur të dhënat e imazheve janë të mbrojtura, caching nuk funksionon, që do të thotë se faqja do të ngarkohet më ngadalë në vizitat e mëvonshme, duke ndikuar kështu në SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Mbrojtja e të dhënave të imazhit mund të rrisë ngarkesën në bazën e të dhënave."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Nëse zgjidhni 'Mbrojt imazhet sa herë që thirret etiketa img', sistemi përdor add_filter për të aplikuar filtrimin kur gjenerohet etiketa img; megjithatë, kjo mund të mos funksionojë siç duhet me disa tema."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Nëse zgjidhni 'Mbroj të gjitha imazhet e ngarkuara në WordPress brenda të gjithë daljes HTML', shtojca do të kapë pothuajse të gjitha operacionet e WordPress-it dhe do të përpunojë çdo etiketë img brenda përmbajtjes. Ju lutemi vini re se kjo mund të mos funksionojë siç duhet me disa tema."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Ju lutemi vini re se imazhet e përcaktuara si imazhe kryesore do të ndahen si të dhëna OGP dhe nuk mund të mbrohen. Nëse me çdo kusht duhet t'i mbroni, ju lutemi ndryshoni cilësimin për daljen e etiketës HEAD në cilësimet e avancuara kur aktivizoni mbrojtjen HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Funksioni i kapjes së ekranit i integruar në sistemin operativ nuk mund të mbrohet."

msgid "画像URLの保護"
msgstr "Mbrojtja e URL-ve të imazheve"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Kjo duhet të përdoret së bashku me mbrojtjen e imazhit; vetë nuk ka asnjë qëllim."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Duke qenë se ngarkohet dembelisht përmes JavaScript, kjo ndikon në SEO."

msgid "画像のウォーターマーク"
msgstr "Ujërroje e imazhit"

msgid "右下"
msgstr "Poshtë djathtas"

msgid "ランダム位置"
msgstr "Pozicion i rastësishëm"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Përdoren së bashku me mbrojtjen e imazheve, markat dinamike të ujit tregojnë qartë pronësinë e të drejtave të autorit, duke i dhënë shikuesve përshtypjen se po monitorohen, dhe kështu veprojnë si një mjet parandalues."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Mbështeten vetëm formatet JPG, PNG dhe WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Aktivizimi i kësaj do të rrisë ngarkesën në server."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Shfaqja e artit ASCII nga kodi burimor i HTML-it gjatë obskurimit dhe mbrojtjes së HTML-it"

msgid "表示なし"
msgstr "Asnjë ekran"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Shfaq art ASCII që tregon një paralajmërim kur shikoni burimin e HTML-it duke përdorur 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Shfaq dizajnin kur kryhet veprimi i synuar"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Një dizajn bazik me tekst të zi mbi një sfond të verdhë"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Një dizajn në stil horror me tekst të kuq mbi sfond të zi"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Një dizajn me tekst të kuq të ndritshëm në sfond të zi"

msgid "対象アクションを起こした時のBGM"
msgstr "Muzikë sfondi që luhet kur kryhet veprimi i synuar"

msgid "サウンドなし"
msgstr "Asnjë tingull"

