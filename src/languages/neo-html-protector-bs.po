msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Zvuk visoke hitnosti nalik na upozorenje o detekciji malvera – 1. dio od ChatGPT-a – 3,3 sekunde – 102.850 bajtova – 256 kbps – Licenca: Javno vlasništvo"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Zvuk visoke hitnosti koji zvuči kao upozorenje o detekciji malvera, 2. dio od ChatGPT-a - 3,3 sekunde - 103.122 bajta - 256 kbps - Licenca: Javno vlasništvo"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Zvuk u stilu MRI-ja od ChatGPT-a – 1 minuta 14,9 sekundi – 3.340.392 bajtova – 320 kbps – Licenca: Javno vlasništvo"

msgid "警告表示中のBGMを選択します"
msgstr "Odaberite pozadinsku muziku koja će se puštati tokom upozorenja."

msgid "びっくりするような雰囲気を作ります"
msgstr "Stvara iznenađujuću atmosferu"

msgid "Firefoxでは音声ブロックされます"
msgstr "Audio je blokiran u Firefoxu"

msgid "対象アクションを起こした時のビープ音"
msgstr "Bip kada se izvrši navedena radnja"

msgid "有効 音量小さ目"
msgstr "Uključi, glasnoća niska"

msgid "有効 音量大き目"
msgstr "Aktivno, glasnoća podešena na visoko"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Upozorenje će biti prikazano, a uz to će se čuti bip za sve događaje tipke i miša."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Stvara se dojam da je uređaj poludio dok se prikazuje upozorenje."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Sakrivanje pokazivača miša kada se izvrši određena radnja"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Sakriva pokazivač miša u području preglednika dok se prikazuje upozorenje"

msgid "デバッグモード"
msgstr "Režim otklanjanja grešaka"

msgid "妨害＋記録のみ"
msgstr "Samo ometanje + zapisi"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Smetnje + evidentiranje + prikaz + preusmjeravanje"

msgid "メニューからは操作できてしまいます"
msgstr "Još uvijek mu možete pristupiti putem menija."

msgid "Firefoxにおけるデバッグモード"
msgstr "Režim otklanjanja grešaka u Firefoxu"

msgid "ブラウザーコンソール"
msgstr "Konzole preglednika"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "U suštini, možete ga koristiti iz načina otklanjanja grešaka."

msgid "HTMLソース表示"
msgstr "Pogledaj HTML izvor"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Možete izvršiti operaciju jednostavno unoseći URL koji počinje sa 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Možete zaštititi svoj sadržaj kombiniranjem ovoga s HTML zaštitom."

