msgid "設定"
msgstr "Postavke"

msgid "IPログリーダー"
msgstr "Čitač IP dnevnika"

msgid "IPアドレスログ"
msgstr "Zapisnik IP adresa"

msgid "全クリア"
msgstr "Završite sve nivoe"

msgid "IPログが全て削除されました"
msgstr "Svi IP zapisi su izbrisani"

msgid "ID"
msgstr "ID"

msgid "タイムスタンプ"
msgstr "Vremenski žig"

msgid "IPアドレス"
msgstr "IP adresa"

msgid "ユーザーエージェント"
msgstr "Korisnički agent"

msgid "イベント"
msgstr "Događaj"

msgid "IPアドレスのデータはありません"
msgstr "Nema podataka za ovu IP adresu."

msgid "EU GDPR対応"
msgstr "Usklađenost sa EU GDPR-om"

msgid "無効"
msgstr "Neispravno"

msgid "有効"
msgstr "Valjano"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Ako koristite WordPress unutar EU ili ako je vaša web stranica namijenjena korisnicima unutar EU, molimo osigurajte da je ovo omogućeno."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Dugme 'Potvrdi' će se promijeniti u 'Slažem se' ili 'Ne slažem se', a ponašanje će se malo promijeniti."

msgid "同意画面の色"
msgstr "Boja ekrana za davanje pristanka"

msgid "自動"
msgstr "Automatski"

msgid "ライトモード"
msgstr "Laki način rada"

msgid "ダークモード"
msgstr "Tamni način"

msgid "同意画面表示中の配色を設定します"
msgstr "Postavite shemu boja za ekran za davanje pristanka."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Zamagljivanje sadržaja na ekranu za davanje saglasnosti"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Postavite nivo zamućenja za sadržaj prikazan na ekranu za davanje pristanka."

msgid "同意画面の透過"
msgstr "Transparentnost ekrana za davanje pristanka"

msgid "透過なし"
msgstr "Nema transparentnosti"

msgid "同意画面の透過具合を設定します"
msgstr "Postavite prozirnost ekrana za pristank"

msgid "お知らせの1行目"
msgstr "Prvi red objave"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ova poruka se uvijek prikazuje prvi put kada se stranica učita."

msgid "お知らせの2行目"
msgstr "Drugi red obavijesti"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ova poruka će se uvijek prikazivati samo na prvom ekranu kada je EU GDPR na snazi."

msgid "お知らせの3行目"
msgstr "Treći red obavijesti"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Pojavit će se desno od poveznice na Politiku privatnosti."

msgid "非EU向け確認の文字列"
msgstr "Potvrdni tekst za zemlje izvan EU"

msgid "EU GDPR向け同意するの文字列"
msgstr "Tekst pristanka za EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Tekst za 'Ne dajem saglasnost' u skladu s EU GDPR-om"

msgid "プライバシーポリシーの文字列"
msgstr "Tekst politike privatnosti"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Molimo postavite URL za politiku privatnosti ovdje."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Molimo dodajte sljedeće u Politiku privatnosti."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Kako bi se otkrila prevarantska aktivnost, identifikatori poput IP adresa pohranjuju se u kolačićima i bazi podataka. Pohranjeni podaci se brišu prema nahođenju administratora."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Kako bismo osigurali da se slike isporučuju ispravno samo kada je zaštita slika omogućena, pohranjujemo hashirane podatke koji obuhvataju IP adresu i naziv datoteke slike u bazi podataka do 60 minuta."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Ako postavljate Uvjete korištenja, molimo vas da osigurate da u svojoj Politici privatnosti uključite poveznicu na njih."

msgid "利用規約の文字列"
msgstr "Tekst uslova korištenja"

msgid "利用規約のページ"
msgstr "Stranica s uslovima i odredbama"

msgid "ページ選択なし"
msgstr "Nije odabrana stranica"

msgid "検索エンジン等のURL"
msgstr "URL-ovi za pretraživače itd."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Postavite URL za pretraživače i slične stranice koje preusmjeravaju korisnike kada nije dato odobrenje."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Režim otklanjanja grešaka, upozoravajuće poruke na konzoli"

msgid "右クリックの警告メッセージ"
msgstr "Desni klik poruka upozorenja"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Upozorenje u vezi s ispisom i spremanjem kao PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Upozoravajuća poruka na snimku ekrana"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Upozorenje u vezi sa sumnjivim snimcima ekrana"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Poruka upozorenja kada je sav tekst odabran"

msgid "ページ保存の警告メッセージ"
msgstr "Upozorenje o spremanju stranice"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Poruka koja se prikazuje prilikom kopiranja ili izrezivanja"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Poruka za prikazivanje pri pregledu HTML izvora"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Poruka koja se prikazuje na vrhu izvornog koda prilikom zamagljivanja ili zaštite HTML-a"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Poruka za prikaz ako jednokratni token za autentifikaciju nije važeći tokom HTML zaštite"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Poruka za prikaz ako su kolačići ili JavaScript onemogućeni"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Zapravo, ovo se prikazuje samo kada je JavaScript onemogućen."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Kada je slika zaštićena, ona se preuzima i na njoj se prikazuje poruka"

msgid "HTML難読化 (圧縮)"
msgstr "HTML zamućivanje"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Ovo je standardna HTML kompresija; postoje i web stranice koje je mogu dešifrirati."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Omogućavanje ove opcije omogućava vam da preuzmete logove view-sourcea."

msgid "HTML保護"
msgstr "HTML zaštita"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ispisuje još manje HTML-a nego postavka za kompresiju HTML-a, što znači da sadržaj unutar oznake BODY neće biti ispisivan uopće."

msgid "Firefoxに対しては無効です"
msgstr "Ovo se ne odnosi na Firefox."

msgid "SEOに著しく影響があります"
msgstr "Ovo ima značajan utjecaj na SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Renderiranje HTML-a pomoću JavaScripta"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Da bismo zaobišli Firefox, renderiramo HTML koristeći JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Omogućavanje JavaScript renderiranja značajno će usporiti brzinu učitavanja web stranice."

msgid "画像の保護"
msgstr "Zaštita slike"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Zaštitite sliku svaki put kada se pozove img tag"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Zaštitite sve slike učitane u WordPress unutar cijelog HTML izlaza"

msgid "画像をダウンロードから保護します"
msgstr "Štiti slike od preuzimanja"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Kada su podaci o slikama zaštićeni, sprječavamo gotovo sve preuzimanja, izdajemo jedinstvene jednokratne URL-ove, autentificiramo pomoću tokena pohranjenih u sesiji i prikazujemo slike putem PHP-a; to učinkovito sprječava gotovo sve slučajeve krađe slika."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Kada su podaci o slikama zaštićeni, keširanje ne radi, što znači da će se stranica pri naknadnim posjetama učitavati sporije, čime se utječe na SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Zaštita podataka o slikama može povećati opterećenje baze podataka."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Ako odaberete 'Zaštiti slike kad god se pozove img tag', sistem koristi add_filter da primijeni filtriranje prilikom generisanja img taga; međutim, ovo možda neće ispravno raditi sa nekim temama."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Ako odaberete 'Zaštiti sve slike učitane u WordPress unutar cijelog HTML izlaza', dodatak će uhvatiti gotovo sve WordPress operacije i obraditi svaki img tag unutar sadržaja. Imajte na umu da ovo možda neće ispravno raditi sa nekim temama."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Imajte na umu da će slike označene kao istaknute slike biti dijeljene kao OGP podaci i ne mogu biti zaštićene. Ako ih apsolutno morate zaštititi, molimo promijenite postavku za izlaz HEAD tagova u naprednim postavkama prilikom omogućavanja HTML zaštite."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Funkcija snimanja ekrana ugrađena u operativni sistem ne može biti zaštićena."

msgid "画像URLの保護"
msgstr "Zaštita URL-ova slika"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Ovo treba koristiti u kombinaciji sa zaštitom slika; samo po sebi nema nikakvu svrhu."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Budući da se učitava putem JavaScript-a, to utječe na SEO."

msgid "画像のウォーターマーク"
msgstr "Vodeni žig slike"

msgid "右下"
msgstr "Donji desni"

msgid "ランダム位置"
msgstr "Nasumična pozicija"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Korištene zajedno sa zaštitom slika, dinamičke vodene oznake jasno ukazuju na vlasništvo nad autorskim pravima, istovremeno dajući gledaocima dojam da su nadgledani, čime djeluju kao odvraćajući faktor."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Podržani su samo JPG, PNG i WebP formati."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Omogućavanje ovoga će povećati opterećenje servera."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ispisivanje ASCII umjetnosti iz HTML izvornog koda tokom zamućivanja i zaštite HTML-a"

msgid "表示なし"
msgstr "Nema prikaza"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Prikazuje ASCII umjetnost koja označava upozorenje prilikom pregledavanja HTML izvornog koda pomoću 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Prikaži dizajn kada je ciljana akcija izvršena"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Osnovni dizajn s crnim tekstom na žutoj pozadini"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Dizajn u horor stilu sa crvenim tekstom na crnoj pozadini"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Dizajn sa sjajnim crvenim tekstom na crnoj pozadini"

msgid "対象アクションを起こした時のBGM"
msgstr "Pozadinska muzika koja se pušta kada se izvrši ciljana radnja"

msgid "サウンドなし"
msgstr "Nema zvuka"

