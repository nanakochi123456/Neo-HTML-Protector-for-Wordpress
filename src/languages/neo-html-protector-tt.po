msgid "設定"
msgstr "Көйләүләр"

msgid "IPログリーダー"
msgstr "IP логлар укучы"

msgid "IPアドレスログ"
msgstr "IP-адреслар журналы"

msgid "全クリア"
msgstr "Барлык дәрәҗәләрне тәмамлагыз"

msgid "IPログが全て削除されました"
msgstr "Барлык IP журналлары бетерелде"

msgid "ID"
msgstr "ID"

msgid "タイムスタンプ"
msgstr "Вакыт штампы"

msgid "IPアドレス"
msgstr "IP адресы"

msgid "ユーザーエージェント"
msgstr "Кулланучы агент"

msgid "イベント"
msgstr "Чара"

msgid "IPアドレスのデータはありません"
msgstr "Бу IP-адрес өчен мәгълүмат юк"

msgid "EU GDPR対応"
msgstr "Европа Берлеге GDPR таләпләренә туры килү"

msgid "無効"
msgstr "Дөрес түгел"

msgid "有効"
msgstr "Дөрес"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Әгәр сез Европа Берлегендә WordPress кулланасыз яки веб-сайтыгыз Европа Берлегендәге кулланучыларга юнәлтелгән булса, зинһар, моның актив булуын тәэмин итегез."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "«Раслау» төймәсе «Килешәм» яки «Килешмим»гә үзгәрәчәк, һәм эш тәртибе бераз үзгәрәчәк."

msgid "同意画面の色"
msgstr "Ризалык экранының төсе"

msgid "自動"
msgstr "Автоматик"

msgid "ライトモード"
msgstr "Җиңел режим"

msgid "ダークモード"
msgstr "Караңгы режим"

msgid "同意画面表示中の配色を設定します"
msgstr "Рөхсәт экраны өчен төс схемасын билгеләгез"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Рөхсәт экранындагы эчтәлекне томалау"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Рөхсәт экранында күрсәтелә торган эчтәлек өчен бозау дәрәҗәсен билгеләгез"

msgid "同意画面の透過"
msgstr "Ризалык экранының ачыклыгы"

msgid "透過なし"
msgstr "Ачыклык юк"

msgid "同意画面の透過具合を設定します"
msgstr "Ризалык экранының үтә күренмәлеген көйләгез"

msgid "お知らせの1行目"
msgstr "Игъланның беренче юлы"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Бу хәбәр бит беренче тапкыр йөкләнгәндә һәрвакыт күрсәтелә."

msgid "お知らせの2行目"
msgstr "Хәбәрнең икенче юлы"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Бу хәбәр һәрвакыт беренче экранда гына, тик EU GDPR гамәлгә кергән очракта гына күренәчәк."

msgid "お知らせの3行目"
msgstr "Хәбәрнең өченче юлы"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ул Шәхси мәгълүматларны яклау сәясәте сылтамасының уң ягында күренәчәк."

msgid "非EU向け確認の文字列"
msgstr "Европа Берлегенә кермәгән илләр өчен раслау тексты"

msgid "EU GDPR向け同意するの文字列"
msgstr "Европа Берлеге GDPR өчен ризалык тексты"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Европа Берлеге GDPR кысаларында «Ризалык бирмәгез» тексты"

msgid "プライバシーポリシーの文字列"
msgstr "Шәхси мәгълүматларны яклау сәясәте тексты"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Зинһар, шәхси мәгълүматларны яклау сәясәтенең URL-ын монда урнаштырыгыз"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Зинһар, түбәндәгеләрне шәхси мәгълүматларны яклау сәясәтенә өстәгез."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Алдаулы эшчәнлекне ачыклау өчен IP-адреслар кебек идентификаторлар cookie-файлларда һәм мәгълүмат базасында саклана. Сакланган мәгълүмат администратор карары буенча бетерелә."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Рәсем саклау функциясе актив булганда рәсемнәрнең дөрес тапшырылуын тәэмин итү өчен без IP-адрес һәм рәсем файлы исемен үз эченә алган хешланган мәгълүматны базабызда 60 минутка кадәр саклыйбыз."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Әгәр сез Куллану шартларын булдырасыз икән, зинһар, Шәхси мәгълүматларны яклау сәясәтегезгә аларга сылтама кертүегезне тәэмин итегез."

msgid "利用規約の文字列"
msgstr "Куллану шартлары тексты"

msgid "利用規約のページ"
msgstr "Шартлар һәм кагыйдәләр бите"

msgid "ページ選択なし"
msgstr "Бер бит тә сайланмаган"

msgid "検索エンジン等のURL"
msgstr "Эзләү системалары өчен URL-лар һ.б."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Кулланучы ризалык бирмәгәндә аны башка биткә юнәлтүче эзләү системалары һәм шундый сайтлар өчен URL-ны билгеләгез."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Хаталарны төзәтү режимы, консоль кисәтү хәбәрләре"

msgid "右クリックの警告メッセージ"
msgstr "Уң төймә белән баскач кисәтү хәбәре"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDF форматында бастыру һәм саклау турында кисәтү хәбәре"

msgid "スクリーンショットの警告メッセージ"
msgstr "Скриншотта кисәтү хәбәре"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Шикләнелгән скриншотлар турында кисәтү хәбәре"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Барлык текст сайланганда кисәтү хәбәре"

msgid "ページ保存の警告メッセージ"
msgstr "Бизне саклау турында кисәтү хәбәре"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Копияләгәндә яки кискәндә күрсәтелә торган хәбәр"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML чыганакны караганда күрсәтелә торган хәбәр"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML-ны обфускацияләгәндә яки саклаганда чыганак кодының иң өске өлешендә күрсәтелә торган хәбәр"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML саклау вакытында бер тапкыр кулланыла торган аутентификация токены дөрес булмаса күрсәтелә торган хәбәр"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Әгәр кукилар яки JavaScript сүндерелгән булса, күрсәтелә торган хәбәр"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Чынлыкта, бу бары тик JavaScript сүндерелгән вакытта гына күрсәтелә."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Сүрәт сакланган вакытта ул йөкләнә һәм шул сүрәткә хәбәр күрсәтелә"

msgid "HTML難読化 (圧縮)"
msgstr "HTMLны буталау"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Бу гадәти HTML кысуы; аны декодлый алучы веб-сайтлар да бар."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Бу опцияне активлаштыру view-source логларын алу мөмкинлеген бирә."

msgid "HTML保護"
msgstr "HTML саклау"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ул HTMLның иң кирәкле минимумын гына чыгара — хәтта HTMLны кыскарту кулланганда чыгарылганнан да азрак — һәм BODY тегы эчендәге эчтәлек бөтенләй чыгарылмый."

msgid "Firefoxに対しては無効です"
msgstr "Бу Firefoxка кагылмый"

msgid "SEOに著しく影響があります"
msgstr "Бу SEOга зур йогынты ясый."

msgid "HTMLをJavaScriptで描画"
msgstr "JavaScript ярдәмендә HTML төзү"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox'ны урап үтү өчен без HTML-ны JavaScript ярдәмендә рендерлыйбыз."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScript-ны эшләтеп җибәрү веб-сайтның йөкләнү тизлеген сизелерлек акрынайтачак."

msgid "画像の保護"
msgstr "Сүрәтне яклау"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img тегын һәр чакыру саен рәсемне яклагыз"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "WordPressка йөкләнгән барлык рәсемнәрне бөтен HTML чыгарылышында саклагыз"

msgid "画像をダウンロードから保護します"
msgstr "Рәсемнәрнең йөкләнүеннән саклый"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Рәсем мәгълүматлары сакланганда без аларны йөкләп алуның күпчелеген булдырмыйбыз, уникаль бер тапкыр кулланыла торган URL-адреслар бирәбез, сессиядә сакланган токеннар ярдәмендә аутентификация үткәрәбез һәм рәсемнәрне PHP аша күрсәтәбез; бу нәтиҗәле рәвештә рәсем урлауның күпчелеген булдырмый."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Рәсем мәгълүматлары сакланганда кэшинг эшләми, бу сайтның киләсе килүләрдә әкренрәк йөкләнүенә һәм шуның белән SEOга тәэсир итүенә китерә."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Рәсем мәгълүматларын саклау мәгълүматлар базасына йөкләнешне арттырырга мөмкин."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Әгәр сез «img тегын чакырганда һәрвакыт рәсемнәрне саклау» пунктын сайласагыз, система img тегы барлыкка килгәндә add_filter функциясен кулланып фильтрлау үткәрә; әмма бу кайбер темаларда дөрес эшләмәскә мөмкин."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Әгәр сез «Бөтен HTML чыгарылышында WordPressка йөкләнгән барлык рәсемнәрне саклау» пунктын сайласагыз, плагин WordPress эшчәнлегенең күпчелеген тотып алачак һәм эчтәлектәге һәр img тегын эшкәртәчәк. Игътибар итегез, бу кайбер темаларда дөрес эшләмәскә мөмкин."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Игътибар итегез: «Өстенлекле рәсемнәр» дип билгеләнгән рәсемнәр OGP мәгълүматы буларак уртаклашылачак һәм аларны яклап булмый. Әгәр дә сез аларны һичшиксез якларга телисез икән, HTML-ны яклауны активлаштырганда алгарышлы көйләүләрдә HEAD тегын чыгару көйләвен үзгәртегез."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Операцион системада стандарт рәвештә кертелгән скриншот функциясен яклап булмый."

msgid "画像URLの保護"
msgstr "Рәсем URL-ларын саклау"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Бу рәсемне яклау белән бергә кулланылырга тиеш; үзе генә ул бернинди максат та тормышка ашырмый."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Ул JavaScript аша йөкләнү сәбәпле, бу SEOга тәэсир итә."

msgid "画像のウォーターマーク"
msgstr "Сүрәткә су тамгасы"

msgid "右下"
msgstr "аскы уң"

msgid "ランダム位置"
msgstr "Очраклы урын"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Рәсемне яклау белән берлектә кулланылганда, динамик су тамгалары авторлык хокукын ачык күрсәтә һәм караучыларга аларның күзәтелүе турында тәэсир калдыра, шуның белән киртә булып тора."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Тик JPG, PNG һәм WebP форматлары гына хуплана."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Буны эшләтү сервер йөкләнешен арттырачак."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "HTML чыганак кодын буталау һәм саклау вакытында ASCII-сәнгать чыгару"

msgid "表示なし"
msgstr "Күрсәтү юк"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "View-source кулланып HTML чыганагын караганда кисәтүне күрсәтүче ASCII-арт"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Максатлы гамәл башкарылганда интерфейс дизайнын күрсәтергә"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Сары фонда кара текст белән төп дизайн"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Кара фонда кызыл текст белән куркыныч стильдәге дизайн"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Кара фонда балкып торган кызыл текстлы дизайн"

msgid "対象アクションを起こした時のBGM"
msgstr "Максатлы гамәл башкарылганда яңгыраучы фон музыка"

msgid "サウンドなし"
msgstr "Тавыш юк"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Сугыш һәм Җиңү - 1 минут 16,3 секунд - 630 056 байт - 64 кбит/с - Лицензия: CC 2.1 яки соңрак"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Dad Short - 3,8 секунд - 32 364 байт - 64 kbps - Лицензия: GPL 2.0 яки соңрак"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23,5 секунд - 195 578 байт - 64 кбит/с - Лицензия: GPL 2.0 яки соңрак"

