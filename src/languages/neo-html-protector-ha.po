msgid "設定"
msgstr "Saituna"

msgid "IPログリーダー"
msgstr "Mai karanta log na IP"

msgid "IPアドレスログ"
msgstr "Rajistar adireshin IP"

msgid "全クリア"
msgstr "Kammala duk matakan"

msgid "IPログが全て削除されました"
msgstr "An goge duk bayanan rajistar IP."

msgid "ID"
msgstr "Shaida"

msgid "タイムスタンプ"
msgstr "Alamar lokaci"

msgid "IPアドレス"
msgstr "Adireshin IP"

msgid "ユーザーエージェント"
msgstr "Mai aikin mai amfani"

msgid "イベント"
msgstr "Taro"

msgid "IPアドレスのデータはありません"
msgstr "Babu bayanai don wannan adireshin IP."

msgid "EU GDPR対応"
msgstr "Bin ƙa'idar GDPR ta EU"

msgid "無効"
msgstr "Ba ingantacce ba"

msgid "有効"
msgstr "Ingantacce"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Idan kuna amfani da WordPress a cikin Tarayyar Turai, ko idan gidan yanar gizonku yana nufin masu amfani a cikin Tarayyar Turai, da fatan za ku tabbatar an kunna wannan."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Maɓallin 'Tabbatar' zai canza zuwa 'Yarda' ko 'Karyata', kuma halayya za ta canza kaɗan."

msgid "同意画面の色"
msgstr "Launin allon amincewa"

msgid "自動"
msgstr "Ta atomatik"

msgid "ライトモード"
msgstr "Halin haske"

msgid "ダークモード"
msgstr "Halin Duhu"

msgid "同意画面表示中の配色を設定します"
msgstr "Saita tsarin launuka na allon amincewa"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Ruɗe abun ciki a allon amincewa"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Saita matakin ruɗe-gani ga abun da ake nunawa a allon amincewa"

msgid "同意画面の透過"
msgstr "Bayyanar allon amincewa"

msgid "透過なし"
msgstr "Babu gaskiya"

msgid "同意画面の透過具合を設定します"
msgstr "Saita bayyanar allon amincewa"

msgid "お知らせの1行目"
msgstr "Layin farko na sanarwar"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ana nuna wannan saƙon koyaushe a karo na farko da aka loda shafin."

msgid "お知らせの2行目"
msgstr "Layin na biyu na sanarwar"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Wannan saƙon zai bayyana koyaushe a nuni na farko kawai idan EU GDPR ta fara aiki."

msgid "お知らせの3行目"
msgstr "Layin na uku na sanarwar"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Zai bayyana a dama na mahaɗin zuwa Manufofin Sirri."

msgid "非EU向け確認の文字列"
msgstr "Rubutun tabbatarwa don ƙasashen da ba na EU ba"

msgid "EU GDPR向け同意するの文字列"
msgstr "Rubutaccen izini don EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Rubutu don 'Kada a yarda' a ƙarƙashin EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Rubutun manufofin sirri"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Don Allah sa adireshin URL na manufofin sirri a nan."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Don Allah a ƙara waɗannan abubuwan zuwa ga Dokar Sirri."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Don gano ayyukan zamba, ana adana alamomi kamar adireshin IP a cikin kukis da ma'ajiyar bayanai. Ana goge bayanan da aka adana bisa ga hukuncin mai gudanarwa."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Don tabbatar da cewa an isar da hotuna yadda ya kamata ne kawai idan an kunna kariyar hotuna, muna adana bayanai da aka yi musu hash, waɗanda suka ƙunshi adireshin IP da sunan fayil ɗin hoto, a cikin ma'ajiyar bayanai na tsawon mintuna 60."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Idan kuna kafa Sharuɗɗan Amfani, don Allah ku tabbatar kun haɗa mahaɗin su a cikin Manufofin Sirri."

msgid "利用規約の文字列"
msgstr "Rubutun Sharuɗɗan Amfani"

msgid "利用規約のページ"
msgstr "Shafin Sharuɗɗa da Ka'idoji"

msgid "ページ選択なし"
msgstr "Ba a zaɓi shafi ba"

msgid "検索エンジン等のURL"
msgstr "URLs don injunan bincike, da sauransu."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Saita URL ɗin injunan bincike da shafuka makamancin haka waɗanda ke tura masu amfani zuwa wani wuri idan ba su yarda ba."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Modi na gyaran kuskure, saƙonnin gargaɗi na console"

msgid "右クリックの警告メッセージ"
msgstr "Danna dama a kan saƙon gargaɗi"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Sako na gargaɗi game da buga da ajiye a matsayin PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Sakon gargaɗi a cikin hoton allo"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Sakon gargaɗi game da hotunan allo da ake zargin an ɗauka"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Sakon gargaɗi lokacin da aka zaɓi duk rubutun"

msgid "ページ保存の警告メッセージ"
msgstr "Sakon gargaɗi game da adana shafi"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Sako da ake nuna lokacin kwafi ko yankan"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Sako da za a nuna lokacin duba tushen HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Sako da za a nuna a saman lambar tushe lokacin da ake ruɗarwa ko kare HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Sako da za a nuna idan token ɗin tabbatarwa na sau ɗaya bai yi aiki ba yayin kariyar HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Sako da za a nuna idan an kashe kukis ko JavaScript"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "A gaskiya, ana nuna wannan ne kawai idan an kashe JavaScript."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Idan an kare hoto, ana sauke shi, sannan a nuna saƙo a kan hoton"

msgid "HTML難読化 (圧縮)"
msgstr "Ruɗa HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Wannan matsewar HTML ce ta al'ada; akwai kuma shafukan yanar gizo da za su iya fassara shi."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ta kunna wannan zaɓi, za ku iya dawo da rajistar duba tushe."

msgid "HTML保護"
msgstr "Karewar HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Yana fitar da HTML kaɗan ma fiye da saitin matse HTML, ma'ana ba za a fitar da abun cikin tag ɗin BODY ba kwata-kwata."

msgid "Firefoxに対しては無効です"
msgstr "Wannan ba ya shafa Firefox."

msgid "SEOに著しく影響があります"
msgstr "Wannan yana da tasiri mai muhimmanci ga SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Gina HTML ta amfani da JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Don magance matsalar Firefox, muna nuna HTML ɗin ta amfani da JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Bada damar aiwatar da JavaScript zai jinkirta saurin ɗorawa na gidan yanar gizo sosai."

msgid "画像の保護"
msgstr "Kare hoto"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Kare hoton duk lokacin da aka kira tag ɗin img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Kare duk hotunan da aka loda a WordPress a cikin dukkan fitarwar HTML"

msgid "画像をダウンロードから保護します"
msgstr "Yana kare hotuna daga saukarwa"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Idan an kare bayanan hotuna, muna hana kusan duk saukarwa, muna samar da URLs na lokaci guda na musamman, muna tabbatar da sahihanci ta amfani da alamomin tsaro da aka ajiye a zaman, sannan muna nuna hotunan ta PHP; wannan yana hana kusan duk sata hotuna."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Idan an kare bayanan hoto, ajiyar wucin gadi ba ta aiki, wanda ke nufin shafin zai loda a hankali a ziyarce-ziyarce na gaba, ta haka yana shafar SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Kare bayanan hoto na iya ƙara nauyi a kan ma'ajiyar bayanai."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Idan ka zaɓi 'Kare hotuna duk lokacin da aka kira tag ɗin img', tsarin zai yi amfani da add_filter don aiwatar da tacewa lokacin da ake ƙirƙirar tag ɗin img; duk da haka, wannan na iya kasa aiki yadda ya kamata tare da wasu jigogi."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Idan ka zaɓi 'Kare duk hotunan da aka loda zuwa WordPress a cikin duk fitarwar HTML', ƙarin zai kama kusan duk ayyukan WordPress kuma ya sarrafa kowanne tag ɗin img a cikin abun ciki. Don Allah a lura cewa wannan na iya kasa aiki yadda ya kamata tare da wasu jigogi."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Da fatan a lura cewa hotunan da aka zaɓa a matsayin hotunan da aka fi so za a raba su a matsayin bayanan OGP kuma ba za a iya kare su ba. Idan lallai ne ku kare su, da fatan za ku canza saitin fitarwar alamomin HEAD a cikin saitunan ci gaba lokacin kunna kariyar HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Ba za a iya kare aikin ɗaukar hoton allo da ke cikin tsarin aiki a matsayin ma'auni ba."

msgid "画像URLの保護"
msgstr "Kare URLs na hotuna"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Ya kamata a yi amfani da wannan tare da kariyar hoto; shi kaɗai, ba shi da wata amfani."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Yayin da ake loda shi cikin kasala ta JavaScript, wannan yana shafar SEO."

msgid "画像のウォーターマーク"
msgstr "Alamar ruwa ta hoto"

msgid "右下"
msgstr "ƙasa a dama"

msgid "ランダム位置"
msgstr "Matsayi na bazuwa"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Ana amfani da su tare da kariyar hoto, alamomin ruwa masu motsi suna nuna a fili mallakar haƙƙin mallaka yayin da suke ba masu kallo ra'ayin ana sa ido a kansu, ta haka suna zama abin hana su aikata laifi."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Ana tallafawa tsarin JPG, PNG da WebP kawai."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Kunna wannan zai ƙara nauyin sabar."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Fitar da fasahar ASCII daga lambar tushe ta HTML yayin ruɗani da kariya"

msgid "表示なし"
msgstr "Babu nuni"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Yana nuna fasahar ASCII da ke nuna gargaɗi lokacin kallon tushen HTML ta amfani da 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Nuna ƙira lokacin da aka aiwatar da aikin da ake nufi"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Ƙirar asali da ke ɗauke da rubutu baki a kan bango rawaya"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Ƙirar salon ban tsoro da ke ɗauke da rubutu ja a kan baya baki"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Ƙira mai ɗauke da rubutu ja mai haske a kan baya baki"

msgid "対象アクションを起こした時のBGM"
msgstr "Kiɗan bango da ke kunnawa lokacin da aka aiwatar da aikin da ake nufi"

msgid "サウンドなし"
msgstr "Babu sauti"

