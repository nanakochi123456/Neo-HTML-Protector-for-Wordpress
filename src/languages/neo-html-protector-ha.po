msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Jerin: Étude d'Exécution Transcendante No. 4, 'Mazeppa' – sigar da kwamfuta ta samar, gajeriyar sigar da aka hanzarta – minti 1 da daƙiƙa 51.6 – baitoci 687,586 – 48 kbps – Lasisi: CC BY-ND 4.0 ko daga baya"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Biki – daƙiƙa 22.3 – baitoci 183,926 – 64 kbps – Lasisi: Dukiya ta Jama'a"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Biki na salo na baya – 2.2 daƙiƙa – 10,536 baitoci – 32 kbps – Lasisi: Yankin jama'a"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Gabatarwa mai salo na baya – 42.1 sakan – 179,138 baitoci – 32 kbps – Lasisi: Dukiya ta jama'a"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Gargaɗi daga ChatGPT - 3.8 sakan - 109,700 baitoci - 256 kbps - Lasisi: Yankin jama'a"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sauti mai gaggawa sosai kamar faɗakarwar gano malware – Sashe na 1 ta ChatGPT – 3.3 sakan – 102,850 baitoci – 256 kbps – Lasisi: Yanki na Jama'a"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sauti mai gaggawa sosai kamar faɗakarwar gano malware, Sashe na 2 ta ChatGPT - 3.3 daƙiƙa - 103,122 baitoci - 256 kbps - Lasisi: Yankin jama'a"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Sautin salon MRI ta ChatGPT – minti 1 da daƙiƙa 14.9 – baitoci 3,340,392 – 320 kbps – Lasisi: Yankin jama'a"

msgid "警告表示中のBGMを選択します"
msgstr "Zaɓi kiɗan bango da za a kunna yayin gargaɗi."

msgid "びっくりするような雰囲気を作ります"
msgstr "Yana ƙirƙirar yanayi mai ban mamaki"

msgid "Firefoxでは音声ブロックされます"
msgstr "An toshe sauti a Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "Beep lokacin da aka aiwatar da aikin da aka kayyade"

msgid "有効 音量小さ目"
msgstr "A kunne, ƙarar sauti ƙasa"

msgid "有効 音量大き目"
msgstr "Ana aiki, an saita ƙarar sauti zuwa mafi girma"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Za a ji karar bip ga duk abubuwan maɓalli da na linzami yayin da ake nuna gargaɗi."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Yana ba da tunanin cewa na'urar ta yi hauka yayin da ake nuna gargaɗin."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Boye ƙursor na linzami lokacin da aka yi wani takamaiman aiki"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Yana ɓoye ƙursor na linzami a yankin burauza yayin da ake nuna gargaɗi."

msgid "デバッグモード"
msgstr "Modi na gyaran kuskure"

msgid "妨害＋記録のみ"
msgstr "Cikas + Rekodi kawai"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Cikas + Rubuce-rubuce + Nuna + Juya"

msgid "メニューからは操作できてしまいます"
msgstr "Har yanzu za ka iya samun sa ta menu ɗin."

msgid "Firefoxにおけるデバッグモード"
msgstr "Modi na gyara kuskure a Firefox"

msgid "ブラウザーコンソール"
msgstr "Konsol na burauza"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "A zahiri, za ka iya sarrafa shi daga yanayin gyaran kuskure."

msgid "HTMLソース表示"
msgstr "Dubi tushen HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
