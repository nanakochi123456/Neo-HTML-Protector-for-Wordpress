msgstr "Энэ IP хаягтай холбоотой ямар ч мэдээлэл байхгүй байна."

msgid "EU GDPR対応"
msgstr "ЕХ-ны GDPR-д нийцэх"

msgid "無効"
msgstr "Хүчин төгөлдөр бус"

msgid "有効"
msgstr "Хүчинтэй"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Хэрэв та Европын Холбоо"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Баталгаажуулах' товч 'Зөвшөөрөх' эсвэл 'Зөвшөөрөхгүй' болж, үйлдэл нь бага зэрэг өөрчлөгдөнө."

msgid "同意画面の色"
msgstr "Зөвшөөрлийн дэлгэцийн өнгө"

msgid "自動"
msgstr "Автомат"

msgid "ライトモード"
msgstr "Хөнгөн горим"

msgid "ダークモード"
msgstr "Харанхуй горим"

msgid "同意画面表示中の配色を設定します"
msgstr "Зөвшөөрлийн дэлгэцийн өнгөний схем тохируулах"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Зөвшөөрлийн дэлгэцийн агуулгыг бүдгэрүүлэх"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Зөвшөөрлийн дэлгэц дээр харуулагдах агуулгын бүдгэрүүлэлтийн түвшинг тохируулна"

msgid "同意画面の透過"
msgstr "Зөвшөөрлийн дэлгэцийн ил тод байдал"

msgid "透過なし"
msgstr "Нээлттэй байдал байхгүй"

msgid "同意画面の透過具合を設定します"
msgstr "Зөвшөөрлийн дэлгэцийн тунгалаг байдлыг тохируулна уу"

msgid "お知らせの1行目"
msgstr "Зар мэдэгдлийн эхний мөр"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Энэ мессеж хуудас анх удаа ачаалагдах бүрт үргэлж харуулагддаг"

msgid "お知らせの2行目"
msgstr "Мэдэгдлийн хоёр дахь мөр"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Энэхүү мессеж зөвхөн EU GDPR хүчин төгөлдөр болсон үед эхний дэлгэц дээр үргэлж гарна."

msgid "お知らせの3行目"
msgstr "Мэдэгдлийн гурав дахь мөр"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Энэ нь Нууцлалын бодлогын холбоосын баруун талд гарч ирнэ."

msgid "非EU向け確認の文字列"
msgstr "ЕХ-нд хамаарахгүй орнуудын баталгаажуулалтын текст"

msgid "EU GDPR向け同意するの文字列"
msgstr "ЕХ-ны GDPR-д зориулсан зөвшөөрлийн текст"

msgid "EU GDPR向け同意しないの文字列"
msgstr "ЕХ-ны GDPR-ийн 'Зөвшөөрөхгүй байх' гэсэн хэсгийн текст"

msgid "プライバシーポリシーの文字列"
msgstr "Нууцлалын бодлогын текст"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Нууцлалын бодлогын URL-ийг энд тохируулна уу."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Нууцлалын бодлогод дараахыг нэмж оруулаарай"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Худалдан авалтын залилан мэхлэлийг илрүүлэхийн тулд IP хаяг зэрэг таних тэмдэглэгээг күүки болон өгөгдлийн санд хадгалдаг. Хадгалагдсан өгөгдлийг администратор хүссэнээр устгадаг."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Зураг хамгаалалтыг идэвхжүүлсэн үед зургуудыг зөв хүргэх зорилгоор бид IP хаяг болон зургийн файлын нэрийг агуулсан хэшлэгдсэн өгөгдлийг өгөгдлийн сандоо 60 минут хүртэл хадгалдаг."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Хэрэв та Ашиглах нөхцлийг тогтоож байгаа бол, тэдгээрийн холбоосыг Нууцлалын бодлогодоо оруулахыг баталгаажуулна уу."

msgid "利用規約の文字列"
msgstr "Ашиглах нөхцлийн текст"

msgid "利用規約のページ"
msgstr "Нөхцөл, журам хуудас"

msgid "ページ選択なし"
msgstr "Худалбаа сонгоогүй"

msgid "検索エンジン等のURL"
msgstr "Хайлтын системүүд болон бусад зориулалтын URL-үүд"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Зөвшөөрөл өгөөгүй үед хэрэглэгчдийг чиглүүлдэг хайлтын систем болон түүнтэй төстэй сайтуудын URL-ыг тохируулна"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Алдаа олж засах горим, консолийн анхааруулга мессежүүд"

msgid "右クリックの警告メッセージ"
msgstr "Баруун товчоор сэрэмжлүүлэх мессеж"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDF хэлбэрээр хэвлэх, хадгалахтай холбоотой анхааруулга"

msgid "スクリーンショットの警告メッセージ"
msgstr "Скриншот дээрх анхааруулга мессеж"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Сэжигтэй дэлгэцийн агшингийн зургуудын талаархи анхааруулга"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Бүх текст сонгогдсон үед гарч буй анхааруулга"

msgid "ページ保存の警告メッセージ"
msgstr "Хуудас хадгалахтай холбоотой анхааруулга"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Хуулбарлах эсвэл тайрах үед харуулах мессеж"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML эх кодыг үзэх үед харуулах мессеж"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML-ийг нууж буюу хамгаалах үед эх кодын дээд хэсэгт харуулах мессеж"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML хамгаалалтын явцад нэг удаагийн баталгаажуулалтын токен хүчин төгөлдөр бус бол харуулах мессеж"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Хэрэв күүки эсвэл JavaScript идэвхгүй бол харуулах мессеж"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Үнэндээ энэ нь зөвхөн JavaScript-ийг идэвхгүй болгосон үед л харагддаг."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Зургийг хамгаалсан үед, тэр зураг татагдаж, дээр нь мессеж"

msgid "HTML難読化 (圧縮)"
msgstr "HTML-ийн будлиантуулалт"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Энэ бол стандарт HTML шахалт юм; үүнийг задлах боломжтой вэбсайтууд ч байдаг."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Энэ сонголтыг идэвхжүүлснээр та view-source логыг татаж авч болно."

msgid "HTML保護"
msgstr "HTML хамгаалалт"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Энэ нь зөвхөн хамгийн бага шаардлагатай HTML-ийг гаргадаг — HTML шахалт ашиглаж байсан үеэс ч бага — мөн BODY тагийн доторх агуулгыг огт гаргадаггүй."

msgid "Firefoxに対しては無効です"
msgstr "Энэ нь Firefox-д хамаарахгүй"

msgid "SEOに著しく影響があります"
msgstr "Энэ нь SEO-д ихээхэн нөлөө үзүүлдэг."

msgid "HTMLをJavaScriptで描画"
msgstr "JavaScript ашиглан HTML үүсгэх"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox-ыг тойрон гарахын тулд бид HTML-ийг JavaScript ашиглан гаргадаг"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScript-ийн рендерийг идэвхжүүлэх нь вэбсайтын ачааллын хурдыг ихээхэн удаашруулна."

msgid "画像の保護"
msgstr "Зургийн хамгаалалт"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img таг дуудагдах бүрт зургийг хамгаалах"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "WordPress-д байршуулсан бүх зургийг HTML-ийн бүхэл гаралтын дотор хамгаалах"

msgid "画像をダウンロードから保護します"
msgstr "Зураг татаж авахыг хамгаална"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Зургийн өгөгдлийг хамгаалах үед бид бараг бүх таталтыг зогсоож, цор ганц удаагийн URL үүсгэж, сессэд хадгалагдсан токенуудаар баталгаажуулж, PHP-ээр зургуудыг харуулдаг; ингэснээр бараг бүх зургийн хулгайг үр дүнтэй зогсоодог."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Зургийн өгөгдлийг хамгаалахад кэшлэлт ажиллахгүй тул сайт дараагийн удаа зочлох үед удаан ачаалагдаж, ингэснээр SEO-д нөлөөлдөг."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Зургийн өгөгдлийг хамгаалах нь өгөгдлийн сангийн ачааллыг нэмэгдүүлж болно."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Хэрэв та 'img таг дуудагдах бүрт зургуудыг хамгаалах' гэж сонговол систем img таг үүсэх үед add_filter-ийг ашиглан шүүлтүүр хэрэглэдэг; гэхдээ энэ нь зарим сэдэвтэй зөв ажиллахгүй байж болно."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Хэрэв та 'Бүх HTML гаралтын хүрээнд WordPress-д байршуулсан бүх зургийг хамгаалах' сонголтыг сонговол, плагин нь бараг бүх WordPress үйлдлийг барьж авч, агуулга дахь img таг бүрийг боловсруулна. Зарим сэдэвтэй энэ нь зөв ажиллахгүй байж магадгүйг анхаарна уу."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Анхаарна уу: онцлох зураг гэж тэмдэглэсэн зургууд OGP өгөгдөл болгон хуваалцагдаж, хамгаалагдах боломжгүй. Хэрэв заавал хамгаалах шаардлагатай бол HTML хамгаалалтыг идэвхжүүлэхдээ дэвшилтэт тохиргооноос HEAD шошго гаралтын тохиргоог өөрчилнө үү."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Үйлдлийн системд суурилсан дэлгэцийн агшны функцийг хамгаалж болдоггүй"

msgid "画像URLの保護"
msgstr "Зургийн URL-үүдийг хамгаалах"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Энэ нь зураг хамгаалалттай хамт ашиглагдах ёстой; ганцаараа ямар ч зорилготой биш."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "JavaScript-ээр залхуугаар ачаалдаг тул энэ нь SEO-д нөлөөлдөг"

msgid "画像のウォーターマーク"
msgstr "Зургийн усны тэмдэг"

msgid "右下"
msgstr "баруун доод"

msgid "ランダム位置"
msgstr "Санамсаргүй байрлал"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Зургийн хамгаалалттай хамт ашигласнаар динамик усны тэмдэг нь зохиогчийн эрхийн эзэмшигчийг тодорхой харуулж, үзэгчдэд хяналт тавигдаж байгаа мэт сэтгэгдэл төрүүлж, ингэснээр сэргийлэх үүрэг гүйцэтгэдэг."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Зөвхөн JPG, PNG болон WebP форматуудыг дэмждэг"

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Үүнийг идэвхжүүлснээр серверийн ачаалал нэмэгдэнэ."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "HTML-ийн эх кодоос ASCII урлаг гаргах HTML-ийг будлиантуулах, хамгаалах явцад"

msgid "表示なし"
msgstr "Дэлгэцгүй"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "'view-source' ашиглан HTML эх кодыг үзэх үед анхааруулга заасан ASCII урлагийг харуулна"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Зорилтот үйлдэл гүйцэтгэх үед дэлгэцийн дизайныг харуулах"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Шар өнгийн дэвсгэр дээр хар тексттэй энгийн загвар"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Хар дэвсгэр дээр улаан үсгээр бичсэн аймшгийн хэв маягийн дизайн"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Хар дэвсгэр дээр улаан гэрэлтсэн текст бүхий загвар"

msgid "対象アクションを起こした時のBGM"
msgstr "Зорилтот үйлдэл гүйцэтгэгдэх үед тоглодог фон хөгжим"

msgid "サウンドなし"
msgstr "Дуугүй"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Тулаан ба ялалт - 1 минут 16.3 секунд - 630,056 байт - 64 kbps - Зөвшөөрөл: CC 2.1 эсвэл түүнээс хойш"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Аав богино - 3.8 секунд - 32,364 байт - 64 кбит/с - Лиценз: GPL 2.0 эсвэл түүнээс хойш"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Ояжи Лонг - 23.5 секунд - 195,578 байт - 64 kbps - Лиценз: GPL 2.0 эсвэл түүнээс хойш"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Шопен Этюд Op. 10 №5"

