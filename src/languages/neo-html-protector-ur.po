msgid "設定"
msgstr "ترتیبات"

msgid "IPログリーダー"
msgstr "آئی پی لاگ ریڈر"

msgid "IPアドレスログ"
msgstr "آئی پی ایڈریس لاگ"

msgid "全クリア"
msgstr "تمام سطحیں مکمل کریں"

msgid "IPログが全て削除されました"
msgstr "تمام آئی پی لاگز حذف کر دیے گئے ہیں۔"

msgid "ID"
msgstr "شناخت"

msgid "タイムスタンプ"
msgstr "وقت کی مہر"

msgid "IPアドレス"
msgstr "آئی پی ایڈریس"

msgid "ユーザーエージェント"
msgstr "صارف ایجنٹ"

msgid "イベント"
msgstr "تقریب"

msgid "IPアドレスのデータはありません"
msgstr "اس آئی پی پتے کے لیے کوئی ڈیٹا موجود نہیں ہے۔"

msgid "EU GDPR対応"
msgstr "یورپی یونین کے جی ڈی پی آر کی تعمیل"

msgid "無効"
msgstr "غلط"

msgid "有効"
msgstr "صحیح"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "اگر آپ EU کے اندر ورڈپریس استعمال کر رہے ہیں، یا اگر آپ کی ویب سائٹ EU کے صارفین کو ہدف بنا رہی ہے، تو براہِ کرم اس کو فعال کریں۔"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'تصدیق' کا بٹن 'رضامندی' یا 'عدمِ رضامندی' میں تبدیل ہو جائے گا، اور رویہ تھوڑا سا بدل جائے گا۔"

msgid "同意画面の色"
msgstr "رضامندی کی اسکرین کا رنگ"

msgid "自動"
msgstr "خودکار"

msgid "ライトモード"
msgstr "ہلکا موڈ"

msgid "ダークモード"
msgstr "ڈارک موڈ"

msgid "同意画面表示中の配色を設定します"
msgstr "رضامندی کی اسکرین کے لیے رنگ سکیم مقرر کریں۔"

msgid "同意画面中のコンテンツのぼかし"
msgstr "رضامندی کی اسکرین پر مواد کا دھندلا ہونا"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "رضامندی اسکرین پر دکھائے جانے والے مواد کے لیے دھندلا پن کی سطح مقرر کریں۔"

msgid "同意画面の透過"
msgstr "رضامندی کی اسکرین کی شفافیت"

msgid "透過なし"
msgstr "کوئی شفافیت نہیں"

msgid "同意画面の透過具合を設定します"
msgstr "رضامندی کی اسکرین کی شفافیت مقرر کریں۔"

msgid "お知らせの1行目"
msgstr "اعلان کی پہلی سطر"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "یہ پیغام ہر بار پہلی مرتبہ صفحہ لوڈ ہونے پر دکھایا جاتا ہے۔"

msgid "お知らせの2行目"
msgstr "نوٹس کی دوسری لائن"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "یہ پیغام ہمیشہ صرف پہلے ڈسپلے پر تب ہی ظاہر ہوگا جب EU GDPR نافذ ہو۔"

msgid "お知らせの3行目"
msgstr "نوٹس کی تیسری لائن"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "یہ پرائیویسی پالیسی کے لنک کے دائیں جانب ظاہر ہوگا۔"

msgid "非EU向け確認の文字列"
msgstr "غیر یورپی یونین ممالک کے لیے تصدیقی متن"

msgid "EU GDPR向け同意するの文字列"
msgstr "یورپی یونین کے ڈیٹا پروٹیکشن قانون"

msgid "EU GDPR向け同意しないの文字列"
msgstr "یورپی یونین کے جی ڈی پی آر کے تحت 'رضامندی نہ دیں' کے لیے متن"

msgid "プライバシーポリシーの文字列"
msgstr "رازداری کی پالیسی کا متن"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "براہ کرم پرائیویسی پالیسی کے لیے یو آر ایل یہاں درج کریں۔"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "براہ کرم ذیل کا متن پرائیویسی پالیسی میں شامل کریں۔"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "دھوکہ دہی کی سرگرمی کا پتہ لگانے کے لیے، شناختی معلومات جیسے آئی پی پتے کوکیز اور ڈیٹا بیس میں محفوظ کیے جاتے ہیں۔ محفوظ شدہ ڈیٹا منتظم کی صوابدید پر حذف کر دیا جاتا ہے۔"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "تصاویر کی حفاظت فعال ہونے کی صورت میں ہی تصاویر صحیح طریقے سے پہنچائی جائیں، اس بات کو یقینی بنانے کے لیے ہم آئی پی ایڈریس اور تصویر کے فائل نام پر مشتمل ہیش شدہ ڈیٹا کو ڈیٹا بیس میں 60 منٹ تک محفوظ رکھتے ہیں۔"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "اگر آپ استعمال کی شرائط مرتب کر رہے ہیں تو براہِ کرم یقینی بنائیں کہ آپ اپنی پرائیویسی پالیسی میں ان کا لنک شامل کریں۔"

msgid "利用規約の文字列"
msgstr "استعمال کی شرائط کا متن"

msgid "利用規約のページ"
msgstr "شرائط و ضوابط کا صفحہ"

msgid "ページ選択なし"
msgstr "کوئی صفحہ منتخب نہیں کیا گیا"

msgid "検索エンジン等のURL"
msgstr "سرچ انجنوں وغیرہ کے لیے یو آر ایل"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "ان سرچ انجنز اور مشابہہ سائٹس کے لیے یو آر ایل سیٹ کریں جو رضامندی نہ دینے پر صارفین کو ری ڈائریکٹ کرتی ہیں۔"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "ڈی بگ موڈ، کنسول انتباہی پیغامات"

msgid "右クリックの警告メッセージ"
msgstr "دائیں کلک انتباہی پیغام"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "پی ڈی ایف کے طور پر پرنٹ کرنے اور محفوظ کرنے کے بارے میں انتباہی پیغام"

msgid "スクリーンショットの警告メッセージ"
msgstr "اسکرین شاٹ میں انتباہی پیغام"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "مشتبہ اسکرین شاٹس کے بارے میں انتباہی پیغام"

msgid "テキスト全選択時の警告メッセージ"
msgstr "تمام متن منتخب ہونے پر انتباہی پیغام"

msgid "ページ保存の警告メッセージ"
msgstr "صفحہ محفوظ کرنے کے بارے میں انتباہی پیغام"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "کاپی یا کاٹتے وقت دکھایا جانے والا پیغام"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML ماخذ دیکھتے وقت دکھانے والا پیغام"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "جب HTML کو مبہم یا محفوظ کیا جائے تو ماخذ کوڈ کے اوپر دکھائے جانے والا پیغام"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "ایچ ٹی ایم ایل تحفظ کے دوران اگر یک بار استعمال ہونے والا توثیقی ٹوکن غیر معتبر ہو تو دکھانے والا پیغام"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "اگر کوکیز یا جاوا اسکرپٹ غیر فعال ہوں تو دکھانے والا پیغام"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "درحقیقت، یہ صرف اس وقت دکھائی دیتا ہے جب جاوا اسکرپٹ غیر فعال ہو۔"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "جب کوئی تصویر محفوظ کی جاتی ہے تو وہ ڈاؤن لوڈ ہو جاتی ہے اور اس پر ایک پیغام ظاہر ہوتا ہے"

msgid "HTML難読化 (圧縮)"
msgstr "ایچ ٹی ایم ایل ابہام کاری"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "یہ معیاری HTML کمپریشن ہے؛ ایسی ویب سائٹس بھی ہیں جو اسے ڈی کوڈ کر سکتی ہیں۔"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "اس آپشن کو فعال کرنے سے آپ ویو-سورس لاگ حاصل کر سکتے ہیں۔"

msgid "HTML保護"
msgstr "ایچ ٹی ایم ایل تحفظ"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "یہ صرف HTML کا انتہائی کم از کم حصہ ہی آؤٹ پٹ کرتا ہے—HTML کمپریشن استعمال کرنے کی صورت میں بھی اس سے کم—اور BODY ٹیگ کے اندر موجود مواد بالکل بھی آؤٹ پٹ نہیں ہوتا۔"

msgid "Firefoxに対しては無効です"
msgstr "یہ فائر فاکس پر لاگو نہیں ہوتا۔"

msgid "SEOに著しく影響があります"
msgstr "اس کا SEO پر نمایاں اثر پڑتا ہے۔"

msgid "HTMLをJavaScriptで描画"
msgstr "جاوا اسکرپٹ کے ذریعے ایچ ٹی ایم ایل پیش کرنا"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "فائر فاکس کے متبادل کے طور پر، ہم جاوا اسکرپٹ استعمال کرتے ہوئے ایچ ٹی ایم ایل کو رینڈر کرتے ہیں۔"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "جاوا اسکرپٹ رینڈرنگ کو فعال کرنے سے ویب سائٹ کی لوڈنگ کی رفتار میں نمایاں سستی آئے گی۔"

msgid "画像の保護"
msgstr "تصویر کی حفاظت"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "ہر بار جب img ٹیگ کال کیا جائے تو تصویر کا تحفظ کریں۔"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "پورے HTML آؤٹ پٹ میں ورڈپریس پر اپلوڈ کی گئی تمام تصاویر کا تحفظ کریں۔"

msgid "画像をダウンロードから保護します"
msgstr "تصاویر کو ڈاؤن لوڈ ہونے سے محفوظ رکھتا ہے۔"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "جب تصویر کا ڈیٹا محفوظ ہوتا ہے، تو ہم تقریباً تمام ڈاؤن لوڈز کو روک دیتے ہیں، منفرد یک مرتبہ استعمال ہونے والی یو آر ایلز جاری کرتے ہیں، سیشن میں محفوظ ٹوکنز کے ذریعے تصدیق کرتے ہیں، اور تصاویر کو PHP کے ذریعے دکھاتے ہیں؛ اس سے تصویر چوری کے تقریباً تمام واقعات مؤثر طریقے سے روکے جاتے ہیں۔"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "جب تصویر کا ڈیٹا محفوظ ہوتا ہے تو کیشنگ کام نہیں کرتی، جس کا مطلب ہے کہ سائٹ اگلی بار وزٹ کرنے پر زیادہ سست لوڈ ہوگی، اور اس طرح SEO متاثر ہوتا ہے۔"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "تصویری ڈیٹا کی حفاظت کرنے سے ڈیٹا بیس پر بوجھ بڑھ سکتا ہے۔"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "اگر آپ 'جب بھی img ٹیگ کال کیا جائے تو تصاویر کو محفوظ کریں' کا انتخاب کرتے ہیں تو سسٹم img ٹیگ بناتے وقت فلٹرنگ کے لیے add_filter استعمال کرتا ہے؛ تاہم، یہ بعض تھیمز کے ساتھ صحیح طریقے سے کام نہیں کر سکتا۔"

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "اگر آپ 'پورے HTML آؤٹ پٹ میں WordPress پر اپلوڈ کی گئی تمام تصاویر کا تحفظ کریں' کا انتخاب کرتے ہیں تو پلگ ان تقریباً تمام WordPress آپریشنز کو ریکارڈ کرے گا اور مواد میں موجود ہر img ٹیگ پر عمل کرے گا۔ براہ کرم نوٹ کریں کہ یہ کچھ تھیمز کے ساتھ صحیح طریقے سے کام نہیں کر سکتا۔"

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "براہ کرم نوٹ کریں کہ فیچرڈ امیجز کے طور پر منتخب کی گئی تصاویر OGP ڈیٹا کے طور پر شیئر کی جائیں گی اور محفوظ نہیں کی جا سکتیں۔ اگر آپ کو انہیں لازماً محفوظ کرنا ہے تو HTML پروٹیکشن فعال کرتے وقت ایڈوانسڈ سیٹنگز میں HEAD ٹیگ آؤٹ پٹ کی سیٹنگ تبدیل کریں۔"

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "آپریٹنگ سسٹم میں موجود اسکرین شاٹ فنکشن کو محفوظ نہیں کیا جا سکتا۔"

msgid "画像URLの保護"
msgstr "تصویری یو آر ایلوں کا تحفظ"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "اسے تصویر کی حفاظت کے ساتھ استعمال کرنا چاہیے؛ اکیلے یہ کسی کام کا نہیں۔"

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "چونکہ اسے جاوا اسکرپٹ کے ذریعے سست طریقے سے لوڈ کیا جاتا ہے، اس سے SEO متاثر ہوتا ہے۔"

msgid "画像のウォーターマーク"
msgstr "تصویر کا واٹر مارک"

msgid "右下"
msgstr "نیچے دائیں"

msgid "ランダム位置"
msgstr "تصادفی پوزیشن"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "تصویر کی حفاظت کے ساتھ استعمال کیے جانے پر، متحرک واٹر مارکس واضح طور پر کاپی رائٹ کی ملکیت کی نشاندہی کرتے ہیں اور ناظرین کو یہ تاثر دیتے ہیں کہ ان کی نگرانی کی جا رہی ہے، یوں یہ روک تھام کا باعث بنتے ہیں۔"

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "صرف JPG، PNG اور WebP فارمیٹس کی حمایت کی جاتی ہے۔"

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "اس کو فعال کرنے سے سرور پر بوجھ بڑھ جائے گا۔"

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "HTML کے ماخذ کوڈ کے دوران ASCII آرٹ پیدا کرنا، HTML کو مبہم بنانے اور تحفظ کے دوران"

msgid "表示なし"
msgstr "کوئی ڈسپلے نہیں"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
