msgid "設定"
msgstr "सेटिंग्स"

msgid "IPログリーダー"
msgstr "आईपी लॉग रीडर"

msgid "IPアドレスログ"
msgstr "आईपी पता लॉग"

msgid "全クリア"
msgstr "सभी स्तर पूरे करें"

msgid "IPログが全て削除されました"
msgstr "सभी आईपी लॉग हटा दिए गए हैं।"

msgid "ID"
msgstr "आईडी"

msgid "タイムスタンプ"
msgstr "समय-मुद्रण"

msgid "IPアドレス"
msgstr "आईपी पता"

msgid "ユーザーエージェント"
msgstr "उपयोगकर्ता एजेंट"

msgid "イベント"
msgstr "कार्यक्रम"

msgid "IPアドレスのデータはありません"
msgstr "आईपी पते के लिए कोई डेटा नहीं है।"

msgid "EU GDPR対応"
msgstr "ईयू जीडीपीआर का अनुपालन"

msgid "無効"
msgstr "अमान्य"

msgid "有効"
msgstr "मान्य"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "यदि आप EU के भीतर वर्डप्रेस का उपयोग कर रहे हैं, या यदि आपकी वेबसाइट EU के भीतर के उपयोगकर्ताओं को लक्षित करती है, तो कृपया सुनिश्चित करें कि यह सक्षम है।"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' बटन 'Agree' या 'Disagree' में बदल जाएगा, और व्यवहार थोड़ा बदल जाएगा।"

msgid "同意画面の色"
msgstr "सहमति स्क्रीन का रंग"

msgid "自動"
msgstr "स्वचालित"

msgid "ライトモード"
msgstr "हल्का मोड"

msgid "ダークモード"
msgstr "डार्क मोड"

msgid "同意画面表示中の配色を設定します"
msgstr "सहमति स्क्रीन के लिए रंग योजना सेट करें"

msgid "同意画面中のコンテンツのぼかし"
msgstr "सहमति स्क्रीन पर सामग्री का धुंधलापन"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "सहमति स्क्रीन पर प्रदर्शित सामग्री के लिए धुंधलापन का स्तर निर्धारित करें।"

msgid "同意画面の透過"
msgstr "सहमति स्क्रीन की पारदर्शिता"

msgid "透過なし"
msgstr "कोई पारदर्शिता नहीं"

msgid "同意画面の透過具合を設定します"
msgstr "सहमति स्क्रीन की पारदर्शिता सेट करें"

msgid "お知らせの1行目"
msgstr "घोषणा की पहली पंक्ति"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "यह संदेश हमेशा पहली बार पेज लोड होने पर प्रदर्शित होता है।"

msgid "お知らせの2行目"
msgstr "सूचना की दूसरी पंक्ति"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "यह संदेश केवल तब पहली डिस्प्ले पर हमेशा दिखाई देगा जब EU GDPR लागू होगा।"

msgid "お知らせの3行目"
msgstr "सूचना की तीसरी पंक्ति"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "यह गोपनीयता नीति के लिंक के दाईं ओर दिखाई देगा।"

msgid "非EU向け確認の文字列"
msgstr "गैर-ईयू देशों के लिए पुष्टि पाठ"

msgid "EU GDPR向け同意するの文字列"
msgstr "ईयू जीडीपीआर के लिए सहमति पाठ"

msgid "EU GDPR向け同意しないの文字列"
msgstr "ईयू जीडीपीआर के तहत 'सहमति न दें' के लिए पाठ"

msgid "プライバシーポリシーの文字列"
msgstr "गोपनीयता नीति का पाठ"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "कृपया यहां गोपनीयता नीति के लिए URL सेट करें।"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "कृपया निम्नलिखित को गोपनीयता नीति में जोड़ें।"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "धोखाधड़ी की गतिविधि का पता लगाने के लिए, आईपी पते जैसे पहचानकर्ता कुकीज़ और डेटाबेस में संग्रहीत किए जाते हैं। संग्रहीत डेटा प्रशासक के विवेकानुसार हटा दिया जाता है।"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "यह सुनिश्चित करने के लिए कि छवियाँ केवल तभी सही ढंग से वितरित हों जब छवि सुरक्षा सक्षम हो, हम डेटाबेस में आईपी पता और छवि फ़ाइल नाम सहित हैश किए गए डेटा को 60 मिनट तक संग्रहीत करते हैं।"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "यदि आप उपयोग की शर्तें स्थापित कर रहे हैं, तो कृपया सुनिश्चित करें कि आप अपनी गोपनीयता नीति में उनका लिंक शामिल करें।"

msgid "利用規約の文字列"
msgstr "उपयोग की शर्तों का पाठ"

msgid "利用規約のページ"
msgstr "नियम और शर्तें पृष्ठ"

msgid "ページ選択なし"
msgstr "कोई पृष्ठ चयनित नहीं है"

msgid "検索エンジン等のURL"
msgstr "खोज इंजनों आदि के लिए यूआरएल।"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "उन सर्च इंजनों और समान साइटों के लिए URL सेट करें जो सहमति न दिए जाने पर उपयोगकर्ताओं को रीडायरेक्ट करती हैं।"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "डिबग मोड, कंसोल चेतावनी संदेश"

msgid "右クリックの警告メッセージ"
msgstr "दाहिने-क्लिक चेतावनी संदेश"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDF के रूप में प्रिंट और सहेजने संबंधी चेतावनी संदेश"

msgid "スクリーンショットの警告メッセージ"
msgstr "स्क्रीनशॉट में चेतावनी संदेश"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "संदिग्ध स्क्रीनशॉट्स के संबंध में चेतावनी संदेश"

msgid "テキスト全選択時の警告メッセージ"
msgstr "सभी पाठ चयनित होने पर चेतावनी संदेश"

msgid "ページ保存の警告メッセージ"
msgstr "पृष्ठ सहेजने संबंधी चेतावनी संदेश"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "कॉपी या कट करते समय प्रदर्शित संदेश"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML स्रोत देखते समय प्रदर्शित करने के लिए संदेश"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML को अस्पष्ट या सुरक्षित करते समय स्रोत कोड के शीर्ष पर प्रदर्शित होने वाला संदेश"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML सुरक्षा के दौरान यदि एक-बारगी प्रमाणीकरण टोकन अमान्य हो तो प्रदर्शित करने के लिए संदेश"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "यदि कुकीज़ या जावास्क्रिप्ट अक्षम हैं तो प्रदर्शित करने के लिए संदेश"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "वास्तव में, यह केवल तब प्रदर्शित होता है जब जावास्क्रिप्ट अक्षम हो।"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "जब कोई छवि संरक्षित होती है, तो वह डाउनलोड हो जाती है, और उस छवि पर एक संदेश प्रदर्शित होता है"

msgid "HTML難読化 (圧縮)"
msgstr "HTML अस्पष्टीकरण"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "यह मानक HTML संपीड़न है; ऐसी वेबसाइटें भी हैं जो इसे डिकोड कर सकती हैं।"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "इस विकल्प को सक्षम करने से आप व्यू-सोर्स लॉग प्राप्त कर सकते हैं।"

msgid "HTML保護"
msgstr "HTML सुरक्षा"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "यह केवल न्यूनतम HTML ही आउटपुट करता है—HTML संपीड़न का उपयोग करने की तुलना में भी कम—और BODY टैग के भीतर की सामग्री बिल्कुल भी आउटपुट नहीं होती।"

msgid "Firefoxに対しては無効です"
msgstr "यह Firefox पर लागू नहीं होता।"

msgid "SEOに著しく影響があります"
msgstr "इसका SEO पर महत्वपूर्ण प्रभाव पड़ता है।"

msgid "HTMLをJavaScriptで描画"
msgstr "जावास्क्रिप्ट का उपयोग करके एचटीएमएल रेंडर करना"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox के काम चलाने के लिए, हम जावास्क्रिप्ट का उपयोग करके HTML को रेंडर करते हैं।"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "जावास्क्रिप्ट रेंडरिंग सक्षम करने से वेबसाइट की लोडिंग गति में काफी कमी आएगी।"

msgid "画像の保護"
msgstr "छवि संरक्षण"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "जब भी img टैग को कॉल किया जाता है, तो छवि की सुरक्षा करें।"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "पूरे HTML आउटपुट में वर्डप्रेस पर अपलोड की गई सभी छवियों की सुरक्षा करें।"

msgid "画像をダウンロードから保護します"
msgstr "छवियों को डाउनलोड होने से बचाता है"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "जब इमेज डेटा सुरक्षित होता है, तो हम लगभग सभी डाउनलोड को रोकते हैं, अद्वितीय एक-बार के URL जारी करते हैं, सत्र में संग्रहीत टोकन का उपयोग करके प्रमाणीकरण करते हैं, और PHP के माध्यम से छवियाँ प्रदर्शित करते हैं; यह प्रभावी रूप से लगभग सभी छवि चोरी को रोकता है।"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "जब इमेज डेटा सुरक्षित होता है, तो कैशिंग काम नहीं करती, जिसका मतलब है कि साइट अगली बार विज़िट करने पर धीमी गति से लोड होगी, जिससे SEO प्रभावित होता है।"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "छवि डेटा की सुरक्षा करने से डेटाबेस पर लोड बढ़ सकता है।"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "यदि आप 'जब भी img टैग कॉल किया जाए तो छवियों की सुरक्षा करें' चुनते हैं, तो सिस्टम img टैग उत्पन्न होने पर फ़िल्टरिंग लागू करने के लिए add_filter का उपयोग करता है; हालांकि, यह कुछ थीमों के साथ ठीक से काम नहीं कर सकता है।"

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "यदि आप 'पूरे HTML आउटपुट में WordPress पर अपलोड की गई सभी छवियों की सुरक्षा करें' चुनते हैं, तो यह प्लगइन लगभग सभी WordPress क्रियाओं को कैप्चर करेगा और सामग्री में प्रत्येक img टैग को संसाधित करेगा। कृपया ध्यान दें कि यह कुछ थीम के साथ ठीक से काम नहीं कर सकता है।"

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "कृपया ध्यान दें कि फीचर्ड इमेज के रूप में चिह्नित छवियाँ OGP डेटा के रूप में साझा की जाएँगी और सुरक्षित नहीं की जा सकतीं। यदि आपको इन्हें अवश्य सुरक्षित करना है, तो HTML सुरक्षा सक्षम करते समय उन्नत सेटिंग्स में HEAD टैग आउटपुट की सेटिंग बदलें।"

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "ऑपरेटिंग सिस्टम में अंतर्निहित स्क्रीनशॉट फ़ंक्शन को सुरक्षित नहीं किया जा सकता।"

msgid "画像URLの保護"
msgstr "छवि यूआरएल की सुरक्षा"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "इसे छवि सुरक्षा के साथ संयोजन में उपयोग किया जाना चाहिए; अपने आप में इसका कोई उद्देश्य नहीं है।"

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "चूंकि इसे जावास्क्रिप्ट के माध्यम से लोड किया जाता है, यह एसईओ को प्रभावित करता है।"

msgid "画像のウォーターマーク"
msgstr "छवि वॉटरमार्क"

msgid "右下"
msgstr "नीचे दाएँ"

msgid "ランダム位置"
msgstr "यादृच्छिक स्थिति"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "छवि संरक्षण के साथ संयोजन में उपयोग किए जाने पर, गतिशील वॉटरमार्क स्पष्ट रूप से कॉपीराइट स्वामित्व को इंगित करते हैं और दर्शकों को यह आभास देते हैं कि उनकी निगरानी की जा रही है, जिससे यह एक निवारक के रूप में कार्य करता है।"

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "केवल JPG, PNG और WebP प्रारूप समर्थित हैं।"

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "इसे सक्षम करने से सर्वर पर लोड बढ़ जाएगा।"

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "अस्पष्टीकरण और सुरक्षा के दौरान HTML स्रोत कोड से ASCII कला उत्पन्न करना"

msgid "表示なし"
msgstr "कोई प्रदर्शन नहीं"

