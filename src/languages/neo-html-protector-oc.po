msgid "設定"
msgstr "Paramètres"

msgid "IPログリーダー"
msgstr "Lector de registres IP"

msgid "IPアドレスログ"
msgstr "Jornal de las adreças IP"

msgid "全クリア"
msgstr "Completar totes los nivèls"

msgid "IPログが全て削除されました"
msgstr "Totes los registres IP an estat suprimits."

msgid "ID"
msgstr "Identificant"

msgid "タイムスタンプ"
msgstr "Marca de temps"

msgid "IPアドレス"
msgstr "Adreça IP"

msgid "ユーザーエージェント"
msgstr "Agent d'utilizaire"

msgid "イベント"
msgstr "Eveniment"

msgid "IPアドレスのデータはありません"
msgstr "I a pas de donadas per aquesta adreça IP."

msgid "EU GDPR対応"
msgstr "Conformitat amb lo RGPD de l'UE"

msgid "無効"
msgstr "Invalid"

msgid "有効"
msgstr "Valid"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Se utilizatz WordPress dins l'UE, o se vòstre sit web es destinat a d'utilizaires dins l'UE, asseguratz-vos que siá activat."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Lo boton «Confirmar» se transformarà en «Acordar» o «Discordar», e lo comportament cambiarà un pauc."

msgid "同意画面の色"
msgstr "Color de l'ecran de consentiment"

msgid "自動"
msgstr "Automatic"

msgid "ライトモード"
msgstr "Mòde clar"

msgid "ダークモード"
msgstr "Mòde escur"

msgid "同意画面表示中の配色を設定します"
msgstr "Establir l'esquema de colors per l'ecran de consentiment."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Floutatge del contengut sus l'ecran de consentiment"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Reglar lo nivèl de flou pel contengut afichat sus l'ecran de consentiment"

msgid "同意画面の透過"
msgstr "Transparéncia de l'ecran de consentiment"

msgid "透過なし"
msgstr "Pas de transparéncia"

msgid "同意画面の透過具合を設定します"
msgstr "Establir la transparéncia de l'ecran de consentiment"

msgid "お知らせの1行目"
msgstr "Primièra linha de l'anóncia"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Aqueste messatge s'aficha totjorn la primièra vegada que la pagina se carga."

msgid "お知らせの2行目"
msgstr "La segonda linha de l'avís"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Aqueste messatge apareisserà totjorn sul primièr afichatge solament quand lo RGPD de l'UE serà en vigor."

msgid "お知らせの3行目"
msgstr "La tresena linha de l'avís"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Aparirà a la drecha del ligam cap a la politica de privacitat."

msgid "非EU向け確認の文字列"
msgstr "Tèxte de confirmacion per los païses non-UE"

msgid "EU GDPR向け同意するの文字列"
msgstr "Tèxte de consentiment per lo RGPD de l'UE"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Tèxte per «Non consentir» jos lo RGPD de l'UE"

msgid "プライバシーポリシーの文字列"
msgstr "Tèxte de la politica de confidencialitat"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Mercés de metre l'URL de la politica de confidencialitat aicí."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Mercés d'apondre çò que seguís a la Politica de Confidencialitat."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Per detectar d'activitats fraudolentas, d'identificadors coma las adreças IP son emmagazinats dins de cookies e dins la basa de donadas. Las donadas emmagazinadas son suprimidas a la discrecion de l'administrator."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Per assegurar que las imatges sián liuradas corrèctament solament quand la proteccion de las imatges es activada, emmagazinam dins la basa de donadas, pendent fins a 60 minutas, de donadas hashadas que comprenon l'adreça IP e lo nom de fichièr de l'imatge."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Se establissètz de Condicions d'Utilizacion, asseguratz-vos d'inclure un ligam cap a elas dins vòstra Politica de Confidencialitat."

msgid "利用規約の文字列"
msgstr "Tèxte de las Condicions d'Utilizacion"

msgid "利用規約のページ"
msgstr "Pagina dels tèrmes e condicions"

msgid "ページ選択なし"
msgstr "Cap de pagina seleccionada"

msgid "検索エンジン等のURL"
msgstr "URLs pels motors de recèrca, etc."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Establir l'URL pels motors de recèrca e los sites similars que redirigisson los utilizaires quand lo consentiment es pas donat."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mòde de depuracion, messatges d'avertiment de la consola"

msgid "右クリックの警告メッセージ"
msgstr "Messatge d'avertiment amb clic drech"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Messatge d'avertiment concernent l'impression e l'enregistrament en PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Messatge d'avertiment dins la captura d'ecran"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Messatge d'avertiment concernent de capturas d'ecran presumidas"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Messatge d'avertiment quand tot lo tèxte es seleccionat"

msgid "ページ保存の警告メッセージ"
msgstr "Messatge d'avertiment concernent l'enregistrament de la pagina"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Messatge afichat quand se copia o se talha"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Messatge d'afichar quand se consulta lo còdi font HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Messatge d'afichar en naut del còdi font quand s'obfusca o se protegís l'HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Messatge d'afichar se lo jeton d'autentificacion d'un sol usatge es invàlid pendent la proteccion HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Messatge d'afichar se los cookies o lo JavaScript son desactivats"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "De fach, aquò s'aficha solament quand JavaScript es desactivat."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Quand una imatge es protegida, se telecarga e un messatge s'aficha sus aquela imatge"

msgid "HTML難読化 (圧縮)"
msgstr "Oblicacion"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Aquò es una compressió estandard d'HTML; i a tanben de sites web que la pòdon decodar."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Activant aquesta opcion, podètz recuperar lo jornal de la vista de la font."

msgid "HTML保護"
msgstr "Proteccion HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Genera encara mens d'HTML que l'ajustament de compressió HTML, çò que vòl dire que lo contengut dins l'etiqueta BODY serà pas generat del tot."

msgid "Firefoxに対しては無効です"
msgstr "Aquò s'aplica pas a Firefox."

msgid "SEOに著しく影響があります"
msgstr "Aquò a un impacte significatiu sus lo SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Generacion d'HTML amb JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Per contornar Firefox, rendèm l'HTML amb JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Activar lo rendut JavaScript ralentirà significativament la velocitat de cargament del sit web."

msgid "画像の保護"
msgstr "Proteccion de l'imatge"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Protegi l'imatge cada còp que l'etiqueta img es apelada."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Protegir totas las imatges telecargadas sus WordPress dins tot lo contengut HTML generat."

msgid "画像をダウンロードから保護します"
msgstr "Proteja las imatges contra lo telecargament"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Quand las donadas d'imatge son protegidas, empacham gaireben totas las telecargas, generam d'URLs unicas d'un sol usatge, nos autenticam amb de tokens emmagazinats dins la session e aficham las imatges via PHP ; aquò empacha eficaçament gaireben tot lo robament d'imatge."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Quand las donadas d'imatge son protegidas, lo cache fonciona pas, çò que vòl dire que lo site se cargarà mai lentament a las visitas seguentas, afectant aital lo SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Protegir las donadas d'imatge pòt aumentar la carga sus la basa de donadas."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Se seleccionatz «Protegi las imatges cada còp qu'un etiqueta img es apelada», lo sistèma utiliza add_filter per aplicar lo filtratge quand l'etiqueta img es generada ; çaquelà, aquò pòt pas foncionar corrèctament amb qualques tèmas."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Se seleccionatz «Protegi totas las imatges telecargadas sus WordPress dins tot lo contengut HTML», lo plugin captarà gaireben totas las operacions de WordPress e tractarà cada etiqueta img dins lo contengut. Notatz que aquò pòt pas foncionar corrèctament amb qualques tèmas."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Mercés de notar que las imatges designadas coma imatges destacadas seràn partejadas coma donadas OGP e non se pòdon protegir. Se cal absolutament las protegir, mercés de cambiar l'ajustament de la sortida de l'etiqueta HEAD dins los paramètres avançats quand activatz la proteccion HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "La foncion de captura d'imatge inclusa coma estandard dins lo sistèma operatiu pòt pas èsser protegida."

msgid "画像URLの保護"
msgstr "Protegir los URL d'imatge"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Cal utilizar aquò en conjoncion amb la proteccion de las imatges ; per se sol, servís a pas res."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Coma es cargat via JavaScript, aquò afècta lo SEO."

msgid "画像のウォーターマーク"
msgstr "Filigrana d'imatge"

msgid "右下"
msgstr "En bas a drecha"

msgid "ランダム位置"
msgstr "Posicion aleatòria"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Utilizadas en conjoncion amb la proteccion d'imatges, las filigranas dinamicas indican clarament la proprietat dels dreches d'autor e donan als espectators l'impression d'èsser susvelhats, agissent atal coma un dissuasiu."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Solament los formats JPG, PNG e WebP son suportats."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Activar aquò aumentarà la carga del servidor."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Generar d'art ASCII a partir del còdi font HTML pendent l'obfusquacion e la proteccion"

msgid "表示なし"
msgstr "Cap d'afichatge"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Aficha d'art ASCII qu'indica un avertiment quand se consulta lo còdi font de l'HTML amb 'view-source'."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Afichar lo dessenh quand l'accion visada es realizada."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Un dessenh de basa amb tèxte negre sus un fons jauna."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Un dessenh d'estil d'orror amb de tèxt roge sus un fons negre."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Un dessenh amb un tèxte roge luminescent sus un fons negre"

msgid "対象アクションを起こした時のBGM"
msgstr "Musica de fons que sona quand l'accion ciblada es realizada"

msgid "サウンドなし"
msgstr "Cap de son"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Batèsta e Victòria - 1 minuta 16,3 segondas - 630 056 octets - 64 kbps - Licéncia: CC 2.1 o mai recenta"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Paire Short - 3,8 segondas - 32 364 octets - 64 kbps - Licéncia: GPL 2.0 o mai novèla"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23,5 segondas - 195 578 octets - 64 kbps - Licéncia: GPL 2.0 o mai recenta"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin Étude Op. 10 n° 5"

msgid "ショパン エチュード Op.10-12 革命 打ち込み版 高速版 - 1分57.6秒 - 724,457bytes - 48kbps -  ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin Estúdio Op. 10 n° 12 «Revolucion» – Version generada per ordinador, a granda velocitat – 1 minuta 57,6 segondas – 724 457 octets – 48 kbps – Licéncia: CC BY-ND 4.0 o mai novèla"

msgid "ショパン スケルツォ 変ロ短調 Op2 打ち込み版 高速短縮版 - 1分48.0秒 - 665,369bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin: Scherzo en si bemòl menor, Op. 2 – Version generada per ordinator, version abreujada a granda velocitat – 1 minuta 48,0 segondas – 665 369 octets – 48 kbps – Licéncia: CC BY-ND 4.0 o mai novèla"

msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Lista: Estúd d'Execucion Transcendent N° 4, «Mazeppa» – version generada per ordinador, version abreujada a granda velocitat – 1 minuta 51,6 segondas – 687 586 octets – 48 kbps – Licéncia: CC BY-ND 4.0 o mai novèla"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfara – 22,3 segondas – 183 926 octets – 64 kbps – Licéncia: Domeni public"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Fanfara d'estil retro – 2,2 segondas – 10 536 octets – 32 kbps – Licéncia: Domeni public"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Introduccion d'estil retro – 42,1 segondas – 179 138 octets – 32 kbps – Licéncia: Domeni public"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Avertiment per ChatGPT - 3,8 segondas - 109 700 octets - 256 kbps - Licéncia: Domeni public"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Un son d'urgéncia nauta que sembla una alèrta de deteccion de maliciel – Partida 1 per ChatGPT – 3,3 segondas – 102 850 octets – 256 kbps – Licéncia: Domeni public"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Un son d'urgéncia nauta coma una alèrta de deteccion de maliciel, Partida 2 per ChatGPT - 3,3 segondas - 103 122 octets - 256 kbps - Licéncia: Domeni public"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Son d'estil IRM per ChatGPT – 1 minuta 14,9 segondas – 3 340 392 octets – 320 kbps – Licéncia: Domeni public"

msgid "警告表示中のBGMを選択します"
msgstr "Seleccionatz la musica de fons que se sonarà pendent un avertiment."

msgid "びっくりするような雰囲気を作ります"
msgstr "Crea una atmosfera susprenenta"

msgid "Firefoxでは音声ブロックされます"
msgstr "L'àudio es blocat dins Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Un bip quand l'accion especificada es realizada"

msgid "有効 音量小さ目"
msgstr "Encès, volum bas"

msgid "有効 音量大き目"
msgstr "Actiu, lo volum es a fòrt"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Un bip sonarà per totes los eveniments del clavièr e de la mirga mentre qu'un avís es afichat."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Crea l'impression que l'aparelh s'es embalat mentre que l'avís es afichat."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Amagar lo cursor del ratolín quand una accion especifica es realizada"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Amaga lo cursor de la ratèla dins la zòna del navegador mentre qu'un avís es afichat."

msgid "デバッグモード"
msgstr "Mòde de depanatge"

msgid "妨害＋記録のみ"
msgstr "Interferéncia + Discografias solament"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Interferéncia + Enregistrament + Afichatge + Redireccion"

msgid "メニューからは操作できてしまいます"
msgstr "Podètz encara i accedir a travèrs del menú."

msgid "Firefoxにおけるデバッグモード"
msgstr "Mòde de depuracion dins Firefox"

msgid "ブラウザーコンソール"
msgstr "Console del navegador"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "En efècte, podètz l'operar en mòde de depanatge."

msgid "HTMLソース表示"
msgstr "Veire lo còdi font HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Podètz efectuar l'operacion simplament en picant una adreça URL que comença per 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Podètz protegir vòstre contengut en combinant aquò amb la proteccion HTML."

msgid "印刷"
msgstr "Imprimir"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Malgrat qu'empacha l'impression, pòt foncionar malament dins cèrts navigadors."

msgid "スクリーンショット"
msgstr "Captura d'ecran"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Segon lo sistèma d'explotacion, lo navegador o lo metòde utilizat, pòt èsser que siá pas possible de blocar aquò, o que siá pas detectat."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Captura d'ecran presumida quand la fenèstra passa en segon plan"

msgid "あわせて、スクリーンショット以外の機能（タブ切り替え・ウィンドウ切り替え）にも反応してしまいます。"
