msgid "設定"
msgstr "ਸੈਟਿੰਗਾਂ"

msgid "IPログリーダー"
msgstr "ਆਈਪੀ ਲੌਗ ਰੀਡਰ"

msgid "IPアドレスログ"
msgstr "ਆਈਪੀ ਪਤਾ ਲੌਗ"

msgid "全クリア"
msgstr "ਸਾਰੇ ਪੱਧਰ ਪੂਰੇ ਕਰੋ"

msgid "IPログが全て削除されました"
msgstr "ਸਾਰੇ IP ਲੌਗ ਮਿਟਾ ਦਿੱਤੇ ਗਏ ਹਨ।"

msgid "ID"
msgstr "ਪਛਾਣ"

msgid "タイムスタンプ"
msgstr "ਸਮਾਂ-ਚਿੰਨ੍ਹ"

msgid "IPアドレス"
msgstr "ਆਈਪੀ ਪਤਾ"

msgid "ユーザーエージェント"
msgstr "ਉਪਭੋਗਤਾ ਏਜੰਟ"

msgid "イベント"
msgstr "ਸਮਾਗਮ"

msgid "IPアドレスのデータはありません"
msgstr "ਇਸ IP ਪਤੇ ਲਈ ਕੋਈ ਡੇਟਾ ਨਹੀਂ ਹੈ।"

msgid "EU GDPR対応"
msgstr "ਈਯੂ ਜੀਡੀਪੀਆਰ ਦੀ ਪਾਲਣਾ"

msgid "無効"
msgstr "ਅਵੈਧ"

msgid "有効"
msgstr "ਮਾਨਯੋਗ"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "ਜੇ ਤੁਸੀਂ EU ਵਿੱਚ WordPress ਵਰਤ ਰਹੇ ਹੋ, ਜਾਂ ਜੇ ਤੁਹਾਡੀ ਵੈਬਸਾਈਟ EU ਦੇ ਉਪਭੋਗਤਾਵਾਂ ਨੂੰ ਨਿਸ਼ਾਨਾ ਬਣਾਉਂਦੀ ਹੈ, ਤਾਂ ਕਿਰਪਾ ਕਰਕੇ ਇਹ ਯਕੀਨੀ ਬਣਾਓ ਕਿ ਇਹ ਚਾਲੂ ਹੈ।"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' ਬਟਨ 'Agree' ਜਾਂ 'Disagree' ਵਿੱਚ ਬਦਲ ਜਾਵੇਗਾ, ਅਤੇ ਵਿਹਾਰ ਥੋੜ੍ਹਾ ਬਦਲ ਜਾਵੇਗਾ।"

msgid "同意画面の色"
msgstr "ਸਹਿਮਤੀ ਸਕ੍ਰੀਨ ਦਾ ਰੰਗ"

msgid "自動"
msgstr "ਆਟੋਮੈਟਿਕ"

msgid "ライトモード"
msgstr "ਹਲਕਾ ਮੋਡ"

msgid "ダークモード"
msgstr "ਗੂੜ੍ਹਾ ਮੋਡ"

msgid "同意画面表示中の配色を設定します"
msgstr "ਸਹਿਮਤੀ ਸਕ੍ਰੀਨ ਲਈ ਰੰਗ ਸਕੀਮ ਸੈੱਟ ਕਰੋ"

msgid "同意画面中のコンテンツのぼかし"
msgstr "ਸਹਿਮਤੀ ਸਕ੍ਰੀਨ 'ਤੇ ਸਮੱਗਰੀ ਨੂੰ ਧੁੰਦਲਾ ਕਰਨਾ"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "ਸਹਿਮਤੀ ਸਕ੍ਰੀਨ 'ਤੇ ਦਿਖਾਏ ਗਏ ਸਮੱਗਰੀ ਲਈ ਧੁੰਦਲਾਪਣ ਦਾ ਪੱਧਰ ਸੈੱਟ ਕਰੋ।"

msgid "同意画面の透過"
msgstr "ਸਹਿਮਤੀ ਸਕ੍ਰੀਨ ਦੀ ਪਾਰਦਰਸ਼ਤਾ"

msgid "透過なし"
msgstr "ਕੋਈ ਪਾਰਦਰਸ਼ਤਾ ਨਹੀਂ"

msgid "同意画面の透過具合を設定します"
msgstr "ਸਹਿਮਤੀ ਸਕ੍ਰੀਨ ਦੀ ਪਾਰਦਰਸ਼ਤਾ ਸੈੱਟ ਕਰੋ"

msgid "お知らせの1行目"
msgstr "ਘੋਸ਼ਣਾ ਦੀ ਪਹਿਲੀ ਲਾਈਨ"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "ਇਹ ਸੁਨੇਹਾ ਹਮੇਸ਼ਾਂ ਪਹਿਲੀ ਵਾਰੀ ਪੰਨਾ ਲੋਡ ਹੋਣ 'ਤੇ ਦਿਖਾਇਆ ਜਾਂਦਾ ਹੈ।"

msgid "お知らせの2行目"
msgstr "ਨੋਟਿਸ ਦੀ ਦੂਜੀ ਲਾਈਨ"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "ਇਹ ਸੁਨੇਹਾ ਸਿਰਫ਼ ਪਹਿਲੀ ਡਿਸਪਲੇ 'ਤੇ ਹੀ ਹਮੇਸ਼ਾਂ ਦਿਖਾਈ ਦੇਵੇਗਾ ਜਦੋਂ EU GDPR ਲਾਗੂ ਹੋਵੇਗਾ।"

msgid "お知らせの3行目"
msgstr "ਨੋਟਿਸ ਦੀ ਤੀਜੀ ਲਾਈਨ"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "ਇਹ ਨਿੱਜਤਾ ਨੀਤੀ ਦੇ ਲਿੰਕ ਦੇ ਸੱਜੇ ਪਾਸੇ ਦਿਖਾਈ ਦੇਵੇਗਾ।"

msgid "非EU向け確認の文字列"
msgstr "ਗੈਰ-ਈਯੂ ਦੇਸ਼ਾਂ ਲਈ ਪੁਸ਼ਟੀਕਰਨ ਪਾਠ"

msgid "EU GDPR向け同意するの文字列"
msgstr "EU GDPR ਲਈ ਸਹਿਮਤੀ ਦਾ ਪਾਠ"

msgid "EU GDPR向け同意しないの文字列"
msgstr "EU GDPR ਦੇ ਤਹਿਤ 'ਸਹਿਮਤੀ ਨਾ ਦਿਓ' ਲਈ ਲਿਖਤ"

msgid "プライバシーポリシーの文字列"
msgstr "ਗੋਪਨੀਯਤਾ ਨੀਤੀ ਦਾ ਪਾਠ"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "ਕਿਰਪਾ ਕਰਕੇ ਇੱਥੇ ਪ੍ਰਾਈਵੇਸੀ ਨੀਤੀ ਲਈ URL ਸੈੱਟ ਕਰੋ।"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "ਕਿਰਪਾ ਕਰਕੇ ਹੇਠ ਲਿਖਿਆ ਗੋਪਨੀਯਤਾ ਨੀਤੀ ਵਿੱਚ ਸ਼ਾਮਲ ਕਰੋ।"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "ਧੋਖਾਧੜੀ ਵਾਲੀਆਂ ਗਤੀਵਿਧੀਆਂ ਦਾ ਪਤਾ ਲਗਾਉਣ ਲਈ, IP ਪਤਿਆਂ ਵਰਗੇ ਪਛਾਣਕਰਤਾ ਕੂਕੀਜ਼ ਅਤੇ ਡੇਟਾਬੇਸ ਵਿੱਚ ਸਟੋਰ ਕੀਤੇ ਜਾਂਦੇ ਹਨ। ਸਟੋਰ ਕੀਤਾ ਡੇਟਾ ਪ੍ਰਸ਼ਾਸਕ ਦੀ ਮਰਜ਼ੀ ਅਨੁਸਾਰ ਮਿਟਾ ਦਿੱਤਾ ਜਾਂਦਾ ਹੈ।"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "ਜਦੋਂ ਚਿੱਤਰ ਸੁਰੱਖਿਆ ਚਾਲੂ ਹੁੰਦੀ ਹੈ, ਤਾਂ ਇਹ ਯਕੀਨੀ ਬਣਾਉਣ ਲਈ ਕਿ ਚਿੱਤਰ ਸਹੀ ਤਰੀਕੇ ਨਾਲ ਪਹੁੰਚਾਏ ਜਾਣ, ਅਸੀਂ ਆਪਣੇ ਡੇਟਾਬੇਸ ਵਿੱਚ IP ਪਤਾ ਅਤੇ ਚਿੱਤਰ ਫਾਈਲ ਨਾਮ ਸਮੇਤ ਹੈਸ਼ ਕੀਤਾ ਡੇਟਾ 60 ਮਿੰਟ ਤੱਕ ਸਟੋਰ ਕਰਦੇ ਹਾਂ।"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "ਜੇ ਤੁਸੀਂ ਵਰਤੋਂ ਦੀਆਂ ਸ਼ਰਤਾਂ ਸੈੱਟ ਕਰ ਰਹੇ ਹੋ, ਤਾਂ ਕਿਰਪਾ ਕਰਕੇ ਇਹ ਯਕੀਨੀ ਬਣਾਓ ਕਿ ਤੁਸੀਂ ਆਪਣੀ ਗੋਪਨੀਯਤਾ ਨੀਤੀ ਵਿੱਚ ਉਹਨਾਂ ਦਾ ਲਿੰਕ ਸ਼ਾਮਲ ਕਰੋ।"

msgid "利用規約の文字列"
msgstr "ਵਰਤੋਂ ਦੀਆਂ ਸ਼ਰਤਾਂ ਦਾ ਪਾਠ"

msgid "利用規約のページ"
msgstr "ਸ਼ਰਤਾਂ ਅਤੇ ਨਿਯਮਾਂ ਦਾ ਪੰਨਾ"

msgid "ページ選択なし"
msgstr "ਕੋਈ ਪੰਨਾ ਚੁਣਿਆ ਨਹੀਂ ਗਿਆ"

msgid "検索エンジン等のURL"
msgstr "ਖੋਜ ਇੰਜਣਾਂ ਆਦਿ ਲਈ ਯੂਆਰਐਲ।"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "ਜਦੋਂ ਉਪਭੋਗਤਾ ਸਹਿਮਤੀ ਨਾ ਦੇਣ, ਤਾਂ ਉਹਨਾਂ ਨੂੰ ਰੀਡਾਇਰੈਕਟ ਕਰਨ ਵਾਲੇ ਖੋਜ ਇੰਜਣਾਂ ਅਤੇ ਸਮਾਨ ਸਾਈਟਾਂ ਲਈ URL ਸੈੱਟ ਕਰੋ।"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "ਡੀਬੱਗ ਮੋਡ, ਕੰਸੋਲ ਚੇਤਾਵਨੀ ਸੁਨੇਹੇ"

msgid "右クリックの警告メッセージ"
msgstr "ਸੱਜੇ-ਕਲਿੱਕ ਚੇਤਾਵਨੀ ਸੁਨੇਹਾ"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "ਪੀਡੀਐਫ਼ ਵਜੋਂ ਛਾਪਣ ਅਤੇ ਸੇਵ ਕਰਨ ਸੰਬੰਧੀ ਚੇਤਾਵਨੀ ਸੁਨੇਹਾ"

msgid "スクリーンショットの警告メッセージ"
msgstr "ਸਕ੍ਰੀਨਸ਼ਾਟ ਵਿੱਚ ਚੇਤਾਵਨੀ ਸੁਨੇਹਾ"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "ਸ਼ੱਕੀ ਸਕ੍ਰੀਨਸ਼ਾਟਾਂ ਸੰਬੰਧੀ ਚੇਤਾਵਨੀ ਸੁਨੇਹਾ"

msgid "テキスト全選択時の警告メッセージ"
msgstr "ਜਦੋਂ ਸਾਰਾ ਟੈਕਸਟ ਚੁਣਿਆ ਹੋਵੇ ਤਾਂ ਚੇਤਾਵਨੀ ਸੁਨੇਹਾ"

msgid "ページ保存の警告メッセージ"
msgstr "ਪੰਨਾ ਸੇਵ ਕਰਨ ਸੰਬੰਧੀ ਚੇਤਾਵਨੀ ਸੁਨੇਹਾ"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "ਕਾਪੀ ਜਾਂ ਕੱਟਣ ਵੇਲੇ ਦਿਖਾਇਆ ਜਾਣ ਵਾਲਾ ਸੁਨੇਹਾ"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML ਸਰੋਤ ਵੇਖਣ ਵੇਲੇ ਦਿਖਾਉਣ ਲਈ ਸੁਨੇਹਾ"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML ਨੂੰ ਓਬਫਸਕੇਟ ਜਾਂ ਸੁਰੱਖਿਅਤ ਕਰਦੇ ਸਮੇਂ ਸਰੋਤ ਕੋਡ ਦੇ ਸਿਖਰ 'ਤੇ ਦਿਖਾਉਣ ਲਈ ਸੁਨੇਹਾ"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML ਸੁਰੱਖਿਆ ਦੌਰਾਨ ਜੇਕਰ ਇੱਕ-ਵਾਰੀ ਪ੍ਰਮਾਣਿਕਤਾ ਟੋਕਨ ਅਵੈਧ ਹੋਵੇ ਤਾਂ ਦਿਖਾਉਣ ਲਈ ਸੁਨੇਹਾ"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "ਜੇਕਰ ਕੂਕੀਜ਼ ਜਾਂ ਜਾਵਾਸਕ੍ਰਿਪਟ ਅਯੋਗ ਹਨ ਤਾਂ ਦਿਖਾਉਣ ਲਈ ਸੁਨੇਹਾ"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "ਅਸਲ ਵਿੱਚ, ਇਹ ਸਿਰਫ਼ ਉਦੋਂ ਹੀ ਦਿਖਾਈ ਦਿੰਦਾ ਹੈ ਜਦੋਂ ਜਾਵਾਸਕ੍ਰਿਪਟ ਅਸਮਰੱਥ ਕੀਤਾ ਗਿਆ ਹੋਵੇ।"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "ਜਦੋਂ ਇੱਕ ਚਿੱਤਰ ਸੁਰੱਖਿਅਤ ਕੀਤਾ ਜਾਂਦਾ ਹੈ, ਤਾਂ ਇਹ ਡਾਊਨਲੋਡ ਹੋ ਜਾਂਦਾ ਹੈ ਅਤੇ ਉਸ ਚਿੱਤਰ 'ਤੇ ਇੱਕ ਸੁਨੇਹਾ ਦਿਖਾਇਆ ਜਾਂਦਾ ਹੈ"

msgid "HTML難読化 (圧縮)"
msgstr "HTML ਅਸਪਸ਼ਟਤਾ"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "ਇਹ ਮਿਆਰੀ HTML ਸੰਕੋਚਨ ਹੈ; ਕੁਝ ਵੈੱਬਸਾਈਟਾਂ ਵੀ ਹਨ ਜੋ ਇਸਨੂੰ ਡੀਕੋਡ ਕਰ ਸਕਦੀਆਂ ਹਨ।"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "ਇਸ ਵਿਕਲਪ ਨੂੰ ਚਾਲੂ ਕਰਨ ਨਾਲ ਤੁਸੀਂ ਵਿਊ-ਸੋਰਸ ਲੌਗਸ ਪ੍ਰਾਪਤ ਕਰ ਸਕਦੇ ਹੋ।"

msgid "HTML保護"
msgstr "HTML ਸੁਰੱਖਿਆ"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "ਇਹ HTML ਕੰਪ੍ਰੈਸ਼ਨ ਸੈਟਿੰਗ ਨਾਲੋਂ ਵੀ ਘੱਟ HTML ਆਉਟਪੁੱਟ ਕਰਦਾ ਹੈ, ਜਿਸਦਾ ਮਤਲਬ ਹੈ ਕਿ BODY ਟੈਗ ਦੇ ਅੰਦਰ ਦੀ ਸਮੱਗਰੀ ਬਿਲਕੁਲ ਵੀ ਆਉਟਪੁੱਟ ਨਹੀਂ ਕੀਤੀ ਜਾਵੇਗੀ।"

msgid "Firefoxに対しては無効です"
msgstr "ਇਹ ਫਾਇਰਫਾਕਸ 'ਤੇ ਲਾਗੂ ਨਹੀਂ ਹੁੰਦਾ।"

msgid "SEOに著しく影響があります"
msgstr "ਇਸਦਾ ਐਸਈਓ 'ਤੇ ਮਹੱਤਵਪੂਰਨ ਪ੍ਰਭਾਵ ਪੈਂਦਾ ਹੈ।"

msgid "HTMLをJavaScriptで描画"
msgstr "ਜਾਵਾਸਕ੍ਰਿਪਟ ਦੀ ਵਰਤੋਂ ਕਰਕੇ HTML ਰੈਂਡਰ ਕਰਨਾ"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "ਫਾਇਰਫਾਕਸ ਦੇ ਬਾਈਪਾਸ ਕਰਨ ਲਈ, ਅਸੀਂ ਜਾਵਾਸਕ੍ਰਿਪਟ ਦੀ ਵਰਤੋਂ ਕਰਕੇ HTML ਨੂੰ ਰੈਂਡਰ ਕਰਦੇ ਹਾਂ।"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "ਜਾਵਾਸਕ੍ਰਿਪਟ ਰੈਂਡਰਿੰਗ ਨੂੰ ਚਾਲੂ ਕਰਨ ਨਾਲ ਵੈੱਬਸਾਈਟ ਦੀ ਲੋਡ ਹੋਣ ਦੀ ਗਤੀ ਕਾਫੀ ਹੌਲੀ ਹੋ ਜਾਵੇਗੀ।"

msgid "画像の保護"
msgstr "ਚਿੱਤਰ ਸੁਰੱਖਿਆ"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "ਜਦੋਂ ਵੀ img ਟੈਗ ਬੁਲਾਇਆ ਜਾਂਦਾ ਹੈ, ਤਸਵੀਰ ਦੀ ਰੱਖਿਆ ਕਰੋ।"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "ਸਾਰੇ HTML ਆਉਟਪੁੱਟ ਵਿੱਚ WordPress 'ਤੇ ਅਪਲੋਡ ਕੀਤੀਆਂ ਸਾਰੀਆਂ ਤਸਵੀਰਾਂ ਦੀ ਰੱਖਿਆ ਕਰੋ।"

msgid "画像をダウンロードから保護します"
msgstr "ਚਿੱਤਰਾਂ ਨੂੰ ਡਾਊਨਲੋਡ ਹੋਣ ਤੋਂ ਰੋਕਦਾ ਹੈ"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "ਜਦੋਂ ਚਿੱਤਰ ਡੇਟਾ ਸੁਰੱਖਿਅਤ ਕੀਤਾ ਜਾਂਦਾ ਹੈ, ਅਸੀਂ ਲਗਭਗ ਸਾਰੇ ਡਾਊਨਲੋਡ ਰੋਕਦੇ ਹਾਂ, ਵਿਲੱਖਣ ਇੱਕ-ਵਾਰੀ ਵਰਤੋਂ ਵਾਲੇ URL ਜਾਰੀ ਕਰਦੇ ਹਾਂ, ਸੈਸ਼ਨ ਵਿੱਚ ਸਟੋਰ ਕੀਤੇ ਟੋਕਨਾਂ ਨਾਲ ਪ੍ਰਮਾਣਿਕਤਾ ਕਰਦੇ ਹਾਂ, ਅਤੇ PHP ਰਾਹੀਂ ਚਿੱਤਰ ਦਿਖਾਉਂਦੇ ਹਾਂ; ਇਸ ਨਾਲ ਲਗਭਗ ਸਾਰੀ ਚਿੱਤਰ ਚੋਰੀ ਰੋਕੀ ਜਾਂਦੀ ਹੈ।"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "ਜਦੋਂ ਚਿੱਤਰ ਡੇਟਾ ਸੁਰੱਖਿਅਤ ਕੀਤਾ ਜਾਂਦਾ ਹੈ, ਤਾਂ ਕੈਸ਼ਿੰਗ ਕੰਮ ਨਹੀਂ ਕਰਦੀ, ਜਿਸਦਾ ਮਤਲਬ ਹੈ ਕਿ ਸਾਈਟ ਅਗਲੀ ਵਾਰੀ ਆਉਣ 'ਤੇ ਹੌਲੀ ਲੋਡ ਹੋਵੇਗੀ, ਜਿਸ ਨਾਲ SEO 'ਤੇ ਅਸਰ ਪੈਂਦਾ ਹੈ।"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "ਚਿੱਤਰ ਡੇਟਾ ਦੀ ਸੁਰੱਖਿਆ ਕਰਨ ਨਾਲ ਡੇਟਾਬੇਸ 'ਤੇ ਲੋਡ ਵੱਧ ਸਕਦਾ ਹੈ।"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "ਜੇ ਤੁਸੀਂ 'ਜਦੋਂ ਵੀ img ਟੈਗ ਬੁਲਾਇਆ ਜਾਵੇ ਤਸਵੀਰਾਂ ਦੀ ਸੁਰੱਖਿਆ ਕਰੋ' ਚੁਣਦੇ ਹੋ, ਤਾਂ ਸਿਸਟਮ img ਟੈਗ ਬਣਾਉਣ ਸਮੇਂ ਫਿਲਟਰ ਲਗਾਉਣ ਲਈ add_filter ਦੀ ਵਰਤੋਂ ਕਰਦਾ ਹੈ; ਹਾਲਾਂਕਿ, ਇਹ ਕੁਝ ਥੀਮਾਂ ਨਾਲ ਠੀਕ ਤਰ੍ਹਾਂ ਕੰਮ ਨਹੀਂ ਕਰ ਸਕਦਾ।"

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "ਜੇ ਤੁਸੀਂ 'ਸਾਰੇ HTML ਆਉਟਪੁੱਟ ਵਿੱਚ WordPress 'ਤੇ ਅਪਲੋਡ ਕੀਤੀਆਂ ਤਸਵੀਰਾਂ ਦੀ ਸੁਰੱਖਿਆ ਕਰੋ' ਚੁਣਦੇ ਹੋ, ਤਾਂ ਪਲੱਗਇਨ ਲਗਭਗ ਸਾਰੇ WordPress ਕਾਰਜਾਂ ਨੂੰ ਕੈਪਚਰ ਕਰੇਗਾ ਅਤੇ ਸਮੱਗਰੀ ਵਿੱਚ ਹਰ img ਟੈਗ ਨੂੰ ਪ੍ਰੋਸੈਸ ਕਰੇਗਾ। ਕਿਰਪਾ ਕਰਕੇ ਧਿਆਨ ਦਿਓ ਕਿ ਇਹ ਕੁਝ ਥੀਮਾਂ ਨਾਲ ਠੀਕ ਤਰ੍ਹਾਂ ਕੰਮ ਨਹੀਂ ਕਰ ਸਕਦਾ।"

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "ਕਿਰਪਾ ਕਰਕੇ ਧਿਆਨ ਦਿਓ ਕਿ ਫੀਚਰਡ ਇਮੇਜ ਵਜੋਂ ਨਿਯੁਕਤ ਕੀਤੀਆਂ ਤਸਵੀਰਾਂ OGP ਡੇਟਾ ਵਜੋਂ ਸਾਂਝੀਆਂ ਕੀਤੀਆਂ ਜਾਣਗੀਆਂ ਅਤੇ ਉਹਨਾਂ ਦੀ ਸੁਰੱਖਿਆ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ। ਜੇ ਤੁਸੀਂ ਬਿਲਕੁਲ ਹੀ ਉਹਨਾਂ ਦੀ ਸੁਰੱਖਿਆ ਕਰਨੀ ਚਾਹੁੰਦੇ ਹੋ, ਤਾਂ HTML ਸੁਰੱਖਿਆ ਚਾਲੂ ਕਰਦੇ ਸਮੇਂ ਐਡਵਾਂਸ ਸੈਟਿੰਗਜ਼ ਵਿੱਚ HEAD ਟੈਗ ਆਉਟਪੁੱਟ ਲਈ ਸੈਟਿੰਗ ਬਦਲੋ।"

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
