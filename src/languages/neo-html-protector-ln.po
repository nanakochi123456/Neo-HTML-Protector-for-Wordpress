msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare – 22.3 segɔnde – 183,926 bɔyte – 64 kbps – Lisansi: Domaine public"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare ya lolenge ya kala – 2.2 segɔnde – 10,536 baitɛ – 32 kbps – Lisansi: Domaine public"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Ebandeli ya lolenge ya kala – 42.1 segɔnde – 179,138 baitɛ – 32 kbps – Lisansi: Domaine public"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Likebisi na ChatGPT - 3.8 segɔnde - 109,700 ba octets - 256 kbps - Lisansi: Domaine public"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Lokito ya likambo ya mbangu makasi lokola alerte ya malware – Eteni ya 1 na ChatGPT – 3.3 segɔnde – 102,850 bytes – 256 kbps – Lisansi: Domaine public"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Lokito ya likambo ya mbangu makasi lokola alerte ya détection ya malware, Eteni ya 2 na ChatGPT - 3.3 secondes - 103,122 bytes - 256 kbps - Lisansi: Domaine public"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Mongongo ya lolenge ya MRI na ChatGPT – miniti 1 na segɔnde 14,9 – 3 340 392 bytes – 320 kbps – Lisansi: Domaine public"

msgid "警告表示中のBGMを選択します"
msgstr "Pona miziki ya nsima oyo ekobeta na tango ya likebisi."

msgid "びっくりするような雰囲気を作ります"
msgstr "Ezalisi ambiance ya kokamwa."

msgid "Firefoxでは音声ブロックされます"
msgstr "Audio ekangami na Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Benga moke tango likambo oyo elakisami esalami"

msgid "有効 音量小さ目"
msgstr "Fungola, mongongo moke"

msgid "有効 音量大き目"
msgstr "Ezali kosala, volume etombwami likolo"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Mongongo ya beep ekobeta mpo na makambo nyonso ya fungola mpe ya souris, ntango likebisi ezali komonana."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Emonanaka lokola aparɛyi ebebi ntango likebisi ezali komonana."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Kobomba curseur ya souris tango likambo moko boye esalami"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Ebombaka curseur ya souris na eteni ya navigateur ntango likebisi ezali komonana."

msgid "デバッグモード"
msgstr "Mode ya kobongisa mabunga"

msgid "妨害＋記録のみ"
msgstr "Kopekisa + Ba disques kaka"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Kopekisa + Bokomisi + Komonisa + Bokembisi"

msgid "メニューからは操作できてしまいます"
msgstr "Okoki kaka kokoma na yango na nzela ya menu."

msgid "Firefoxにおけるデバッグモード"
msgstr "Mode ya débugage na Firefox"

msgid "ブラウザーコンソール"
msgstr "Esika ya botalisi ya navigateur"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Na bosolo, okoki kosalela yango uta na mode ya debug."

msgid "HTMLソース表示"
msgstr "Tala source ya HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Okoki kosala opération yango na ndenge ya pete kaka na kokotisa URL oyo ebandi na 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Okoki kobatela contenu na yo na kosangisa yango na bobateli ya HTML."

msgid "印刷"
msgstr "Kobimisa na papie"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Ata epekisaka ko-imprimé, ekoki kosala malamu te na ba navigateurs mosusu."

msgid "スクリーンショット"
msgstr "Elilingi ya écran"

