msgstr "Papa Mokuse - Basegɔnde 3.8 - Ba octets 32,364 - 64 kbps - Lisansi: GPL 2.0 to oyo elandi"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Molai - basegɔnde 23.5 - ba octets 195,578 - 64 kbps - Lisansi: GPL 2.0 to oyo elandi"

