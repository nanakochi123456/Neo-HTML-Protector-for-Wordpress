msgstr "Faneva fomba retro – 2,2 segondra – 10 536 bait – 32 kbps – Fahazoan-dàlana: An'ny daholobe"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Fampidirana amin'ny fomba retro – 42,1 segondra – 179 138 baites – 32 kbps – Fahazoan-dàlana: An'ny daholobe"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Fampitandremana avy amin'ny ChatGPT - 3.8 segondra - 109,700 bytes - 256 kbps - Fahazoan-dàlana: An'ny daholobe"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Feo maika tokoa toy ny fampitandremana fitiliana malware – Ampahany 1 avy amin'i ChatGPT – 3,3 segondra – 102.850 bytes – 256 kbps – Fahazoan-dàlana: An'ny daholobe"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Feo maika tokoa toy ny fampitandremana fitiliana malware, Fizarana 2 nataon'i ChatGPT - 3,3 segondra - 103.122 bytes - 256 kbps - Fahazoan-dàlana: An'ny daholobe"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Feo karazana MRI avy amin'ny ChatGPT – 1 minitra 14,9 segondra – 3 340 392 octets – 320 kbps – Fahazoan-dàlana: An'ny daholobe"

msgid "警告表示中のBGMを選択します"
msgstr "Safidio ny mozika ambadika hihira mandritra ny fampitandremana."

msgid "びっくりするような雰囲気を作ります"
msgstr "Mamorona atmosfera mahagaga."

msgid "Firefoxでは音声ブロックされます"
msgstr "Voasakana ny feo ao amin'ny Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Feo bip rehefa tanterahina ny hetsika voatondro"

msgid "有効 音量小さ目"
msgstr "Mandeha, feo ambany"

msgid "有効 音量大き目"
msgstr "Miasa, ny feo napetraka amin'ny avo"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Heno ny feon'ny bip ho an'ny hetsika rehetra amin'ny fanalahidy sy ny totozy, raha aseho fampitandremana."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Miteraka fahatsapana fa lasa tsy voafehy ny fitaovana raha mbola aseho ny fampitandremana."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Manafina ny kisary totozy rehefa tanterahina ny hetsika iray manokana"

