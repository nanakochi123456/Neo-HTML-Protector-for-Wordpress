msgid "設定"
msgstr "Fikirana"

msgid "IPログリーダー"
msgstr "Mpamaky ny log IP"

msgid "IPアドレスログ"
msgstr "Lisitry ny adiresy IP"

msgid "全クリア"
msgstr "Vitao ny ambaratonga rehetra"

msgid "IPログが全て削除されました"
msgstr "Voafafa daholo ny rakitra IP rehetra."

msgid "ID"
msgstr "Famaritana mampiavaka"

msgid "タイムスタンプ"
msgstr "Marika fotoana"

msgid "IPアドレス"
msgstr "Adiresy IP"

msgid "ユーザーエージェント"
msgstr "Solontenan'ny mpampiasa"

msgid "イベント"
msgstr "Hetsika"

msgid "IPアドレスのデータはありません"
msgstr "Tsy misy angon-drakitra ho an'ity adiresy IP ity."

msgid "EU GDPR対応"
msgstr "Fanarahana ny GDPR an'ny Vondrona Eoropeanina"

msgid "無効"
msgstr "Tsy manan-kery"

msgid "有効"
msgstr "Manan-kery"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Raha mampiasa WordPress ao anatin'ny Vondrona Eoropeanina ianao, na raha mikendry mpampiasa ao anatin'ny Vondrona Eoropeanina ny tranokalanao, dia azafady mba ataovy azo antoka fa mandeha izy ity."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Ny bokotra 'Hamarino' dia hiova ho 'Manaiky' na 'Tsy manaiky', ary hiova kely ny fitondran-tena."

msgid "同意画面の色"
msgstr "Loko amin'ny efijery fanekena"

msgid "自動"
msgstr "Mandeha ho azy"

msgid "ライトモード"
msgstr "Fomba maivana"

msgid "ダークモード"
msgstr "Fomba Maizina"

msgid "同意画面表示中の配色を設定します"
msgstr "Farito ny fandaharana loko ho an'ny efijery fanekena"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Fanaovana manjavozavo ny votoaty eo amin'ny efijery fanekena"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Farito ny haavon'ny fanamaizana ny votoaty aseho eo amin'ny efijery fanekena."

msgid "同意画面の透過"
msgstr "Fahazavan'ny efijery fanekena"

msgid "透過なし"
msgstr "Tsy mangarahara"

msgid "同意画面の透過具合を設定します"
msgstr "Farito ny mangaraharan'ny efijery fanekena"

msgid "お知らせの1行目"
msgstr "Andalana voalohany amin'ny fanambarana"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ity hafatra ity dia aseho foana amin'ny voalohany ampidirana ny pejy."

msgid "お知らせの2行目"
msgstr "Ny andalana faharoa amin'ny fampandrenesana"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Hiseho hatrany amin'ny fampisehoana voalohany ity hafatra ity rehefa manan-kery ny EU GDPR."

msgid "お知らせの3行目"
msgstr "Ny andalana fahatelo amin'ny fampandrenesana"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Hiseho eo ankavananan'ny rohy mankany amin'ny Politikan'ny Tsiambaratelo."

msgid "非EU向け確認の文字列"
msgstr "Teny fanamafisana ho an'ny firenena tsy ao anatin'ny Vondrona Eoropeanina"

msgid "EU GDPR向け同意するの文字列"
msgstr "Teny fanekena ho an'ny GDPR an'ny Vondrona Eoropeana"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Teny ho an'ny 'Aza manaiky' eo ambanin'ny GDPR an'ny Vondrona Eoropeana"

msgid "プライバシーポリシーの文字列"
msgstr "Teny momba ny politika fiarovana ny tsiambaratelo"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Azafady, apetraho eto ny URL ho an'ny politika momba ny tsiambaratelo."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Azafady ampio ireto manaraka ireto ao amin'ny Politikan'ny Tsiambaratelo."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Mba hahitana hetsika hosoka, dia tehirizina ao anaty cookies sy tahiry angona ny mombamomba toy ny adiresy IP. Fafana araka ny sitrapon'ny mpitantana ny angona voatahiry."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Mba hahazoana antoka fa alefa araka ny tokony ho izy ny sary rehefa mandeha ny fiarovana sary, dia mitahiry angon-drakitra voahash izay ahitana ny adiresy IP sy ny anaran'ny rakitra sary ao amin'ny tahiry izahay mandritra ny 60 minitra."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Raha mametraka Fepetra fampiasana ianao, azafady mba ataovy azo antoka fa mampiditra rohy mankany amin'izy ireo ao amin'ny Politikan'ny tsiambaratelo anao."

msgid "利用規約の文字列"
msgstr "Lahatsoratr'ireo Fepetran'ny Fampiasana"

msgid "利用規約のページ"
msgstr "Pejin'ny Fepetra sy Fitsipika"

msgid "ページ選択なし"
msgstr "Tsy misy pejy voafidy"

msgid "検索エンジン等のURL"
msgstr "URL ho an'ny milina fikarohana, sns."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Farito ny URL ho an'ny milina fikarohana sy ireo tranonkala mitovy izay mandefa mpampiasa any amin'ny toerana hafa rehefa tsy omena fankatoavana."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Maody famahana hadisoana, hafatra fampitandremana amin'ny console"

msgid "右クリックの警告メッセージ"
msgstr "Tsindrio-ankavanana ny hafatra fampitandremana"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Fampitandremana momba ny fanontana sy ny fitahirizana ho PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Hafatra fampitandremana ao amin'ny pikantsary"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Fampitandremana momba ny sary efijery ahiana"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Hafatra fampitandremana rehefa voafidy ny lahatsoratra rehetra"

msgid "ページ保存の警告メッセージ"
msgstr "Fampitandremana momba ny fitahirizana pejy"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Haseho ity hafatra ity rehefa maka na manapaka."

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Hafatra haseho rehefa mijery ny loharanon'ny HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Hafatra haseho eo an-tampon'ny kaody loharano rehefa manafina na miaro HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Haseho ny hafatra raha tsy manankery ny token fanamarinana indray mandeha mandritra ny fiarovana HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Hafatra haseho raha toa ka voasakana ny cookies na ny JavaScript"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Raha ny marina, tsy miseho ity afa-tsy rehefa voasakana ny JavaScript."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Rehefa arovana ny sary iray, dia alaina izy, ary miseho eo amboniny ny hafatra"

msgid "HTML難読化 (圧縮)"
msgstr "Fanafenana ny kaody HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Ity no fanerena HTML mahazatra; misy koa tranonkala afaka mandika azy."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ny fampandehanana ity safidy ity dia ahafahanao maka ny rakitra log-n'ny fijerena ny loharano."

msgid "HTML保護"
msgstr "Fiarovana HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Mamoaka HTML fototra indrindra fotsiny izy—na dia kely kokoa aza noho ny fampiasana fanerena HTML—ary tsy mamoaka mihitsy ny votoaty ao anatin'ny tag BODY."

msgid "Firefoxに対しては無効です"
msgstr "Tsy mihatra amin'ny Firefox ity."

msgid "SEOに著しく影響があります"
msgstr "Manana fiantraikany lehibe amin'ny SEO izany."

msgid "HTMLをJavaScriptで描画"
msgstr "Fanaovana sary an-tsary HTML amin'ny alalan'ny JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Mba hiasa manodidina ny Firefox, dia asehontsika amin'ny alalan'ny JavaScript ny HTML."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Ny fampandehanana ny fanehoana JavaScript dia hampiadana be ny hafainganam-pandehan'ny fampidinana ny tranonkala."

msgid "画像の保護"
msgstr "Fiarovana ny sary"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Arovy ny sary isaky ny antsoina ny tag img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Arovy ny sary rehetra ampidirina ao amin'ny WordPress ao anatin'ny vokatra HTML manontolo."

msgid "画像をダウンロードから保護します"
msgstr "Miaro ny sary tsy ho alaina"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Rehefa arovana ny angon-tsary dia misakana saika ny fisintomana rehetra izahay, mamoaka URL tokana ampiasaina indray mandeha, manamarina ny mombamomba amin'ny alalan'ny token voatahiry ao anatin'ny session, ary mampiseho ny sary amin'ny alalan'ny PHP; izany dia misakana am-pahombiazana saika ny tranga rehetra amin'ny halatra sary."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Rehefa arovana ny angon-tsary, tsy miasa ny fitahirizana vonjimaika, izay midika fa haharitra ela kokoa ny fampidinana ny tranonkala amin'ny fitsidihana manaraka, ka misy fiantraikany amin'ny SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ny fiarovana ny angon-tsary dia mety hampitombo ny enta-mavesatra amin'ny tahiry angona."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Raha misafidy ny 'Miaro ny sary isaky ny antsoina ny tag img' ianao, dia mampiasa add_filter ny rafitra mba hanasivanana rehefa foronina ny tag img; na izany aza, mety tsy hiasa tsara amin'ny lohahevitra sasany izany."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Raha misafidy ny 'Miaro ny sary rehetra ampidirina ao amin'ny WordPress ao anatin'ny vokatra HTML manontolo' ianao, dia handrakitra saika ny asa rehetra ataon'ny WordPress ny plugin ary handinika ny tag img tsirairay ao anatin'ny votoaty. Mariho fa mety tsy hiasa tsara amin'ny lohahevitra sasany izany."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Mariho fa ny sary voatendry ho sary misongadina dia hozaraina ho toy ny angon-drakitra OGP ary tsy azo arovana. Raha tena ilainao arovana izy ireo dia ovay ny fikirana momba ny famoahana ny marika HEAD ao amin'ny fikirakirana mandroso rehefa mampavitrika ny fiarovana HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Tsy azo arovana ny fiasa fakana sary efijery tafiditra ho fenitra ao amin'ny rafitra fandidiana."

msgid "画像URLの保護"
msgstr "Fiarovana ny URL-n'ny sary"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Tokony ampiasaina miaraka amin'ny fiarovana sary izy ity; raha irery izy dia tsy misy ilana azy."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Satria ampidirina miadana amin'ny alalan'ny JavaScript izy, dia misy fiantraikany amin'ny SEO izany."

msgid "画像のウォーターマーク"
msgstr "Marika rano amin'ny sary"

msgid "右下"
msgstr "Ambany ankavanana"

msgid "ランダム位置"
msgstr "Toerana kisendrasendra"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Ampiasaina miaraka amin'ny fiarovana ny sary, ny marika an-drano mihetsika dia mampiseho mazava tsara ny maha-tompon'ny zon'ny mpamorona sady manome fahatsapana ho an'ny mpijery fa arahi-maso izy ireo, ka manakana azy ireo tsy hanao ratsy."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Ny endrika JPG, PNG ary WebP ihany no tohanana."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Ny fampandehanana izany dia hampitombo ny enta-mavesatra amin'ny mpizara."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Mamoaka zavakanto ASCII avy amin'ny kaody loharano HTML mandritra ny fanalana mazava sy ny fiarovana"

msgid "表示なし"
msgstr "Tsy misy fampisehoana"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Mampiseho sary ASCII mampitandrina rehefa mijery ny loharano HTML amin'ny alalan'ny 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Asehoy ny famolavolana rehefa tanterahina ny hetsika kendrena."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Endrika fototra misy soratra mainty eo ambonin'ny lamina mavo."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Endrika mampihoron-koditra misy soratra mena eo ambonin'ny lafika mainty."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Endrika iray misy soratra mena mamirapiratra eo ambonin'ny lamba mainty."

msgid "対象アクションを起こした時のBGM"
msgstr "Mozika ambadika mandeha rehefa tanterahina ny hetsika kendrena"

msgid "サウンドなし"
msgstr "Tsy misy feo"

