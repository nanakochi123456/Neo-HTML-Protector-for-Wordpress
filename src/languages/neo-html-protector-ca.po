msgid "設定"
msgstr "Configuració"

msgid "IPログリーダー"
msgstr "Lector de registres IP"

msgid "IPアドレスログ"
msgstr "Registres d'adreces IP"

msgid "全クリア"
msgstr "Completa tots els nivells"

msgid "IPログが全て削除されました"
msgstr "S'han eliminat tots els registres d'IP."

msgid "ID"
msgstr "Identificador"

msgid "タイムスタンプ"
msgstr "Segell de temps"

msgid "IPアドレス"
msgstr "Adreça IP"

msgid "ユーザーエージェント"
msgstr "Agent d'usuari"

msgid "イベント"
msgstr "Esdeveniment"

msgid "IPアドレスのデータはありません"
msgstr "No hi ha dades per a aquesta adreça IP."

msgid "EU GDPR対応"
msgstr "Compliment del RGPD de la UE"

msgid "無効"
msgstr "Invalid"

msgid "有効"
msgstr "Vàlid"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Si utilitzeu WordPress dins de la UE, o si el vostre lloc web està dirigit a usuaris dins de la UE, assegureu-vos que això estigui habilitat."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "El botó 'Confirmar' canviarà a 'D'acord' o 'En desacord', i el comportament canviarà lleugerament."

msgid "同意画面の色"
msgstr "Color de la pantalla de consentiment"

msgid "自動"
msgstr "Automàtic"

msgid "ライトモード"
msgstr "Mode lleuger"

msgid "ダークモード"
msgstr "Modo fosc"

msgid "同意画面表示中の配色を設定します"
msgstr "Estableix l'esquema de colors per a la pantalla de consentiment."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Emborronament del contingut a la pantalla de consentiment"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Establiu el nivell de difuminat per al contingut que es mostra a la pantalla de consentiment."

msgid "同意画面の透過"
msgstr "Transparència de la pantalla de consentiment"

msgid "透過なし"
msgstr "Sense transparència"

msgid "同意画面の透過具合を設定します"
msgstr "Establiu la transparència de la pantalla de consentiment"

msgid "お知らせの1行目"
msgstr "Primera línia de l'anunci"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Aquest missatge sempre es mostra la primera vegada que la pàgina es carrega."

msgid "お知らせの2行目"
msgstr "La segona línia de l'avís"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Aquest missatge sempre apareixerà només a la primera pantalla quan el RGPD de la UE estigui en vigor."

msgid "お知らせの3行目"
msgstr "La tercera línia de l'avís"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Aparirà a la dreta de l'enllaç a la Política de privadesa."

msgid "非EU向け確認の文字列"
msgstr "Text de confirmació per a països no pertanyents a la UE"

msgid "EU GDPR向け同意するの文字列"
msgstr "Text de consentiment per al RGPD de la UE"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Text per a 'No consentir' en virtut del RGPD de la UE"

msgid "プライバシーポリシーの文字列"
msgstr "Text de la política de privacitat"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Si us plau, establiu l'URL de la política de privadesa aquí."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Si us plau, afegiu el següent a la Política de privacitat."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Per detectar activitat fraudulenta, s'emmagatzemen identificadors com ara adreces IP a les galetes i a la base de dades. Les dades emmagatzemades s'eliminen a discreció de l'administrador."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Per garantir que les imatges es lliurin correctament quan està habilitada la protecció d'imatges, emmagatzemem a la nostra base de dades, durant un màxim de 60 minuts, les dades hashades que inclouen l'adreça IP i el nom del fitxer de la imatge."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Si esteu establint Condicions d'Ús, assegureu-vos d'incloure-hi un enllaç a la vostra Política de privacitat."

msgid "利用規約の文字列"
msgstr "Text de les condicions d'ús"

msgid "利用規約のページ"
msgstr "Pàgina de termes i condicions"

msgid "ページ選択なし"
msgstr "No s'ha seleccionat cap pàgina"

msgid "検索エンジン等のURL"
msgstr "URLs per a motors de cerca, etc."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Establiu l'URL per als motors de cerca i llocs similars que redirigeixen a una pàgina diferent quan no es dóna el consentiment."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mode de depuració, missatges d'advertència de la consola"

msgid "右クリックの警告メッセージ"
msgstr "Missatge d'advertiment amb clic dret"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Missatge d'advertència sobre la impressió i l'emmagatzematge com a PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Missatge d'advertiment a la captura de pantalla"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Missatge d'advertència sobre captures de pantalla sospitoses"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Missatge d'advertència quan tot el text està seleccionat"

msgid "ページ保存の警告メッセージ"
msgstr "Missatge d'advertiment sobre l'emmagatzematge de la pàgina"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Missatge que es mostra en copiar o retallar"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Missatge per mostrar quan es visualitza el codi font HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Missatge que s'ha de mostrar a la part superior del codi font quan s'estigui ofuscant o protegint HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Missatge que es mostrarà si el token d'autenticació d'un sol ús és invàlid durant la protecció HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Missatge per mostrar si les galetes o el JavaScript estan desactivats"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "De fet, això només es mostra quan JavaScript està desactivat."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Quan una imatge està protegida, es descarrega i es mostra un missatge sobre aquesta imatge"

msgid "HTML難読化 (圧縮)"
msgstr "Obstrucció"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Això és una compressió HTML estàndard; també hi ha llocs web que la poden descodificar."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Activant aquesta opció, podeu recuperar el registre de la visualització del codi font."

msgid "HTML保護"
msgstr "Protecció HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Només genera el mínim imprescindible d'HTML —fins i tot menys que amb la compressió d'HTML— i el contingut dins de l'etiqueta BODY no es mostra en absolut."

msgid "Firefoxに対しては無効です"
msgstr "Això no s'aplica al Firefox."

msgid "SEOに著しく影響があります"
msgstr "Això té un impacte significatiu en el SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Generació d'HTML amb JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Per eludir el Firefox, renderitzem l'HTML mitjançant JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Activar el renderitzat de JavaScript alentirà significativament la velocitat de càrrega del lloc web."

msgid "画像の保護"
msgstr "Protecció de la imatge"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Protegiu la imatge cada vegada que es crida l'etiqueta img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Protegiu totes les imatges pujades a WordPress dins de tot el codi HTML generat."

msgid "画像をダウンロードから保護します"
msgstr "Protegeix les imatges perquè no es puguin descarregar"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Quan les dades de les imatges estan protegides, evitem gairebé totes les descàrregues, generem URL únics d'un sol ús, autentiquem mitjançant tokens emmagatzemats a la sessió i mostrem les imatges mitjançant PHP; això evita de manera efectiva gairebé tots els casos de robatori d'imatges."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Quan les dades de les imatges estan protegides, la memòria cau no funciona, cosa que fa que el lloc es carregi més lentament en visites posteriors, afectant així el SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Protegir les dades de les imatges pot augmentar la càrrega de la base de dades."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Si seleccioneu 'Protegiu les imatges sempre que s'utilitzi l'etiqueta img', el sistema utilitza add_filter per aplicar el filtratge quan es genera l'etiqueta img; tanmateix, això pot no funcionar correctament amb alguns temes."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Si seleccioneu 'Protegiu totes les imatges pujades a WordPress dins de tot el contingut HTML', el complement capturarà gairebé totes les operacions de WordPress i processarà cada etiqueta img dins del contingut. Tingueu en compte que això pot no funcionar correctament amb alguns temes."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Tingueu en compte que les imatges designades com a imatges destacades es compartiran com a dades OGP i no es poden protegir. Si realment heu de protegir-les, canvieu la configuració de la sortida de l'etiqueta HEAD a la configuració avançada quan activeu la protecció HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "La funció de captura de pantalla integrada al sistema operatiu no es pot desactivar."

msgid "画像URLの保護"
msgstr "Protegir les URL d'imatge"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Això s'ha d'utilitzar conjuntament amb la protecció d'imatges; per si sol, no serveix de res."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Com que es carrega de manera mandrosa mitjançant JavaScript, això afecta el SEO."

msgid "画像のウォーターマーク"
msgstr "Filigrana de la imatge"

msgid "右下"
msgstr "A baix a la dreta"

msgid "ランダム位置"
msgstr "Posició aleatòria"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Utilitzades conjuntament amb la protecció d'imatges, les filigranes dinàmiques indiquen clarament la titularitat dels drets d'autor i, alhora, donen als espectadors la impressió que estan sent vigilats, actuant així com a element dissuasiu."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Només es suporten els formats JPG, PNG i WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Activar això augmentarà la càrrega del servidor."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Generació d'art ASCII a partir del codi font HTML durant l'ofuscació i protecció d'HTML"

msgid "表示なし"
msgstr "Sense pantalla"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Mostra art ASCII que indica un avís quan es visualitza el codi font HTML amb 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Mostra el disseny quan es realitza l'acció objectiu."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Un disseny bàsic amb text negre sobre un fons groc."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Un disseny d'estil terrorífic amb text vermell sobre un fons negre."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Un disseny amb text vermell lluminós sobre un fons negre"

msgid "対象アクションを起こした時のBGM"
msgstr "Música de fons que sona quan es realitza l'acció objectiu."

msgid "サウンドなし"
msgstr "Sense so"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Batalla i victòria - 1 minut 16,3 segons - 630.056 bytes - 64 kbps - Llicència: CC 2.1 o posterior"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Pare Breu - 3,8 segons - 32.364 bytes - 64 kbps - Llicència: GPL 2.0 o posterior"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23,5 segons - 195.578 bytes - 64 kbps - Llicència: GPL 2.0 o posterior"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin Étude Op. 10 núm. 5"

msgid "ショパン エチュード Op.10-12 革命 打ち込み版 高速版 - 1分57.6秒 - 724,457bytes - 48kbps -  ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin Étude Op. 10 núm. 12 'Revolució' – versió generada per ordinador, a gran velocitat – 1 minut 57,6 segons – 724.457 bytes – 48 kbps – Llicència: CC BY-ND 4.0 o posterior"

msgid "ショパン スケルツォ 変ロ短調 Op2 打ち込み版 高速短縮版 - 1分48.0秒 - 665,369bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin: Scherzo en si bemoll menor, Op. 2 – Versió generada per ordinador, versió abreujada d'alta velocitat – 1 minut 48,0 segons – 665.369 bytes – 48 kbps – Llicència: CC BY-ND 4.0 o posterior"

msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Llista: Étude d'Exécution núm. 4 'Mazeppa'"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfàrria – 22,3 segons – 183.926 bytes – 64 kbps – Llicència: Domini públic"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Fanfàrria d'estil retro – 2,2 segons – 10.536 bytes – 32 kbps – Llicència: Domini públic"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Intro d'estil retro – 42,1 segons – 179.138 bytes – 32 kbps – Llicència: Domini públic"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Avís de ChatGPT - 3,8 segons - 109.700 bytes - 256 kbps - Llicència: Domini públic"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Un so d'alta urgència que sona com una alerta de detecció de programari maliciós – Part 1 per ChatGPT – 3,3 segons – 102.850 bytes – 256 kbps – Llicència: Domini públic"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Un so d'alta urgència com una alerta de detecció de programari maliciós, Part 2 per ChatGPT - 3,3 segons - 103.122 bytes - 256 kbps - Llicència: Domini públic"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "So d'estil MRI per ChatGPT – 1 minut 14,9 segons – 3.340.392 bytes – 320 kbps – Llicència: Domini públic"

msgid "警告表示中のBGMを選択します"
msgstr "Seleccioneu la música de fons que es reproduirà durant un avís."

msgid "びっくりするような雰囲気を作ります"
msgstr "Crea una atmosfera sorprenent"

msgid "Firefoxでは音声ブロックされます"
msgstr "L'àudio està bloquejat al Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Un bip quan es realitza l'acció especificada"

msgid "有効 音量小さ目"
msgstr "Activat, volum baix"

msgid "有効 音量大き目"
msgstr "Actiu, volum a un nivell alt"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Sonarà un bip per a tots els esdeveniments de teclat i ratolí mentre es mostra un avís."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Crea la impressió que el dispositiu s'ha descontrolat mentre es mostra l'avís."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Amagar el cursor del ratolí quan es realitza una acció específica"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Amaga el cursor del ratolí a l'àrea del navegador mentre es mostra un avís."

msgid "デバッグモード"
msgstr "Mode de depuració"

msgid "妨害＋記録のみ"
msgstr "Interferència + Discos només"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Interferència + Registre + Visualització + Redirecció"

msgid "メニューからは操作できてしまいます"
msgstr "Encara hi pots accedir a través del menú."

msgid "Firefoxにおけるデバッグモード"
msgstr "Mode de depuració al Firefox"

msgid "ブラウザーコンソール"
msgstr "Consola del navegador"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "En efecte, el pots fer funcionar en mode de depuració."

msgid "HTMLソース表示"
msgstr "Veure el codi font d'HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Podeu dur a terme l'operació simplement introduint una URL que comenci per 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Podeu protegir el vostre contingut combinant això amb la protecció HTML."

msgid "印刷"
msgstr "Imprimeix"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Tot i que evita la impressió, pot ser que no funcioni correctament en alguns navegadors."

msgid "スクリーンショット"
msgstr "Captura de pantalla"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Segons el sistema operatiu, el navegador o el mètode utilitzat, pot ser que no sigui possible bloquejar-ho o que no es detecti."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Captura de pantalla sospitada quan la finestra es desplaça al fons"

msgid "あわせて、スクリーンショット以外の機能（タブ切り替え・ウィンドウ切り替え）にも反応してしまいます。"
msgstr "També respon a funcions diferents de les captures de pantalla"

msgid "2キー押下のスクリーンショットの疑い"
msgstr "Captura de pantalla presumpta presa prement dues tecles"

