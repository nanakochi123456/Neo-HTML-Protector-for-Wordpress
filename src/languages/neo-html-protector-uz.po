msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Agar siz Yevropa Ittifoqida WordPress'dan foydalanayotgan bo'lsangiz yoki veb-saytingiz Yevropa Ittifoqi foydalanuvchilariga mo'ljallangan bo'lsa, iltimos, buni yoqilganligiga ishonch hosil qiling."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Tasdiqlash' tugmasi 'Rozi bo'lish' yoki 'Rozi bo'lmaslik' ga o'zgaradi va xatti-harakat biroz o'zgaradi."

msgid "同意画面の色"
msgstr "Rozilik ekrani rangi"

msgid "自動"
msgstr "Avtomatik"

msgid "ライトモード"
msgstr "Yengil rejim"

msgid "ダークモード"
msgstr "Qorong'i rejim"

msgid "同意画面表示中の配色を設定します"
msgstr "Rozilik ekrani uchun rang sxemasini sozlang"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Ruxsat ekrani mazmunining xiralashishi"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Rozilik ekrani ko'rsatadigan kontent uchun xiralashtirish darajasini belgilang"

msgid "同意画面の透過"
msgstr "Rozilik ekrani shaffofligi"

msgid "透過なし"
msgstr "Shaffoflik yo'q"

msgid "同意画面の透過具合を設定します"
msgstr "Rozilik ekrani shaffofligini sozlang"

msgid "お知らせの1行目"
msgstr "E'lonning birinchi qatori"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ushbu xabar sahifa birinchi marta yuklanganda har doim ko'rsatiladi."

msgid "お知らせの2行目"
msgstr "Bildirishnomaning ikkinchi qatori"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ushbu xabar faqat EU GDPR kuchga kirganda birinchi ekranda doimiy ravishda paydo bo'ladi."

msgid "お知らせの3行目"
msgstr "Bildirishnomaning uchinchi qatori"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Bu Maxfiylik siyosatiga havolaning o'ng tomonida paydo bo'ladi."

msgid "非EU向け確認の文字列"
msgstr "Yevropa Ittifoqiga a'zo bo'lmagan mamlakatlar uchun tasdiqlash matni"

msgid "EU GDPR向け同意するの文字列"
msgstr "Yevropa Ittifoqi GDPR uchun rozilik matni"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Yevropa Ittifoqi GDPR bo'yicha Rozilik bermang matni"

msgid "プライバシーポリシーの文字列"
msgstr "Maxfiylik siyosati matni"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Iltimos, maxfiylik siyosati URL manzilini bu yerga belgilang."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Iltimos, quyidagilarni Maxfiylik siyosatiga qo'shing."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Firibgarlik faoliyatini aniqlash uchun IP-manzillar kabi identifikatorlar cookie-fayllarda va ma'lumotlar bazasida saqlanadi. Saqlangan ma'lumotlar administratorning ixtiyoriga ko'ra o'chirib tashlanadi."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Rasm himoyasi faollashtirilganda rasmlarning to'g'ri yetkazilishini ta'minlash uchun biz IP manzili va rasm fayl nomidan iborat xesh qilingan ma'lumotlarni ma'lumotlar bazasida 60 daqiqagacha saqlaymiz."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Agar siz Foydalanish shartlarini sozlayotgan bo'lsangiz, iltimos, ularga havolani Maxfiylik siyosatingizga kiritganingizga ishonch hosil qiling."

msgid "利用規約の文字列"
msgstr "Foydalanish shartlari matni"

msgid "利用規約のページ"
msgstr "Shartlar va qoidalar sahifasi"

msgid "ページ選択なし"
msgstr "Hech qanday sahifa tanlanmagan"

msgid "検索エンジン等のURL"
msgstr "Qidiruv tizimlari va boshqalar uchun URL manzillari."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Ruxsat berilmagan hollarda foydalanuvchilarni yo'naltiradigan qidiruv tizimlari va shunga o'xshash saytlar uchun URL manzilini belgilang."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Xatoliklarni tuzatish rejimi, konsol ogohlantirish xabarlari"

msgid "右クリックの警告メッセージ"
msgstr "O'ng tugma bilan bosish ogohlantirish xabari"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDFga chop etish va saqlash bo'yicha ogohlantirish xabari"

msgid "スクリーンショットの警告メッセージ"
msgstr "Ekran tasviridagi ogohlantirish xabari"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Taxmin qilingan skrinshotlar bo'yicha ogohlantirish xabari"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Barcha matn tanlanganda ogohlantirish xabari"

msgid "ページ保存の警告メッセージ"
msgstr "Sahifani saqlash bo'yicha ogohlantirish xabari"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Ko'chirish yoki kesish paytida ko'rsatiladigan xabar"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML manba kodini ko'rayotganda ko'rsatiladigan xabar"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTMLni obfuskatsiya qilish yoki himoya qilish paytida manba kodining yuqori qismida ko'rsatiladigan xabar"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML himoyasi vaqtida bir martalik autentifikatsiya tokeni haqiqiy bo'lmasa ko'rsatiladigan xabar"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Cookie-lar yoki JavaScript o'chirilgan bo'lsa ko'rsatiladigan xabar"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Aslida, bu faqat JavaScript o'chirilganda ko'rsatiladi."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Rasm himoyalanganida, u yuklab olinadi va rasm ustida xabar ko'rsatiladi"

msgid "HTML難読化 (圧縮)"
msgstr "HTMLni mavhumlashtirish"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Bu standart HTML siqilishi; uni dekompressiya qila oladigan veb-saytlar ham mavjud."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ushbu opsiyani yoqish sizga view-source logini olish imkonini beradi."

msgid "HTML保護"
msgstr "HTML himoyasi"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "U faqat eng zarur HTML kodini chiqaradi — HTML siqilganda bo'ladigandan ham kamroq — va BODY tegidagi kontent umuman chiqarilmaydi."

msgid "Firefoxに対しては無効です"
msgstr "Bu Firefoxga tegishli emas."

msgid "SEOに著しく影響があります"
msgstr "Bu SEOga sezilarli ta'sir ko'rsatadi."

msgid "HTMLをJavaScriptで描画"
msgstr "JavaScript yordamida HTML renderlash"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox'ni chetlab o'tish uchun HTMLni JavaScript yordamida render qilamiz."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScript renderlashni yoqish veb-saytning yuklanish tezligini sezilarli darajada sekinlashtiradi."

msgid "画像の保護"
msgstr "Rasmni himoya qilish"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img teg har safar chaqirilganda rasmni himoya qiling"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "WordPressga yuklangan barcha rasmlarni butun HTML chiqishida himoya qiling"

msgid "画像をダウンロードから保護します"
msgstr "Rasmlarning yuklab olinishini oldini oladi"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Rasm ma'lumotlari himoyalanganida, biz deyarli barcha yuklab olishlarni oldini olamiz, noyob bir martalik URL-manzillar beramiz, sessiyada saqlangan tokenlar yordamida autentifikatsiya qilamiz va rasmlarni PHP orqali ko'rsatamiz; bu esa rasm o'g'irligining deyarli barcha holatlarini samarali oldini oladi."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Rasm ma'lumotlari himoyalanganida keshlash ishlamaydi, bu esa saytning keyingi tashriflarda sekinroq yuklanishiga va shu bilan SEOga ta'sir qilishiga olib keladi."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Rasm ma'lumotlarini himoya qilish ma'lumotlar bazasiga tushadigan yukni oshirishi mumkin."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Agar siz 'img teg chaqirilganda rasmlarni himoya qilish'ni tanlasangiz, tizim img teg hosil bo'lganda filtrlashni qo'llash uchun add_filter funksiyasidan foydalanadi; ammo bu ba'zi mavzular bilan to'g'ri ishlamasligi mumkin."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Agar siz 'Butun HTML chiqishida WordPressga yuklangan barcha rasmlarni himoya qilish'ni tanlasangiz, plagin deyarli barcha WordPress operatsiyalarini qamrab oladi va kontentdagi har bir img tegini qayta ishlaydi. Iltimos, bu ba'zi mavzular bilan to'g'ri ishlamasligi mumkinligini yodda tuting."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Iltimos, e'tiborga olingki, ajratilgan rasmlar OGP ma'lumotlari sifatida ulashiladi va himoyalanmaydi. Agar ularni albatta himoya qilishingiz kerak bo'lsa, HTML himoyasini yoqishda ilg'or sozlamalarda HEAD tegining chiqishini o'zgartiring."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Operatsion tizimga o'rnatilgan skrinshot funksiyasi himoyalanishi mumkin emas."

msgid "画像URLの保護"
msgstr "Rasm URL manzillarini himoya qilish"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Bu rasmni himoya qilish bilan birgalikda ishlatilishi kerak; o'zi yolg'iz hech qanday maqsadga xizmat qilmaydi."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "U JavaScript orqali dangasalik bilan yuklanadi, bu esa SEOga ta'sir qiladi."

msgid "画像のウォーターマーク"
msgstr "Rasmga suv belgisi qo'shish"

msgid "右下"
msgstr "Pastki o'ng"

msgid "ランダム位置"
msgstr "Tasodifiy pozitsiya"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Rasmni himoya qilish bilan birgalikda qo'llanganda, dinamik suv belgilar mualliflik huquqi egaligini aniq ko'rsatadi va tomoshabinlarga ular nazorat ostida ekanliklari haqida taassurot uyg'otadi, shu bilan ularni to'xtatib turuvchi vosita bo'lib xizmat qiladi."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Faqat JPG, PNG va WebP formatlari qo'llab-quvvatlanadi."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Buni yoqish server yukini oshiradi."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "HTML manba kodidan ASCII san'atini chiqarish HTMLni obfuskatsiya qilish va himoya qilish jarayonida"

msgid "表示なし"
msgstr "Ko'rsatish yo'q"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "'view-source' yordamida HTML manbasini ko'rib chiqayotganda ogohlantirishni bildiruvchi ASCII san'atini namoyish etadi."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Maqsadli harakat bajarilganda dizaynni ko'rsating"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Sariq fon ustida qora matndan iborat oddiy dizayn"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Qora fon ustida qizil matndan iborat dahshat uslubidagi dizayn"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Qora fon ustida porlab turgan qizil matnli dizayn"

msgid "対象アクションを起こした時のBGM"
msgstr "Maqsadli harakat bajarilganda ijro etiladigan fon musiqasi"

msgid "サウンドなし"
msgstr "Ovoz yo'q"

