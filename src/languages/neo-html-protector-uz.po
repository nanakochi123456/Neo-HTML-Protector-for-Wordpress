msgid "警告表示中のBGMを選択します"
msgstr "Ogohlantirish paytida ijro etiladigan fon musiqasini tanlang"

msgid "びっくりするような雰囲気を作ります"
msgstr "Bu kutilmagan muhit yaratadi"

msgid "Firefoxでは音声ブロックされます"
msgstr "Firefox'da audio bloklangan."

msgid "対象アクションを起こした時のビープ音"
msgstr "Belgilangan harakat bajarilganda bip tovushi chiqadi"

msgid "有効 音量小さ目"
msgstr "Yoqilgan, ovoz past"

msgid "有効 音量大き目"
msgstr "Faol, hajmi yuqori darajaga o'rnatilgan"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Ogohlantirish ko'rsatilayotgan paytda barcha klaviatura va sichqoncha voqealariga javoban bip tovushi yangraydi."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Ogohlantirish ekranda ko'rsatilayotgan paytda qurilma nazoratdan chiqqandek taassurot paydo bo'ladi."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Muayyan harakat bajarilganda sichqoncha kursorini yashirish"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Ogohlantirish ko'rsatilayotgan paytda brauzer hududida sichqoncha kursorini yashiradi."

msgid "デバッグモード"
msgstr "Xatoliklarni tuzatish rejimi"

msgid "妨害＋記録のみ"
msgstr "Faqat aralashuv + yozuvlar"

