msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Son stil MRI pa ChatGPT – 1 minit 14.9 segonn – 3,340,392 bytes – 320 kbps – Lisans: Domèn Piblik"

msgid "警告表示中のBGMを選択します"
msgstr "Chwazi mizik fon an pou jwe pandan yon avètisman."

msgid "びっくりするような雰囲気を作ります"
msgstr "Li kreye yon atmosfè siprizan."

msgid "Firefoxでは音声ブロックされます"
msgstr "Odyo bloke nan Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Yon bip lè aksyon espesifye a fèt"

msgid "有効 音量小さ目"
msgstr "Mete l, volim ba"

msgid "有効 音量大き目"
msgstr "Aktif, volim la wo"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Yon bip ap sonnen pou reponn tout evènman kle ak sourit pandan y ap afiche yon avètisman."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Sa kreye enpresyon ke aparèy la ap fonksyone san kontwòl pandan avètisman an ap parèt."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Kache kousè sourit la lè yon aksyon espesifik fèt"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Kache koursè sourit la nan zòn navigatè a pandan y ap afiche yon avètisman."

msgid "デバッグモード"
msgstr "Mòd debogaj"

msgid "妨害＋記録のみ"
msgstr "Entèferans + Rekò sèlman"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Entèferans + Anrejistreman + Afichaj + Redireksyon"

msgid "メニューからは操作できてしまいます"
msgstr "Ou ka toujou jwenn aksè a li atravè meni an."

msgid "Firefoxにおけるデバッグモード"
msgstr "Mòd debogaj nan Firefox"

msgid "ブラウザーコンソール"
msgstr "Konsole navigatè"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "An reyalite, ou ka opere li nan mòd debogaj."

msgid "HTMLソース表示"
msgstr "Gade sous HTML la"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Ou ka fè operasyon an tou senpleman lè w antre yon URL ki kòmanse ak 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Ou ka pwoteje kontni ou lè w konbine sa a ak pwoteksyon HTML."

msgid "印刷"
msgstr "Enprime"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Malgre li anpeche enprime, li ka pa fonksyone kòrèkteman nan kèk navigatè."

msgid "スクリーンショット"
msgstr "Kaptire ekran"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Dapre sistèm operasyon an, navigatè a oswa metòd ki itilize a, li ka pa posib pou bloke sa a, oswa li ka pa detekte."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Sispèk kapti ekran lè fenèt la deplase nan background la"

msgid "あわせて、スクリーンショット以外の機能（タブ切り替え・ウィンドウ切り替え）にも反応してしまいます。"
