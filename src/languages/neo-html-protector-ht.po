msgid "設定"
msgstr "Aranjman"

msgid "IPログリーダー"
msgstr "Lektè Jounal IP"

msgid "IPアドレスログ"
msgstr "Jounal adrès IP"

msgid "全クリア"
msgstr "Konplete tout nivo yo"

msgid "IPログが全て削除されました"
msgstr "Tout jounal IP yo efase."

msgid "ID"
msgstr "ID"

msgid "タイムスタンプ"
msgstr "Mak tan"

msgid "IPアドレス"
msgstr "Adrès IP"

msgid "ユーザーエージェント"
msgstr "Ajan itilizatè"

msgid "イベント"
msgstr "Evènman"

msgid "IPアドレスのデータはありません"
msgstr "Pa gen done pou adrès IP a."

msgid "EU GDPR対応"
msgstr "Konfòmite ak GDPR Inyon Ewopeyèn nan"

msgid "無効"
msgstr "Envayid"

msgid "有効"
msgstr "Valab"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Si w ap itilize WordPress nan Inyon Ewopeyen an, oswa si sitwèb ou vize itilizatè nan Inyon Ewopeyen an, tanpri asire w ke sa a aktive."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Bouton 'Konfime' a ap chanje pou 'Akò' oswa 'Pa dakò', epi konpòtman an ap chanje yon ti kras."

msgid "同意画面の色"
msgstr "Koulè ekran konsantman an"

msgid "自動"
msgstr "Otomatik"

msgid "ライトモード"
msgstr "Mòd klè"

msgid "ダークモード"
msgstr "Mòd Fènwa"

msgid "同意画面表示中の配色を設定します"
msgstr "Mete konbinezon koulè pou ekran konsantman an"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Flou kontni sou ekran konsantman an"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Ajiste nivo flou pou kontni ki parèt sou ekran konsantman an"

msgid "同意画面の透過"
msgstr "Transparans ekran konsantman an"

msgid "透過なし"
msgstr "Pa gen transparans"

msgid "同意画面の透過具合を設定します"
msgstr "Mete opasite ekran konsantman an"

msgid "お知らせの1行目"
msgstr "Premye liy anons la"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Mesaj sa a toujou parèt premye fwa paj la chaje."

msgid "お知らせの2行目"
msgstr "Dezyèm liy avi a"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Mesaj sa a ap toujou parèt sou premye afichaj la sèlman lè GDPR Inyon Ewopeyen an an vigè."

msgid "お知らせの3行目"
msgstr "Twazyèm liy avi a"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Li pral parèt sou bò dwat lyen Règleman sou Konfidansyalite a."

msgid "非EU向け確認の文字列"
msgstr "Tèks konfimasyon pou peyi ki pa nan Inyon Ewopeyen an"

msgid "EU GDPR向け同意するの文字列"
msgstr "Tèks konsantman pou GDPR Inyon Ewopeyen an"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Tèks pou 'Pa bay konsantman' anba GDPR Inyon Ewopeyen an"

msgid "プライバシーポリシーの文字列"
msgstr "Tèks politik konfidansyalite"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Tanpri mete URL pou politik konfidansyalite a isit la."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Tanpri ajoute sa ki annapre nan Règleman sou Konfidansyalite a."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Pou detekte aktivite fwod, idantifyan tankou adrès IP yo estoke nan cookies ak baz done. Done ki estoke yo efase selon diskresyon administratè a."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Pou asire imaj yo delivre kòrèkteman sèlman lè pwoteksyon imaj la aktive, nou estoke done haché ki gen adrès IP a ak non fichye imaj la nan baz done a pou jiska 60 minit."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Si w ap mete sou pye Kondisyon Itilizasyon, tanpri asire w ou mete yon lyen ki mennen nan yo nan Règleman sou Konfidansyalite w la."

msgid "利用規約の文字列"
msgstr "Tèks Kondisyon Itilizasyon yo"

msgid "利用規約のページ"
msgstr "Paj Tèm ak Kondisyon"

msgid "ページ選択なし"
msgstr "Pa gen paj ki chwazi"

msgid "検索エンジン等のURL"
msgstr "URL pou motè rechèch, elatriye."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Etabli URL pou motè rechèch ak sit ki sanble ki redirije itilizatè yo lè yo pa bay konsantman."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mòd debogaj, mesaj avètisman sou konsòl la"

msgid "右クリックの警告メッセージ"
msgstr "Mesaj avètisman klike dwat"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Mesaj avètisman konsènan enprime ak anrejistre kòm PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Mesaj avètisman nan kapti ekran an"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Mesaj avètisman konsènan foto ekran sispèk"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Mesaj avètisman lè tout tèks la seleksyone"

msgid "ページ保存の警告メッセージ"
msgstr "Mesaj avètisman konsènan anrejistreman paj la"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Mesaj ki parèt lè w ap kopye oswa koupe"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Mesaj pou afiche lè w ap gade kòd sous HTML la."

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Mesaj pou afiche anlè kòd sous la lè w ap obfuskate oswa pwoteje HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Mesaj pou afiche si jeton otantifikasyon yon sèl fwa a pa valab pandan pwoteksyon HTML la."

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Mesaj pou afiche si cookie oswa JavaScript dezaktive"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "An reyalite, sa a sèlman parèt lè JavaScript dezaktive."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Lè yon imaj pwoteje, li telechaje epi yon mesaj parèt sou imaj la"

msgid "HTML難読化 (圧縮)"
msgstr "Obfwasyon HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Sa a se konpresyon HTML estanda; genyen tou sit entènèt ki ka dechifre li."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Lè w aktive opsyon sa a, sa pèmèt ou rekipere jounal sous vizyalizasyon an."

msgid "HTML保護"
msgstr "Pwoteksyon HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Li pwodui sèlman HTML ki pi minimòm lan—menm mwens pase lè w ap itilize konpresyon HTML—epi kontni ki nan etikèt BODY a pap parèt ditou."

msgid "Firefoxに対しては無効です"
msgstr "Sa a pa aplike pou Firefox"

msgid "SEOに著しく影響があります"
msgstr "Sa gen yon enpak siyifikatif sou SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Rendè HTML ak JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Pou kontoune Firefox, nou rande HTML la ak JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Pèmèt JavaScript rande ap ralanti anpil vitès chajman sit wèb la."

msgid "画像の保護"
msgstr "Pwoteksyon imaj"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Pwoteje imaj la chak fwa yo rele etikèt img la."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Pwoteje tout imaj telechaje sou WordPress nan tout pwodiksyon HTML la."

msgid "画像をダウンロードから保護します"
msgstr "Pwoteje imaj pou yo pa telechaje yo"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Lè done imaj yo pwoteje, nou prèske konplètman anpeche telechajman, nou bay URL inik pou yon sèl fwa, nou otantifye ak jeton ki estoke nan sesyon an, epi nou afiche imaj yo atravè PHP; sa a efektivman anpeche vòl imaj."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Lè done imaj yo pwoteje, kachaj pa mache, sa vle di sit la ap chaje pi dousman nan vizit ki vin apre yo, konsa li afekte SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Pwoteje done imaj yo ka ogmante chaj sou baz done a."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Si ou chwazi 'Pwoteje imaj chak fwa yo rele yon etikèt img', sistèm nan itilize add_filter pou aplike filtraj lè etikèt img la jenere; sepandan, sa ka pa mache kòrèkteman ak kèk tèm."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Si ou chwazi 'Pwoteje tout imaj telechaje sou WordPress nan tout pwodiksyon HTML la', plugin nan ap kaptire prèske tout operasyon WordPress epi trete chak etikèt img nan kontni an. Tanpri sonje ke sa ka pa fonksyone kòrèkteman ak kèk tèm."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Tanpri note ke imaj ki deziyen kòm imaj vedèt yo pral pataje kòm done OGP e yo pa ka pwoteje. Si ou absoliman bezwen pwoteje yo, tanpri chanje paramèt pou pwodiksyon etikèt HEAD nan paramèt avanse lè w ap aktive pwoteksyon HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Fonksyon kaptire ekran ki enkli kòm estanda nan sistèm operasyon an pa ka pwoteje"

msgid "画像URLの保護"
msgstr "Pwoteje URL imaj yo"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Sa a dwe itilize ansanm ak pwoteksyon imaj; poukont li, li pa gen okenn itilite."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Kòm li chaje parese atravè JavaScript, sa afekte SEO."

msgid "画像のウォーターマーク"
msgstr "Filigran imaj"

msgid "右下"
msgstr "Anba adwat"

msgid "ランダム位置"
msgstr "Pozisyon o aza"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Lè yo itilize ansanm ak pwoteksyon imaj, filigran dinamik yo endike klèman pwopriyetè dwa otè a pandan y ap bay moun k ap gade yo enpresyon ke y ap siveye, konsa yo sèvi kòm yon faktè dekourajan."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Se sèlman fòma JPG, PNG ak WebP ki sipòte."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Lè w aktive sa a, sa ap ogmante chaj sou sèvè a."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Pwodui atizay ASCII apati kòd sous HTML pandan obfuskasyon ak pwoteksyon HTML"

msgid "表示なし"
msgstr "Pa gen afichaj"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Afiche atizay ASCII ki endike yon avètisman lè w ap gade kòd sous HTML la ak 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Afiche konsepsyon an lè aksyon sib la fèt."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Yon konsepsyon debaz ki gen tèks nwa sou yon fon jòn."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Yon konsepsyon stil laterè ki gen tèks wouj sou yon fon nwa."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Yon konsepsyon ki gen tèks wouj ki klere sou yon fon nwa"

msgid "対象アクションを起こした時のBGM"
msgstr "Mizik an fon ki jwe lè aksyon sib la fèt"

msgid "サウンドなし"
msgstr "Pa gen son"

