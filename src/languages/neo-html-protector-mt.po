msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare – 22.3 sekondi – 183,926 bajts – 64 kbps – Liċenzja: Domenju Pubbliku"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Fanfara b'stil retro – 2.2 sekondi – 10,536 bajts – 32 kbps – Liċenzja: Domenju Pubbliku"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Introduzzjoni b'stil retro – 42.1 sekondi – 179,138 bajts – 32 kbps – Liċenzja: Domenju Pubbliku"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Twissija minn ChatGPT - 3.8 sekondi - 109,700 bajts - 256 kbps - Liċenzja: Domenju Pubbliku"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Ħoss ta' urġenza għolja bħal allerta ta' skoperta ta' malware – Parti 1 minn ChatGPT – 3.3 sekondi – 102,850 bajts – 256 kbps – Liċenzja: Domenju Pubbliku"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Ħoss ta' urġenza għolja bħal allerta ta' skoperta ta' malware, Parti 2 minn ChatGPT - 3.3 sekondi - 103,122 bajts - 256 kbps - Liċenzja: Domenju Pubbliku"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Ħoss b'stil MRI minn ChatGPT – 1 minuta u 14.9 sekondi – 3,340,392 bajts – 320 kbps – Liċenzja: Domenju Pubbliku"

msgid "警告表示中のBGMを選択します"
msgstr "Agħżel il-mużika ta' sfond biex tintlagħab waqt twissija."

msgid "びっくりするような雰囲気を作ります"
msgstr "Joħloq atmosfera sorprendenti"

msgid "Firefoxでは音声ブロックされます"
msgstr "L-awdjo huwa mblukkat f'Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Bip meta l-azzjoni speċifikata titwettaq"

msgid "有効 音量小さ目"
msgstr "Mixgħul, volum baxx"

msgid "有効 音量大き目"
msgstr "Attiv, il-volum issettjat fuq għoli"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Se tinħareġ sinjal ta' bip għal kull avveniment tat-tastiera u tal-maws, filwaqt li jintwera twissija."

