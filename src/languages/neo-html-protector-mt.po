msgid "設定"
msgstr "Issettjarijiet"

msgid "IPログリーダー"
msgstr "Qarrej tal-Logs tal-IP"

msgid "IPアドレスログ"
msgstr "Reġistru tal-indirizzi IP"

msgid "全クリア"
msgstr "Kompleta l-livelli kollha"

msgid "IPログが全て削除されました"
msgstr "Il-logijiet kollha tal-IP ġew imħassra."

msgid "ID"
msgstr "Identifikazzjoni"

msgid "タイムスタンプ"
msgstr "Ħin tal-istampa"

msgid "IPアドレス"
msgstr "Indirizz IP"

msgid "ユーザーエージェント"
msgstr "Aġent tal-utent"

msgid "イベント"
msgstr "Avveniment"

msgid "IPアドレスのデータはありません"
msgstr "M'hemm l-ebda dejta għal din l-indirizz IP."

msgid "EU GDPR対応"
msgstr "Konformità mal-GDPR tal-UE"

msgid "無効"
msgstr "Invalid"

msgid "有効"
msgstr "Validu"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Jekk qed tuża WordPress fl-Unjoni Ewropea, jew jekk is-sit web tiegħek huwa mmirat lejn utenti fl-Unjoni Ewropea, jekk jogħġbok kun żgur li dan ikun attivat."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Il-buttuna 'Ikkonferma' se tinbidel f' 'Jaqbel' jew 'Ma jaqbilx', u l-imġiba se tinbidel ftit."

msgid "同意画面の色"
msgstr "Il-kulur tal-iskrin tal-kunsens"

msgid "自動"
msgstr "Awtomatiku"

msgid "ライトモード"
msgstr "Modalità ħafifa"

msgid "ダークモード"
msgstr "Modalità skura"

msgid "同意画面表示中の配色を設定します"
msgstr "Issettja l-iskema tal-kuluri għas-skrin tal-kunsens"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Imċajpar tal-kontenut fuq l-iskrin tal-kunsens"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Issettja l-livell ta' offuscament għall-kontenut li jidher fuq l-iskrin tal-kunsens"

msgid "同意画面の透過"
msgstr "Trasparenza tal-iskrin tal-kunsens"

msgid "透過なし"
msgstr "L-ebda trasparenza"

msgid "同意画面の透過具合を設定します"
msgstr "Issettja l-opaku tal-iskrin tal-kunsens"

msgid "お知らせの1行目"
msgstr "L-ewwel linja tal-annunzju"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Dan il-messaġġ jidher dejjem l-ewwel darba li l-paġna titgħabba"

msgid "お知らせの2行目"
msgstr "It-tieni linja tan-notifika"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Dan il-messaġġ se jidher dejjem fuq l-ewwel wirja biss meta l-GDPR tal-UE ikun fis-seħħ."

msgid "お知らせの3行目"
msgstr "It-tielet linja tan-notifika"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Se jidher fuq il-lemin tal-link għall-Politika tal-Privatezza."

msgid "非EU向け確認の文字列"
msgstr "Test ta' konferma għall-pajjiżi mhux tal-UE"

msgid "EU GDPR向け同意するの文字列"
msgstr "Test ta' kunsens għall-GDPR tal-UE"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Test għal 'Ma tagħtix il-kunsens' skont il-GDPR tal-UE"

msgid "プライバシーポリシーの文字列"
msgstr "Test tal-politika tal-privatezza"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Jekk jogħġbok issettja l-URL tal-politika tal-privatezza hawnhekk."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Jekk jogħġbok żid dan li ġej mal-Politika tal-Privatezza."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Biex jiġu skoperti attivitajiet frodulenti, identifikaturi bħal indirizzi IP jinħażnu fil-cookies u fid-database. Id-dejta maħżuna titħassar skont id-diskrezzjoni tal-amministratur."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Biex niżguraw li l-immaġini jitwasslu b'mod korrett meta l-protezzjoni tal-immaġini tkun attivata, aħna naħżnu fid-database tagħna data imhashjata li tinkludi l-indirizz IP u l-isem tal-fajl tal-immaġni għal sa 60 minuta."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Jekk qed toħloq Termini ta' Użu, jekk jogħġbok kun żgur li tinkludi link għalihom fil-Politika tal-Privatezza tiegħek."

msgid "利用規約の文字列"
msgstr "Test tat-Termini ta' Użu"

msgid "利用規約のページ"
msgstr "Paġna tat-Termini u l-Kundizzjonijiet"

msgid "ページ選択なし"
msgstr "L-ebda paġna ma ġiet magħżula"

msgid "検索エンジン等のURL"
msgstr "URLs għal magni tat-tiftix, eċċ."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Issettja l-URL għat-magni tat-tiftix u siti simili li jirreindirizzaw l-utenti meta ma jagħtux il-kunsens tagħhom."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Modalità ta' debug, messaġġi ta' twissija fil-konsola"

msgid "右クリックの警告メッセージ"
msgstr "Messaġġ ta' twissija bil-klik tal-lemin"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Messaġġ ta' twissija dwar il-istampar u l-ħażna bħala PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Messaġġ ta' twissija fis-screenshot"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Messaġġ ta' twissija rigward screenshots suspettati"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Messaġġ ta' twissija meta tkun magħżula l-kull test"

msgid "ページ保存の警告メッセージ"
msgstr "Messaġġ ta' twissija dwar l-iffrankar tal-paġna"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Messaġġ li jidher meta tikkopja jew taqta'"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Messaġġ li jidher meta tkun qed tara s-sors tal-HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Messaġġ li jidher fil-quċċata tal-kodiċi sors meta tkun qed tiffoska jew tipproteġi l-HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Messaġġ li jidher jekk it-token ta' awtentikazzjoni ta' darba jkun invalidu waqt il-protezzjoni HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Messaġġ li jidher jekk il-cookies jew il-JavaScript ikunu diżattivati"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Fil-fatt, dan jidher biss meta JavaScript ikun diżattivat."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Meta immaġni tkun protetta, tiġi mniżżla, u jidher messaġġ fuq dik l-immaġni"

msgid "HTML難読化 (圧縮)"
msgstr "Obfuskazzjoni"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Din hija kompressjoni standard ta' HTML; hemm ukoll siti web li jistgħu jiddekodifikawha."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "L-attivazzjoni ta' din l-għażla tippermettilek tirrekupera l-logs tal-view-source."

msgid "HTML保護"
msgstr "Protezzjoni tal-HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Jipproduċi anqas HTML minn dik tal-issettjar ta' kompressjoni tal-HTML, li jfisser li l-kontenut ġewwa t-tag BODY mhux se jiġi pproduċut xejn."

msgid "Firefoxに対しては無効です"
msgstr "Dan ma japplikax għal Firefox"

msgid "SEOに著しく影響があります"
msgstr "Dan għandu impatt sinifikanti fuq l-SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Ġenerazzjoni ta' HTML billi tuża JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Biex naħdmu madwar Firefox, nirendjaw l-HTML billi nużaw JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "L-attivazzjoni tar-rendering ta' JavaScript se tnaqqas b'mod sinifikanti l-veloċità tat-tagħbija tal-websajt."

msgid "画像の保護"
msgstr "Protezzjoni tal-immaġni"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Ħares l-immaġni kull darba li tiġi msejħa t-tikketta img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Ħares l-immaġini kollha mniżżla fuq WordPress fi ħdan l-output kollu tal-HTML."

msgid "画像をダウンロードから保護します"
msgstr "Jipproteġi l-immaġini milli jitniżżlu"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Meta d-dejta tal-immaġni tkun protetta, nipprevjenu kważi l-downloads kollha, noħorġu URLs uniċi ta' darba biss, nikkawtentaw billi nużaw tokens maħżuna fis-sessjoni, u nuru l-immaġini permezz ta' PHP; dan jipprevjeni b'mod effettiv kważi l-każijiet kollha ta' serq ta' immaġni."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Meta d-dejta tal-immaġini tkun protetta, il-kaching ma jaħdimx, li jfisser li s-sit se jitgħabba aktar bil-mod f'żjarat sussegwenti, u b'hekk jaffettwa l-SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Il-protezzjoni tad-dejta tal-immaġni tista' żżid il-piż fuq il-bażi tad-dejta."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Jekk tagħżel 'Ipproteġi l-immaġini kull meta jkun sejjaħ tag img', is-sistema tuża add_filter biex tapplika l-filtrazzjoni meta jiġi ġġenerat it-tag img; madankollu, dan jista' ma jaħdimx b'mod korrett ma' ċerti temi."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Jekk tagħżel 'Ipproteġi l-immaġini kollha mniżżla f'WordPress fl-output kollu tal-HTML', il-plugin se jaqbad kważi l-operazzjonijiet kollha ta' WordPress u jipproċessa kull tag img fil-kontenut. Jekk jogħġbok innota li dan jista' ma jaħdimx b'mod korrett ma' xi temi."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Jekk jogħġbok innota li l-immaġini mmarkati bħala featured images se jiġu maqsuma bħala data OGP u ma jistgħux jiġu protetti. Jekk tassew trid tipproteġihom, jekk jogħġbok ibdel l-issettjar għall-output tat-tag HEAD fl-issettjar avvanzat meta tattiva l-protezzjoni HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Il-funzjoni tal-iskrinshot inkluża bħala standard fis-sistema operattiva ma tistax tiġi protetta."

msgid "画像URLの保護"
msgstr "Il-protezzjoni tal-URLs tal-immaġini"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Dan għandu jintuża flimkien ma' protezzjoni tal-immaġni; waħdu, m'għandu l-ebda skop."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Peress li huwa mgħobbi permezz ta' JavaScript, dan jaffettwa l-SEO."

msgid "画像のウォーターマーク"
msgstr "Ilmaġġ tal-immaġni"

msgid "右下"
msgstr "Taħt il-lemin"

msgid "ランダム位置"
msgstr "Pożizzjoni każwali"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Użati flimkien ma' protezzjoni tal-immaġni, il-marki tal-ilma dinamici juru b'mod ċar min hu s-sid tad-drittijiet tal-awtur, filwaqt li jagħtu lill-osservaturi l-impressjoni li qed jiġu mmonitorjati, u b'hekk jaġixxu bħala deterrent."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Hemm appoġġ biss għall-formati JPG, PNG u WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "L-attivazzjoni ta' dan se żżid il-piż fuq is-server."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ġenerazzjoni ta' arti ASCII minn kodiċi sors HTML waqt obfuskazzjoni u protezzjoni"

msgid "表示なし"
msgstr "L-ebda wirja"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Juri arti ASCII li tindika twissija meta tkun qed tara s-sors tal-HTML billi tuża 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Uri d-disinn meta l-azzjoni fil-mira titwettaq"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Disinn bażiku b'test iswed fuq sfond isfar"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Disinn b'stil ta' orrur b'test aħmar fuq sfond iswed"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Disinn li jinkludi test aħmar jiddi fuq sfond iswed"

msgid "対象アクションを起こした時のBGM"
msgstr "Mużika ta' sfond li tinħareġ meta l-azzjoni fil-mira titwettaq"

msgid "サウンドなし"
msgstr "L-ebda ħoss"

