msgid "設定"
msgstr "Cài đặt"

msgid "IPログリーダー"
msgstr "Trình đọc nhật ký IP"

msgid "IPアドレスログ"
msgstr "Nhật ký địa chỉ IP"

msgid "全クリア"
msgstr "Hoàn thành tất cả"

msgid "IPログが全て削除されました"
msgstr "Tất cả các bản ghi IP đã bị xóa"

msgid "ID"
msgstr "ID"

msgid "タイムスタンプ"
msgstr "Dấu thời gian"

msgid "IPアドレス"
msgstr "Địa chỉ IP"

msgid "ユーザーエージェント"
msgstr "Trình duyệt"

msgid "イベント"
msgstr "Sự kiện"

msgid "IPアドレスのデータはありません"
msgstr "Không có dữ liệu về địa chỉ IP"

msgid "EU GDPR対応"
msgstr "Tuân thủ Quy định chung về bảo vệ dữ liệu của EU"

msgid "無効"
msgstr "Không hợp lệ"

msgid "有効"
msgstr "Hiệu lực"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Nếu bạn sử dụng WordPress trong khu vực EU, hoặc nếu trang web của bạn nhắm đến người dùng trong khu vực EU, hãy nhớ kích hoạt tính năng này"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Nút Xác nhận sẽ được thay thế bằng nút Đồng ý hoặc Không đồng ý, và cách thức hoạt động sẽ có một chút thay đổi"

msgid "同意画面の色"
msgstr "Màu của màn hình xác nhận"

msgid "自動"
msgstr "Tự động"

msgid "ライトモード"
msgstr "Chế độ sáng"

msgid "ダークモード"
msgstr "Chế độ tối"

msgid "同意画面表示中の配色を設定します"
msgstr "Cài đặt màu sắc cho màn hình xác nhận"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Làm mờ nội dung trên màn hình xác nhận"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Cài đặt mức độ làm mờ nội dung khi hiển thị màn hình xác nhận"

msgid "同意画面の透過"
msgstr "Độ trong suốt của màn hình xác nhận"

msgid "透過なし"
msgstr "Không trong suốt"

msgid "同意画面の透過具合を設定します"
msgstr "Cài đặt độ trong suốt của màn hình xác nhận"

msgid "お知らせの1行目"
msgstr "Dòng đầu tiên của thông báo"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Đây là thông báo luôn hiển thị khi truy cập lần đầu"

msgid "お知らせの2行目"
msgstr "Dòng thứ hai của thông báo"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Đây là thông báo sẽ luôn hiển thị trong lần hiển thị đầu tiên, chỉ khi Quy định chung về bảo vệ dữ liệu của EU"

msgid "お知らせの3行目"
msgstr "Dòng thứ ba của thông báo"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Sẽ hiển thị ở bên phải liên kết Chính sách bảo mật"

msgid "非EU向け確認の文字列"
msgstr "Dòng xác nhận dành cho các thị trường ngoài EU"

msgid "EU GDPR向け同意するの文字列"
msgstr "Dòng văn bản về việc đồng ý theo Quy định chung về bảo vệ dữ liệu của EU"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Dòng văn bản từ chối đồng ý theo Quy định chung về bảo vệ dữ liệu của EU"

msgid "プライバシーポリシーの文字列"
msgstr "Nội dung Chính sách bảo mật"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Vui lòng thiết lập URL của Chính sách bảo mật tại đây"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Vui lòng bổ sung các nội dung sau vào Chính sách bảo mật"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Để phát hiện các hành vi thao túng trái phép, chúng tôi sẽ lưu trữ các thông tin nhận dạng như địa chỉ IP vào cookie và cơ sở dữ liệu. Dữ liệu được lưu trữ sẽ được xóa theo quyết định của người quản trị vào bất kỳ thời điểm nào."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Chỉ khi tính năng bảo vệ hình ảnh được kích hoạt, để đảm bảo hình ảnh được phân phối bình thường, dữ liệu băm từ địa chỉ IP và tên tệp hình ảnh sẽ được lưu trữ trong cơ sở dữ liệu tối đa 60 phút."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Khi thiết lập Điều khoản sử dụng, vui lòng đảm bảo rằng bạn đã chèn liên kết đến Điều khoản sử dụng trong Chính sách bảo mật"

msgid "利用規約の文字列"
msgstr "Nội dung Điều khoản sử dụng"

msgid "利用規約のページ"
msgstr "Trang Điều khoản sử dụng"

msgid "ページ選択なし"
msgstr "Không chọn trang"

msgid "検索エンジン等のURL"
msgstr "URL của công cụ tìm kiếm, v.v."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Cài đặt URL của các công cụ tìm kiếm sẽ chuyển sang trang khác khi người dùng không đồng ý"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Chế độ gỡ lỗi, thông báo cảnh báo trên bảng điều khiển"

msgid "右クリックの警告メッセージ"
msgstr "Thông báo cảnh báo khi nhấp chuột phải"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Thông báo cảnh báo khi in hoặc lưu dưới dạng PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Thông báo cảnh báo trên ảnh chụp màn hình"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Thông báo cảnh báo về ảnh chụp màn hình nghi ngờ"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Thông báo cảnh báo khi chọn toàn bộ văn bản"

msgid "ページ保存の警告メッセージ"
msgstr "Thông báo cảnh báo khi lưu trang"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Thông báo hiển thị khi sao chép hoặc cắt"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Thông báo hiển thị khi xem mã nguồn HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Thông báo hiển thị ở đầu mã nguồn khi mã hóa và bảo vệ HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Thông báo hiển thị khi mã xác thực dùng một lần gặp sự cố trong quá trình bảo vệ HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Thông báo hiển thị khi Cookie và Javascript bị tắt"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Trên thực tế, nội dung này chỉ hiển thị khi JavaScript bị tắt"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Khi hình ảnh được bảo vệ, hình ảnh đó sẽ được tải xuống và thông báo hiển thị trên hình ảnh đó chỉ có tiếng Anh"

msgid "HTML難読化 (圧縮)"
msgstr "Làm rối mã HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Đây là phương pháp nén HTML thông thường; cũng có một số trang web giúp giải mã mã hóa"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Khi bật tùy chọn này, bạn có thể lấy nhật ký view-source"

msgid "HTML保護"
msgstr "Bảo vệ HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Không chỉ nén HTML mà còn chỉ xuất ra lượng HTML tối thiểu, khiến nội dung bên trong thẻ BODY hoàn toàn không được hiển thị"

msgid "Firefoxに対しては無効です"
msgstr "Tính năng này không hoạt động trên Firefox"

msgid "SEOに著しく影響があります"
msgstr "Điều này có ảnh hưởng đáng kể đến SEO"

msgid "HTMLをJavaScriptで描画"
msgstr "Vẽ HTML bằng JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Để đối phó với Firefox, chúng tôi sẽ hiển thị HTML bằng JavaScript"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Nếu bật tính năng vẽ bằng JavaScript, tốc độ hiển thị trang web sẽ chậm đi đáng kể"

msgid "画像の保護"
msgstr "Bảo vệ hình ảnh"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Bảo vệ hình ảnh mỗi khi thẻ img được gọi"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Bảo vệ tất cả các hình ảnh đã được tải lên WordPress trong toàn bộ mã HTML được xuất ra"

msgid "画像をダウンロードから保護します"
msgstr "Bảo vệ hình ảnh khỏi bị tải xuống"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Khi bảo vệ dữ liệu hình ảnh, hệ thống sẽ ngăn chặn gần như hoàn toàn việc tải xuống trái phép, cấp phát URL dùng một lần duy nhất, xác thực thông qua mã thông báo được lưu trữ trong phiên làm việc và hiển thị hình ảnh thông qua PHP; nhờ đó, hệ thống ngăn chặn gần như hoàn toàn việc đánh cắp hình ảnh."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Khi dữ liệu hình ảnh được bảo vệ, bộ nhớ đệm hình ảnh sẽ không hoạt động, dẫn đến việc trang web tải chậm hơn trong lần truy cập tiếp theo, từ đó ảnh hưởng đến SEO"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Khi bảo vệ dữ liệu hình ảnh, tải trọng của cơ sở dữ liệu có thể tăng cao"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Trong trường hợp “bảo vệ hình ảnh mỗi khi thẻ img được gọi”, hãy sử dụng add_filter để thực hiện lọc khi thẻ img được phát ra; tuy nhiên, tùy thuộc vào chủ đề, chức năng này có thể không hoạt động chính xác"

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Trong trường hợp chọn “Bảo vệ tất cả hình ảnh được tải lên WordPress trong toàn bộ mã HTML được xuất ra”, hệ thống sẽ ghi lại gần như toàn bộ hoạt động của WordPress và xử lý tất cả các thẻ img trong nội dung. Tùy thuộc vào chủ đề, tính năng này có thể không hoạt động chính xác"

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Xin lưu ý rằng hình ảnh được chỉ định làm hình ảnh nổi bật sẽ được chia sẻ dưới dạng OGP nên không thể bảo vệ được. Nếu nhất định phải bảo vệ, vui lòng thay đổi tùy chọn xuất thẻ HEAD trong phần cài đặt nâng cao khi kích hoạt bảo vệ HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Không thể bảo vệ tính năng chụp ảnh màn hình được cài đặt sẵn trong hệ điều hành"

msgid "画像URLの保護"
msgstr "Bảo vệ URL hình ảnh"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Sử dụng kết hợp với tính năng bảo vệ hình ảnh; nếu dùng riêng lẻ thì không có ý nghĩa gì"

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Vì nội dung được tải chậm nhờ JavaScript nên sẽ ảnh hưởng đến SEO"

msgid "画像のウォーターマーク"
msgstr "Hình mờ trên ảnh"

msgid "右下"
msgstr "Góc dưới bên phải"

msgid "ランダム位置"
msgstr "Vị trí ngẫu nhiên"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Sử dụng kết hợp với tính năng bảo vệ hình ảnh; bằng cách sử dụng hình mờ động để thể hiện rõ quyền tác giả, đồng thời tạo cảm giác cho người xem rằng họ đang bị theo dõi, từ đó tăng cường hiệu quả răn đe"

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Chỉ hỗ trợ định dạng JPG, PNG và WebP"

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Nếu bật tính năng này, tải trọng của máy chủ sẽ tăng lên"

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Hiển thị mã ASCII từ mã nguồn HTML khi mã hóa và bảo vệ HTML"

msgid "表示なし"
msgstr "Không hiển thị"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Khi hiển thị mã nguồn HTML bằng lệnh `view-source`, hệ thống sẽ hiển thị hình ảnh ASCII biểu thị cảnh báo"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Thiết kế hiển thị khi thực hiện hành động tương ứng"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Thiết kế cơ bản với chữ đen trên nền vàng"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Thiết kế theo phong cách kinh dị với chữ đỏ trên nền đen"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Thiết kế chữ đỏ phát sáng trên nền đen"

msgid "対象アクションを起こした時のBGM"
msgstr "Nhạc nền khi thực hiện hành động tương ứng"

msgid "サウンドなし"
msgstr "Không có âm thanh"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Chiến đấu & Chiến thắng - 1 phút 16,3 giây - 630.056 byte - 64 kbps - Giấy phép: CC 2.1 trở lên"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Short - 3,8 giây - 32.364 byte - 64 kbps - Giấy phép GPL 2.0 hoặc mới hơn"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23,5 giây - 195.578 byte - 64 kbps - Giấy phép GPL 2.0 hoặc mới hơn"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin: Etude Op.10-5"

msgid "ショパン エチュード Op.10-12 革命 打ち込み版 高速版 - 1分57.6秒 - 724,457bytes - 48kbps -  ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin: Etude Op.10-12 Cách mạng - Phiên bản nhập liệu - Phiên bản tốc độ cao - 1 phút 57,6 giây - 724.457 byte - 48 kbps - Giấy phép: CC BY-ND 4.0 hoặc phiên bản mới hơn"

msgid "ショパン スケルツォ 変ロ短調 Op2 打ち込み版 高速短縮版 - 1分48.0秒 - 665,369bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin: Scherzo, giọng Si thứ, Op. 2 – Phiên bản nhạc điện tử, bản rút gọn tốc độ cao – 1 phút 48,0 giây – 665.369 byte – 48 kbps – Giấy phép: CC BY-ND 4.0 hoặc phiên bản mới hơn"

msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Danh sách: Etude số 4 Mazeppa - Phiên bản nhập liệu - Phiên bản rút gọn tốc độ cao - 1 phút 51,6 giây - 687.586 byte - 48 kbps - Giấy phép: CC BY-ND 4.0 hoặc phiên bản mới hơn"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
