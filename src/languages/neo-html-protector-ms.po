msgid "設定"
msgstr "Tetapan"

msgid "IPログリーダー"
msgstr "Pembaca Log IP"

msgid "IPアドレスログ"
msgstr "Log alamat IP"

msgid "全クリア"
msgstr "Lengkapkan semua peringkat"

msgid "IPログが全て削除されました"
msgstr "Semua log IP telah dipadamkan."

msgid "ID"
msgstr "ID"

msgid "タイムスタンプ"
msgstr "Cap masa"

msgid "IPアドレス"
msgstr "Alamat IP"

msgid "ユーザーエージェント"
msgstr "Agens Pengguna"

msgid "イベント"
msgstr "Acara"

msgid "IPアドレスのデータはありません"
msgstr "Tiada data untuk alamat IP ini"

msgid "EU GDPR対応"
msgstr "Pematuhan kepada GDPR EU"

msgid "無効"
msgstr "Tidak sah"

msgid "有効"
msgstr "Sah"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Jika anda menggunakan WordPress di dalam EU, atau jika laman web anda menyasarkan pengguna di dalam EU, sila pastikan ini diaktifkan."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Butang 'Konfirmasi' akan berubah menjadi 'Setuju' atau 'Tidak Setuju', dan kelakuannya akan berubah sedikit."

msgid "同意画面の色"
msgstr "Warna skrin persetujuan"

msgid "自動"
msgstr "Otomatik"

msgid "ライトモード"
msgstr "Mod ringan"

msgid "ダークモード"
msgstr "Mod Gelap"

msgid "同意画面表示中の配色を設定します"
msgstr "Tetapkan skema warna untuk skrin persetujuan"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Penyamaran kandungan pada skrin persetujuan"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Tetapkan tahap pengaburan untuk kandungan yang dipaparkan pada skrin persetujuan"

msgid "同意画面の透過"
msgstr "Keterbukaan skrin persetujuan"

msgid "透過なし"
msgstr "Tiada ketelusan"

msgid "同意画面の透過具合を設定します"
msgstr "Tetapkan ketelusan skrin persetujuan"

msgid "お知らせの1行目"
msgstr "Baris pertama pengumuman"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Mesej ini sentiasa dipaparkan pada kali pertama halaman dimuatkan."

msgid "お知らせの2行目"
msgstr "Baris kedua notis itu"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Mesej ini akan sentiasa muncul pada paparan pertama hanya apabila EU GDPR berkuat kuasa."

msgid "お知らせの3行目"
msgstr "Baris ketiga pemberitahuan itu"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ia akan muncul di sebelah kanan pautan kepada Dasar Privasi."

msgid "非EU向け確認の文字列"
msgstr "Teks pengesahan untuk negara bukan EU"

msgid "EU GDPR向け同意するの文字列"
msgstr "Teks persetujuan untuk EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Teks untuk 'Jangan bersetuju' di bawah EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Teks dasar privasi"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Sila tetapkan URL untuk dasar privasi di sini."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Sila tambah yang berikut ke dalam Dasar Privasi."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Untuk mengesan aktiviti penipuan, pengecam seperti alamat IP disimpan dalam kuki dan pangkalan data. Data yang disimpan akan dipadam mengikut budi bicara pentadbir."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Untuk memastikan imej dihantar dengan betul hanya apabila perlindungan imej diaktifkan, kami menyimpan data hashed yang merangkumi alamat IP dan nama fail imej dalam pangkalan data selama sehingga 60 minit."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Jika anda menyediakan Terma Penggunaan, sila pastikan anda menyertakan pautan kepadanya dalam Dasar Privasi anda."

msgid "利用規約の文字列"
msgstr "Teks Terma Penggunaan"

msgid "利用規約のページ"
msgstr "Halaman Terma dan Syarat"

msgid "ページ選択なし"
msgstr "Tiada halaman dipilih"

msgid "検索エンジン等のURL"
msgstr "URL untuk enjin carian, dan sebagainya."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Tetapkan URL untuk enjin carian dan laman serupa yang mengalihkan pengguna apabila kebenaran tidak diberikan"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mod penyahpepijat, mesej amaran konsol"

msgid "右クリックの警告メッセージ"
msgstr "Tetingkap amaran klik kanan"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Mesej amaran mengenai mencetak dan menyimpan sebagai PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Mesej amaran dalam tangkapan skrin"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Mesej amaran mengenai tangkapan skrin yang disyaki"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Mesej amaran apabila semua teks dipilih"

msgid "ページ保存の警告メッセージ"
msgstr "Pesan amaran mengenai penyimpanan halaman"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Mesej yang dipaparkan semasa menyalin atau memotong"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Mesej untuk dipaparkan apabila melihat sumber HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Mesej untuk dipaparkan di bahagian atas kod sumber apabila mengaburkan atau melindungi HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Mesej untuk dipaparkan jika token pengesahan sekali guna tidak sah semasa perlindungan HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Mesej untuk dipaparkan jika kuki atau JavaScript dilumpuhkan"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Sebenarnya, ini hanya dipaparkan apabila JavaScript dilumpuhkan."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Apabila imej dilindungi, ia dimuat turun dan mesej akan dipaparkan pada imej tersebut"

msgid "HTML難読化 (圧縮)"
msgstr "Pengaburan HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Ini adalah pemampatan HTML standard; terdapat juga laman web yang boleh menyahsandi semula."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Mengaktifkan pilihan ini membolehkan anda mendapatkan log sumber tontonan."

msgid "HTML保護"
msgstr "Pelindung HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ia menghasilkan HTML yang lebih sedikit daripada tetapan pemampatan HTML, bermakna kandungan dalam tag BODY langsung tidak akan dikeluarkan."

msgid "Firefoxに対しては無効です"
msgstr "Ini tidak terpakai kepada Firefox"

msgid "SEOに著しく影響があります"
msgstr "Ini mempunyai kesan yang ketara terhadap SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Menyusun HTML menggunakan JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Untuk mengatasi sekatan Firefox, kami menjana HTML menggunakan JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Mengaktifkan render JavaScript akan memperlahankan dengan ketara kelajuan pemuatan laman web."

msgid "画像の保護"
msgstr "Pelindung imej"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Lindungi imej setiap kali tag img dipanggil"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Lindungi semua imej yang dimuat naik ke WordPress dalam keseluruhan keluaran HTML."

msgid "画像をダウンロードから保護します"
msgstr "Melindungi imej daripada dimuat turun"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Apabila data imej dilindungi, kami menghalang hampir semua muat turun, mengeluarkan URL sekali guna yang unik, mengesahkan menggunakan token yang disimpan dalam sesi, dan memaparkan imej melalui PHP; ini secara berkesan menghalang hampir semua kes kecurian imej."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Apabila data imej dilindungi, penimbalan tidak berfungsi, yang bermakna laman web akan memuat lebih perlahan pada lawatan seterusnya, sekali gus menjejaskan SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Melindungi data imej mungkin meningkatkan beban pada pangkalan data."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Jika anda memilih 'Lindungi imej setiap kali tag img dipanggil', sistem akan menggunakan add_filter untuk menerapkan penapisan apabila tag img dijana; bagaimanapun, ini mungkin tidak berfungsi dengan betul pada beberapa tema."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Jika anda memilih 'Lindungi semua imej yang dimuat naik ke WordPress dalam keseluruhan keluaran HTML', pemalam ini akan merakam hampir semua operasi WordPress dan memproses setiap tag img dalam kandungan. Sila ambil perhatian bahawa ini mungkin tidak berfungsi dengan betul pada beberapa tema."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Sila ambil perhatian bahawa imej yang ditetapkan sebagai imej unggulan akan dikongsi sebagai data OGP dan tidak dapat dilindungi. Jika anda benar-benar perlu melindunginya, sila ubah tetapan keluaran tag HEAD dalam tetapan lanjutan apabila mengaktifkan perlindungan HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Fungsi tangkapan skrin yang disertakan sebagai standard dalam sistem pengendalian tidak dapat dilindungi."

msgid "画像URLの保護"
msgstr "Melindungi URL imej"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Ini harus digunakan bersama pelindung imej; jika digunakan sendiri, ia tidak mempunyai sebarang tujuan."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Oleh kerana ia dimuat secara malas melalui JavaScript, ini menjejaskan SEO."

msgid "画像のウォーターマーク"
msgstr "Air tanda imej"

msgid "右下"
msgstr "Bawah kanan"

msgid "ランダム位置"
msgstr "Posisi rawak"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Digunakan bersama perlindungan imej, tanda air dinamik jelas menunjukkan pemilikan hak cipta sambil memberi kesan kepada penonton bahawa mereka dipantau, sekaligus berfungsi sebagai penghalang."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Hanya format JPG, PNG dan WebP disokong."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Mengaktifkan ini akan meningkatkan beban pelayan."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Menghasilkan seni ASCII daripada kod sumber HTML semasa pengaburan dan perlindungan"

msgid "表示なし"
msgstr "Tiada paparan"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Menunjukkan seni ASCII yang menandakan amaran apabila melihat sumber HTML menggunakan 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Tunjukkan reka bentuk apabila tindakan sasaran dilakukan"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Reka bentuk asas yang menampilkan teks hitam pada latar belakang kuning"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Reka bentuk gaya seram yang menampilkan teks merah pada latar belakang hitam"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Reka bentuk yang menampilkan teks merah menyala pada latar belakang hitam"

msgid "対象アクションを起こした時のBGM"
msgstr "Musik latar yang dimainkan apabila tindakan sasaran dilakukan"

msgid "サウンドなし"
msgstr "Tiada bunyi"

