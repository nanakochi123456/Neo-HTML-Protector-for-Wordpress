msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare – 22.3 saat – 183,926 bait – 64 kbps – Lesen: Domain Awam"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare gaya retro – 2.2 saat – 10,536 bait – 32 kbps – Lesen: Domain Awam"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Intro gaya retro – 42.1 saat – 179,138 bait – 32 kbps – Lesen: Domain Awam"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Amaran oleh ChatGPT - 3.8 saat - 109,700 bait - 256 kbps - Lesen: Domain Awam"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Suara kecemasan tinggi seperti amaran pengesanan perisian hasad – Bahagian 1 oleh ChatGPT – 3.3 saat – 102,850 bait – 256 kbps – Lesen: Domain Awam"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Suara kecemasan tinggi seperti amaran pengesanan perisian hasad, Bahagian 2 oleh ChatGPT - 3.3 saat - 103,122 bait - 256 kbps - Lesen: Domain Awam"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Bunyi gaya MRI oleh ChatGPT – 1 minit 14.9 saat – 3,340,392 bait – 320 kbps – Lesen: Domain Awam"

msgid "警告表示中のBGMを選択します"
msgstr "Pilih muzik latar untuk dimainkan semasa amaran."

msgid "びっくりするような雰囲気を作ります"
msgstr "Ia mencipta suasana yang mengejutkan"

msgid "Firefoxでは音声ブロックされます"
msgstr "Audio disekat dalam Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "Bunyi bip apabila tindakan yang ditetapkan dilaksanakan"

msgid "有効 音量小さ目"
msgstr "Dihidupkan, kelantangan rendah"

msgid "有効 音量大き目"
msgstr "Aktif, kelantangan ditetapkan pada tahap tinggi"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Bunyi bip akan kedengaran untuk semua acara kekunci dan tetikus sementara amaran dipaparkan."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Ia memberi kesan bahawa peranti telah menjadi tidak terkawal semasa amaran dipaparkan."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Menyembunyikan penunjuk tetikus apabila tindakan tertentu dilakukan"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Menyembunyikan penunjuk tetikus di kawasan pelayar semasa amaran dipaparkan."

msgid "デバッグモード"
msgstr "Mod periksa ralat"

msgid "妨害＋記録のみ"
msgstr "Gangguan + Rekod sahaja"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Gangguan + Logging + Paparan + Pengalihan"

msgid "メニューからは操作できてしまいます"
msgstr "Anda masih boleh mengaksesnya melalui menu."

msgid "Firefoxにおけるデバッグモード"
msgstr "Mod debug dalam Firefox"

msgid "ブラウザーコンソール"
msgstr "Konsol pelayar"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Sebenarnya, anda boleh mengoperasikannya dalam mod nyahpepijat."

msgid "HTMLソース表示"
msgstr "Lihat sumber HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Anda boleh melaksanakan operasi itu dengan hanya memasukkan URL yang bermula dengan 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Anda boleh melindungi kandungan anda dengan menggabungkan ini dengan perlindungan HTML."

msgid "印刷"
msgstr "Cetak"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Walaupun ia menghalang pencetakan, ia mungkin tidak berfungsi dengan betul dalam beberapa pelayar."

msgid "スクリーンショット"
msgstr "Tangkapan skrin"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Bergantung pada sistem operasi, pelayar atau kaedah yang digunakan, mungkin tidak dapat menyekat ini, atau mungkin tidak dikesan."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Skrinshot yang disyaki apabila tetingkap bergerak ke latar belakang"

msgid "あわせて、スクリーンショット以外の機能（タブ切り替え・ウィンドウ切り替え）にも反応してしまいます。"
msgstr "Ia juga bertindak balas terhadap fungsi selain tangkapan skrin"

