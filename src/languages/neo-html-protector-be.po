msgstr "Бацька Кароткі - 3,8 секунды - 32 364 байты - 64 кбіт/с - Ліцэнзія: GPL 2.0 або пазней"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23,5 секунды - 195 578 байтаў - 64 кбіт/с - Ліцэнзія: GPL 2.0 або пазней"

