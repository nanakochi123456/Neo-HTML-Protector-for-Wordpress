msgid "設定"
msgstr "Налады"

msgid "IPログリーダー"
msgstr "Чытальнік IP-логаў"

msgid "IPアドレスログ"
msgstr "Лог IP-адрасоў"

msgid "全クリア"
msgstr "Здайце ўсе ўзроўні"

msgid "IPログが全て削除されました"
msgstr "Усе логі IP-адрасоў выдалены."

msgid "ID"
msgstr "ID"

msgid "タイムスタンプ"
msgstr "Часавы штамп"

msgid "IPアドレス"
msgstr "IP-адрас"

msgid "ユーザーエージェント"
msgstr "Карыстальніцкі агент"

msgid "イベント"
msgstr "Мерапрыемства"

msgid "IPアドレスのデータはありません"
msgstr "Няма даных для гэтага IP-адраса."

msgid "EU GDPR対応"
msgstr "Адпаведнасць GDPR ЕС"

msgid "無効"
msgstr "Несапраўдны"

msgid "有効"
msgstr "Дзейнічае"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Калі вы выкарыстоўваеце WordPress у ЕС або калі ваш вэб-сайт разлічаны на карыстальнікаў з ЕС, калі ласка, пераканайцеся, што гэта ўключана."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Кнопка «Пацвердзіць» зменіцца на «Згадзіцца» або «Не згадзіцца», і паводзіны крыху зменяцца."

msgid "同意画面の色"
msgstr "Колер экрана згод"

msgid "自動"
msgstr "Аўтаматычны"

msgid "ライトモード"
msgstr "Лёгкі рэжым"

msgid "ダークモード"
msgstr "Цёмны рэжым"

msgid "同意画面表示中の配色を設定します"
msgstr "Устанавіце каляровую схему для экрана згоды"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Размыццё змесціва на экране згоды"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Усталюйце ўзровень размыцця для змесціва, якое адлюстроўваецца на экране згоды."

msgid "同意画面の透過"
msgstr "Празрыстасць экрана згоды"

msgid "透過なし"
msgstr "Няма празрыстасці"

msgid "同意画面の透過具合を設定します"
msgstr "Устанавіце празрыстасць экрана згоды"

msgid "お知らせの1行目"
msgstr "Першы радок аб'явы"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Гэтая паведамленне заўсёды адлюстроўваецца пры першым загрузцы старонкі."

msgid "お知らせの2行目"
msgstr "Другі радок апавяшчэння"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Гэтая абвестка будзе заўсёды адлюстроўвацца толькі на першым экране, калі GDPR ЕС будзе дзейнічаць."

msgid "お知らせの3行目"
msgstr "Трэці радок аб'явы"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Яно з'явіцца справа ад спасылкі на Палітыку прыватнасці."

msgid "非EU向け確認の文字列"
msgstr "Тэкст для пацвярджэння для краін, якія не ўваходзяць у ЕС"

msgid "EU GDPR向け同意するの文字列"
msgstr "Тэкст згоды ў адпаведнасці з GDPR ЕС"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Тэкст для «Не даваць згоду» ў адпаведнасці з GDPR ЕС"

msgid "プライバシーポリシーの文字列"
msgstr "Тэкст палітыкі прыватнасці"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Калі ласка, усталюйце URL-адрас палітыкі прыватнасці тут."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Калі ласка, дадайце наступнае ў Палітыку прыватнасці."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Для выяўлення махлярскай дзейнасці ідэнтыфікатары, такія як IP-адрасы, захоўваюцца ў файлах cookie і базе даных. Захоўваныя даныя выдаляюцца на меркаванне адміністратара."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Каб гарантаваць правільную дастаўку выяў толькі тады, калі абарона выяў уключана, мы захоўваем у базе даных хешаваныя даныя, якія ўключаюць IP-адрас і назву файла выявы, на працягу 60 хвілін."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Калі вы ствараеце Умовы выкарыстання, калі ласка, пераканайцеся, што вы змясцілі спасылку на іх у вашай Палітыцы прыватнасці."

msgid "利用規約の文字列"
msgstr "Тэкст умоў выкарыстання"

msgid "利用規約のページ"
msgstr "Старонка ўмоў і палажэнняў"

msgid "ページ選択なし"
msgstr "Ніводнай старонкі не выбрана"

msgid "検索エンジン等のURL"
msgstr "URL для пошукавых сістэм і г.д."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Усталюйце URL для пошукавых сістэм і падобных сайтаў, якія перанакіроўваюць карыстальнікаў у выпадку адсутнасці згоды"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Рэжым адладкі, папярэджанні кансолі"

msgid "右クリックの警告メッセージ"
msgstr "Правы клік па папярэджанні"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Папярэджанне аб друку і захаванні ў фармаце PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Папярэджанне на скрыншоце"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Папярэджанне адносна падазроных скрыншотаў"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Папярэджанне, калі выбраны ўвесь тэкст"

msgid "ページ保存の警告メッセージ"
msgstr "Папярэджанне аб захаванні старонкі"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Паведамленне, якое адлюстроўваецца пры капіраванні або выразцы"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Паведамленне для адлюстравання пры праглядзе зыходнага кода HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Паведамленне для адлюстравання ўверсе зыходнага кода пры абфускацыі або абароне HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Паведамленне для адлюстравання, калі аднаразовы токен аўтэнтыфікацыі несапраўдны падчас абароны HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Паведамленне для адлюстравання, калі файлы cookie або JavaScript адключаны"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Насамрэч, гэта адлюстроўваецца толькі калі JavaScript адключаны."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Калі выява абаронена, яна спампоўваецца, і на ёй адлюстроўваецца паведамленне"

msgid "HTML難読化 (圧縮)"
msgstr "Зацямненне HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Гэта стандартная кампрэсія HTML; таксама ёсць вэб-сайты, якія могуць яе дэкадаваць."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Уключэнне гэтага опцыі дазваляе атрымаць лог адлюстравання крыніка."

msgid "HTML保護"
msgstr "Абарона HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Выводзіцца толькі абсалютны мінімум HTML — нават менш, чым пры выкарыстанні сціску HTML — і змесціва тэга BODY зусім не выводзіцца."

msgid "Firefoxに対しては無効です"
msgstr "Гэта не датычыцца Firefox"

msgid "SEOに著しく影響があります"
msgstr "Гэта аказвае значны ўплыў на SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Рэндарынг HTML з дапамогай JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Каб абысці Firefox, мы адлюстроўваем HTML з дапамогай JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Уключэнне рэндэрынгу JavaScript значна запаволіць хуткасць загрузкі вэб-сайта."

msgid "画像の保護"
msgstr "Абарона выявы"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Абараняйце выяву кожны раз, калі выклікаецца тэгі img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Абараніце ўсе выявы, загружаныя ў WordPress, у ўсім HTML-вывадзе."

msgid "画像をダウンロードから保護します"
msgstr "Абараняе выявы ад спампоўвання"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Калі даныя выяў абаронены, мы перашкаджаем амаль усім спампоўкам, выдаём унікальныя аднаразовыя URL-адрасы, аўтэнтыфікуемся з дапамогай токенаў, якія захоўваюцца ў сесіі, і адлюстроўваем выявы праз PHP; гэта эфектыўна перашкаджае амаль усім выпадкам крадзяжу выяў."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Калі даныя выявы абаронены, кэшаванне не працуе, што азначае, што сайт будзе загружацца павольней пры паўторных наведваннях, тым самым уплываючы на SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Абарона даных выявы можа павялічыць нагрузку на базу даных."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Калі вы выбіраеце «Абараняць выявы пры кожным выкліку тэга img», сістэма выкарыстоўвае add_filter для прымянення фільтрацыі, калі генеруецца тэга img; аднак гэта можа не працаваць правільна з некаторымі тэмамі."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Калі вы выбераце «Абараніць усе выявы, загружаныя ў WordPress, у ўсім HTML-вывадзе», плагін будзе ахопліваць амаль усе аперацыі WordPress і апрацоўваць кожны тэг img у змесце. Звярніце ўвагу, што гэта можа не працаваць належным чынам з некаторымі тэмамі."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Звярніце ўвагу, што выявы, прызначаныя як асноўныя, будуць перадавацца як даныя OGP і не могуць быць абаронены. Калі вы абавязкова павінны іх абараніць, калі ласка, змяніце налады для вываду тэга HEAD у раздзеле «Пашыраныя налады» пры ўключэнні HTML-абароны."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Функцыя здымкі экрана, убудаваная ў аперацыйную сістэму, не можа быць абаронена."

msgid "画像URLの保護"
msgstr "Абарона URL-адрасоў выяў"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Гэта трэба выкарыстоўваць у спалучэнні з абаронай выявы; сама па сабе яна не мае ніякага сэнсу."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Паколькі ён загружаецца ляніва праз JavaScript, гэта ўплывае на SEO."

msgid "画像のウォーターマーク"
msgstr "Вадзяны знак выявы"

msgid "右下"
msgstr "унізе справа"

msgid "ランダム位置"
msgstr "выпадковае палажэнне"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Выкарыстоўваючыся разам з абаронай выявы, дынамічныя вадзяныя знакі відавочна паказваюць на прыналежнасць правоў аўтарства і ствараюць у гледачоў уражанне, што за імі вядзецца назіранне, тым самым служачы сродкам адпужвання."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Падтрымліваюцца толькі фарматы JPG, PNG і WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Уключэнне гэтага павялічыць нагрузку на сервер."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Вывад ASCII-арту з зыходнага кода HTML падчас абфускацыі і абароны"

msgid "表示なし"
msgstr "Няма дысплея"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Паказвае ASCII-арт-папярэджанне пры праглядзе зыходнага кода HTML з дапамогай 'view-source'."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Паказаць дызайн, калі выканана мэтавае дзеянне"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Базавы дызайн з чорным тэкстам на жоўтым фоне"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Дызайн у стылі хоррара з чырвоным тэкстам на чорным фоне."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Дызайн з яркім чырвоным тэкстам на чорным фоне"

msgid "対象アクションを起こした時のBGM"
msgstr "Фонавая музыка, якая грае, калі выканана мэтавая дзеянне"

msgid "サウンドなし"
msgstr "Няма гуку"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Бітва і перамога - 1 хвіліна 16,3 секунды - 630 056 байтаў - 64 кбіт/с - Ліцэнзія: CC 2.1 або пазней"

