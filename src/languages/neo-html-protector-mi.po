msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Rārangi: Étude d'Exécution No. 4 'Mazeppa'"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Whakanui – 22.3 hēkona – 183,926 baiti – 64 kbps – Raihana: Rawa tūmatanui"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Harikoa āhua retro – 2.2 hēkona – 10,536 baiti – 32 kbps – Raihana: Rawa tūmatanui"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Whakataki āhua retro – 42.1 hēkona – 179,138 baiti – 32 kbps – Raihana: Rawa tūmatanui"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Whakatūpato nā ChatGPT - 3.8 hēkona - 109,700 baiti - 256 kbps - Raihana: Rawa tūmatanui"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "He oro tino ohorere, pērā i te whakatūpato mō te kitenga raupaparorohiko kino – Wāhanga 1 nā ChatGPT – 3.3 hēkona – 102,850 baiti – 256 kbps – Raihana: Rawa tūmatanui"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "He oro tino ohorere, pērā i te whakatūpato mō te kitenga raupatu rorohiko, Wāhanga 2 nā ChatGPT - 3.3 hēkona - 103,122 baiti - 256 kbps - Raihana: Rawa tūmatanui"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Oro āhua MRI nā ChatGPT – 1 meneti 14.9 hēkona – 3,340,392 baiti – 320 kbps – Raihana: Rawa tūmatanui"

msgid "警告表示中のBGMを選択します"
msgstr "Tīpakohia te puoro papamuri hei purei i te wā o te whakatūpato."

msgid "びっくりするような雰囲気を作ります"
msgstr "Ka waihanga i tētahi āhuatanga ohorere"

msgid "Firefoxでは音声ブロックされます"
msgstr "Kua aukatia te oro i Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "He bipa ka mahia te mahi kua tautuhia"

msgid "有効 音量小さ目"
msgstr "Kei runga, he iti te rōrahi"

msgid "有効 音量大き目"
msgstr "Kei te mahi, kua whakaritea te rōrahi ki te teitei"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Ka tangi tētahi bip mō ngā mahi katoa o te matua me te kiore, i te wā e whakaatuhia ana he whakatūpato."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Ka waihanga i te āhua kua hē te pūrere i te wā e whakaatuhia ana te whakatūpato."

