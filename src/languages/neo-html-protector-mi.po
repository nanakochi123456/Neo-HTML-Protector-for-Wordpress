msgid "設定"
msgstr "Tautuhinga"

msgid "IPログリーダー"
msgstr "Pānui Rēkōta IP"

msgid "IPアドレスログ"
msgstr "Rārangi wāhitau IP"

msgid "全クリア"
msgstr "Whakaoti i ngā taumata katoa"

msgid "IPログが全て削除されました"
msgstr "Kua mukua ngā rangitaki IP katoa"

msgid "ID"
msgstr "Tohu tuakiri"

msgid "タイムスタンプ"
msgstr "Tohu wā"

msgid "IPアドレス"
msgstr "Wāhitau IP"

msgid "ユーザーエージェント"
msgstr "Kaihoko kaiwhakamahi"

msgid "イベント"
msgstr "Hātepe"

msgid "IPアドレスのデータはありません"
msgstr "Kāore he raraunga mō tēnei wāhitau IP."

msgid "EU GDPR対応"
msgstr "Te ū ki te GDPR o te Uniana o Europi"

msgid "無効"
msgstr "Hē"

msgid "有効"
msgstr "Pono"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Mēnā kei te whakamahi koe i te WordPress i roto i te EU, rānei mēnā e aro ana tō paetukutuku ki ngā kaiwhakamahi i roto i te EU, tēnā whakarite kia whakahohea tēnei."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Ka huri te pātene 'Whakapūmau' ki 'Whakaae' rānei 'Kāore e whakaae', ā, ka rerekē paku te whanonga."

msgid "同意画面の色"
msgstr "Tae o te mata whakaaetanga"

msgid "自動"
msgstr "Aunoa"

msgid "ライトモード"
msgstr "Aratau māmā"

msgid "ダークモード"
msgstr "Aratau Pōuri"

msgid "同意画面表示中の配色を設定します"
msgstr "Whakaritea te hoahoa tae mō te mata whakaae"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Te whakaparuparu o ngā ihirangi i runga i te mata whakaaetanga"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Whakaritea te taumata o te whakamatapō mō ngā ihirangi e whakaatuhia ana i runga i te mata whakaaetanga"

msgid "同意画面の透過"
msgstr "Mārama o te mata whakaae"

msgid "透過なし"
msgstr "Kāore he mārama"

msgid "同意画面の透過具合を設定します"
msgstr "Whakaritea te mārama o te mata whakaaetanga"

msgid "お知らせの1行目"
msgstr "Raina tuatahi o te pānui"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ka whakaatuhia tonu tēnei karere i te wā tuatahi ka utaina te whārangi."

msgid "お知らせの2行目"
msgstr "Te rārangi tuarua o te pānui"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ka puta tonu tēnei karere i te whakaaturanga tuatahi anake ina whai mana te EU GDPR."

msgid "お知らせの3行目"
msgstr "Ko te rārangi tuatoru o te pānui"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ka puta ki te taha matau o te hono ki te Kaupapahere Tūmataiti."

msgid "非EU向け確認の文字列"
msgstr "Tēnēhi whakapūmau mō ngā whenua kāore i roto i te EU"

msgid "EU GDPR向け同意するの文字列"
msgstr "Tēnehi whakaaetanga mō te EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Tuhi mō te 'Kaua e whakaae' i raro i te EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Tēnehi mō te kaupapa here tūmataiti"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Tēnā, whakaritea te URL mō te kaupapa here tūmataiti ki konei."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Tēnā koa tāpiri i ngā mea e whai ake nei ki te Kaupapahere Tūmataiti."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Hei kite i ngā mahi tinihanga, ka penapenahia ngā tohu tuakiri pērā i ngā wāhitau IP ki ngā kuki me te pātengi raraunga. Ka mukua ngā raraunga kua penapenahia i runga i te whakaaro a te kaiwhakahaere."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Hei whakarite kia tukuna tika ngā whakaahua ina whakahohea te tiaki whakaahua, ka penapenahia e mātou ngā raraunga hash e kapi ana i te wāhitau IP me te ingoa kōnae whakaahua ki tō mātou pātengi raraunga mō te 60 meneti."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Mēnā kei te whakarite koe i ngā Tikanga Whakamahi, tēnā whakarite kia whakauru koe i tētahi hononga ki a rātou i roto i tō Kaupapahere Tūmataitinga."

msgid "利用規約の文字列"
msgstr "Tuhi o ngā tikanga whakamahi"

msgid "利用規約のページ"
msgstr "Whārangi Ngā Tikanga me Ngā Here"

msgid "ページ選択なし"
msgstr "Kāore he whārangi kua tīpakohia"

msgid "検索エンジン等のURL"
msgstr "Ngā URL mō ngā miihini rapu, me ērā atu."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Whakaritea te URL mō ngā miihini rapu me ērā atu pae e whakahoki ana i ngā kaiwhakamahi ina kāore i whakaaetia."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Aratau wetewete hapa, karere whakatūpato o te papamātiti"

msgid "右クリックの警告メッセージ"
msgstr "Panui whakatūpato pāwhiri-matau"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Panui whakatūpato mō te tā me te penapena hei PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Karere whakatūpato i te whakaahua mata"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Panui whakatūpato mō ngā whakaahua mata e whakapaetia ana"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Panui whakatūpato ina kua tohua katoa ngā kuputuhi"

msgid "ページ保存の警告メッセージ"
msgstr "Panui whakatūpato mō te penapena whārangi"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Te karere ka whakaatuhia ina tārua, ina tapahia rānei"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Karere hei whakaatu i te wā e tiro ana i te puna HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Karere hei whakaatu i te tihi o te waehere puna ina whakawātea, ina tiaki rānei i te HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Karere hei whakaatu mēnā kāore te tohu whakamana kotahi-wa i whaimana i te wā e tiakina ana te HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Karere hei whakaatu mēnā kua whakawetohia ngā kuki, ngā JavaScript rānei"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Inā hoki, ka whakaatuhia anake tēnei ina kua whakawetohia te JavaScript."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Ka tiakina tētahi whakaahua, ka tikiake, ā, ka whakaatuhia he karere ki runga i taua whakaahua"

msgid "HTML難読化 (圧縮)"
msgstr "Whakamāhāhā HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "He pēhanga paerewa HTML tēnei; he paetukutuku anō hoki e taea ana te wetewete."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Mā te whakahohe i tēnei kōwhiringa ka taea e koe te tiki i ngā rangitaki tirohanga pūtake."

msgid "HTML保護"
msgstr "Tiaki HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ka whakaputa ia i te HTML iti ake i te tautuhinga pēhanga HTML, arā, kāore rawa ngā ihirangi kei roto i te tapanga BODY e whakaputaina."

msgid "Firefoxに対しては無効です"
msgstr "Ehara tēnei i te mea e pā ana ki a Firefox."

msgid "SEOに著しく影響があります"
msgstr "He pānga nui tēnei ki te SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Te whakaputa i te HTML mā te JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Hei karo i a Firefox, ka whakaputa mātou i te HTML mā te JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Mā te whakahohe i te whakaaturanga JavaScript ka tino whakaroa te tere utaina o te paetukutuku."

msgid "画像の保護"
msgstr "Tiaki whakaahua"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Tiakina te whakaahua ia wā ka karangahia te tapanga img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Tiakina ngā whakaahua katoa kua tukuna ki WordPress i roto i te whakaputanga HTML katoa."

msgid "画像をダウンロードから保護します"
msgstr "E tiaki ana i ngā whakaahua kia kore ai e taea te tikiake"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Ka tiakina ngā raraunga whakaahua, ka aukatia e mātou te nuinga o ngā tango, ka whakaputahia he URL motuhake mō te kotahi anake, ka whakamana mā ngā tohu kua penapenahia i roto i te wāhanga, ā, ka whakaatuhia ngā whakaahua mā PHP; nā konei ka aukatia te nuinga o ngā tahae whakaahua."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Ki te tiakina ngā raraunga whakaahua, kāore e mahi te penapena wā-poto, arā, ka utaina āta haere te paetukutuku i ngā haerenga whai ake, ā, ka pā tēnei ki te SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ka piki pea te kawenga ki runga i te pātengi raraunga mēnā ka tiakina ngā raraunga whakaahua."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Mēnā ka tīpako koe i te 'Tiaki whakaahua ia wā ka karangahia te tapanga img', ka whakamahi te pūnaha i te add_filter hei tāpiri tātari i te wā e waihangatia ana te tapanga img; heoi, kāore pea e mahi tika tēnei ki ētahi kaupapa āhua."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Mēnā ka tīpako koe i te 'Tiakina ngā whakaahua katoa kua tukuna ki WordPress i roto i te putanga HTML katoa', ka hopu te mono i te nuinga o ngā mahi a WordPress, ā, ka tukatuka ia i ia tapanga img i roto i te ihirangi. Tēnā kia mōhio, kāore pea e mahi tika tēnei me ētahi kaupapa āhua."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Tēnā koa mōhio, ka tohaina ngā whakaahua kua tohua hei whakaahua ārahi hei raraunga OGP, ā, kāore e taea te tiaki. Mēnā me tino tiaki koe i ēnei, tēnā huri i te tautuhinga mō te whakaputanga o te tapanga HEAD i ngā tautuhinga matatau ina whakahohe koe i te tiaki HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Kāore e taea te tiaki i te āheinga hopu mata kua whakaurua hei paerewa i te pūnaha whakahaere."

msgid "画像URLの保護"
msgstr "Te tiaki i ngā URL whakaahua"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Me whakamahi tēnei i te taha o te tiaki whakaahua; ki tōna anake, kāore he take."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Nā te mea ka utaina mā JavaScript i runga i te māngere, ka pā tēnei ki te SEO."

msgid "画像のウォーターマーク"
msgstr "Tohu wai tohu whakaahua"

msgid "右下"
msgstr "Wāhi raro matau"

msgid "ランダム位置"
msgstr "Tūranga tūpono"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Ka whakamahia ngātahi me te tiaki whakaahua, ka tohu mārama ngā tohu wai huringa i te rangatiratanga mana kaituhi, ā, ka waiho he whakaaro ki ngā kaitirotiro kei te aroturuki rātou, nā reira ka mahi hei aukati."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Ka tautokohia anake ngā hōputu JPG, PNG me WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Mā te whakahohe i tēnei ka piki ake te kawenga o te tūmau."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Te whakaputa i te toi ASCII mai i te waehere puna HTML i te wā e whakawātea ana, e tiakina ana"

msgid "表示なし"
msgstr "Kāore he whakaaturanga"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "E whakaatu ana i ngā toi ASCII e tohu ana i tētahi whakatūpato ina tirotiro ana i te puna HTML mā te 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Whakaatu i te hoahoa ina oti te mahi whāinga"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "He hoahoa taketake e whakaatu ana i ngā kupu pango i runga i te papamuri kōwhai"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "He hoahoa āhua mataku me te tuhinga whero i runga i te papamuri pango"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "He hoahoa e whakaatu ana i ngā kupu whero kanapa i runga i te papamuri pango"

msgid "対象アクションを起こした時のBGM"
msgstr "Puoro papamuri e rere ana ina mahia te mahi whāinga"

msgid "サウンドなし"
msgstr "Kāore he oro"

