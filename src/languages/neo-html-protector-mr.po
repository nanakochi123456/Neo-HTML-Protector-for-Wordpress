msgid "設定"
msgstr "सेटिंग्ज"

msgid "IPログリーダー"
msgstr "आयपी लॉग रीडर"

msgid "IPアドレスログ"
msgstr "आयपी पत्ता लॉग"

msgid "全クリア"
msgstr "सर्व स्तर पूर्ण करा"

msgid "IPログが全て削除されました"
msgstr "सर्व आयपी नोंदी हटवल्या गेल्या आहेत"

msgid "ID"
msgstr "ओळखपत्र"

msgid "タイムスタンプ"
msgstr "वेळचिन्ह"

msgid "IPアドレス"
msgstr "आयपी पत्ता"

msgid "ユーザーエージェント"
msgstr "वापरकर्ता एजंट"

msgid "イベント"
msgstr "कार्यक्रम"

msgid "IPアドレスのデータはありません"
msgstr "या आयपी पत्त्यासाठी कोणतीही माहिती उपलब्ध नाही."

msgid "EU GDPR対応"
msgstr "EU GDPR चे अनुपालन"

msgid "無効"
msgstr "अमान्य"

msgid "有効"
msgstr "वैध"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "जर आपण EU मध्ये WordPress वापरत असाल किंवा आपली वेबसाइट EU मधील वापरकर्त्यांना लक्ष्य करत असेल, तर कृपया हे सक्षम असल्याची खात्री करा."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' बटण 'Agree' किंवा 'Disagree' मध्ये बदलेल आणि वर्तन थोडेसे बदलेल."

msgid "同意画面の色"
msgstr "संमती स्क्रीनचा रंग"

msgid "自動"
msgstr "स्वयंचलित"

msgid "ライトモード"
msgstr "हलका मोड"

msgid "ダークモード"
msgstr "डार्क मोड"

msgid "同意画面表示中の配色を設定します"
msgstr "संमती स्क्रीनसाठी रंगसंगती सेट करा"

msgid "同意画面中のコンテンツのぼかし"
msgstr "संमती स्क्रीनवरील सामग्री अस्पष्ट करणे"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "संमती स्क्रीनवर प्रदर्शित होणाऱ्या सामग्रीसाठी धुंधळेपणाची पातळी सेट करा"

msgid "同意画面の透過"
msgstr "संमती स्क्रीनची पारदर्शकता"

msgid "透過なし"
msgstr "पारदर्शकता नाही"

msgid "同意画面の透過具合を設定します"
msgstr "संमती स्क्रीनची पारदर्शकता सेट करा"

msgid "お知らせの1行目"
msgstr "घोषणेची पहिली ओळ"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "हा संदेश पृष्ठ प्रथमच लोड झाल्यावर नेहमी प्रदर्शित होतो."

msgid "お知らせの2行目"
msgstr "सूचनेची दुसरी ओळ"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "हा संदेश फक्त पहिल्या डिस्प्लेवरच नेहमी दिसेल जेव्हा EU GDPR लागू असेल."

msgid "お知らせの3行目"
msgstr "सूचनेची तिसरी ओळ"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "हे गोपनीयता धोरणाच्या दुव्याच्या उजवीकडे दिसेल."

msgid "非EU向け確認の文字列"
msgstr "EU बाहेरील देशांसाठी पुष्टीकरण मजकूर"

msgid "EU GDPR向け同意するの文字列"
msgstr "EU GDPR साठी संमती मजकूर"

msgid "EU GDPR向け同意しないの文字列"
msgstr "EU GDPR अंतर्गत 'सहमती देऊ नका' साठी मजकूर"

msgid "プライバシーポリシーの文字列"
msgstr "गोपनीयता धोरण मजकूर"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "कृपया येथे गोपनीयता धोरणाची URL सेट करा"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "कृपया खालील गोष्टी गोपनीयता धोरणात समाविष्ट करा."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "फसवणुकीच्या क्रियाकलापांचा शोध घेण्यासाठी, आयपी पत्ते यांसारखी ओळखपत्रां कुकीज आणि डेटाबेसमध्ये संग्रहित केली जातात. संग्रहित डेटा प्रशासकाच्या विवेकानुसार हटवला जातो."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "प्रतिमा संरक्षण सक्षम असतानाच प्रतिमा अचूकपणे वितरित होण्याची खात्री करण्यासाठी, आम्ही डेटाबेसमध्ये आयपी पत्ता आणि प्रतिमा फाईलनाव यांचा समावेश असलेला हॅश केलेला डेटा ६० मिनिटांपर्यंत संग्रहित करतो."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "जर आपण वापराच्या अटी तयार करत असाल, तर कृपया आपल्या गोपनीयता धोरणात त्यांचा दुवा समाविष्ट असल्याची खात्री करा."

msgid "利用規約の文字列"
msgstr "वापर अटींचा मजकूर"

msgid "利用規約のページ"
msgstr "अटी व शर्ती पृष्ठ"

msgid "ページ選択なし"
msgstr "कोणतीही पृष्ठे निवडलेली नाहीत"

msgid "検索エンジン等のURL"
msgstr "शोध इंजिन इत्यादींसाठी URL"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "जेव्हा संमती दिली जात नाही तेव्हा वापरकर्त्यांना पुनर्निर्देशित करणाऱ्या शोध इंजिन आणि तत्सम साइट्ससाठी URL सेट करा"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "डिबग मोड, कन्सोल चेतावणी संदेश"

msgid "右クリックの警告メッセージ"
msgstr "उजव्या-क्लिक चेतावणी संदेश"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDF मध्ये मुद्रण आणि जतन करण्याबाबतचे चेतावणी संदेश"

msgid "スクリーンショットの警告メッセージ"
msgstr "स्क्रीनशॉटमधील चेतावणी संदेश"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "संशयित स्क्रीनशॉट्सबाबतचे चेतावणी संदेश"

msgid "テキスト全選択時の警告メッセージ"
msgstr "सर्व मजकूर निवडल्यावर चेतावणी संदेश"

msgid "ページ保存の警告メッセージ"
msgstr "पृष्ठ जतन करण्याबाबतचे चेतावणी संदेश"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "कॉपी किंवा कट करताना प्रदर्शित होणारा संदेश"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML स्त्रोत पाहताना प्रदर्शित होणारा संदेश"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML अस्पष्ट किंवा संरक्षित करताना स्रोत कोडच्या शीर्षस्थानी प्रदर्शित होणारा संदेश"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML संरक्षणादरम्यान एकदा वापरता येणारा प्रमाणीकरण टोकन अमान्य असल्यास प्रदर्शित होणारा संदेश"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "कुकीज किंवा जावास्क्रिप्ट अक्षम असल्यास प्रदर्शित होणारा संदेश"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "प्रत्यक्षात, हे फक्त तेव्हाच प्रदर्शित होते जेव्हा जावास्क्रिप्ट अक्षम केलेले असते."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "जेव्हा एखादी प्रतिमा संरक्षित असते, तेव्हा ती डाउनलोड होते आणि त्या प्रतिमेवर एक संदेश प्रदर्शित होतो"

msgid "HTML難読化 (圧縮)"
msgstr "HTML अस्पष्टीकरण"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "हे मानक HTML संकुचन आहे; ते डीकोड करू शकणाऱ्या वेबसाइट्स देखील आहेत."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "हा पर्याय सक्षम केल्यास तुम्हाला व्यू-सोर्स लॉग्स मिळवता येतात."

msgid "HTML保護"
msgstr "HTML संरक्षण"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "हे HTML संकुचन सेटिंगपेक्षा आणखी कमी HTML आउटपुट करते, म्हणजे BODY टॅगमधील सामग्री अजिबात आउटपुट होत नाही."

msgid "Firefoxに対しては無効です"
msgstr "हे फायरफॉक्सवर लागू होत नाही."

msgid "SEOに著しく影響があります"
msgstr "याचा एसईओवर महत्त्वपूर्ण परिणाम होतो."

msgid "HTMLをJavaScriptで描画"
msgstr "जावास्क्रिप्ट वापरून HTML तयार करणे"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox वर काम करण्यासाठी, आम्ही JavaScript वापरून HTML रेंडर करतो."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "जावास्क्रिप्ट रेंडरिंग सक्षम केल्याने वेबसाइटच्या लोडिंग गतीमध्ये लक्षणीय मंदता येईल."

msgid "画像の保護"
msgstr "प्रतिमा संरक्षण"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img टॅग प्रत्येक वेळी कॉल झाल्यावर प्रतिमा संरक्षित करा"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "संपूर्ण HTML आउटपुटमधील WordPress मध्ये अपलोड केलेल्या सर्व प्रतिमांचे संरक्षण करा."

msgid "画像をダウンロードから保護します"
msgstr "प्रतिमा डाउनलोड होण्यापासून संरक्षण करते"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "जेव्हा प्रतिमा डेटा संरक्षित केला जातो, तेव्हा आम्ही जवळजवळ सर्व डाउनलोड प्रतिबंधित करतो, अद्वितीय एकदाच वापरता येणारे URL जारी करतो, सत्रात संग्रहित टोकन्स वापरून प्रमाणीकरण करतो आणि PHP द्वारे प्रतिमा प्रदर्शित करतो; यामुळे प्रतिमा चोरीच्या जवळजवळ सर्व घटना प्रभावीपणे प्रतिबंधित होतात."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "जेव्हा प्रतिमा डेटा संरक्षित केला जातो, तेव्हा कॅशिंग काम करत नाही, ज्यामुळे साइट पुढील भेटींवर हळू लोड होते आणि परिणामी SEO प्रभावित होते."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "प्रतिमा डेटाचे संरक्षण केल्याने डेटाबेसवरील भार वाढू शकतो."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "जर आपण 'img टॅग प्रत्येक वेळी कॉल झाल्यावर प्रतिमा संरक्षित करा' निवडले, तर सिस्टम img टॅग तयार होताना फिल्टरिंग करण्यासाठी add_filter वापरते; तथापि, काही थीम्समध्ये हे योग्यरित्या काम नसू शकते."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "जर आपण 'संपूर्ण HTML आउटपुटमध्ये WordPress वर अपलोड केलेल्या सर्व प्रतिमांचे संरक्षण करा' हा पर्याय निवडला, तर प्लगइन जवळजवळ सर्व WordPress क्रियाकलाप कॅप्चर करेल आणि सामग्रीतील प्रत्येक img टॅगवर प्रक्रिया करेल. कृपया लक्षात घ्या की काही थीमसह हे योग्यरित्या कार्य करणार नाही."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "कृपया लक्षात घ्या की वैशिष्ट्यीकृत प्रतिमा म्हणून निवडलेल्या प्रतिमा OGP डेटा म्हणून शेअर केल्या जातील आणि संरक्षित करता येणार नाहीत. जर तुम्हाला त्या नक्कीच संरक्षित करायच्या असतील, तर HTML संरक्षण सक्षम करताना प्रगत सेटिंग्जमध्ये HEAD टॅग आउटपुटसाठीची सेटिंग बदला."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "ऑपरेटिंग सिस्टममध्ये अंगभूत असलेले स्क्रीनशॉट फंक्शन संरक्षित करता येणार नाही."

msgid "画像URLの保護"
msgstr "प्रतिमा URL संरक्षण"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "हे प्रतिमा संरक्षणासोबतच वापरावे; स्वतःमध्ये याचा कोणताही उपयोग नाही."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "जेव्हा ते जावास्क्रिप्टद्वारे लोड केले जाते, तेव्हा याचा SEO वर परिणाम होतो."

msgid "画像のウォーターマーク"
msgstr "प्रतिमेवरील वॉटरमार्क"

msgid "右下"
msgstr "खाली उजवीकडे"

msgid "ランダム位置"
msgstr "यादृच्छिक स्थान"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "प्रतिमा संरक्षणासोबत वापरल्यास, गतिशील वॉटरमार्क स्पष्टपणे कॉपीराइट मालकीचे सूचक असतात आणि पाहणाऱ्यांना ते पाहिले जात असल्याचा भास देतात, ज्यामुळे ते प्रतिबंधक म्हणून कार्य करतात."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "केवळ JPG, PNG आणि WebP स्वरूप समर्थित आहेत."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "हे सक्षम केल्याने सर्व्हरवरील लोड वाढेल."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
