msgid "設定"
msgstr "सेटिङहरू"

msgid "IPログリーダー"
msgstr "आईपी लग रिडर"

msgid "IPアドレスログ"
msgstr "आईपी ठेगाना लग"

msgid "全クリア"
msgstr "सबै स्तरहरू पूरा गर्नुहोस्"

msgid "IPログが全て削除されました"
msgstr "सबै आईपी लगहरू मेटाइएका छन्।"

msgid "ID"
msgstr "परिचय"

msgid "タイムスタンプ"
msgstr "समय-चिह्न"

msgid "IPアドレス"
msgstr "आईपी ठेगाना"

msgid "ユーザーエージェント"
msgstr "प्रयोगकर्ता एजेन्ट"

msgid "イベント"
msgstr "कार्यक्रम"

msgid "IPアドレスのデータはありません"
msgstr "यो आईपी ठेगानाको लागि कुनै डाटा छैन।"

msgid "EU GDPR対応"
msgstr "EU GDPR को अनुपालन"

msgid "無効"
msgstr "अमान्य"

msgid "有効"
msgstr "मान्य"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "यदि तपाईं EU भित्र WordPress प्रयोग गर्दै हुनुहुन्छ, वा तपाईंको वेबसाइटले EU भित्रका प्रयोगकर्ताहरूलाई लक्षित गर्छ भने, कृपया यो सक्षम गरिएको सुनिश्चित गर्नुहोस्।"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' बटन 'Agree' वा 'Disagree' मा परिवर्तन हुनेछ, र व्यवहार थोरै परिवर्तन हुनेछ।"

msgid "同意画面の色"
msgstr "सहमति स्क्रिनको रङ"

msgid "自動"
msgstr "स्वचालित"

msgid "ライトモード"
msgstr "हल्का मोड"

msgid "ダークモード"
msgstr "अँध्यारो मोड"

msgid "同意画面表示中の配色を設定します"
msgstr "सहमति स्क्रिनको रङ योजना सेट गर्नुहोस्"

msgid "同意画面中のコンテンツのぼかし"
msgstr "सहमति स्क्रिनमा सामग्री धमिलो हुनु"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "सहमति स्क्रिनमा देखाइने सामग्रीको धुमिल बनाउने स्तर सेट गर्नुहोस्।"

msgid "同意画面の透過"
msgstr "सहमति स्क्रिनको पारदर्शिता"

msgid "透過なし"
msgstr "पारदर्शिता छैन"

msgid "同意画面の透過具合を設定します"
msgstr "सहमति स्क्रिनको अपारदर्शिता सेट गर्नुहोस्"

msgid "お知らせの1行目"
msgstr "घोषणाको पहिलो पङ्क्ति"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "यो सन्देश पृष्ठ पहिलो पटक लोड हुँदा सधैं देखाइन्छ।"

msgid "お知らせの2行目"
msgstr "सूचनाको दोस्रो पङ्क्ति"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "यो सन्देश पहिलो प्रदर्शनमा मात्र तब देखिनेछ जब EU GDPR लागू हुन्छ।"

msgid "お知らせの3行目"
msgstr "सूचनाको तेस्रो पङ्क्ति"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "यो गोपनीयता नीति को लिङ्कको दायाँपट्टि देखा पर्नेछ।"

msgid "非EU向け確認の文字列"
msgstr "गैर-EU देशहरूको लागि पुष्टिकरण पाठ"

msgid "EU GDPR向け同意するの文字列"
msgstr "EU GDPR का लागि सहमति पाठ"

msgid "EU GDPR向け同意しないの文字列"
msgstr "EU GDPR अन्तर्गत 'सहमति नगर्नुहोस्' को लागि पाठ"

msgid "プライバシーポリシーの文字列"
msgstr "गोपनीयता नीति पाठ"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "कृपया गोपनीयता नीति को URL यहाँ सेट गर्नुहोस्।"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "कृपया गोपनीयता नीतिमा निम्न कुराहरू थप्नुहोस्।"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "ठगीपूर्ण गतिविधि पत्ता लगाउन IP ठेगाना जस्ता पहिचानकर्ताहरू कुकीहरू र डेटाबेसहरूमा भण्डारण गरिन्छन्। भण्डारण गरिएको डेटा प्रशासकको विवेकअनुसार मेटाइन्छ।"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "छवि सुरक्षा सक्षम हुँदा मात्र छविहरू सही रूपमा डेलिभर हुने सुनिश्चित गर्न, हामी आईपी ठेगाना र छवि फाइलनाम समावेश भएको ह्यास गरिएको डेटालाई ६० मिनेटसम्म डेटाबेसमा भण्डारण गर्छौं।"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "यदि तपाईं प्रयोगका सर्तहरू तयार गर्दै हुनुहुन्छ भने, कृपया सुनिश्चित गर्नुहोस् कि तपाईंले आफ्नो गोपनीयता नीतिमा त्यसको लिङ्क समावेश गर्नुभएको छ।"

msgid "利用規約の文字列"
msgstr "उपयोगका सर्तहरूको पाठ"

msgid "利用規約のページ"
msgstr "नियम र सर्तहरू पृष्ठ"

msgid "ページ選択なし"
msgstr "कुनै पृष्ठ चयन गरिएको छैन"

msgid "検索エンジン等のURL"
msgstr "खोज इन्जिनहरू, आदि का लागि URL हरू"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "सन्धि नदिइएमा प्रयोगकर्ताहरूलाई पुनर्निर्देशित गर्ने खोज इन्जिनहरू र यस्तै साइटहरूको URL सेट गर्नुहोस्।"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "डिबग मोड, कन्सोल चेतावनी सन्देशहरू"

msgid "右クリックの警告メッセージ"
msgstr "दायाँ-क्लिक चेतावनी सन्देश"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDF मा प्रिन्ट र सेभ गर्ने सम्बन्धी चेतावनी सन्देश"

msgid "スクリーンショットの警告メッセージ"
msgstr "स्क्रिनशटमा चेतावनी सन्देश"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "शंकास्पद स्क्रिनसटहरू सम्बन्धी चेतावनी सन्देश"

msgid "テキスト全選択時の警告メッセージ"
msgstr "सबै पाठ चयन हुँदा चेतावनी सन्देश"

msgid "ページ保存の警告メッセージ"
msgstr "पृष्ठ सुरक्षित गर्ने सम्बन्धी चेतावनी सन्देश"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "कपी वा कट गर्दा देखाइने सन्देश"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML स्रोत हेर्दा देखाइने सन्देश"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML लाई अस्पष्ट बनाउँदा वा सुरक्षा गर्दा स्रोत कोडको शीर्षमा देखाउनका लागि सन्देश"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML सुरक्षाको क्रममा एक-पटकको प्रमाणीकरण टोकन अमान्य भएमा देखाइने सन्देश"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "कुकीज वा जाभास्क्रिप्ट असक्षम गरिएको खण्डमा देखाइने सन्देश"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "वास्तवमा, यो तब मात्र देखाइन्छ जब जाभास्क्रिप्ट अक्षम गरिएको हुन्छ।"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "जब कुनै छवि सुरक्षित गरिन्छ, यो डाउनलोड हुन्छ र सो छविमा एउटा सन्देश देखाइन्छ"

msgid "HTML難読化 (圧縮)"
msgstr "HTML अस्पष्टीकरण"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "यो मानक HTML कम्प्रेशन हो; यसलाई डिकोड गर्न सक्ने वेबसाइटहरू पनि छन्।"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "यो विकल्प सक्षम गर्दा तपाईंले भ्यू-सोर्स लग प्राप्त गर्न सक्नुहुन्छ।"

msgid "HTML保護"
msgstr "HTML सुरक्षा"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "यसले केवल न्यूनतम HTML मात्र आउटपुट गर्छ—HTML कम्प्रेसन प्रयोग गर्दा भन्दा पनि कम—र BODY ट्यागभित्रको सामग्री बिलकुलै आउटपुट हुँदैन।"

msgid "Firefoxに対しては無効です"
msgstr "यो फायरफक्समा लागू हुँदैन।"

msgid "SEOに著しく影響があります"
msgstr "यसले एसईओमा महत्वपूर्ण प्रभाव पार्छ।"

msgid "HTMLをJavaScriptで描画"
msgstr "जाभास्क्रिप्ट प्रयोग गरेर HTML रेन्डरिङ"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox लाई बाइपास गर्न, हामी JavaScript प्रयोग गरेर HTML रेंडर गर्छौं।"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "जाभास्क्रिप्ट रेंडरिंग सक्षम गर्दा वेबसाइटको लोडिङ गतिमा उल्लेखनीय ढिलाइ हुनेछ।"

msgid "画像の保護"
msgstr "छवि संरक्षण"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img ट्याग प्रत्येक पटक बोलाउँदा छवि सुरक्षित गर्नुहोस्।"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "सम्पूर्ण HTML आउटपुटभित्र WordPress मा अपलोड गरिएका सबै छविहरू सुरक्षित गर्नुहोस्।"

msgid "画像をダウンロードから保護します"
msgstr "छविहरू डाउनलोड हुनबाट जोगाउँछ"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "जब छवि डेटा सुरक्षित गरिन्छ, हामी डाउनलोडहरू लगभग पूर्ण रूपमा रोक्छौं, अद्वितीय एकपटक प्रयोग गर्न मिल्ने URL हरू जारी गर्छौं, सत्रमा भण्डारण गरिएका टोकनहरू प्रयोग गरी प्रमाणीकरण गर्छौं, र PHP मार्फत छविहरू प्रदर्शन गर्छौं; यसले प्रभावकारी रूपमा छवि चोरी रोक्छ।"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "जब छवि डेटा सुरक्षित गरिन्छ, क्यासिङले काम गर्दैन, जसको अर्थ हो कि साइट पछिल्ला भ्रमणहरूमा ढिलो लोड हुनेछ, जसले एसईओमा असर पार्छ।"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "छवि डेटा सुरक्षित गर्दा डेटाबेसमा लोड बढ्न सक्छ।"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "यदि तपाईंले 'जब पनि img ट्याग बोलाइन्छ तब छविहरू सुरक्षित गर' चयन गर्नुभयो भने, प्रणालीले img ट्याग उत्पन्न हुँदा फिल्टरिङ लागू गर्न add_filter प्रयोग गर्छ; यद्यपि, केही थिमहरूसँग यो ठीकसँग काम नगर्न सक्छ।"

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "यदि तपाईंले 'सम्पूर्ण HTML आउटपुटभित्र WordPress मा अपलोड गरिएका सबै छविहरू सुरक्षित गर्नुहोस्' चयन गर्नुभयो भने, प्लगइनले लगभग सबै WordPress क्रियाकलापहरू समात्नेछ र सामग्रीभित्रको प्रत्येक img ट्याग प्रशोधन गर्नेछ। कृपया ध्यान दिनुहोस् कि यो केही थिमहरूसँग ठीकसँग काम नगर्न सक्छ।"

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "कृपया ध्यान दिनुहोस् कि विशेष छविहरू भनेर तोकिएका छविहरू OGP डेटाको रूपमा साझा गरिनेछन् र सुरक्षित गर्न सकिँदैनन्। यदि तपाईंले तिनीहरूलाई अवश्य सुरक्षित गर्नैपर्छ भने, HTML सुरक्षा सक्षम गर्दा उन्नत सेटिङहरूमा HEAD ट्याग आउटपुटको सेटिङ परिवर्तन गर्नुहोस्।"

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "अपरेटिङ सिस्टममा निर्मित स्क्रिनशट कार्यलाई सुरक्षित गर्न सकिँदैन।"

msgid "画像URLの保護"
msgstr "छवि URL हरूको सुरक्षा"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "यसलाई छवि सुरक्षासँगै प्रयोग गर्नुपर्छ; आफैंमा यसको कुनै उद्देश्य छैन।"

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "किनकि यो जाभास्क्रिप्टमार्फत सुस्त रूपमा लोड गरिन्छ, यसले SEO मा असर पार्छ।"

msgid "画像のウォーターマーク"
msgstr "छवि वाटरमार्क"

msgid "右下"
msgstr "तल्लो दायाँ"

msgid "ランダム位置"
msgstr "अनियमित स्थिति"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "छवि संरक्षणसँगै प्रयोग गर्दा, गतिशील वाटरमार्कहरूले प्रतिलिपि अधिकारको स्वामित्व स्पष्ट रूपमा देखाउँछन् र दर्शकहरूलाई उनीहरूको निगरानी भइरहेको अनुभूति दिन्छन्, जसले निवारकको रूपमा काम गर्छ।"

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "केवल JPG, PNG र WebP ढाँचाहरू समर्थित छन्।"

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "यसलाई सक्षम गर्दा सर्भरमा लोड बढ्नेछ।"

