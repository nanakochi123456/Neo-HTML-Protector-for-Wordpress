msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Aviso de ChatGPT - 3,8 segundos - 109.700 bytes - 256 kbps - Licenza: Dominio público"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Un son de alta urxencia que soa como unha alerta de detección de malware – Parte 1 por ChatGPT – 3,3 segundos – 102.850 bytes – 256 kbps – Licenza: Dominio público"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Un son de alta urxencia que soa como unha alerta de detección de malware, Parte 2 por ChatGPT - 3,3 segundos - 103.122 bytes - 256 kbps - Licenza: Dominio público"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Son estilo MRI por ChatGPT – 1 minuto 14,9 segundos – 3.340.392 bytes – 320 kbps – Licenza: Dominio público"

msgid "警告表示中のBGMを選択します"
msgstr "Selecciona a música de fondo que se reproducirá durante unha advertencia."

msgid "びっくりするような雰囲気を作ります"
msgstr "Crea unha atmosfera sorprendente"

msgid "Firefoxでは音声ブロックされます"
msgstr "O audio está bloqueado en Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "Un bip cando se realiza a acción especificada"

msgid "有効 音量小さ目"
msgstr "Encender, volume baixo"

msgid "有効 音量大き目"
msgstr "Activo, volume axustado a alto"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Soará un pitido en resposta a todos os eventos de teclas e rato mentres se mostra unha advertencia."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Crea a impresión de que o dispositivo se descontrolou mentres se mostra a advertencia."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Ocultar o cursor do rato cando se realiza unha acción específica"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Oculta o cursor do rato na área do navegador mentres se mostra un aviso."

msgid "デバッグモード"
msgstr "Modo de depuración"

msgid "妨害＋記録のみ"
msgstr "Interferencia + só rexistros"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Interferencia + Rexistro + Visualización + Redirección"

msgid "メニューからは操作できてしまいます"
msgstr "Aínda podes acceder a el a través do menú."

msgid "Firefoxにおけるデバッグモード"
msgstr "Modo de depuración en Firefox"

msgid "ブラウザーコンソール"
msgstr "Consola do navegador"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "De feito, podes operalo desde o modo de depuración."

msgid "HTMLソース表示"
msgstr "Ver o código fonte HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Podes realizar a operación simplemente introducindo unha URL que comece con 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Podes protexer o teu contido combinando isto coa protección HTML."

msgid "印刷"
msgstr "Imprimir"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Aínda que evita a impresión, pode que non funcione correctamente nalgúns navegadores."

msgid "スクリーンショット"
msgstr "Captura de pantalla"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Dependendo do sistema operativo, do navegador ou do método empregado, pode que non sexa posible bloquear isto ou pode que non se detecte."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Captura de pantalla sospeitosa cando a xanela pasa ao fondo"

msgid "あわせて、スクリーンショット以外の機能（タブ切り替え・ウィンドウ切り替え）にも反応してしまいます。"
msgstr "Tamén responde a funcións distintas das capturas de pantalla"

msgid "2キー押下のスクリーンショットの疑い"
msgstr "Suposta captura de pantalla tomada premendo dúas teclas"

msgid "上の項目の検出方法は完全ではありません、予防的に検出を行います"
msgstr "Os métodos de detección dos elementos anteriores non son infalibles; a detección realízase como unha medida de precaución."

msgid "スクリーンショットだけではなく、デバッグモード等も検出します"
msgstr "Detecta non só capturas de pantalla, senón tamén modos de depuración e similares."

msgid "ページ保存"
msgstr "Garda páxina"

msgid "右クリック"
msgstr "Clic co botón dereito"

msgid "アドオンがインストールされていると操作できてしまいます"
msgstr "Se o complemento está instalado, poderás usalo."

