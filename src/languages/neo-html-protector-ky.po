msgid "設定"
msgstr "Жөндөөлөр"

msgid "IPログリーダー"
msgstr "IP журнал окугуч"

msgid "IPアドレスログ"
msgstr "IP даректеринин журналы"

msgid "全クリア"
msgstr "Бардык деңгээлдерди бүтүрүңүз"

msgid "IPログが全て削除されました"
msgstr "Бардык IP журналдары өчүрүлдү."

msgid "ID"
msgstr "ID"

msgid "タイムスタンプ"
msgstr "Убакыт белгиси"

msgid "IPアドレス"
msgstr "IP дарек"

msgid "ユーザーエージェント"
msgstr "Колдонуучу агент"

msgid "イベント"
msgstr "Иш-чара"

msgid "IPアドレスのデータはありません"
msgstr "Бул IP дарек боюнча маалымат жок."

msgid "EU GDPR対応"
msgstr "ЕБ ГДРнын талаптарына ылайык болуу"

msgid "無効"
msgstr "Жараксыз"

msgid "有効"
msgstr "Жарактуу"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Эгерде сиз Европа Биримдигинде WordPressти колдонуп жатсаңыз же веб-сайтыңыз Европа Биримдигиндеги колдонуучуларга багытталган болсо, анда бул функциянын күйгүзүлгөнүнө ынанууңузду суранабыз."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "«Тастыктоо» баскычы «Макулмун» же «Макул эмесмин» баскычына өзгөрөт жана жүрүм-турум бир аз өзгөрөт."

msgid "同意画面の色"
msgstr "Макулдук экранынын түсү"

msgid "自動"
msgstr "Автоматтык"

msgid "ライトモード"
msgstr "Жарык режим"

msgid "ダークモード"
msgstr "Караңгы режим"

msgid "同意画面表示中の配色を設定します"
msgstr "Макулдук экраны үчүн түстөр схемасын орнотуңуз"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Келишүү экранындагы мазмундун бүдөмүк болушу"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Колдонуучунун макулдугун алуу экранында көрсөтүлгөн мазмундун бүдөмүк деңгээлин орнотуңуз."

msgid "同意画面の透過"
msgstr "Макулдук экранынын ачыктыгы"

msgid "透過なし"
msgstr "Ачыктык жок"

msgid "同意画面の透過具合を設定します"
msgstr "Келишим экранынын тунукдугун орнотуңуз"

msgid "お知らせの1行目"
msgstr "Жарыянын биринчи сап"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Бул билдирүү баракча биринчи жолу жүктөлгөндө ар дайым көрсөтүлөт."

msgid "お知らせの2行目"
msgstr "Эскертүүнүн экинчи сапты"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Бул билдирүү EU GDPR күчүнө киргенде гана биринчи дисплейде ар дайым көрсөтүлөт."

msgid "お知らせの3行目"
msgstr "Эскертүүнүн үчүнчү саптары"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ал Купуялык саясаты шилтемесинин оң жагында көрүнөт."

msgid "非EU向け確認の文字列"
msgstr "Евробиримдикке кирбеген өлкөлөр үчүн тастыктоочу текст"

msgid "EU GDPR向け同意するの文字列"
msgstr "ЕБ GDPR үчүн макулдук тексти"

msgid "EU GDPR向け同意しないの文字列"
msgstr "ЕБ ГДРнын «Макулдук бербеңиз» үчүн текст"

msgid "プライバシーポリシーの文字列"
msgstr "Жеке маалыматтарды коргоо саясатынын тексти"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Жеке купуялык саясатынын URL дарегин бул жерге коюңуз."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Жеке купуялык саясатына төмөнкүлөрдү кошуңуз"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Алаяктуу аракеттерди аныктоо үчүн IP даректери сыяктуу идентификаторлор cookie-файлдарда жана маалымат базасында сакталат. Сакталган маалыматтар администратордун чечими боюнча өчүрүлөт."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Сүрөттөрдү коргоо кызматы күйгүзүлгөндө сүрөттөрдүн туура жеткирилишине кепилдик берүү үчүн биз IP-дарек менен сүрөттүн файлынын аты камтылган хешталган маалыматтарды базабызда 60 мүнөткө чейин сактайбыз."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Эгерде сиз Пайдалануу шарттарын түзүп жатсаңыз, анда аларга шилтемени Купуялык саясатыңызга кошконуңузга ынанууңуз керек."

msgid "利用規約の文字列"
msgstr "Колдонуу шарттарынын тексти"

msgid "利用規約のページ"
msgstr "Шарттар жана эрежелер баракчасы"

msgid "ページ選択なし"
msgstr "Бет тандалган жок"

msgid "検索エンジン等のURL"
msgstr "Издөө системалары үчүн URL даректер ж.б."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Макулдук берилбегенде башка баракка багытталган издөө системалары жана окшош сайттар үчүн URL дарегин белгилеңиз."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Каталарды оңдоо режими, консолдогу эскертүү билдирүүлөр"

msgid "右クリックの警告メッセージ"
msgstr "Оң чыкылдатуу эскертүү билдирүүсү"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDFке басып чыгаруу жана сактоо боюнча эскертүү билдирүүсү"

msgid "スクリーンショットの警告メッセージ"
msgstr "Скриншотто эскертүү билдирүүсү"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Шектүү скриншоттор боюнча эскертүү билдирүүсү"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Бардык текст тандалганда эскертүү билдирүүсү"

msgid "ページ保存の警告メッセージ"
msgstr "Бетти сактоо боюнча эскертүү билдирүүсү"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Көчүрүү же кесүү учурунда көрсөтүлүүчү билдирүү"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML булагын карап жатканда көрсөтүлүүчү билдирүү"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTMLди бурмалоо же коргоо учурунда булак кодунун жогорку бөлүгүндө көрсөтүлүүчү билдирүү"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML коргоо учурунда бир жолку аутентификация токени жараксыз болгондо көрсөтүлүүчү билдирүү"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Эгерде cookie-файлдар же JavaScript өчүрүлгөн болсо, көрсөтүлө турган билдирүү"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Чындыгында, бул JavaScript өчүрүлгөндө гана көрсөтүлөт."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Сүрөт корголгондо, ал жүктөлүп, сүрөткө билдирүү көрсөтүлөт"

msgid "HTML難読化 (圧縮)"
msgstr "HTMLди бурмалоо"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Бул стандарттык HTML кысуу; аны декоддоого мүмкүнчүлүгү бар веб-сайттар да бар."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Бул опцияны иштетүү view-source журналдарын алууга мүмкүндүк берет."

msgid "HTML保護"
msgstr "HTML коргоо"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ал HTMLдин эң минималдуу нускасын гана чыгарат — HTMLды кысуу колдонгондо чыккандан да азыраак — жана BODY тегиндеги мазмун такыр эле чыгарылбайт."

msgid "Firefoxに対しては無効です"
msgstr "Бул Firefoxке тиешелүү эмес."

msgid "SEOに著しく影響があります"
msgstr "Бул SEOга олуттуу таасир тийгизет."

msgid "HTMLをJavaScriptで描画"
msgstr "JavaScript аркылуу HTML түзүү"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox'ту айланып өтүү үчүн биз HTMLди JavaScript аркылуу чыгарабыз."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScriptти иштетүү веб-сайттын жүктөлүү ылдамдыгын олуттуу жайлатат."

msgid "画像の保護"
msgstr "Сүрөттү коргоо"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img теги чакырылган сайын сүрөттү коргоңуз"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "WordPressке жүктөлгөн бардык сүрөттөрдү бүт HTML чыгарылышында коргоңуз."

msgid "画像をダウンロードから保護します"
msgstr "Сүрөттөрдүн жүктөлүп алынышын алдын алат"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Сүрөт маалыматтары корголгондо, биз дээрлик бардык жүктөөлөрдү бөгөттөйбүз, уникалдуу бир жолу колдонулуучу URL-дарды беребиз, сеанска сакталган токендерди колдонуп аутентификация жүргүзөбүз жана сүрөттөрдү PHP аркылуу көрсөтөбүз; бул сүрөттөрдү уурдоонун дээрлик бардык учурларын натыйжалуу алдын алат."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Сүрөт маалыматтары корголгондо кэширлөө иштебейт, демек сайт кийинки кирүүлөрдө жайыраак ачылып, бул SEOга таасир этет."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Сүрөт маалыматтарын коргоо маалымат базасына түшүүчү жүктү көбөйтүшү мүмкүн."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Эгерде сиз «img теги чакырылган сайын сүрөттөрдү коргоо» опциясын тандасаңыз, система img теги түзүлгөндө add_filter функциясын колдонуп фильтрлөөнү ишке ашырат; бирок бул айрым темаларда туура иштебеши мүмкүн."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Эгерде сиз «Бүткүл HTML чыгарылышында WordPressке жүктөлгөн бардык сүрөттөрдү коргоо» опциясын тандасаңыз, плагин дээрлик бардык WordPress операцияларын камтып, мазмундагы ар бир img тегин иштетет. Кээ бир темаларда бул туура иштебеши мүмкүн экенин эсиңизде болсун."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Маалымат үчүн: «Featured Images» катары белгиленген сүрөттөр OGP маалыматы катары бөлүшүлөт жана коргоого алынбайт. Эгер аларды сөзсүз коргошуңуз келсе, HTML коргоону күйгүзүүдө Жогорку жөндөөлөрдө HEAD тегинин чыгарылышын жөндөп коюңуз."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Операциялык системанын стандарттык түзүмүнө киргизилген скриншот функциясын коргоого болбойт."

msgid "画像URLの保護"
msgstr "Сүрөттөрдүн URL даректерин коргоо"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Бул сүрөттү коргоо менен бирге колдонулушу керек; өз алдынча ал эч кандай максатты көздөбөйт."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Ал JavaScript аркылуу жалкоо жүктөлгөндүктөн, бул SEOга таасир этет."

msgid "画像のウォーターマーク"
msgstr "Сүрөттүн суу белгиси"

msgid "右下"
msgstr "оң ылдый"

msgid "ランダム位置"
msgstr "Кездейсоқ орун"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Сүрөттү коргоо менен бирге колдонулганда, динамикалык суу белгилери автордук укук ээсин так көрсөтүп, көрүүчүлөргө көзөмөлдөнүп жаткандай таасир берип, аларды мыйзамсыз аракеттерден алыс кармап турат."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Жөн гана JPG, PNG жана WebP форматтары колдоого алынат."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Муну иштетүү серверге түшүүчү жүктү көбөйтөт."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "HTML булак кодун бурмалоо жана коргоо учурунда ASCII-сүрөттөрдү чыгаруу"

msgid "表示なし"
msgstr "Экран жок"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "View-source аркылуу HTML булагын карап жатканда эскертүү көрсөтүүчү ASCII-артты көрсөтөт"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Максаттуу аракет аткарылганда дисплей дизайнын көрсөтүү"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Сары фондо кара текст менен жөнөкөй дизайн"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Кара фондо кызыл текст менен коркунучтуу стилдеги дизайн"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Кара фондо кызгылт-кызыл текст менен жасалган дизайн"

msgid "対象アクションを起こした時のBGM"
msgstr "Максаттуу аракет аткарылганда ойнолуучу фондук музыка"

msgid "サウンドなし"
msgstr "Үн жок"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Согуш жана Жеңиш - 1 мүнөт 16,3 секунд - 630 056 байт - 64 кбит/с - Лицензия: CC 2.1 же андан кийинки"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Dad Short - 3,8 секунд - 32 364 байт - 64 кбит/с - Лицензия: GPL 2.0 же андан кийинки"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23,5 секунд - 195 578 байт - 64 кбит/с - Лицензия: GPL 2.0 же андан кийинки"

