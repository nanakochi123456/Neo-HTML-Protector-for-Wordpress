msgstr "Fonncheol stíl retro – 2.2 soicind – 10,536 bait – 32 kbps – Ceadúnas: An Fearann Poiblí"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Réamhrá i stíl retro – 42.1 soicind – 179,138 bait – 32 kbps – Ceadúnas: An Fearann Poiblí"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Rabhadh ó ChatGPT - 3.8 soicind - 109,700 bait - 256 kbps - Ceadúnas: An Fearann Poiblí"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Fuaim phráinneach ard cosúil le foláireamh braite malbhreogáin – Cuid 1 le ChatGPT – 3.3 soicind – 102,850 bait – 256 kbps – Ceadúnas: An Fearann Poiblí"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Fuaim phráinne arda cosúil le foláireamh braite malbhogtha, Cuid 2 le ChatGPT - 3.3 soicind - 103,122 bait - 256 kbps - Ceadúnas: An Fearann Poiblí"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Fuaim i stíl MRI le ChatGPT – 1 nóiméad 14.9 soicind – 3,340,392 bait – 320 kbps – Ceadúnas: An Fearann Poiblí"

msgid "警告表示中のBGMを選択します"
msgstr "Roghnaigh an ceol cúlra le seinm le linn foláirimh."

msgid "びっくりするような雰囲気を作ります"
msgstr "Cruthaíonn sé atmaisféar iontasach."

msgid "Firefoxでは音声ブロックされます"
msgstr "Tá fuaim bactha in Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Bíp nuair a dhéantar an gníomh sonraithe"

msgid "有効 音量小さ目"
msgstr "Ar siúl, fuaim íseal"

msgid "有効 音量大き目"
msgstr "Gníomhach, an toirt ar ard"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Seinnfidh bíop do gach teagmhas méarchláir agus luchair fad is a bheidh rabhadh ar taispeáint."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
