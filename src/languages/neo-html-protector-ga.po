msgstr "Socruithe"

msgid "IPログリーダー"
msgstr "Léitheoir Loga IP"

msgid "IPアドレスログ"
msgstr "Lógh IP"

msgid "全クリア"
msgstr "Críochnaigh na leibhéil go léir"

msgid "IPログが全て削除されました"
msgstr "Tá na logaí IP go léir scriosta."

msgid "ID"
msgstr "Aitheantas"

msgid "タイムスタンプ"
msgstr "Cloigcheann"

msgid "IPアドレス"
msgstr "Seoladh IP"

msgid "ユーザーエージェント"
msgstr "Gníomhaire úsáideora"

msgid "イベント"
msgstr "Imeacht"

msgid "IPアドレスのデータはありません"
msgstr "Níl aon sonraí ann don seoladh IP seo."

msgid "EU GDPR対応"
msgstr "Comhlíonadh RGCS an AE"

msgid "無効"
msgstr "Míbhailí"

msgid "有効"
msgstr "Bailí"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Má tá tú ag úsáid WordPress laistigh den AE, nó má tá do shuíomh gréasáin dírithe ar úsáideoirí laistigh den AE, cinntigh le do thoil go bhfuil sé seo cumasaithe."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Athróidh an cnaipe 'Dearbhaigh' go 'Aontaím' nó 'Ní Aontaím', agus athróidh an iompar beagáinín."

msgid "同意画面の色"
msgstr "Dath an scáileáin toiliú"

msgid "自動"
msgstr "Uathoibríoch"

msgid "ライトモード"
msgstr "Mód éadrom"

msgid "ダークモード"
msgstr "Mód Dorcha"

msgid "同意画面表示中の配色を設定します"
msgstr "Socraigh scéim dathanna an scáileáin toiliúcháin."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Doiléiriú an ábhair ar an scáileán toiliúcháin"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Socraigh an leibhéal doiléirthe don ábhar a thaispeántar ar an scáileán toiliú."

msgid "同意画面の透過"
msgstr "Trédhearcacht an scáileáin toiliúcháin"

msgid "透過なし"
msgstr "Gan trédhearcacht"

msgid "同意画面の透過具合を設定します"
msgstr "Socraigh trédhearcacht an scáileáin toiliú"

msgid "お知らせの1行目"
msgstr "An chéad líne den fhógra"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Taispeántar an teachtaireacht seo i gcónaí an chéad uair a lódáiltear an leathanach."

msgid "お知らせの2行目"
msgstr "An dara líne den fhógra"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ní thaispeánfar an teachtaireacht seo ach ar an gcéad taispeáint, agus an GDPR de chuid an AE i bhfeidhm."

msgid "お知らせの3行目"
msgstr "An tríú líne den fhógra"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Beidh sé le feiceáil ar dheis na naíonnaisc chuig an bPolasaí Príobháideachais."

msgid "非EU向け確認の文字列"
msgstr "Téacs deimhnithe do thíortha nach bhfuil san AE"

msgid "EU GDPR向け同意するの文字列"
msgstr "Téacs toiliú do Rialachán Ginearálta an AE maidir le Cosaint Sonraí"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Téacs do 'Ná toirimheas' faoin RGCS de chuid an AE"

msgid "プライバシーポリシーの文字列"
msgstr "Téacs an bheartais phríobháideachais"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Le do thoil, socraigh an URL don pholasaí príobháideachais anseo."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Cuir an méid seo a leanas leis an bPolasaí Príobháideachais, le do thoil."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Chun gníomhaíocht chalaoiseach a bhrath, stóráiltear sainaithnéithe ar nós seoltaí IP i bhfianáin agus sa bhunachar sonraí. Scriostar na sonraí stóráilte de réir rogha an riarthóra."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Chun a chinntiú go seachadtar íomhánna i gceart ach amháin nuair a bhíonn cosaint íomhá cumasaithe, stórálaimid sonraí haischithe ina bhfuil an seoladh IP agus ainm comhaid na híomhá sa bhunachar sonraí ar feadh suas le 60 nóiméad."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Má tá Téarmaí Úsáide á socrú agat, cinntigh le do thoil go gcuireann tú nasc chucu san áireamh i do Pholasaí Príobháideachais."

msgid "利用規約の文字列"
msgstr "Téacs na dTéarmaí Úsáide"

msgid "利用規約のページ"
msgstr "Téarmaí agus Coinníollacha"

msgid "ページ選択なし"
msgstr "Níl leathanach ar bith roghnaithe"

msgid "検索エンジン等のURL"
msgstr "URLanna do chuardaitheoirí gréasáin, srl."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Socraigh an URL do innill chuardaigh agus suíomhanna comhchosúla a atreoraíonn úsáideoirí nuair nach dtugtar toiliú."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mód dífhabhtaithe, teachtaireachtaí rabhaidh consóil"

msgid "右クリックの警告メッセージ"
msgstr "Cliceáil deas ar an teachtaireacht rabhaidh"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Fógra rabhaidh maidir le priontáil agus sábháil mar PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Teachtaireacht rabhaidh sa phictiúr scáileáin"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Fógra rabhaidh maidir le seatanna scáileáin amhrasta"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Teachtaireacht rabhaidh nuair a bhíonn an téacs ar fad roghnaithe"

msgid "ページ保存の警告メッセージ"
msgstr "Fógra rabhaidh maidir le leathanach a shábháil"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Teachtaireacht a thaispeántar agus cóipeáil nó gearradh á ndéanamh"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Teachtaireacht le taispeáint agus an fhoinse HTML á breathnú"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Teachtaireacht le taispeáint ag barr an chóid foinseach agus HTML á doiléiriú nó á chosaint"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Teachtaireacht le taispeáint má bhíonn an t-eochairchomhartha fíordheimhnithe aonuaire neamhbhailí le linn cosanta HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Teachtaireacht le taispeáint má tá fianáin nó JavaScript díchumasaithe"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Go deimhin, ní thaispeántar é seo ach amháin nuair a bhíonn JavaScript díchumasaithe."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Nuair a chosnaítear íomhá, íoslódáiltear í, agus taispeántar teachtaireacht ar an íomhá sin"

msgid "HTML難読化 (圧縮)"
msgstr "Doiléiriú"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Is comhbhrú caighdeánach HTML é seo; tá suíomhanna gréasáin ann freisin a fhéadann é a dhíchódú."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ligeann cumasú an rogha seo duit an loga foinse-amhairc a aisghabháil."

msgid "HTML保護"
msgstr "Cosaint HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ní thugann sé amach ach an t-íosmhéid lom de HTML—níos lú fós ná nuair a úsáidtear comhbhrú HTML—agus ní thugtar an t-ábhar laistigh den chlibe BODY amach ar chor ar bith."

msgid "Firefoxに対しては無効です"
msgstr "Ní bhaineann sé seo le Firefox."

msgid "SEOに著しく影響があります"
msgstr "Tá tionchar suntasach aige seo ar SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Rindreáil HTML le JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Chun an fhadhb le Firefox a shárú, déanaimid an HTML a rindreáil le JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Má chumasaítear rindreáil JavaScript, maolófar go mór ar luas lódála an tsuímh ghréasáin."

msgid "画像の保護"
msgstr "Cosaint íomhá"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Cosain an íomhá gach uair a thugtar gairm don chlibe img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Cosain gach íomhá a uaslódáiltear chuig WordPress laistigh den toraidh HTML iomlán."

msgid "画像をダウンロードから保護します"
msgstr "Cosnaíonn sé íomhánna ó íoslódáil"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Nuair a chosnaítear sonraí íomhá, cuirimid cosc ar bheagnach gach íoslódáil, eisímid URLanna uathúla aonuaire, déanaimid fíordheimhniú ag úsáid comharthaí a stóráiltear sa seisiún, agus taispeánaimid na híomhánna trí PHP; cuireann sé seo cosc éifeachtach ar bheagnach gach cás de ghoid íomhánna."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Nuair a chosnaítear sonraí íomhá, ní oibríonn an taisceadh, rud a chiallaíonn go lódálfaidh an suíomh níos moille ar chuairteanna ina dhiaidh sin, agus mar sin go mbíonn tionchar aige ar SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "D'fhéadfadh cosaint sonraí íomhá an t-ualach ar an mbunachar sonraí a mhéadú."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Má roghnaíonn tú 'Íomhánna a chosaint aon uair a ghlaoitear ar chlibe img', úsáideann an córas add_filter chun scagadh a chur i bhfeidhm nuair a ghintear an chlibe img; áfach, d'fhéadfadh sé nach n-oibreoidh sé seo i gceart le roinnt téamaí."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Má roghnaíonn tú 'Cosain gach íomhá a uaslódáiltear ar WordPress laistigh den aschur HTML iomlán', gabhfaidh an breiseán beagnach gach oibríocht de chuid WordPress agus próiseálfaidh sé gach clib img laistigh den ábhar. Tabhair faoi deara, le do thoil, go bhféadfadh sé nach n-oibreoidh sé seo i gceart le roinnt téamaí."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Tabhair faoi deara, le do thoil, go roinnfear íomhánna a ainmnítear mar íomhánna réadmhaoin mar shonraí OGP agus nach féidir iad a chosaint. Más gá duit iad a chosaint ar gach costas, athraigh an socrú d'aschur an chlib HEAD sna socruithe ardleibhéil nuair a chumasaíonn tú cosaint HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Ní féidir an fheidhm seat scáileáin atá ionsuite sa chóras oibriúcháin a chosaint."

msgid "画像URLの保護"
msgstr "URLanna íomhá a chosaint"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Ba cheart é seo a úsáid i gcomhar le cosaint íomhá; ina aonar, níl aon chuspóir leis."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Toisc go lódáiltear é go leisciúil trí JavaScript, cuireann sé seo isteach ar SEO."

msgid "画像のウォーターマーク"
msgstr "Uisce-mharc an íomhá"

msgid "右下"
msgstr "íos-deas"

msgid "ランダム位置"
msgstr "Suíomh randamach"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Nuair a úsáidtear iad i gcomhar le cosaint íomhá, léiríonn uisceadáin dhinimiciúla úinéireacht chóipchirt go soiléir agus ag an am céanna tugann siad an tuiscint do lucht féachana go bhfuiltear á monatóireacht, agus dá bhrí sin feidhmíonn siad mar dhíspreagadh."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Ní thacaítear ach le formáidí JPG, PNG agus WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Má chuirtear seo i ngníomh, méadófar an t-ualach ar an bhfreastalaí."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "ASCII-ealaín a aschur ó chód foinseach HTML le linn doiléiriú agus cosaint HTML"

msgid "表示なし"
msgstr "Gan taispeáint"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Taispeánann ealaín ASCII a léiríonn rabhadh agus an fhoinse HTML á breathnú trí 'view-source'."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Taispeáin an dearadh nuair a dhéantar an gníomh spriocdhírithe."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Dearadh bunúsach le téacs dubh ar chúlra buí."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Dearadh de chineál uafáis le téacs dearg ar chúlra dubh."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Dearadh ina bhfuil téacs dearg lonrach ar chúlra dubh"

msgid "対象アクションを起こした時のBGM"
msgstr "Ceol cúlra a sheinntear nuair a dhéantar an gníomh sprioc."

msgid "サウンドなし"
msgstr "Gan fuaim"

