msgid "設定"
msgstr "تنظیمات"

msgid "IPログリーダー"
msgstr "خوانندهٔ گزارش‌های IP"

msgid "IPアドレスログ"
msgstr "سوابق آدرس IP"

msgid "全クリア"
msgstr "تمام سطوح را کامل کنید"

msgid "IPログが全て削除されました"
msgstr "تمام گزارش‌های IP حذف شده‌اند"

msgid "ID"
msgstr "شناسه"

msgid "タイムスタンプ"
msgstr "برچسب زمانی"

msgid "IPアドレス"
msgstr "آدرس آی‌پی"

msgid "ユーザーエージェント"
msgstr "نماینده کاربر"

msgid "イベント"
msgstr "رویداد"

msgid "IPアドレスのデータはありません"
msgstr "داده‌ای برای این آدرس IP وجود ندارد."

msgid "EU GDPR対応"
msgstr "رعایت GDPR اتحادیه اروپا"

msgid "無効"
msgstr "نامعتبر"

msgid "有効"
msgstr "معتبر"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "اگر از وردپرس در اتحادیه اروپا استفاده می‌کنید، یا اگر وب‌سایت شما کاربران داخل اتحادیه اروپا را هدف قرار داده است، لطفاً اطمینان حاصل کنید که این قابلیت فعال باشد."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "دکمه «تأیید» به «موافقم» یا «مخالفم» تغییر خواهد کرد و رفتار آن کمی تغییر خواهد کرد."

msgid "同意画面の色"
msgstr "رنگ صفحهٔ رضایت‌نامه"

msgid "自動"
msgstr "خودکار"

msgid "ライトモード"
msgstr "حالت سبک"

msgid "ダークモード"
msgstr "حالت تاریک"

msgid "同意画面表示中の配色を設定します"
msgstr "قالب رنگ صفحهٔ رضایت را تنظیم کنید"

msgid "同意画面中のコンテンツのぼかし"
msgstr "تار شدن محتوا در صفحهٔ رضایت‌نامه"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "سطح تاری برای محتوای نمایش‌داده‌شده در صفحهٔ رضایت را تنظیم کنید."

msgid "同意画面の透過"
msgstr "شفافیت صفحهٔ رضایت‌نامه"

msgid "透過なし"
msgstr "شفافیت وجود ندارد"

msgid "同意画面の透過具合を設定します"
msgstr "شفافیت صفحه رضایت را تنظیم کنید"

msgid "お知らせの1行目"
msgstr "اولین خط اطلاعیه"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "این پیام همیشه اولین باری که صفحه بارگذاری می‌شود نمایش داده می‌شود."

msgid "お知らせの2行目"
msgstr "خط دوم اطلاعیه"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "این پیام همیشه تنها در اولین نمایش و زمانی که GDPR اتحادیه اروپا اجرایی باشد، نمایش داده می‌شود."

msgid "お知らせの3行目"
msgstr "خط سوم اطلاعیه"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "این در سمت راست لینک سیاست حفظ حریم خصوصی ظاهر خواهد شد."

msgid "非EU向け確認の文字列"
msgstr "متن تأیید برای کشورهای غیر اتحادیه اروپا"

msgid "EU GDPR向け同意するの文字列"
msgstr "متن رضایت برای GDPR اتحادیه اروپا"

msgid "EU GDPR向け同意しないの文字列"
msgstr "متن برای «موافقت نکنید» تحت GDPR اتحادیه اروپا"

msgid "プライバシーポリシーの文字列"
msgstr "متن سیاست حفظ حریم خصوصی"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "لطفاً URL سیاست حفظ حریم خصوصی را اینجا تنظیم کنید."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "لطفاً موارد زیر را به سیاست حفظ حریم خصوصی اضافه کنید."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "برای شناسایی فعالیت‌های تقلب‌آمیز، شناسه‌هایی مانند آدرس‌های IP در کوکی‌ها و پایگاه داده ذخیره می‌شوند. داده‌های ذخیره‌شده بنا به صلاحدید مدیر حذف می‌شوند."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "برای اطمینان از تحویل صحیح تصاویر هنگام فعال بودن محافظت از تصویر، ما داده‌های هش‌شده شامل آدرس IP و نام فایل تصویر را تا ۶۰ دقیقه در پایگاه داده خود ذخیره می‌کنیم."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "اگر در حال تنظیم شرایط استفاده هستید، لطفاً اطمینان حاصل کنید که در سیاست حفظ حریم خصوصی خود لینکی به آن گنجانده‌اید."

msgid "利用規約の文字列"
msgstr "متن شرایط استفاده"

msgid "利用規約のページ"
msgstr "صفحه شرایط و ضوابط"

msgid "ページ選択なし"
msgstr "هیچ صفحه‌ای انتخاب نشده است"

msgid "検索エンジン等のURL"
msgstr "URLها برای موتورهای جستجو و غیره."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "URL را برای موتورهای جستجو و سایت‌های مشابه که در صورت عدم رضایت کاربران را هدایت می‌کنند، تنظیم کنید."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "حالت اشکال‌زدایی، پیام‌های هشدار کنسول"

msgid "右クリックの警告メッセージ"
msgstr "پیام هشدار کلیک راست"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "پیام هشدار در مورد چاپ و ذخیره به صورت PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "پیام هشدار در تصویر صفحه"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "پیام هشدار در مورد اسکرین‌شات‌های مشکوک"

msgid "テキスト全選択時の警告メッセージ"
msgstr "پیام هشدار هنگام انتخاب تمام متن"

msgid "ページ保存の警告メッセージ"
msgstr "پیام هشدار در مورد ذخیرهٔ صفحه"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "پیامی که هنگام کپی یا برش نمایش داده می‌شود"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "پیامی که هنگام مشاهدهٔ منبع HTML نمایش داده شود"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "پیامی که در بالای کد منبع هنگام مبهم‌سازی یا محافظت از HTML نمایش داده می‌شود."

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "پیامی که در صورت نامعتبر بودن توکن احراز هویت یک‌باره در حین محافظت HTML نمایش داده می‌شود."

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "پیامی که در صورت غیرفعال بودن کوکی‌ها یا جاوااسکریپت نمایش داده شود"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "در واقع، این تنها زمانی نمایش داده می‌شود که جاوااسکریپت غیرفعال باشد."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "وقتی یک تصویر محافظت می‌شود، دانلود شده و پیامی روی آن نمایش داده می‌شود"

msgid "HTML難読化 (圧縮)"
msgstr "مبهم‌سازی"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "این فشرده‌سازی استاندارد HTML است؛ وب‌سایت‌هایی هم وجود دارند که می‌توانند آن را رمزگشایی کنند."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "فعال‌سازی این گزینه به شما امکان می‌دهد تا لاگ‌های view-source را بازیابی کنید."

msgid "HTML保護"
msgstr "حفاظت از HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "این تنها حداقل لازم HTML را تولید می‌کند—حتی کمتر از زمانی که از فشرده‌سازی HTML استفاده می‌شود—و محتوای داخل تگ BODY اصلاً نمایش داده نخواهد شد."

msgid "Firefoxに対しては無効です"
msgstr "این در مورد فایرفاکس صدق نمی‌کند."

msgid "SEOに著しく影響があります"
msgstr "این تأثیر قابل‌توجهی بر سئو دارد."

msgid "HTMLをJavaScriptで描画"
msgstr "رندر کردن HTML با استفاده از جاوااسکریپت"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "برای دور زدن فایرفاکس، HTML را با استفاده از جاوااسکریپت رندر می‌کنیم."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "فعال‌سازی رندرینگ جاوااسکریپت سرعت بارگذاری وب‌سایت را به‌طور قابل‌توجهی کاهش می‌دهد."

msgid "画像の保護"
msgstr "حفاظت از تصویر"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "هر بار که تگ img فراخوانی می‌شود، تصویر را محافظت کنید."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "تمام تصاویر بارگذاری‌شده در وردپرس را در سراسر خروجی HTML محافظت کنید."

msgid "画像をダウンロードから保護します"
msgstr "از دانلود تصاویر جلوگیری می‌کند"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "وقتی داده‌های تصویر محافظت می‌شوند، ما تقریباً همه دانلودها را مسدود می‌کنیم، آدرس‌های اینترنتی یک‌باره و منحصربه‌فرد صادر می‌کنیم، با استفاده از توکن‌های ذخیره‌شده در جلسه احراز هویت می‌کنیم و تصاویر را از طریق PHP نمایش می‌دهیم؛ این روش عملاً از تقریباً همه سرقت‌های تصویر جلوگیری می‌کند."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "وقتی داده‌های تصویر محافظت می‌شوند، کشینگ کار نمی‌کند، که به این معنی است سایت در بازدیدهای بعدی کندتر بارگذاری می‌شود و در نتیجه بر سئو تأثیر می‌گذارد."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "حفاظت از داده‌های تصویری ممکن است بار روی پایگاه داده را افزایش دهد."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "اگر گزینه «هر زمان که تگ img فراخوانی می‌شود، تصاویر را محافظت کن» را انتخاب کنید، سیستم از add_filter برای اعمال فیلتر هنگام تولید تگ img استفاده می‌کند؛ با این حال، این ممکن است با برخی قالب‌ها به‌درستی کار نکند."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "اگر گزینه «حفاظت از تمام تصاویر بارگذاری‌شده در وردپرس در کل خروجی HTML» را انتخاب کنید، افزونه تقریباً تمام عملیات وردپرس را ضبط کرده و هر تگ img در محتوا را پردازش می‌کند. لطفاً توجه داشته باشید که این ممکن است با برخی قالب‌ها به‌درستی کار نکند."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "لطفاً توجه داشته باشید که تصاویری که به‌عنوان تصاویر ویژه مشخص می‌شوند، به‌عنوان داده‌های OGP به اشتراک گذاشته می‌شوند و قابل محافظت نیستند. اگر حتماً می‌خواهید آن‌ها را محافظت کنید، لطفاً هنگام فعال‌سازی محافظت HTML، در بخش تنظیمات پیشرفته، تنظیمات خروجی تگ HEAD را تغییر دهید."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "عملکرد اسکرین‌شات تعبیه‌شده در سیستم‌عامل قابل محافظت نیست."

msgid "画像URLの保護"
msgstr "حفاظت از آدرس‌های اینترنتی تصاویر"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "این باید همراه با محافظت از تصویر استفاده شود؛ به‌تنهایی هیچ کاربردی ندارد."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "از آنجا که از طریق جاوااسکریپت بارگذاری می‌شود، این موضوع بر سئو تأثیر می‌گذارد."

msgid "画像のウォーターマーク"
msgstr "واترمارک تصویر"

msgid "右下"
msgstr "پایین راست"

msgid "ランダム位置"
msgstr "موقعیت تصادفی"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "واترمارک‌های پویا که همراه با محافظت از تصویر استفاده می‌شوند، به‌وضوح مالکیت حق نشر را نشان می‌دهند و در عین حال این تصور را در بینندگان ایجاد می‌کنند که تحت نظارت هستند و بدین ترتیب به‌عنوان عاملی بازدارنده عمل می‌کنند."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "فقط فرمت‌های JPG، PNG و WebP پشتیبانی می‌شوند."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "فعال‌سازی این مورد بار سرور را افزایش می‌دهد."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "خروجی گرفتن هنر ASCII از کد منبع HTML در حین مبهم‌سازی و محافظت"

msgid "表示なし"
msgstr "نمایش داده نمی‌شود"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "نمایش آثار هنری ASCII که هنگام مشاهدهٔ منبع HTML با استفاده از «view-source» هشدار را نشان می‌دهند."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "طراحی نمایش زمانی که اقدام هدف انجام می‌شود"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "یک طرح ساده با متن سیاه روی پس‌زمینه زرد"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "طراحی به سبک وحشتناک با متن قرمز روی پس‌زمینه سیاه"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "طراحی با متن قرمز درخشان روی پس‌زمینهٔ سیاه"

msgid "対象アクションを起こした時のBGM"
msgstr "موسیقی پس‌زمینه‌ای که هنگام انجام اقدام هدف پخش می‌شود"

msgid "サウンドなし"
msgstr "صدایی نیست"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "نبرد و پیروزی - ۱ دقیقه و ۱۶٫۳ ثانیه - ۶۳۰٬۰۵۶ بایت - ۶۴ کیلوبیت بر ثانیه - مجوز: CC 2.1 یا جدیدتر"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "پدر کوتاه - ۳٫۸ ثانیه - ۳۲٬۳۶۴ بایت - ۶۴ کیلوبیت بر ثانیه - مجوز: GPL 2.0 یا بالاتر"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - ۲۳٫۵ ثانیه - ۱۹۵٬۵۷۸ بایت - ۶۴ کیلوبیت بر ثانیه - مجوز: GPL 2.0 یا جدیدتر"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
