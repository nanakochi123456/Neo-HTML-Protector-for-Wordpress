msgstr "Laban at Tagumpay - 1 minuto 16.3 segundo - 630,056 baites - 64 kbps - Lisensya: CC 2.1 o mas bago"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Maikling Tatay - 3.8 segundo - 32,364 baites - 64 kbps - Lisensya: GPL 2.0 o mas bago"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23.5 segundo - 195,578 baites - 64 kbps - Lisensya: GPL 2.0 o mas bago"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
