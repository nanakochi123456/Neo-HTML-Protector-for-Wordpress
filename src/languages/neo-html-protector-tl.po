msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Fanfare – 22.3 segundo – 183,926 baites – 64 kbps – Lisensya: Pampublikong Dominyo"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Palakpak na istilong retro – 2.2 segundo – 10,536 baites – 32 kbps – Lisensya: Pampublikong domain"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Intro na may retro na istilo – 42.1 segundo – 179,138 baites – 32 kbps – Lisensya: Pampublikong domain"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Babala mula sa ChatGPT - 3.8 segundo - 109,700 baites - 256 kbps - Lisensya: Pampublikong Dominyo"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Isang tunog na may mataas na pagka-apurado na parang alerto ng pagtuklas ng malware – Bahagi 1 ni ChatGPT – 3.3 segundo – 102,850 baites – 256 kbps – Lisensya: Pampublikong Ari-arian"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Isang tunog na may mataas na pagmamadali na parang alerto ng pagtuklas ng malware, Bahagi 2 ni ChatGPT - 3.3 segundo - 103,122 bait - 256 kbps - Lisensya: Pampublikong Ari-arian"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Tunog na istilong MRI ni ChatGPT – 1 minuto 14.9 segundo – 3,340,392 bait – 320 kbps – Lisensya: Pampublikong Dominyo"

msgid "警告表示中のBGMを選択します"
msgstr "Piliin ang musika sa background na ipapatugtog habang may babala."

msgid "びっくりするような雰囲気を作ります"
msgstr "Naglilikha ito ng nakakagulat na atmospera."

msgid "Firefoxでは音声ブロックされます"
msgstr "Nabara ang audio sa Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Isang bip kapag naisagawa ang tinukoy na aksyon"

msgid "有効 音量小さ目"
msgstr "Naka-on, mababa ang lakas ng tunog"

msgid "有効 音量大き目"
msgstr "Aktibo, naka-set sa mataas ang bolyum"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Tutunog ang isang beep bilang tugon sa lahat ng kaganapan ng susi at mouse habang ipinapakita ang babala."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Nagbibigay ito ng impresyon na nagkaroon ng aberya ang aparato habang ipinapakita ang babala."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Pagtatago ng cursor ng mouse kapag isinagawa ang isang tiyak na aksyon"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Itinatago ang cursor ng mouse sa lugar ng browser habang ipinapakita ang babala."

msgid "デバッグモード"
msgstr "Modo ng pag-debug"

msgid "妨害＋記録のみ"
msgstr "Interference + Records lamang"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Pagsagabal + Pag-log + Pagpapakita + Pag-redirect"

msgid "メニューからは操作できてしまいます"
msgstr "Maaari mo pa ring ma-access ito sa pamamagitan ng menu."

msgid "Firefoxにおけるデバッグモード"
msgstr "Debug mode sa Firefox"

msgid "ブラウザーコンソール"
msgstr "Konsol ng browser"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Sa katunayan, maaari mo itong patakbuhin mula sa debug mode."

msgid "HTMLソース表示"
msgstr "Tingnan ang pinagmulang HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Maaari mong isagawa ang operasyon nang simple sa pamamagitan ng pagpasok ng URL na nagsisimula sa 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Maaari mong protektahan ang iyong nilalaman sa pamamagitan ng pagsasama nito sa proteksyon ng HTML."

msgid "印刷"
msgstr "I-print"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Bagaman pinipigilan nito ang pagpi-print, maaaring hindi ito gumana nang maayos sa ilang mga browser."

msgid "スクリーンショット"
msgstr "Skrinshot"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Depende sa operating system, browser, o pamamaraang ginamit, maaaring hindi ito ma-block, o maaaring hindi ito matukoy."

