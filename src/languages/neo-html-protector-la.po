msgid "設定"
msgstr "Configurationes"

msgid "IPログリーダー"
msgstr "Lector Diariorum IP"

msgid "IPアドレスログ"
msgstr "Registrum inscriptionum IP"

msgid "全クリア"
msgstr "Perage omnes gradus"

msgid "IPログが全て削除されました"
msgstr "Omnes commentarii IP deleti sunt."

msgid "ID"
msgstr "Identificatio"

msgid "タイムスタンプ"
msgstr "Tempus notationis"

msgid "IPアドレス"
msgstr "Inscriptio Protocollaris"

msgid "ユーザーエージェント"
msgstr "Agentis Usoris"

msgid "イベント"
msgstr "Eventus"

msgid "IPアドレスのデータはありません"
msgstr "Nulla data sunt pro hoc inscriptione IP."

msgid "EU GDPR対応"
msgstr "Conformitas cum GDPR UE"

msgid "無効"
msgstr "Invalidus"

msgid "有効"
msgstr "Valet"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Si WordPress intra Unionem Europaeam uteris, aut si situs tuus usoribus intra Unionem Europaeam destinatur, quaeso cura ut hoc activetur."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Bullula 'Confirma' in 'Assentior' aut 'Dissentio' mutabitur, et modus agendi leviter mutabitur."

msgid "同意画面の色"
msgstr "Color paginae assensus"

msgid "自動"
msgstr "Sponte sua"

msgid "ライトモード"
msgstr "Modus levis"

msgid "ダークモード"
msgstr "Modus Obscurus"

msgid "同意画面表示中の配色を設定します"
msgstr "Constitue ordinem colorum pro pagina consensūs."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Imaginis conturbatio in velo consensūs"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Constitue gradum obscuritatis pro materia in velo assentimenti exhibita."

msgid "同意画面の透過"
msgstr "Perspicuitas monitorii assensus"

msgid "透過なし"
msgstr "Nulla perspicuitas"

msgid "同意画面の透過具合を設定します"
msgstr "Transparentiā tabulae assentīmentī statuendā"

msgid "お知らせの1行目"
msgstr "Prima linea nuntii"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Hoc nuntius semper ostenditur cum pagina primum oneratur."

msgid "お知らせの2行目"
msgstr "Secunda linea notitiae"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Hoc nuntium semper in primo ostento apparebit, dum GDPR UE valet."

msgid "お知らせの3行目"
msgstr "Tertia linea nuntii"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ad dextram nexu ad Praescriptum de Re Privata apparebit."

msgid "非EU向け確認の文字列"
msgstr "Textus confirmationis pro civitatibus non UE"

msgid "EU GDPR向け同意するの文字列"
msgstr "Textus assensus pro GDPR UE"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Textus pro 'Noli consentire' sub GDPR UE"

msgid "プライバシーポリシーの文字列"
msgstr "Textus de secreto servando"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Quaeso, hic URL consilii de secreto constitue."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Quaeso, sequentia ad Praescriptum de Re Privata addite."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Ad actiones fraudulentas detegendas, indicia, sicut inscriptiones IP, in crustulis et in repositorio datorum servantur. Data servata ad arbitrium administratoris delentur."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Ut certum sit imagines recte tradi solum cum praesidium imaginum activum est, data cryptographice digesta, quae inscriptionem IP et nomen documenti imaginis continent, in tabulario usque ad sexaginta minuta servamus."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Si Condiciones Usus instituitis, curate ut nexum ad eas in Politica Vestra de Re Privata includatis."

msgid "利用規約の文字列"
msgstr "Textus Conditionum Usus"

msgid "利用規約のページ"
msgstr "Conditiones et Pacta"

msgid "ページ選択なし"
msgstr "Nulla pagina selecta"

msgid "検索エンジン等のURL"
msgstr "Nexus ad machinas quaerendi, etc."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Pone URL pro machinis quaerendi et sitibus similibus qui utentes redirectant cum consensus non datur."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Modus emendationis, monita consolaria"

msgid "右クリックの警告メッセージ"
msgstr "Monitum de nuntio dextro"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Monitum de imprimendo et servando ut PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Nuntius monitus in imagine scrinii"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Monitum de imaginibus scrinii suspectis"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Monitum cum omnis textus selectus est"

msgid "ページ保存の警告メッセージ"
msgstr "Monitum de pagina servanda"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Nuntius qui monstratur cum exscribitur aut resecatur"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Nuntius qui ostendatur cum fons HTML inspicitur"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Nuntius in summa parte codicis fontis ostendendus, cum HTML obscuratur aut protegitur."

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Nuntius qui ostendatur si tessera authentificationis unius vicis inter tutelam HTML invalida sit."

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Nuntius qui ostendatur si crustula aut JavaScript inactivata sunt."

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Re vera, hoc solum monstratur cum JavaScript exstinguitur."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Cum imago protegitur, deponitur et nuntius super ea ostenditur"

msgid "HTML難読化 (圧縮)"
msgstr "Obfuscatio"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Haec est compressio HTML usitata; sunt etiam situs interretiales qui eam decodificare possunt."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Hac optione activa, potes recuperāre acta fontis visificandi."

msgid "HTML保護"
msgstr "Protectio HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Minimum solum codicis HTML reddit—paucius etiam quam cum compressione HTML adhibita—et materia intra tesseram BODY omnino non redditur."

msgid "Firefoxに対しては無効です"
msgstr "Hoc ad Firefox non pertinet."

msgid "SEOに著しく影響があります"
msgstr "Hoc magnum momentum in SEO habet."

msgid "HTMLをJavaScriptで描画"
msgstr "Renditio HTML per JavaScriptum"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Ut Firefox circumveniamus, HTML per JavaScript reddimus."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Activatio interpretationis JavaScript graviter tardabit celeritatem onerationis situs interretialis."

msgid "画像の保護"
msgstr "Imaginis praesidium"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Imaginem protege quotiescumque titulus img vocatur."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Omnes imagines in WordPress impositas intra totum textum HTML emissum protege."

msgid "画像をダウンロードから保護します"
msgstr "Imagines a depromptione protegit"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Cum data imaginum proteguntur, paene omnes depromptiones prohibemus, nexus singulares semel valentes emittimus, per tesseras in sessione repertas authentificamus, et imagines per PHP ostendimus; hoc reapse paene omnem furtum imaginum prohibet."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Cum data imaginum proteguntur, memoria cache non fungitur, quod efficit ut situs in visitationibus posterioribus tardius oneretur, ita SEO afficiendo."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Data imaginum tuenda onus in repositorio datorum augere potest."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Si optionem 'Imagines protege quotiescumque tegula img vocatur' seligis, systema add_filter adhibet ut filtrationem applicet cum tegula img generatur; tamen, hoc non recte cum quibusdam thematibus operari potest."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Si optionem 'Protege omnes imagines in WordPress impositas intra totum exsitum HTML' seligis, additamentum paene omnes operationes WordPress comprehendet et omnem notam img in contentis tractabit. Nota, quaeso, hoc fortasse non recte cum quibusdam thematis fungetur."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Notandum est imagines, quae imagines praecipuae designantur, ut data OGP communicari et protegi non posse. Si eas omnino protegere necesse est, quaeso, in configurationibus provectis, cum protectionem HTML habilitas, configurationem emissionis notae HEAD muta."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Functio imaginum capiendarum, quae ut norma in systemate operandi includitur, protegi non potest."

msgid "画像URLの保護"
msgstr "De URL imaginum tuendis"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Hoc una cum praesidio imaginum adhibendum est; per se, nihil prodest."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Quoniam per JavaScript oneratur, hoc SEO afficit."

msgid "画像のウォーターマーク"
msgstr "Signum aquatile imaginis"

msgid "右下"
msgstr "Infima dextra"

msgid "ランダム位置"
msgstr "Positio fortuita"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Una cum tutela imaginum adhibitae, filigranæ dynamicae proprietatem iuris auctoris clare indicant, dum spectatoribus opinionem se observari habere inducunt, ita deterrentes."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Tantum formae JPG, PNG et WebP sustinentur."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Hoc activato, onus servitori augebitur."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ex codice fonte HTML artem ASCII emittere inter obscurationem et tutelam"

msgid "表示なし"
msgstr "Nullum ostentum"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Ars ASCII monstrat monitum cum fons HTML per 'view-source' inspicitur."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Ostende consilium cum actio petita perficitur."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Forma simplex textu nigro in fundo flavo."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Forma horrifica cum textu rubro in fundo nigro."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Forma textu rubro lucente in fundo nigro"

msgid "対象アクションを起こした時のBGM"
msgstr "Musica comitans quae sonat cum actio petita perficitur."

msgid "サウンドなし"
msgstr "Nullus sonus"

