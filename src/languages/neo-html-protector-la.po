msgid "警告表示中のBGMを選択します"
msgstr "Elige musicam comitantem quae per monitum sonet."

msgid "びっくりするような雰囲気を作ります"
msgstr "Creat miram atmosphaeram."

msgid "Firefoxでは音声ブロックされます"
msgstr "Sonus in Firefox obstructus est."

msgid "対象アクションを起こした時のビープ音"
msgstr "Sibilus cum actio praescripta perficitur."

msgid "有効 音量小さ目"
msgstr "In, volumen humile"

msgid "有効 音量大き目"
msgstr "Activum, volumen ad summum positum"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Sibilus edetur ad omnia eventa clavis et muris, dum monitus ostenditur."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Videtur machinamentum insanire dum monitus ostenditur."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Cursorem muris celare cum actio certa perficitur."

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Cursorem muris in area navigatri celat, dum monitus ostenditur."

msgid "デバッグモード"
msgstr "Modus emendationis"

msgid "妨害＋記録のみ"
msgstr "Interferentia et Acta Sola"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Interferentia + Registratio + Ostensio + Redirectio"

msgid "メニューからは操作できてしまいます"
msgstr "Ad eam per indicem adhuc accedere potes."

msgid "Firefoxにおけるデバッグモード"
msgstr "Modus mendorum corrigendorum in Firefox"

msgid "ブラウザーコンソール"
msgstr "Consola navigatri"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Re vera, id ex modo deprehendendi operari potes."

msgid "HTMLソース表示"
msgstr "Fontem HTML vide"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Operationem simpliciter exsequi potes URL inserendo quod 'view-source:' incipit."

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Potestis contenta vestra tueri, hoc cum tutela HTML coniungendo."

msgid "印刷"
msgstr "Imprime"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Quamquam impressionem impedit, in quibusdam navigatris fortasse non recte fungitur."

msgid "スクリーンショット"
msgstr "Imago monitorii"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Secundum systema operativum, navigatrum, aut modum adhibitum, hoc aut prohiberi non poterit, aut non detegetur."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Imago fenestrae in recessum motae, ut suspicatur."

msgid "あわせて、スクリーンショット以外の機能（タブ切り替え・ウィンドウ切り替え）にも反応してしまいます。"
msgstr "Respondet etiam functionibus aliis quam imaginum capiendarum"

msgid "2キー押下のスクリーンショットの疑い"
msgstr "Imago monitorii suspecta duabus clavibus pressis capta"

msgid "上の項目の検出方法は完全ではありません、予防的に検出を行います"
msgstr "Rationes ad supradicta detegenda non sunt omnino certae; detectio ad cautelam peragitur."

msgid "スクリーンショットだけではなく、デバッグモード等も検出します"
msgstr "Non solum imagines scrutiales, sed etiam modos emendatorios et similia detegit."

msgid "ページ保存"
msgstr "Serva paginam"

msgid "右クリック"
msgstr "Dextera preme"

msgid "アドオンがインストールされていると操作できてしまいます"
msgstr "Si additamentum installatum erit, eo uti poteris."

msgid "コピー・カット"
msgstr "Exscribe et seca"

msgid "本プラグインの設定によってはこのイベントにたどり着くことはほとんどない場合があります"
msgstr "Secundum configurationes huius additamenti, hoc eventum raro experieris."

msgid "テキスト全選択"
msgstr "Omne textum selige"

msgid "テキスト選択"
msgstr "Textum selige"

msgid "デバッガー起動ログ、デバッガー妨害"
msgstr "Registrum initiale depuratoris, Interferentia depuratoris"

msgid "デバッグモードの使い勝手を少し悪くし、デバッガを起動したことをログに残します、ブラウザによってはこの挙動が止められてしまいます"
msgstr "Hoc modum deprehensorium paulo minus usoribus commodum reddit et notat deprehensorem inceptum esse; tamen, nonnulli navigatores hanc actionem impedire possunt."

msgid "リダイレクトするURL"
msgstr "URL redirectum"

msgid "利用規約などのページに転送すると良いでしょう"
msgstr "Consilium bonum esset utentes ad paginas sicut Conditiones Usus redirectare."

msgid "空欄にすると元のURLにリダイレクトをします"
msgstr "Si vacuum relinquatur, ad URL primigenium rediriget."

