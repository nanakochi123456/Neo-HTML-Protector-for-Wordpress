msgstr "Sagalee kabajaa akka durii – sekondii 2.2 – baayitii 10,536 – 32 kbps – Eeyyama: Qabeenya Ummataa"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Seensa akkaataa durii – sekondii 42.1 – baayitii 179,138 – 32 kbps – Eeyyama: Qabeenya Ummataa"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Akeekkachiisa ChatGPT - sekondii 3.8 - baayitii 109,700 - kbps 256 - Eeyyama: Qabeenya Ummataa"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sagalee ariifannaa guddaa qabu kan akka akeekkachiisa argannoo maaliweerii – Kutaa 1 kan ChatGPT – sekondii 3.3 – baayitii 102,850 – 256 kbps – Eeyyama: Qabeenya Ummataa"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Sagalee ariifachiisa guddaa qabu kan akka akeekkachiisa argannoo maaliweerii, Kutaa 2 kan ChatGPT-n hojjetame - sekondii 3.3 - baayitii 103,122 - 256 kbps - Eeyyama: Qabeenya Ummataa"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Sagalee akka MRI'tiin ChatGPT'n hojjetame – daqiiqaa 1, sekondii 14.9 – baayitii 3,340,392 – 320 kbps – Eeyyama: Qabeenya Ummataa"

msgid "警告表示中のBGMを選択します"
msgstr "Yeroo akeekkachiisaa muuziqaa duubaa akka taphatu filadhu."

msgid "びっくりするような雰囲気を作ります"
msgstr "Qilleensa nama ajaa'ibu uuma."

msgid "Firefoxでは音声ブロックされます"
msgstr "Firefox keessatti sagaleen cufameera."

msgid "対象アクションを起こした時のビープ音"
msgstr "Yeroo gochi ajajame raawwatamu sagaleen biip"

msgid "有効 音量小さ目"
msgstr "Bani, sagalee gadi aanaa"

msgid "有効 音量大き目"
msgstr "Banaadha, sagaleen ol ka'aadha"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Yeroo akeekkachiisni agarsiifamu, gochaalee furtuu fi maawsii hundumaaf deebii ta'ee sagaleen 'beep' ni dhaga'ama."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Yeroo akeekkachiisni mul'atu, meeshichi akka waan maraateetti fakkeessa."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Yeroo gochi addaa raawwatamu agarsiiftuu maawsii dhoksuu"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Yeroo akeekkachiisni agarsiifamu, kursorii maawsii naannoo biraawzarii keessatti dhoksa."

msgid "デバッグモード"
msgstr "Haala sirreessaa"

msgid "妨害＋記録のみ"
msgstr "Hidhaa + Galmeewwan qofa"

