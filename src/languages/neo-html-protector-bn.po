msgid "設定"
msgstr "সেটিংস"

msgid "IPログリーダー"
msgstr "আইপি লগ রিডার"

msgid "IPアドレスログ"
msgstr "আইপি ঠিকানার লগ"

msgid "全クリア"
msgstr "সব স্তর সম্পন্ন করুন"

msgid "IPログが全て削除されました"
msgstr "সমস্ত আইপি লগ মুছে ফেলা হয়েছে।"

msgid "ID"
msgstr "আইডি"

msgid "タイムスタンプ"
msgstr "সময়চিহ্ন"

msgid "IPアドレス"
msgstr "আইপি ঠিকানা"

msgid "ユーザーエージェント"
msgstr "ব্যবহারকারী এজেন্ট"

msgid "イベント"
msgstr "ইভেন্ট"

msgid "IPアドレスのデータはありません"
msgstr "এই আইপি ঠিকানার জন্য কোনো তথ্য নেই।"

msgid "EU GDPR対応"
msgstr "ইইউ জিডিপিআর-এর সাথে সম্মতি"

msgid "無効"
msgstr "অবৈধ"

msgid "有効"
msgstr "বৈধ"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "যদি আপনি ইইউ-এর মধ্যে WordPress ব্যবহার করছেন, অথবা আপনার ওয়েবসাইট ইইউ-এর ব্যবহারকারীদের লক্ষ্য করে, তবে অনুগ্রহ করে নিশ্চিত করুন যে এটি সক্ষম করা আছে।"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' বোতামটি 'Agree' বা 'Disagree' তে পরিবর্তিত হবে, এবং আচরণ সামান্য পরিবর্তিত হবে।"

msgid "同意画面の色"
msgstr "সম্মতির স্ক্রিনের রঙ"

msgid "自動"
msgstr "স্বয়ংক্রিয়"

msgid "ライトモード"
msgstr "হালকা মোড"

msgid "ダークモード"
msgstr "ডার্ক মোড"

msgid "同意画面表示中の配色を設定します"
msgstr "সম্মতি স্ক্রিনের রঙের স্কিম নির্ধারণ করুন"

msgid "同意画面中のコンテンツのぼかし"
msgstr "সম্মতি স্ক্রিনে বিষয়বস্তু ঝাপসা হওয়া"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "সম্মতি স্ক্রিনে প্রদর্শিত বিষয়বস্তুর অস্পষ্টতার স্তর নির্ধারণ করুন।"

msgid "同意画面の透過"
msgstr "সম্মতির স্ক্রিনের স্বচ্ছতা"

msgid "透過なし"
msgstr "কোনও স্বচ্ছতা নেই"

msgid "同意画面の透過具合を設定します"
msgstr "সম্মতির স্ক্রিনের স্বচ্ছতা নির্ধারণ করুন"

msgid "お知らせの1行目"
msgstr "ঘোষণার প্রথম লাইন"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "এই বার্তাটি পৃষ্ঠা প্রথমবার লোড হলে সর্বদা প্রদর্শিত হয়।"

msgid "お知らせの2行目"
msgstr "অবহিতের দ্বিতীয় লাইন"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "এই বার্তাটি শুধুমাত্র তখনই প্রথম প্রদর্শনে সবসময় দেখা যাবে যখন EU GDPR কার্যকর থাকবে।"

msgid "お知らせの3行目"
msgstr "অবহিতের তৃতীয় লাইন"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "এটি গোপনীয়তা নীতি লিঙ্কের ডানদিকে প্রদর্শিত হবে।"

msgid "非EU向け確認の文字列"
msgstr "অ-ইইউ দেশগুলির জন্য নিশ্চিতকরণ পাঠ্য"

msgid "EU GDPR向け同意するの文字列"
msgstr "ইইউ জিডিপিআরের জন্য সম্মতি টেক্সট"

msgid "EU GDPR向け同意しないの文字列"
msgstr "ইইউ জিডিপিআরের 'সম্মতি দেবেন না' শিরোনামের জন্য টেক্সট"

msgid "プライバシーポリシーの文字列"
msgstr "গোপনীয়তা নীতি টেক্সট"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "অনুগ্রহ করে এখানে গোপনীয়তা নীতির URL সেট করুন।"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "অনুগ্রহ করে গোপনীয়তা নীতিতে নিম্নলিখিত বিষয়গুলো যোগ করুন।"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "প্রতারণামূলক কার্যকলাপ সনাক্ত করতে আইপি ঠিকানার মতো শনাক্তকারী তথ্য কুকিজ এবং ডাটাবেসে সংরক্ষণ করা হয়। সংরক্ষিত তথ্য প্রশাসকের বিবেচনায় মুছে ফেলা হয়।"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "চিত্র সুরক্ষা সক্রিয় থাকলে চিত্রগুলো সঠিকভাবে সরবরাহিত হয় তা নিশ্চিত করতে, আমরা আইপি ঠিকানা ও চিত্র ফাইলের নামসহ হ্যাশকৃত তথ্য ডাটাবেসে সর্বোচ্চ ৬০ মিনিট পর্যন্ত সংরক্ষণ করি।"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "যদি আপনি ব্যবহারের শর্তাবলী সেট আপ করছেন, তবে অনুগ্রহ করে নিশ্চিত করুন যে আপনি আপনার গোপনীয়তা নীতিতে সেগুলোর একটি লিঙ্ক অন্তর্ভুক্ত করেছেন।"

msgid "利用規約の文字列"
msgstr "ব্যবহারের শর্তাবলীর পাঠ"

msgid "利用規約のページ"
msgstr "শর্তাবলী ও নিয়মাবলী পৃষ্ঠা"

msgid "ページ選択なし"
msgstr "কোনও পৃষ্ঠা নির্বাচিত নয়"

msgid "検索エンジン等のURL"
msgstr "সার্চ ইঞ্জিন ইত্যাদির জন্য URL-সমূহ"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "যখন সম্মতি দেওয়া হয় না তখন ব্যবহারকারীদের পুনঃনির্দেশ করে এমন সার্চ ইঞ্জিন এবং অনুরূপ সাইটগুলির জন্য URL সেট করুন।"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "ত্রুটি মোড, কনসোলের সতর্কবার্তা"

msgid "右クリックの警告メッセージ"
msgstr "ডান-ক্লিক সতর্কবার্তা"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDF হিসেবে মুদ্রণ ও সংরক্ষণ সম্পর্কিত সতর্কবার্তা"

msgid "スクリーンショットの警告メッセージ"
msgstr "স্ক্রিনশটে সতর্কবার্তা"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "সন্দেহভাজন স্ক্রিনশট সম্পর্কিত সতর্কবার্তা"

msgid "テキスト全選択時の警告メッセージ"
msgstr "সমস্ত টেক্সট নির্বাচিত হলে সতর্কবার্তা"

msgid "ページ保存の警告メッセージ"
msgstr "পৃষ্ঠা সংরক্ষণ সম্পর্কিত সতর্কবার্তা"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "কপি বা কাট করার সময় প্রদর্শিত বার্তা"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "এইচটিএমএল সোর্স দেখার সময় প্রদর্শনের বার্তা"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML অস্পষ্টকরণ বা সুরক্ষার সময় সোর্স কোডের শীর্ষে প্রদর্শনের বার্তা"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "এইচটিএমএল সুরক্ষার সময় এককালীন প্রমাণীকরণ টোকেন অসিদ্ধ হলে প্রদর্শনের বার্তা"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "কুকিজ বা জাভাস্ক্রিপ্ট নিষ্ক্রিয় থাকলে প্রদর্শনের বার্তা"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "আসলে, এটি শুধুমাত্র তখনই প্রদর্শিত হয় যখন জাভাস্ক্রিপ্ট নিষ্ক্রিয় থাকে।"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "যখন একটি ছবি সুরক্ষিত থাকে, তখন তা ডাউনলোড হয় এবং ছবির উপর একটি বার্তা প্রদর্শিত হয়"

msgid "HTML難読化 (圧縮)"
msgstr "এইচটিএমএল অবস্কিউরেশন"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "এটি স্ট্যান্ডার্ড HTML সংকোচন; এমন কিছু ওয়েবসাইটও আছে যা এটিকে ডিকোড করতে পারে।"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "এই বিকল্পটি সক্ষম করলে আপনি ভিউ-সোর্স লগ পুনরুদ্ধার করতে পারবেন।"

msgid "HTML保護"
msgstr "এইচটিএমএল সুরক্ষা"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "এটি শুধুমাত্র ন্যূনতম HTML আউটপুট করে—HTML সংকোচন ব্যবহার করার তুলনায়ও কম—এবং BODY ট্যাগের ভিতরের বিষয়বস্তু মোটেও আউটপুট হবে না।"

msgid "Firefoxに対しては無効です"
msgstr "এটি ফায়ারফক্সে প্রযোজ্য নয়।"

msgid "SEOに著しく影響があります"
msgstr "এটির এসইও-তে উল্লেখযোগ্য প্রভাব রয়েছে।"

msgid "HTMLをJavaScriptで描画"
msgstr "জাভাস্ক্রিপ্ট ব্যবহার করে HTML রেন্ডার করা"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "ফায়ারফক্সের সমস্যা এড়াতে আমরা জাভাস্ক্রিপ্ট ব্যবহার করে HTML রেন্ডার করি।"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "জাভাস্ক্রিপ্ট রেন্ডারিং সক্ষম করলে ওয়েবসাইটের লোডিং গতি উল্লেখযোগ্যভাবে ধীর হয়ে যাবে।"

msgid "画像の保護"
msgstr "ছবির সুরক্ষা"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "প্রতি বার img ট্যাগ কল হলে ছবিটি সুরক্ষিত রাখুন।"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "সমগ্র HTML আউটপুটের মধ্যে WordPress-এ আপলোড করা সমস্ত ছবি সুরক্ষিত করুন।"

msgid "画像をダウンロードから保護します"
msgstr "ছবি ডাউনলোড হওয়া থেকে রক্ষা করে"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "যখন ইমেজ ডেটা সুরক্ষিত থাকে, আমরা প্রায় সব ডাউনলোডই রোধ করি, অনন্য এককালীন ইউআরএল ইস্যু করি, সেশনে সংরক্ষিত টোকেন ব্যবহার করে প্রমাণীকরণ করি এবং PHP-এর মাধ্যমে ইমেজগুলো প্রদর্শন করি; এতে ইমেজ চুরির প্রায় সব ঘটনাই কার্যকরভাবে প্রতিরোধ হয়।"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "যখন ইমেজ ডেটা সুরক্ষিত থাকে, ক্যাশিং কাজ করে না, যার ফলে পরবর্তী ভিজিটগুলিতে সাইটটি ধীরে লোড হবে এবং এতে এসইও প্রভাবিত হয়।"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "ইমেজ ডেটা সুরক্ষিত করলে ডাটাবেসের লোড বাড়তে পারে।"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "যদি আপনি 'যখনই img ট্যাগ কল করা হয় তখনই ছবি সুরক্ষিত করো' নির্বাচন করেন, সিস্টেম img ট্যাগ তৈরি করার সময় ফিল্টারিং প্রয়োগ করতে add_filter ব্যবহার করে; তবে কিছু থিমে এটি সঠিকভাবে কাজ নাও করতে পারে।"

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
