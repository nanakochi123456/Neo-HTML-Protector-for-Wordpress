msgstr "Umfundi we-IP Log"

msgid "IPアドレスログ"
msgstr "Irekhodi lwamakheli e-IP"

msgid "全クリア"
msgstr "Qedela zonke izigaba"

msgid "IPログが全て削除されました"
msgstr "Zonke amarekhodi e-IP sesusiwe"

msgid "ID"
msgstr "Isazisi"

msgid "タイムスタンプ"
msgstr "Isiginesha yesikhathi"

msgid "IPアドレス"
msgstr "Ikheli le-IP"

msgid "ユーザーエージェント"
msgstr "Ijenti yomsebenzisi"

msgid "イベント"
msgstr "Umcimbi"

msgid "IPアドレスのデータはありません"
msgstr "Ayikho idatha yekheli le-IP."

msgid "EU GDPR対応"
msgstr "Ukuhambisana ne-EU GDPR"

msgid "無効"
msgstr "Akulungile"

msgid "有効"
msgstr "Kuvumelekile"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Uma usebenzisa i-WordPress ngaphakathi kwe-EU, noma uma iwebhusayithi yakho ihloselwe abasebenzisi abangaphakathi kwe-EU, sicela uqinisekise ukuthi lokhu kuvuliwe."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Inkinobho ethi 'Qinisekisa' izoguquka ibe 'Vuma' noma 'Ungavumelani', futhi ukuziphatha kuzoshintsha kancane."

msgid "同意画面の色"
msgstr "Umbala wesikrini sokuvuma"

msgid "自動"
msgstr "Ngokuzenzakalelayo"

msgid "ライトモード"
msgstr "Imodi elula"

msgid "ダークモード"
msgstr "Imodi emnyama"

msgid "同意画面表示中の配色を設定します"
msgstr "Sethaphi uhlelo lombala kwesikrini sokuvuma"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Ukudambisa okuqukethwe esikrinini sokuvuma"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Beka izinga lokudambisa ukucaca kokuqukethwe okuboniswa esikrinini sokuvuma"

msgid "同意画面の透過"
msgstr "Ukuqhakazeka kwesikrini sokuvuma"

msgid "透過なし"
msgstr "Akukho ukusobala"

msgid "同意画面の透過具合を設定します"
msgstr "Seta ukusobala kwesikrini sokuvuma"

msgid "お知らせの1行目"
msgstr "Umugqa wokuqala womemezelo"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Lomlayezo uhlale ubonakala okokuqala ikhasi livalwa."

msgid "お知らせの2行目"
msgstr "Umugqa wesibili wesaziso"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Lomlayezo uzohlala uvela ekubonisweni kokuqala kuphela lapho i-EU GDPR isebenza."

msgid "お知らせの3行目"
msgstr "Umugqa wesithathu wesaziso"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Kuzovela ngakwesokudla kwesixhumanisi soMgaqo Wokuvikelwa Kwemfihlo."

msgid "非EU向け確認の文字列"
msgstr "Umbhalo wokuqinisekisa wamazwe angaphandle kwe-EU"

msgid "EU GDPR向け同意するの文字列"
msgstr "Umbhalo wemvume we-EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Umbhalo we-'Ungavumi' ngaphansi kwe-EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Umbhalo wenqubomgomo yobumfihlo"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Sicela usethe i-URL yenqubomgomo yobumfihlo lapha."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Sicela wengeze okulandelayo kuNqubomgomo Yobumfihlo."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Ukuze kutholakale imisebenzi yokukhwabanisa, izazisi ezifana namakheli e-IP zigcinwa kumakhukhi nasemgqeni wedatha. Idatha egciniwe iyasuswa ngokuthanda komlawuli."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Ukuqinisekisa ukuthi izithombe zihanjiswa ngendlela efanele kuphela lapho ukuvikelwa kwezithombe kuvuliwe, sigcina idatha eyi-hashed equkethe ikheli le-IP negama lefayela lesithombe kudathabheyisi kuze kufike emizuzwini engu-60."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Uma usetha Imigomo Yokusetshenziswa, sicela uqinisekise ukuthi ufaka isixhumanisi sayo kuNqubomgomo Yakho Yobumfihlo."

msgid "利用規約の文字列"
msgstr "Umbhalo Wezimo Zokusetshenziswa"

msgid "利用規約のページ"
msgstr "Ikhasi Lezimo Nemibandela"

msgid "ページ選択なし"
msgstr "Akukho ikhasi elikhethiwe"

msgid "検索エンジン等のURL"
msgstr "Ama-URL ezinjini zokusesha, njll."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Seta i-URL yamajini wokusesha namasayithi afanayo adlulisela abasebenzisi lapho imvume inganikezwanga"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Imodi yokuxilonga amaphutha, imilayezo yesixwayiso yekhonsoli"

msgid "右クリックの警告メッセージ"
msgstr "Chofoza kwesokudla umyalezo wesixwayiso"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Umyalezo wesixwayiso mayelana nokuphrinta nokugcina njenge-PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Umyalezo wesixwayiso esithombeni sesikrini"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Umyalezo wesixwayiso mayelana nezithombe-skrini ezikholelwa ukuthi zithathwe ngokungekho emthethweni"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Umyalezo wesixwayiso lapho wonke umbhalo ukhethiwe"

msgid "ページ保存の警告メッセージ"
msgstr "Umyalezo wesixwayiso mayelana nokulondolozwa kwekhasi"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Umlayezo oboniswa lapho ukopisha noma usika"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Umyalezo ozoboniswa lapho kubukwa umthombo we-HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Umyalezo okufanele ubonakale phezulu kukhodi yomthombo lapho kufihlwa noma kuvikelwa i-HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Umyalezo ozovezwa uma ithokheni yokungena eyodwa ingasebenzi ngesikhathi sokuvikelwa kwe-HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Umyalezo ozovezwa uma ama-cookie noma i-JavaScript kuvinjiwe"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Eqinisweni, lokhu kukhishwa kuphela uma i-JavaScript ivinjwe."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Uma isithombe sivikelwe, siyalanda, bese umlayezo ubonakala kuleso sithombe"

msgid "HTML難読化 (圧縮)"
msgstr "Ukudideka kwe-HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Lokhu kuwucindezelo olujwayelekile lwe-HTML; kukhona futhi amawebhusayithi angakwazi ukulihumusha."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ukwenza kube nesici lokhu kukuvumela ukuthi uthole ilogi yokubuka umthombo."

msgid "HTML保護"
msgstr "Ukuvikelwa kwe-HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Ikhiqiza kuphela i-HTML eyisisekelo kakhulu—ngisho kuncane kunalapho kusetshenziswa ukucindezelwa kwe-HTML—futhi okuqukethwe ngaphakathi kwethegi ye-BODY akukhiqizwa nhlobo."

msgid "Firefoxに対しては無効です"
msgstr "Lokhu akusebenzi ku-Firefox."

msgid "SEOに著しく影響があります"
msgstr "Lokhu kunomthelela omkhulu ku-SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Ukudweba i-HTML usebenzisa i-JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Ukuze sidlule ku-Firefox, sikhiqiza i-HTML sisebenzisa i-JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Ukwenza i-JavaScript ikwazi ukudweba kuzodambisa kakhulu isivinini sokulayisha kwewebhusayithi."

msgid "画像の保護"
msgstr "Ukuvikelwa kwesithombe"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Vikela isithombe njalo lapho kuthiwa i-tag ye-img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Vikela zonke izithombe ezilayishiwe ku-WordPress ngaphakathi kukho konke okukhiphayo kwe-HTML."

msgid "画像をダウンロードから保護します"
msgstr "Ivikela izithombe ekulandweni"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Uma idatha yezithombe ivikelwe, sivimbela cishe zonke izilanda, sikhipha ama-URL awodwa asebenza kanye kuphela, siqinisekisa ubuqiniso sisebenzisa amatokheni agcinwe eseshini, futhi sikhombisa izithombe nge-PHP; lokhu kuvimbela ngempumelelo cishe zonke izimo zokweba izithombe."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Uma idatha yezithombe ivikelwe, ukugcinwa kwesikhashana akusebenzi, okusho ukuthi isayithi lizolayisha kancane ezivakashelweni ezilandelayo, ngaleyo ndlela kuthinta i-SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ukuvikela idatha yomfanekiso kungakhuphula umthwalo kudathabheyisi."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Uma ukhetha 'Vikela izithombe noma nini lapho kuthiwa i-tag ye-img', uhlelo lusebenzisa add_filter ukufaka ukuhlunga lapho i-tag ye-img ikhiqizwa; nokho, lokhu kungase kungasebenzi kahle kwezinye izindikimba."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Uma ukhetha 'Vikela zonke izithombe ezilayishiwe ku-WordPress ngaphakathi kukho konke okukhiphayo kwe-HTML', le plugin izobamba cishe yonke imisebenzi ye-WordPress bese icubungula wonke amathegi e-img okuqukethweni. Sicela uqaphele ukuthi lokhu kungase kungasebenzi kahle kwezinye izindikimba."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Sicela uqaphele ukuthi izithombe ezibekwe njengezithombe ezivelele zizokwabelwa njenge-OGP data futhi azikwazi ukuvikelwa. Uma ngempela kufanele uzivikele, sicela ushintshe isethingi yokukhipha i-HEAD tag ezilungiselweni ezithuthukisiwe lapho uvula ukuvikelwa kwe-HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Umsebenzi wokuthwebula isithombe-skrini owakhelwe ngaphakathi kohlelo lokusebenza awunakuvikelwa."

msgid "画像URLの保護"
msgstr "Ukuvikela ama-URL wezithombe"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Lokhu kufanele kusetshenziswe ngokuhlanganyela nokuvikelwa kwesithombe; ngokwalo, akusizi lutho."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Njengoba ilayishwa ngokunganaki nge-JavaScript, lokhu kuthinta i-SEO."

msgid "画像のウォーターマーク"
msgstr "Isitembu sesithombe"

msgid "右下"
msgstr "Phansi kwesokudla"

msgid "ランダム位置"
msgstr "Isikhundla esingahleliwe"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Uma isetshenziswa ngokuhlangene nokuvikelwa kwesithombe, amawatermark aguquguqukayo abonisa ngokusobala ubunikazi bamalungelo obunikazi futhi enikeza ababukeli umbono wokuthi bayabhekwa, ngaleyo ndlela esebenza njengesithiyo."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Kusekelwa kuphela amafomethi e-JPG, e-PNG kanye ne-WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Ukwenza lokhu kuzokwandisa umthwalo kuseva."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ukukhiqiza ubuciko be-ASCII kusuka kukhodi yomthombo ye-HTML ngesikhathi sokudida nokuvikela i-HTML"

msgid "表示なし"
msgstr "Akukho okuboniswayo"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Ibonisa ubuciko be-ASCII obuveza isixwayiso lapho ubuka umthombo we-HTML usebenzisa 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Bonisa umklamo lapho isenzo esihlosiwe senziwa"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Umklamo oyisisekelo onezincwadi ezimnyama esizeni esiphuzi"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Umklamo wesitayela sokwesabisa onezincwadi ezibomvu kumgqeni omnyama"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Umklamo onezincwadi ezibomvu ezikhanyayo esizeni esimnyama"

msgid "対象アクションを起こした時のBGM"
msgstr "Umculo wangemuva odlalwayo lapho isenzo esihlosiwe senziwa"

msgid "サウンドなし"
msgstr "Akukho umsindo"

