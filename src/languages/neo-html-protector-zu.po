msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Umkhosi wesitayela se-retro – imizuzwana engu-2.2 – amabhayithi angu-10,536 – 32 kbps – Ilayisensi: Umphakathi Ovulekile"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Isingeniso sesitayela se-retro – imizuzwana engu-42.1 – amabhayithi angu-179,138 – 32 kbps – Ilayisensi: Umphakathi ovulekile"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Isixwayiso sika-ChatGPT - imizuzwana engu-3.8 - amabhayithi angu-109,700 - i-256 kbps - Ilayisensi: Umphakathi ovulekile"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Isandi esiphuthumayo esiphakeme esifana nesixwayiso sokutholwa kwemalware – Ingxenye 1 ngu-ChatGPT – imizuzwana engu-3.3 – amabhayithi angu-102,850 – i-256 kbps – Ilayisensi: Umbuso Ovulekile"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Isandi esiphuthumayo esiphakeme esifana nesexwayiso sokutholwa kwemalware, Ingxenye 2 ngu-ChatGPT - imizuzwana engu-3.3 - amabhayithi angu-103,122 - 256 kbps - Ilayisensi: Umbuso Ovulekile"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Umsindo ofana ne-MRI owenziwe nge-ChatGPT – imizuzu engu-1 nemizuzwana engu-14.9 – amabhayithi angu-3,340,392 – 320 kbps – Ilayisensi: Umphakathi Ovulekile"

msgid "警告表示中のBGMを選択します"
msgstr "Khetha umculo wangemuva ozodlalwa ngesikhathi sesixwayiso."

msgid "びっくりするような雰囲気を作ります"
msgstr "Kudala umoya omangazayo"

msgid "Firefoxでは音声ブロックされます"
msgstr "Umsindo uvaliwe ku-Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "Ukubiza lapho isenzo esichaziwe senziwa"

msgid "有効 音量小さ目"
msgstr "Shesha, ivolumu iphansi"

msgid "有効 音量大き目"
msgstr "Isebenza, ivolumu isethwe phezulu"

