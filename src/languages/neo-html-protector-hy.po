msgid "設定"
msgstr "Կարգավորումներ"

msgid "IPログリーダー"
msgstr "IP գրանցումների ընթերցիչ"

msgid "IPアドレスログ"
msgstr "IP հասցեների օրագրություն"

msgid "全クリア"
msgstr "Ավարտեք բոլոր մակարդակները"

msgid "IPログが全て削除されました"
msgstr "Բոլոր IP-լոգերը ջնջվել են"

msgid "ID"
msgstr "Իդ"

msgid "タイムスタンプ"
msgstr "Ժամանակադրոշմ"

msgid "IPアドレス"
msgstr "IP հասցե"

msgid "ユーザーエージェント"
msgstr "Օգտվող գործակալ"

msgid "イベント"
msgstr "Միջոցառում"

msgid "IPアドレスのデータはありません"
msgstr "Այս IP հասցեի համար տվյալներ չկան։"

msgid "EU GDPR対応"
msgstr "ԵՄ GDPR-ի պահանջներին համապատասխանություն"

msgid "無効"
msgstr "Անվավեր"

msgid "有効"
msgstr "Վավեր"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Եթե դուք օգտագործում եք WordPress-ը ԵՄ-ում կամ ձեր կայքը ուղղված է ԵՄ օգտատերերին, խնդրում ենք համոզվել, որ սա միացված է։"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "«Հաստատել» կոճակը կփոխվի «Համաձայն եմ» կամ «Համաձայն չեմ» կոճակների, և վարքագիծը մի փոքր կփոխվի։"

msgid "同意画面の色"
msgstr "Համաձայնության էկրանին գույնը"

msgid "自動"
msgstr "Ավտոմատ"

msgid "ライトモード"
msgstr "թեթև ռեժիմ"

msgid "ダークモード"
msgstr "Խավար ռեժիմ"

msgid "同意画面表示中の配色を設定します"
msgstr "Տեղադրեք համաձայնության էկրանի գունային սխեման"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Համաձայնության էկրանին բովանդակության մշուշացում"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Սահմանեք համաձայնության էկրանին ցուցադրվող բովանդակության մշուշման մակարդակը։"

msgid "同意画面の透過"
msgstr "Համաձայնության էկրանին թափանցիկություն"

msgid "透過なし"
msgstr "Չկա թափանցիկություն"

msgid "同意画面の透過具合を設定します"
msgstr "Տեղադրեք համաձայնության էկրանին թափանցիկությունը"

msgid "お知らせの1行目"
msgstr "Հայտարարության առաջին տողը"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Այս հաղորդագրությունը միշտ ցուցադրվում է էջը առաջին անգամ բեռնելիս։"

msgid "お知らせの2行目"
msgstr "Ծանուցման երկրորդ տողը"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Այս հաղորդագրությունը միշտ կհայտնվի միայն առաջին էկրանին, երբ ԵՄ GDPR-ը ուժի մեջ է։"

msgid "お知らせの3行目"
msgstr "Ծանուցման երրորդ տողը"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Այն կհայտնվի Գաղտնիության քաղաքականության հղման աջ կողմում։"

msgid "非EU向け確認の文字列"
msgstr "Հաստատման տեքստ ոչ ԵՄ երկրների համար"

msgid "EU GDPR向け同意するの文字列"
msgstr "ԵՄ GDPR համաձայնության տեքստ"

msgid "EU GDPR向け同意しないの文字列"
msgstr "ԵՄ GDPR-ի «Մի համաձայնվեք» տեքստը"

msgid "プライバシーポリシーの文字列"
msgstr "Գաղտնիության քաղաքականության տեքստ"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Խնդրում ենք այստեղ նշել գաղտնիության քաղաքականության URL-ը։"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Խնդրում ենք ավելացնել հետևյալը Գաղտնիության քաղաքականության մեջ։"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Խարդախության գործունեությունը հայտնաբերելու համար նույնականացուցիչներ, ինչպիսիք են IP հասցեները, պահվում են cookie-ներում և տվյալների բազայում։ Պահպանված տվյալները ջնջվում են ադմինիստրատորի հայեցողությամբ։"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Որպեսզի պատկերները ճիշտ առաքվեն միայն այն դեպքում, երբ պատկերի պաշտպանությունը ակտիվացված է, մենք տվյալների բազայում մինչև 60 րոպե պահպանում ենք IP հասցեն և պատկերի ֆայլի անունը պարունակող հեշացված տվյալները։"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Եթե դուք կազմում եք Օգտման պայմանները, խնդրում ենք համոզվել, որ դրանց հղումը ներառված է ձեր Գաղտնիության քաղաքականությունում։"

msgid "利用規約の文字列"
msgstr "Օգտագործման պայմանների տեքստը"

msgid "利用規約のページ"
msgstr "Պայմաններ և դրույթներ էջ"

msgid "ページ選択なし"
msgstr "Ընտրված էջ չկա"

msgid "検索エンジン等のURL"
msgstr "Որոնիչների URL-ներ և այլն։"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Սահմանեք URL-ը որոնողական համակարգերի և նմանատիպ կայքերի համար, որոնք օգտվողներին վերաուղղում են, եթե համաձայնություն չի տրվել։"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Սխալների հայտնաբերման ռեժիմ, կոնսոլի նախազգուշացնող հաղորդագրություններ"

msgid "右クリックの警告メッセージ"
msgstr "Աջ կտտոցով նախազգուշացնող հաղորդագրություն"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Զգուշացում տպելու և PDF-ով պահպանելու վերաբերյալ"

msgid "スクリーンショットの警告メッセージ"
msgstr "Սքրինշոթում նախազգուշացնող հաղորդագրություն"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Կասկածվող էկրանային նկարների վերաբերյալ նախազգուշացնող հաղորդագրություն"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Բոլոր տեքստը ընտրված լինելու դեպքում նախազգուշացնող հաղորդագրություն"

msgid "ページ保存の警告メッセージ"
msgstr "Էջի պահպանման վերաբերյալ նախազգուշացում"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Հաղորդագրություն, որը ցուցադրվում է պատճենելու կամ կտրելու ժամանակ"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Հաղորդագրություն, որը ցուցադրվում է HTML-աղբյուրը դիտելիս"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Հաղորդագրություն, որը ցուցադրվում է աղբյուրային կոդի վերևում՝ HTML-ը obfuscating կամ պաշտպանելիս"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Հաղորդագրություն, որը ցուցադրվում է, եթե HTML պաշտպանության ընթացքում մեկանգամյա վավերացման տոկենը անվավեր է"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Հաղորդագրություն, որը ցուցադրվում է, եթե cookie-ները կամ JavaScript-ը անջատված են"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Իրականում սա ցուցադրվում է միայն այն ժամանակ, երբ JavaScript-ը անջատված է։"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Երբ պատկերը պաշտպանված է, այն ներբեռնվում է, և պատկերի վրա ցուցադրվում է հաղորդագրություն"

msgid "HTML難読化 (圧縮)"
msgstr "HTML-ի մթագնում"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Սա ստանդարտ HTML կոմպրեսիա է; կան նաև կայքեր, որոնք կարող են այն դեկոդավորել։"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Այս տարբերակը միացնելով՝ հնարավորություն է ստեղծվում ստանալ view-source լոգը։"

msgid "HTML保護"
msgstr "HTML պաշտպանություն"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Այն արտածում է միայն HTML-ի ամենաանհրաժեշտ նվազագույնը՝ նույնիսկ ավելի քիչ, քան HTML կոմպրեսիայի դեպքում, և BODY պիտակի ներսի բովանդակությունը ընդհանրապես չի արտածվում։"

msgid "Firefoxに対しては無効です"
msgstr "Սա չի վերաբերում Firefox-ին։"

msgid "SEOに著しく影響があります"
msgstr "Սա զգալի ազդեցություն ունի SEO-ի վրա։"

msgid "HTMLをJavaScriptで描画"
msgstr "HTML-ի ներկայացում JavaScript-ով"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox-ի սահմանափակումները շրջանցելու համար մենք HTML-ը ներկայացնում ենք JavaScript-ով։"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScript-ի ցուցադրումը միացնելը զգալիորեն կդանդաղեցնի կայքի բեռման արագությունը։"

msgid "画像の保護"
msgstr "Պատկերի պաշտպանություն"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Պաշտպանեք պատկերը յուրաքանչյուր անգամ, երբ կանչվում է img թեգը։"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Պաշտպանեք WordPress-ում վերբեռնված բոլոր պատկերները ամբողջ HTML ելքի շրջանակում։"

msgid "画像をダウンロードから保護します"
msgstr "Պաշտպանում է պատկերները ներբեռնելուց"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Երբ պատկերների տվյալները պաշտպանված են, մենք գրեթե բոլոր ներբեռնումները արգելափակում ենք, տրամադրում ենք յուրահատուկ մեկանգամյա URL-ներ, նստաշրջանում պահվող տոկեններով ավտենտիֆիկացնում և պատկերները ցուցադրում ենք PHP-ի միջոցով; սա արդյունավետորեն կանխում է պատկերների գողության գրեթե բոլոր դեպքերը։"

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Երբ պատկերի տվյալները պաշտպանված են, քեշավորումը չի աշխատում, ինչը նշանակում է, որ կայքը հաջորդ այցելությունների ժամանակ ավելի դանդաղ կբեռնվի և դա ազդում է SEO-ի վրա։"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
