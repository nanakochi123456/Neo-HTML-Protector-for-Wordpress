msgstr "Поставки"

msgid "IPログリーダー"
msgstr "Читач на IP-лози"

msgid "IPアドレスログ"
msgstr "Лог на IP-адреси"

msgid "全クリア"
msgstr "Заврши ги сите нивоа"

msgid "IPログが全て削除されました"
msgstr "Сите IP-лог-датотеки се избришани"

msgid "ID"
msgstr "ИД"

msgid "タイムスタンプ"
msgstr "Временски печат"

msgid "IPアドレス"
msgstr "IP-адреса"

msgid "ユーザーエージェント"
msgstr "Кориснички агент"

msgid "イベント"
msgstr "Настан"

msgid "IPアドレスのデータはありません"
msgstr "Нема податоци за оваа IP-адреса."

msgid "EU GDPR対応"
msgstr "Усогласеност со GDPR на ЕУ"

msgid "無効"
msgstr "Невалидно"

msgid "有効"
msgstr "Важечки"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Ако користите WordPress во рамките на ЕУ, или ако вашата веб-страница е наменета за корисници во рамките на ЕУ, ве молиме осигурајте се дека ова е овозможено."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Копчето Потврди ќе се смени во Се согласувам или Не се согласувам, а однесувањето ќе се промени малку."

msgid "同意画面の色"
msgstr "Боја на екранот за согласност"

msgid "自動"
msgstr "Автоматски"

msgid "ライトモード"
msgstr "Лесен режим"

msgid "ダークモード"
msgstr "Темна верзија"

msgid "同意画面表示中の配色を設定します"
msgstr "Поставете ја шемата на бои за екранот за согласност."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Замаглување на содржината на екранот за согласност"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Поставете го нивото на замаглување за содржината прикажана на екранот за согласност"

msgid "同意画面の透過"
msgstr "Прозирност на екранот за согласност"

msgid "透過なし"
msgstr "Нема транспарентност"

msgid "同意画面の透過具合を設定します"
msgstr "Поставете ја проѕирноста на екранот за согласност"

msgid "お知らせの1行目"
msgstr "Прва линија на соопштението"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Оваа порака секогаш се прикажува првиот пат кога страницата се вчитува."

msgid "お知らせの2行目"
msgstr "Втората линија на известувањето"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Оваа порака секогаш ќе се појавува на првиот екран само кога ЕУ ГДПР е во сила."

msgid "お知らせの3行目"
msgstr "Третиот ред на известувањето"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ќе се појави десно од линкот до Политиката за приватност."

msgid "非EU向け確認の文字列"
msgstr "Текст за потврда за земјите што не се членки на ЕУ"

msgid "EU GDPR向け同意するの文字列"
msgstr "Текст за согласност за ЕУ ГДПР"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Текст за Не давајте согласност според GDPR на ЕУ"

msgid "プライバシーポリシーの文字列"
msgstr "Текст на политиката за приватност"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Ве молиме поставете ја URL-адресата за политиката за приватност овде."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Ве молиме додајте го следново во Политиката за приватност."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "За да се открие измамничка активност, идентификатори како IP-адреси се зачувуваат во колачиња и во базата на податоци. Зачуваните податоци се бришат по дискреција на администраторот."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "За да се осигураме дека сликите се доставуваат правилно кога е овозможена заштита на слики, ние ги складираме во нашата база на податоци хеш-датотеките што ги содржат IP-адресата и името на датотеката на сликата, и тоа до 60 минути."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Ако поставувате Услови за користење, ве молиме осигурајте се дека сте вклучиле линк до нив во вашата Политика за приватност."

msgid "利用規約の文字列"
msgstr "Текст на Условите за користење"

msgid "利用規約のページ"
msgstr "Страница со услови и правила"

msgid "ページ選択なし"
msgstr "Не е избрана страница"

msgid "検索エンジン等のURL"
msgstr "URL-адреси за пребарувачи, итн."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Поставете ја URL-адресата за пребарувачи и слични сајтови кои ги пренасочуваат корисниците кога тие не даваат согласност"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Режим за отстранување грешки, предупредувачки пораки во конзолата"

msgid "右クリックの警告メッセージ"
msgstr "Десен клик предупредувачка порака"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Предупредувачка порака во врска со печатење и зачувување како PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Предупредувачка порака на сликата од екранот"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Предупредувачка порака во врска со сомнителни скриншотови"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Предупредувачка порака кога целиот текст е избран"

msgid "ページ保存の警告メッセージ"
msgstr "Предупредување за зачувување на страницата"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Порака што се прикажува при копирање или сечење"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Порака за прикажување при прегледување на HTML изворот"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Порака што се прикажува на врвот на изворниот код при затајување или заштита на HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Порака за прикажување доколку еднократниот токен за автентикација е неважечки за време на HTML заштита"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Порака за прикажување ако колачињата или JavaScript се оневозможени"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Всушност, ова се прикажува само кога JavaScript е оневозможен."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Кога сликата е заштитена, таа се презема и на неа се прикажува порака"

msgid "HTML難読化 (圧縮)"
msgstr "Омрачување на HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Ова е стандардно HTML компресирање; постојат и веб-страници што можат да го декодираат."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Овозможувањето на оваа опција ви овозможува да го добиете логот на view-source."

msgid "HTML保護"
msgstr "HTML заштита"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Тој генерира дури и помалку HTML отколку поставката за компресија на HTML, што значи дека содржината во тагот BODY воопшто нема да се прикаже."

msgid "Firefoxに対しては無効です"
msgstr "Ова не важи за Firefox"

msgid "SEOに著しく影響があります"
msgstr "Ова има значително влијание врз СЕО"

msgid "HTMLをJavaScriptで描画"
msgstr "Исцртување HTML со JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "За да го заобиколиме Firefox, го рендерираме HTML-от со JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Овозможувањето на JavaScript рендерирање значително ќе ја забави брзината на вчитување на веб-страницата."

msgid "画像の保護"
msgstr "Заштита на слика"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Заштитете ја сликата секојпат кога се повикува тагот img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Заштитете ги сите слики прикачени во WordPress во целиот HTML-излез."

msgid "画像をダウンロードから保護します"
msgstr "Ги штити сликите од преземање"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Кога податоците за сликите се заштитени, ние спречуваме речиси сите преземања, издаваме уникатни еднократни URL-адреси, автентицираме со токени зачувани во сесијата и ги прикажуваме сликите преку PHP; ова ефикасно спречува речиси сите случаи на кражба на слики."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Кога податоците за сликите се заштитени, кеширањето не функционира, што значи дека страницата ќе се вчитува побавно при следните посети, со што се влијае на SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Заштитата на податоците за слики може да го зголеми оптоварувањето на базата на податоци."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Ако изберете Заштити слики секогаш кога се повикува тагот img, системот користи add_filter за да примени филтрирање кога се генерира тагот img; сепак, ова може да не функционира правилно со некои теми."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Ако изберете Заштити ги сите слики прикачени во WordPress во целокупниот HTML излез, додатокот ќе ги фати речиси сите операции на WordPress и ќе ја обработи секоја ознака img во содржината. Имајте предвид дека ова може да не функционира правилно со некои теми."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Ве молиме имајте предвид дека сликите означени како истакнати ќе бидат споделени како OGP податоци и не можат да бидат заштитени. Ако апсолутно морате да ги заштитите, ве молиме променете ја поставката за излез на HEAD тагот во напредните поставки кога овозможувате HTML заштита."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Функцијата за слика од екранот вклучена како стандард во оперативниот систем не може да се заштити."

msgid "画像URLの保護"
msgstr "Заштита на URL-адреси на слики"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Ова треба да се користи во комбинација со заштита на слики; самостојно, нема никаква намена."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Бидејќи се вчитува преку JavaScript, ова влијае на SEO."

msgid "画像のウォーターマーク"
msgstr "Воден жиг на сликата"

msgid "右下"
msgstr "долу десно"

msgid "ランダム位置"
msgstr "Случајна позиција"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Кога се користат заедно со заштита на слики, динамичките водени жигови јасно ја означуваат сопственоста на авторските права, додека им даваат на гледачите впечаток дека се надгледувани, со што делуваат како одвраќач."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Поддржани се само формати JPG, PNG и WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Овозможувањето на ова ќе го зголеми оптоварувањето на серверот."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Генерирање ASCII-арт од HTML-изворен код за време на замутување и заштита"

msgid "表示なし"
msgstr "Нема приказ"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Прикажува ASCII-уметност која укажува на предупредување при прегледување на HTML-изворниот код со view-source"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Прикажи дизајн кога целната акција е извршена"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Основен дизајн со црн текст на жолта позадина"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Дизајн во стил на хорор со црвен текст на црна позадина"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Дизајн со светлоцрвен текст на црна позадина"

msgid "対象アクションを起こした時のBGM"
msgstr "Позадинска музика што се пушта кога целната акција е извршена"

msgid "サウンドなし"
msgstr "Нема звук"

