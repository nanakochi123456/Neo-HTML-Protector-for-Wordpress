msgid "設定"
msgstr "Mbohekorã"

msgid "IPログリーダー"
msgstr "Moñe'ẽha IP Kuatiañe'ẽ"

msgid "IPアドレスログ"
msgstr "IP moñe'ẽrenda"

msgid "全クリア"
msgstr "Emohu'ã opaite nivelkuéra"

msgid "IPログが全て削除されました"
msgstr "Opaite IP kuatiakuéra oñemboguepáma."

msgid "ID"
msgstr "Téra tee"

msgid "タイムスタンプ"
msgstr "Ára ha aravo ra'anga"

msgid "IPアドレス"
msgstr "Moñe'ẽrã apyte"

msgid "ユーザーエージェント"
msgstr "Puruhára Rembiguái"

msgid "イベント"
msgstr "Tembiapo"

msgid "IPアドレスのデータはありません"
msgstr "Ndaipóri dato ko dirección IP-pe guarã."

msgid "EU GDPR対応"
msgstr "Oñemoañete GDPR UE pegua"

msgid "無効"
msgstr "Ndaiporãi"

msgid "有効"
msgstr "Iporã"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Reipurúrõ WordPress Unión Europea-pe, térã ne ñanduti renda ohekáva puruhárakuéra Unión Europea-pegua, emomba'e porãke oñemyendýpa kóva."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Pe votõ 'Moañete' oñemoambuéne 'Aime' térã 'Ndaiime'-pe, ha pe oikóva iñambue michĩta."

msgid "同意画面の色"
msgstr "Jeheja ojehecháva sa'y"

msgid "自動"
msgstr "Ijeheguiete"

msgid "ライトモード"
msgstr "Modo ivevúi"

msgid "ダークモード"
msgstr "Tymba'y Sysýi"

msgid "同意画面表示中の配色を設定します"
msgstr "Emohenda sa'y ñemohenda pe tembiporu jeheja hag̃ua."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Mba'e ojehecháva ñembohypy'a pe tenda oñemoĩháme jeheja"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Emohenda mboýpa oñembohasáta umi mba'e ojehechaukáva ta'anga ñemoneĩrãme."

msgid "同意画面の透過"
msgstr "Jehecha porã pe tembiporurã jehejaha"

msgid "透過なし"
msgstr "Ndaipóri hesakãva"

msgid "同意画面の透過具合を設定します"
msgstr "Emohenda pe ta'anga jehecha pe tembiporavo ñemoneĩrãme"

msgid "お知らせの1行目"
msgstr "Marandu ñepyrũha"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Ko marandu ojehechauka tapiaite pe kuatiarogue ojepe'a ypy vove."

msgid "お知らせの2行目"
msgstr "Marandu tysýi mokõiha"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Ko marandu ojehechaukáta tapiaite pe jehechauka peteĩháme añoite, pe EU GDPR oñepyrũ vove oñemba'apo."

msgid "お知らせの3行目"
msgstr "Marandu mbohapyha tysýi"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Ojehecháta pe joajuha Tekorã Ñemiguáva rehegua akatúape."

msgid "非EU向け確認の文字列"
msgstr "Jehaipyre ñemboaje hag̃ua tetãnguéra ndaha'éiva UE-pegua"

msgid "EU GDPR向け同意するの文字列"
msgstr "Jeheja jehaipyre UE GDPR-pe guarã"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Jehaipyre 'Ani eipota' g̃uarã UE GDPR guýpe"

msgid "プライバシーポリシーの文字列"
msgstr "Ñemiguáva ñe'ẽme'ẽ"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Emoĩ ko'ápe pe URL política de privacidad-pe guarã."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Emoĩke ko oúva Tekopy Ñeñangarekorãme."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Ojejuhu hag̃ua tembiapo japu, oñeñongatu cookies ha marandu ñongatuhápe techaukaha ha'eháicha dirección IP. Umi marandu oñeñongatúva oñembogue pe sãmbyhyhára oipotaháicha."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Oñembohape porã hag̃ua ta'angakuéra ñemondo oñemoĩ vove ta'anga ñeñangareko, roñongatu marandu oñembohasapyre, oikéva pype IP moñe'ẽha ha ta'anga réra, ore marandu ñongatuhápe 60 aravo peve."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Rembosako'íramo Purukatu Rekorã, emañamína emoĩha peteĩ joajuha hendápekuéra ne Ñemiguáva Ñangareko Apoukapýpe."

msgid "利用規約の文字列"
msgstr "Jepuru Rekorã Kuatiañe'ẽ"

msgid "利用規約のページ"
msgstr "Ñe'ẽme'ẽ ha Tekorã Kuatiarogue"

msgid "ページ選択なし"
msgstr "Ndaipóri kuatiarogue oñeporavóva"

msgid "検索エンジン等のURL"
msgstr "URL-kuéra ohekáva vore, ha ambueve."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Emoĩ URL umi hekahavusu ha tenda ojoguávape g̃uarã ombohasáva puruhárape ha'ekuéra ndoipotáiramo."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mba'evai jeheka, marandu ñemomarandurã"

msgid "右クリックの警告メッセージ"
msgstr "Marandu ñemomarandurã akatúa-pe"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Marandu ñemomarandurã oñembokuatia ha oñeñongatu hag̃ua PDF-pe"

msgid "スクリーンショットの警告メッセージ"
msgstr "Marandu ñemomarandurã ta'anga oñenohẽva'ekuépe"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Marandu ñemomarandurã ta'anga oñeimo'ãva rehegua"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Marandu ñemomarandurã oñembohasapa vove opaite jehaipyre"

msgid "ページ保存の警告メッセージ"
msgstr "Marandu ñemomarandurã kuatiarogue ñongatu rehegua"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Marandu ojehechaukáva oñembohasa térã oñeikytĩ jave"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Marandu ojehechaukátava ojehechávo HTML moñepyrũha"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Marandu ojehechaukáva yvate gotyo código fuente-pe oñembohasávo térã oñeñangarekóvo HTML-re"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Marandu ojehechaukátava pe token jehechakuaarã peteĩ jeyguáva ndoikóiramo ñeñangareko HTML aja"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Marandu ojehechaukátava oñemboguejy ramo cookies térã JavaScript"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Añetehápe, kóva ojehechauka JavaScript oñemboguejy ramo añoite."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Peteĩ ta'anga oñeñangarekóvo, oñemboguejy ha ojehechauka peteĩ marandu hese"

msgid "HTML難読化 (圧縮)"
msgstr "HTML ñemokañy"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Kóva ha'e HTML ñemboguejy jepigua; oĩ avei ñanduti renda ikatuva ombojevy jey."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Emoñepyrũvo ko jeporavorã ikatu rehupyty pe marandu jehechauka apytegua."

msgid "HTML保護"
msgstr "HTML ñeñangareko"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Omoherakuã sa'ive voi HTML pe HTML ñembomichĩha oiporavóvagui, he'iséva pe oĩva pe etikéta BODY ryepýpe ndojehechaukáiha mba'evéichavérõ."

msgid "Firefoxに対しては無効です"
msgstr "Kóva ndaha'éi Firefox-pe g̃uarã."

msgid "SEOに著しく影響があります"
msgstr "Kóva oguereko pokatu tuicháva SEO-pe."

msgid "HTMLをJavaScriptで描画"
msgstr "HTML apo JavaScript rupive"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox-pe ñamboguata hag̃ua, ñamohechauka pe HTML JavaScript rupive."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScript ñembohasa ñemoneĩ omboguejy vaietereíta ñanduti renda ñembopu."

msgid "画像の保護"
msgstr "Ta'anga ñeñangareko"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Eñangareko ta'angáre oñehenói jave pe etikéta img."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Eñangareko opaite ta'anga ojehupi va'ekue WordPress-pe rehe, pe HTML osẽva kompletoitépe."

msgid "画像をダウンロードから保護します"
msgstr "Oñangareko ta'angakuérare ani hag̃ua oñemboguejy"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Ta'anga marandu oñeñangarekóvo, rojoko haimete opaite ñemboguejy, rome'ẽ URL ijojaha'ỹva peteĩ jevy guarã, rohechakuaa mávapa pe oipurúva oipurúvo token oñeñongatúva sesión-pe, ha rohechauka ta'angakuéra PHP rupive; kóva añetehápe ojoko haimete opaite ta'anga ñemonda."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Ta'anga marandu oñeñangarekóvo, pe ñongatumi'i ndoikói, upéva he'ise pe tenda oñemoingevetaha mbegueve jevy jevy ojeikévo, ha péicha omyangekói SEO-pe."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ta'anga marandu ñeñangareko ikatu ombohetave tembiapo marandu ñongatuhápe."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Reiporavóramo 'Eñangareko ta'angakuérare ojeipuru jave pe etikéta img', pe sistema oipuru add_filter ombohasávo pe etikéta img ojejapo jave; upeicharõ jepe, kóva ikatu ndoikói porã oimeraẽva téma ndive."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Reiporavóramo 'Eñangareko opaite ta'anga ojehupíva WordPress-pe oĩva pe HTML osẽva ryepýpe', pe plugin oipyhýta haimete opaite WordPress rembiapo ha omba'apóta opaite 'img tag' oĩva pe tembipuru ryepýpe. Tereikuaa kóva ikatu ndoikoporãi oĩramo umi 'theme' ndive."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Ejesarekomína umi ta'anga oñembohérava ta'anga tenondegua oñembohasataha OGP marandúicha ha ndaikatuiha oñeñangareko. Reñangarekosetereírõ hesekuéra, embohekopyahu pe ñemboheko HEAD etiqueta osẽva g̃uarã umi ñemboheko pypukuvépe, remoñepyrũvo pe ñeñangareko HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Ndikatúi oñeñangareko pe tembiporu oñenohẽ hag̃ua ta'anga oĩva sistema operativo ryepýpe."

msgid "画像URLの保護"
msgstr "Oñeñangareko ta'anga URL-kuérare"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Kóva ojepuruva'erã ta'anga ñeñangareko ndive; ha'eño, ndojapói mba'eve."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Oñemoinge mbegueterei rupi JavaScript rupive, kóva ombyai SEO."

msgid "画像のウォーターマーク"
msgstr "Ta'anga jehaipyre'i"

msgid "右下"
msgstr "Upe akatúa guýpe"

msgid "ランダム位置"
msgstr "Tenda oimeraẽva"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Ojeipurúvo ta'anga ñeñangareko ndive, umi marca dinámica ohechauka porã mávapa ijára, ha upéicha avei omoñeñandu umi ohechávape oñemaña heseha, ha péicha omomombyry chupekuéra."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Oñemboaje JPG, PNG ha WebP formáto añoite."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Kóva oñemoĩramo ombohetavéta mba'e ojejapova'erã servidór-pe."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Oñeguenohẽvo ta'anga ASCII código fuente HTML-gui oñembo'a ha oñeñangareko aja HTML-re."

msgid "表示なし"
msgstr "Ndaipóri jehechauka"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Ohechauka ta'anga ASCII ohechaukáva peteĩ ñe'ẽmondo ojehechávo HTML kuatiarogue oipurúvo 'view-source'."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Ohechauka diseño ojejapóvo pe tembiapo ojeipotáva."

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Peteĩ ta'anga ypy ojehechaukáva tai hũva peteĩ ao sa'yju ári."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Peteĩ ta'anga kyhyje rehegua, orekóva jehai pytã peteĩ tesape hũ ári."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Peteĩ ta'anga oguerekóva jehai pytã rendy peteĩ tesape hũ ári."

msgid "対象アクションを起こした時のBGM"
msgstr "Purahei oñembopúva ojejapo vove pe tembiapo ojeipotáva."

msgid "サウンドなし"
msgstr "Ndaipóri tyapu"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Ñorairõ ha Pu'aka - 1 aravo'i 16,3 aravo'imi - 630.056 byte - 64 kbps - Lisénsia: CC 2.1 térã upe rire"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Túva Mbyky - 3,8 segundo - 32.364 byte - 64 kbps - Lisénsia: GPL 2.0 térã upe rire"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Puku - 23.5 aravo'i - 195.578 byte - 64 kbps - Lisénsia: GPL 2.0 térã upe rire"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin Étude Op. 10 No. 5"

msgid "ショパン エチュード Op.10-12 革命 打ち込み版 高速版 - 1分57.6秒 - 724,457bytes - 48kbps -  ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin Étude Op. 10 No. 12 'Revolución' – Versión kombutadóra ojapopyréva, pya'e – 1 aravo'i 57,6 aravo'imi – 724.457 byte – 48 kbps – Lisénsia: CC BY-ND 4.0 térã upe riregua"

msgid "ショパン スケルツォ 変ロ短調 Op2 打ち込み版 高速短縮版 - 1分48.0秒 - 665,369bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin: Scherzo Si bemol menor-pe, Op. 2 – Versión kombutadóra ojapóva, versión mbykypyre pya'e – 1 aravo'i 48,0 segundo – 665.369 byte – 48 kbps – Lisénsia: CC BY-ND 4.0 térã upe rire"

msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Tysýi: Étude d'Exécution Transcendante No. 4, 'Mazeppa' – Versión kombutadóra ojapopyréva, versión mbykypyre pya'e – 1 aravo'i 51,6 aravo'i'i – 687.586 byte – 48 kbps – Lisénsia: CC BY-ND 4.0 térã upe riregua"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Mbopu guasu – 22,3 aravo'i – 183.926 byte – 64 kbps – Lisénsia: Oparupigua mba'e"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Purahéi guasu yma guaréicha – 2,2 segundo – 10.536 byte – 32 kbps – Lisénsia: Oparupigua mba'e"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Moñepyrũha yma guareicha – 42,1 segundo – 179.138 byte – 32 kbps – Lisénsia: Opaite mba'e opavavépe g̃uarã"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Marandu ChatGPT-gui - 3.8 segundo - 109.700 byte - 256 kbps - Lisénsia: Oparupigua mba'e"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Peteĩ pu pya'e oikotevẽva oñehendu pya'e, ha'ete peteĩ ñemomarandu ojejuhuhague mba'evai – Vore 1, ChatGPT ojapóva – 3,3 segundo – 102.850 byte – 256 kbps – Lisénsia: Opaite ikatu oipuru."

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Peteĩ pu pya'e oñeikotevẽva, oñehendúva peteĩ ñe'ẽmondoicha ojejuhuhague mba'evai, Mokõiha Vore, ChatGPT ojapóva - 3,3 segundo - 103.122 byte - 256 kbps - Lisénsia: Opaite yvypóra mba'e"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Pu MRI-ichagua ChatGPT ojapóva – 1 aravo'i 14,9 aravo'i'i – 3.340.392 byte – 320 kbps – Lisénsia: Oparavéva mba'e"

msgid "警告表示中のBGMを選択します"
msgstr "Eiporavo purahéi oñembopúva oñemoñe'ẽ aja."

msgid "びっくりするような雰囲気を作ります"
msgstr "Omoheñói peteĩ tekoha ñanemondýiva."

msgid "Firefoxでは音声ブロックされます"
msgstr "Pu oñemboty Firefox-pe."

msgid "対象アクションを起こした時のビープ音"
msgstr "Peteĩ tyapu ojejapóvo pe tembiapo oje'éva."

msgid "有効 音量小さ目"
msgstr "Oñemyendy, pu mbovy"

msgid "有効 音量大き目"
msgstr "Omba'apo, ipu hatã"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
