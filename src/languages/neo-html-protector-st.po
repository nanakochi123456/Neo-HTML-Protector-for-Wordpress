msgid "設定"
msgstr "Litlhophiso"

msgid "IPログリーダー"
msgstr "Mmadi wa Lirekoto tsa IP"

msgid "IPアドレスログ"
msgstr "Lengolo la liaterese tsa IP"

msgid "全クリア"
msgstr "Phethela maemo ohle"

msgid "IPログが全て削除されました"
msgstr "Liloko tsohle tsa IP li hlakotsoe."

msgid "ID"
msgstr "Boitsebiso ba motho"

msgid "タイムスタンプ"
msgstr "Nako ea ketsahalo"

msgid "IPアドレス"
msgstr "Aterese ea IP"

msgid "ユーザーエージェント"
msgstr "Moemeli oa mosebelisi"

msgid "イベント"
msgstr "Ketsahalo"

msgid "IPアドレスのデータはありません"
msgstr "Ha ho na datha bakeng sa aterese ena ea IP."

msgid "EU GDPR対応"
msgstr "Ho latela GDPR ea EU"

msgid "無効"
msgstr "Ha e sebetse"

msgid "有効"
msgstr "E nepahetse"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Haeba o sebedisa WordPress ka hara EU, kapa haeba websaete ya hao e lebisitswe ho basebedisi ba ka hara EU, ka kopo etsa bonnete ba hore sena se kenyeleditswe."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Konopo ea 'Netefatsa' e tla fetoha ho ba 'Tumellana' kapa 'Hana', 'me tsela eo e sebetsang ka eona e tla fetoha hanyenyane."

msgid "同意画面の色"
msgstr "Mmala oa skrine sa tumello"

msgid "自動"
msgstr "Ka boiketsetso"

msgid "ライトモード"
msgstr "Mokgwa o bobebe"

msgid "ダークモード"
msgstr "Mokgwa o Lefifi"

msgid "同意画面表示中の配色を設定します"
msgstr "Beha moralo oa mebala bakeng sa skrine sa tumello."

msgid "同意画面中のコンテンツのぼかし"
msgstr "Ho fifatsa dikahare skrineng sa tumello"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Beha boemo ba ho fifatsa bakeng sa litaba tse hlahang skrineng sa tumello."

msgid "同意画面の透過"
msgstr "Pepesa ea skrine sa tumello"

msgid "透過なし"
msgstr "Ha ho ponaletso"

msgid "同意画面の透過具合を設定します"
msgstr "Beha ponaletso ea skrine sa tumello"

msgid "お知らせの1行目"
msgstr "Mola oa pele oa phatlalatso"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Molaetsa ona o lula o bontšoa lekhetlo la pele leqephe le laeloa."

msgid "お知らせの2行目"
msgstr "Mola oa bobeli oa tsebiso"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Molaetsa ona o tla hlaha kamehla pontshong ya pele feela ha EU GDPR e sebetsa."

msgid "お知らせの3行目"
msgstr "Mola oa boraro oa tsebiso"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "E tla hlaha ka ho le letona ha sehokelo sa Leano la Lekunutu."

msgid "非EU向け確認の文字列"
msgstr "Molaetsa oa netefatso bakeng sa linaha tse seng tsa EU"

msgid "EU GDPR向け同意するの文字列"
msgstr "Molaetsa oa tumello bakeng sa EU GDPR"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Molaetsa oa 'Se lumellane' tlas'a EU GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "Molaoana oa lekunutu"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Ka kopo, kenya URL ea leano la lekunutu mona."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Ka kopo, eketsa tse latelang ho Leano la Lekunutu."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Ho lemoha liketso tsa bomenemene, lintlha tse khethollang tse kang liaterese tsa IP li bolokoa li-cookie le polokelong ea lintlha. Lintlha tse bolokiloeng li hlakoloa ho ea ka kahlolo ea motsamaisi."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Ho netefatsa hore litšoantšo li fanoa ka nepo ha tšireletso ea litšoantšo e kenyelelitsoe, re boloka data e fetotsoeng ka khoutu e kenyeletsang aterese ea IP le lebitso la faele ea setšoantšo polokelong ea rona ea data ka nako e ka fihlang metsotso e 60."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Haeba o hlophisa Melao ya Tshebediso, ka kopo etsa bonnete ba hore o kenyeletsa sehokelo sa yona ho Leano la hao la Lekunutu."

msgid "利用規約の文字列"
msgstr "Mongolo oa Lipehelo tsa Tšebeliso"

msgid "利用規約のページ"
msgstr "Leqephe la Melao le Lipehelo"

msgid "ページ選択なし"
msgstr "Ha ho leqephe le kgethilweng"

msgid "検索エンジン等のURL"
msgstr "Li-URL bakeng sa lienjine tsa ho batla, jj."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Beha URL bakeng sa lienjine tsa patlo le liwebsaete tse tšoanang tse fetisetsang basebelisi ha ba sa lumellane."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mokgwa wa ho lokisa diphoso, melaetsa ya tlhokomediso ya khonsolo"

msgid "右クリックの警告メッセージ"
msgstr "Tlhokomediso ea ho tobetsa ka ho le letona"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Molaetsa oa temoso mabapi le ho hatisa le ho boloka e le PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Molaetsa oa temoso setšoantšong sa skrine"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Molaetsa oa temoso mabapi le litšoantšo tsa skrine tse belaelloang"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Molaetsa oa temoso ha mongolo oohle o khethiloe"

msgid "ページ保存の警告メッセージ"
msgstr "Molaetsa oa temoso mabapi le poloko ea leqephe"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Molaetsa o hlahang ha o kopitsa kapa o seha"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Molaetsa o bontshwang ha ho shebile mohlodi wa HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Molaetsa o bontshwang hodima khoutu ya mohlodi ha ho ntse ho sireletswa kapa ho fifatswa HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Molaetsa o tla hlahisoa haeba tokena ea netefatso ea hang e sa sebetse nakong ea tšireletso ea HTML."

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Molaetsa o tla bontšoa haeba li-cookie kapa JavaScript li koetsoe."

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Ha e le hantle, sena se bonahala feela ha JavaScript e koetsoe."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Ha setshwantsho se sireleditswe, se a jarollwa, mme molaetsa o a hlahiswa hodima sona"

msgid "HTML難読化 (圧縮)"
msgstr "Ho fifatsa HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Hona ke khatello e tloaelehileng ea HTML; hape ho na le liwebsaete tse ka e fetolelang."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Ho nolofatsa kgetho ena ho o dumella ho fumana direkoto tsa mohlodi wa ponahatso."

msgid "HTML保護"
msgstr "Tšireletso ea HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "E hlahisa HTML e fokolang le ho feta ho feta tokisetso ea ho hatella HTML, ho bolelang hore litaba tse ka hare ho tag ea BODY ha li na ho hlahisoa ho hang."

msgid "Firefoxに対しては無効です"
msgstr "Sena ha se sebetse ho Firefox."

msgid "SEOに著しく影響があります"
msgstr "Sena se na le tšusumetso e kholo ho SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Ho hlahisa HTML ka JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Ho sebetsana le Firefox, re hlahisa HTML ka JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Ho nolofatsa ts'ebetso ea JavaScript ho tla fokotsa haholo lebelo leo sebaka sa marang-rang se bula ka lona."

msgid "画像の保護"
msgstr "Tšireletso ea setšoantšo"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Sireletsa setšoantšo nako le nako ha letšoao la img le bitsoa."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Sireletsa ditshwantsho tsohle tse kenngwang ho WordPress ka hara HTML yohle e hlahiswang."

msgid "画像をダウンロードから保護します"
msgstr "E sireletsa litšoantšo hore li se ke tsa khoasolloa"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Ha data ea litšoantšo e sirelelitsoe, re thibela hoo e ka bang li-download kaofela, re fana ka li-URL tse ikhethang tsa hang feela, re netefatsa bonnete ba basebelisi ka li-token tse bolokiloeng nakong ea phihlello, 'me re bontša litšoantšo ka PHP; sena se thibela ka katleho hoo e ka bang maemo kaofela a bosholu ba litšoantšo."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Ha data ea litšoantšo e sirelelitsoe, caching ha e sebetse, e leng se bolelang hore sebaka sa marang-rang se tla bula butle maetong a latelang, 'me sena se ama SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ho sireletsa datha ya ditshwantsho ho ka eketsa morwalo hodima polokelo ya datha."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Ha o kgetha 'Sireletsa ditshwantsho nako le nako ha letshwao la img le bitswa', tsamaiso e sebedisa add_filter ho kenya tshebetsong tlhotlho ya ditshwantsho ha letshwao la img le etswa; leha ho le jwalo, sena se ka nna sa se sebetse hantle ka di-theme tse ding."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Ha o kgetha 'Sireletsa ditshwantsho tsohle tse kenngwang ho WordPress ka hara HTML yohle e hlahiswang', plugin e tla hapa hoo e ka bang mesebetsi yohle ya WordPress mme e sebetse tag e nngwe le e nngwe ya img ka hara dikahare. Ka kopo hlokomela hore sena se kanna sa se sebetse hantle le di-theme tse ding."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Ka kopo hlokomela hore litšoantšo tse khethiloeng e le litšoantšo tse hlahelletseng li tla arolelanoa e le data ea OGP 'me ha li khone ho sireletsoa. Haeba o tlameha ho li sireletsa, ka kopo fetola tlhophiso ea tlhahiso ea HEAD tag litlhophisong tse tsoetseng pele ha o kenya tšebetsong tšireletso ea HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Tshebetso ya ho nka setshwantsho sa skrine e kenyelleditsweng ka mokgwa o tlwaelehileng tsamaisong ya tshebetso e ke ke ya sireletswa."

msgid "画像URLの保護"
msgstr "Ho sireletsa li-URL tsa litšoantšo"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Sena se lokela ho sebediswa hammoho le tshireletso ya setshwantsho; ha se sebediswa feela, ha se na thuso."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Kaha e laelletsoa ka ho lieha ka JavaScript, sena se ama SEO."

msgid "画像のウォーターマーク"
msgstr "Letšoao la setšoantšo"

msgid "右下"
msgstr "Tlase ka ho le letona"

msgid "ランダム位置"
msgstr "Boemo bo iketsahalletseng"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Ha li sebediswa mmoho le tshireletso ya ditshwantsho, li-watermark tse fetohang li bontsha ka ho hlaka bo-nngwe ba tokelo ya bongodi, ha ka nako e tshwanang li fa bashebelli maikutlo a hore ba a shebilwa, mme ka hona li sebetsa e le se thibelang."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Ho tšehetsoa feela lifomate tsa JPG, PNG le WebP."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Ho nolofatsa sena ho tla eketsa moroalo ho seva."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ho hlahisa bonono ba ASCII ho tsoa khoutung ea mohloli ea HTML nakong ea ho fifatsa le ho sireletsa"

msgid "表示なし"
msgstr "Ha ho pontšo"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "E bontša bonono ba ASCII bo bontšang tlhokomeliso ha ho shebisoa mohloli oa HTML ka ho sebelisa 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Bontsha moralo ha ketso e lebelletsweng e phethilwe"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Moralo o motheo o nang le mongolo o motsho hodima bokamorao bo boseroledi."

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Moralo oa mofuta oa tšabo o nang le mongolo o mofubelu holim'a bokamorao bo botšo."

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Moralo o nang le mongolo o mofubedu o khanyang holim'a bokamorao bo botšo"

msgid "対象アクションを起こした時のBGM"
msgstr "Mmino o bapalang ha ketso e rerilweng e etswa."

msgid "サウンドなし"
msgstr "Ha ho molumo"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "Ntoa le Tlhōlo - motsotso o le 1 metsotsoana e 16.3 - libaete tse 630,056 - 64 kbps - Laesense: CC 2.1 kapa e ncha"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Ntate Short - metsotsoana e 3.8 - li-byte tse 32,364 - 64 kbps - Laesense: GPL 2.0 kapa e ncha"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - metsotswana e 23.5 - libaete tse 195,578 - 64 kbps - Laesense: GPL 2.0 kapa e ncha"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
