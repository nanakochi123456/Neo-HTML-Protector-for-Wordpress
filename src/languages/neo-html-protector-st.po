msgid "ショパン エチュード Op.10-12 革命 打ち込み版 高速版 - 1分57.6秒 - 724,457bytes - 48kbps -  ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin Étude Op. 10 No. 12 'Revolution' – Mofuta o hlahisitsweng ke khomphutha, mofuta wa lebelo le phahameng – motsotso o le 1 le metsotswana e 57.6 – di-byte tse 724,457 – 48 kbps – Laesense: CC BY-ND 4.0 kapa e morao ho feta"

msgid "ショパン スケルツォ 変ロ短調 Op2 打ち込み版 高速短縮版 - 1分48.0秒 - 665,369bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Chopin: Scherzo ka B flat minor, Op. 2 – Mofuta o hlahisitsweng ke khomphutha, mofuta o kgutsufaditsweng wa lebelo le phahameng – motsotso o le 1 le metsotswana e 48.0 – 665,369 bytes – 48 kbps – Laesense: CC BY-ND 4.0 kapa e ncha ho feta moo"

msgid "リスト 超絶技巧練習曲 4番 マゼッパ 打ち込み版 高速短縮版 - 1分51.6秒 - 687,586bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "Lethathamo: Étude d'Exécution No. 4 'Mazeppa'"

msgid "ファンファーレ - 22.3秒 - 183,926bytes - 64kbps - ライセンス：パブリックドメイン"
msgstr "Modumo wa mokete – metsotswana e 22.3 – dibaete tse 183,926 – 64 kbps – Laesense: Setsoalle sa setjhaba"

msgid "レトロ風ファンファーレ - 2.2秒 - 10,536bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Mokete oa setaele sa khale – metsotsoana e 2.2 – li-byte tse 10,536 – 32 kbps – Laesense: Setsoalle sa sechaba"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Selelekela sa setaele sa khale – metsotsoana e 42.1 – libaete tse 179,138 – 32 kbps – Laesense: Setsoalle sa sechaba"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Temoso ka ChatGPT - metsotswana e 3.8 - li-byte tse 109,700 - 256 kbps - Laesense: Setša sa sechaba"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Modumo o potlakileng haholo o kang tlhokomediso ya ho fumana malware – Karolo ya 1 ka ChatGPT – metsotswana e 3.3 – di-byte tse 102,850 – 256 kbps – Laesense: Setsoalle sa Setjhaba"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Modumo o potlakileng haholo o kang tlhokomediso ya ho fumana malware, Karolo ya 2 ka ChatGPT - metsotswana e 3.3 - dibaete tse 103,122 - 256 kbps - Laesense: Setsoalle sa Setjhaba"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Modumo wa mofuta wa MRI ka ChatGPT – motsotso o le 1 le metsotswana e 14.9 – di-byte tse 3,340,392 – 320 kbps – Laesense: Setsoalle sa Setjhaba"

msgid "警告表示中のBGMを選択します"
msgstr "Kgetha mmino wa ka morao o tla bapala nakong ya temoso."

msgid "びっくりするような雰囲気を作ります"
msgstr "E bopa moea o makatsang."

msgid "Firefoxでは音声ブロックされます"
msgstr "Molumo o thibetsoe ho Firefox."

msgid "対象アクションを起こした時のビープ音"
msgstr "Ho lla ha ketso e boletsweng e phethilwe"

msgid "有効 音量小さ目"
msgstr "Ho, molumo o tlase"

msgid "有効 音量大き目"
msgstr "E sebetsa, molumo o phahamisitsoe haholo"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Ho tla utlwahala modumo bakeng sa diketsahalo tsohle tsa konopo le mouse ha temoso e ntse e bontshwa."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "E fana ka maikutlo a hore sesebediswa se sa sebetse hantle ha temoso e ntse e bontshwa."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Ho pata sesupa-mouse ha ketso e itseng e etsoa"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "E pata sesupa-mouse sebakeng sa sebatli ha temoso e ntse e bontšoa."

msgid "デバッグモード"
