msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Intro gaya retro – 42,1 detik – 179.138 bait – 32 kbps – Lisensi: Domain Umum"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Peringatan saka ChatGPT - 3,8 detik - 109.700 bait - 256 kbps - Lisensi: Domain Umum"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Swara darurat dhuwur kaya tandha peringatan deteksi malware – Bagéan 1 déning ChatGPT – 3,3 detik – 102.850 bait – 256 kbps – Lisensi: Domain Umum"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Swara darurat dhuwur kaya tandha peringatan deteksi malware, Bagéan 2 dening ChatGPT - 3,3 detik - 103.122 bait - 256 kbps - Lisensi: Domain Umum"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "Swara gaya MRI dening ChatGPT – 1 menit 14,9 detik – 3.340.392 bait – 320 kbps – Lisensi: Domain Umum"

msgid "警告表示中のBGMを選択します"
msgstr "Pilih musik latar sing bakal diputer nalika ana peringatan"

msgid "びっくりするような雰囲気を作ります"
msgstr "Iki nggawe suasana sing nggumunake"

msgid "Firefoxでは音声ブロックされます"
msgstr "Audio diblokir ing Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "Suara bip nalika tumindak sing ditemtokake wis rampung"

msgid "有効 音量小さ目"
msgstr "Urip, volume cilik"

msgid "有効 音量大き目"
msgstr "Aktif, volume disetel dhuwur"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Suara bip bakal muni kanggo kabèh acara tombol lan mouse nalika peringatan ditampilaké."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Iki marakake kesan yèn piranti wis ora terkendali nalika peringatan ditampilake."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Nyumputake kursor mouse nalika tumindak tartamtu ditindakake"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Nyumputake kursor mouse ing area browser nalika ana peringatan sing ditampilake"

msgid "デバッグモード"
msgstr "Mode debug"

msgid "妨害＋記録のみ"
msgstr "Gangguan + Rekaman waé"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Gangguan + Pencatatan + Tampilan + Pengalihan"

msgid "メニューからは操作できてしまいます"
msgstr "Sampeyan isih bisa ngakses liwat menu."

msgid "Firefoxにおけるデバッグモード"
msgstr "Mode debug ing Firefox"

msgid "ブラウザーコンソール"
msgstr "Konsol panyungsi"

msgid "事実上デバッグモードから操作できてしまいます"
msgstr "Sakjane, sampeyan bisa ngoperasikake saka mode debug."

msgid "HTMLソース表示"
msgstr "Deleng sumber HTML"

msgid "view-source:から始まるURLを入力すれば操作できてしまいます"
msgstr "Sampeyan bisa nindakake operasi iki kanthi gampang mung kanthi ngetik URL sing diwiwiti karo 'view-source:'"

msgid "HTML保護と組み合わせることでコンテンツを保護することができます"
msgstr "Sampeyan bisa nglindhungi konten sampeyan kanthi nggabungake iki karo proteksi HTML."

msgid "印刷"
msgstr "Cithak"

msgid "印刷阻止をするもものの、ブラウザによってはうまく動作しません"
msgstr "Sanajan nyegah nyithak, bisa uga ora bisa digunakake kanthi bener ing sawetara panyungsi web."

msgid "スクリーンショット"
msgstr "Tangkapan layar"

msgid "OSやブラウザ、方法によっては妨害できず、もしくは検出しないことがあります"
msgstr "Gumantung marang sistem operasi, panyungsi, utawa cara sing digunakake, bisa uga ora bisa ngalangi iki, utawa bisa uga ora dideteksi."

msgid "ウインドウが背面に移動した時スクリーンショットの疑い"
msgstr "Dugaan tangkapan layar nalika jendhela pindhah menyang latar mburi"

msgid "あわせて、スクリーンショット以外の機能（タブ切り替え・ウィンドウ切り替え）にも反応してしまいます。"
msgstr "Iki uga nanggapi fungsi liyane saliyane njupuk tangkapan layar"

