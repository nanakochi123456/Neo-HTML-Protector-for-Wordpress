msgid "設定"
msgstr "Setelan"

msgid "IPログリーダー"
msgstr "Pembaca Log IP"

msgid "IPアドレスログ"
msgstr "Cathetan alamat IP"

msgid "全クリア"
msgstr "Rampungna kabeh tingkat"

msgid "IPログが全て削除されました"
msgstr "Kabeh log IP wis dibusak"

msgid "ID"
msgstr "Identifikasi"

msgid "タイムスタンプ"
msgstr "Cap wektu"

msgid "IPアドレス"
msgstr "Alamat IP"

msgid "ユーザーエージェント"
msgstr "Agen pangguna"

msgid "イベント"
msgstr "Acara"

msgid "IPアドレスのデータはありません"
msgstr "Ora ana data kanggo alamat IP iki"

msgid "EU GDPR対応"
msgstr "Patuh marang GDPR EU"

msgid "無効"
msgstr "Ora sah"

msgid "有効"
msgstr "Bener"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Yen sampeyan nggunakake WordPress ing Uni Éropa, utawa yen situs web sampeyan ditujokake kanggo pangguna ing Uni Éropa, mangga priksa manawa iki wis diaktifake."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Tombol 'Konfirmasi' bakal owah dadi 'Setuju' utawa 'Ora Setuju', lan prilakune bakal rada owah."

msgid "同意画面の色"
msgstr "Werna layar persetujuan"

msgid "自動"
msgstr "Oto"

msgid "ライトモード"
msgstr "Mode entheng"

msgid "ダークモード"
msgstr "Mode Peteng"

msgid "同意画面表示中の配色を設定します"
msgstr "Atur skéma warna kanggo layar persetujuan"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Kabur isi ing layar persetujuan"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Atur tingkat kabur kanggo konten sing ditampilake ing layar persetujuan"

msgid "同意画面の透過"
msgstr "Keterbukaan layar persetujuan"

msgid "透過なし"
msgstr "Ora ana transparansi"

msgid "同意画面の透過具合を設定します"
msgstr "Atur transparansi layar persetujuan"

msgid "お知らせの1行目"
msgstr "Garis pisanan saka pangumuman"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Pesen iki tansah ditampilake pisanan nalika kaca dimuat."

msgid "お知らせの2行目"
msgstr "Baris kapindho saka kabar"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Pesen iki bakal tansah katon mung ing tampilan kapisan nalika EU GDPR wis berlaku."

msgid "お知らせの3行目"
msgstr "Baris katelu saka kabar"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Iku bakal katon ing sisih tengen pranala menyang Kebijakan Privasi."

msgid "非EU向け確認の文字列"
msgstr "Tèks konfirmasi kanggo negara non-Uni Éropa"

msgid "EU GDPR向け同意するの文字列"
msgstr "Tèks persetujuan kanggo GDPR EU"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Tèks kanggo 'Aja sarujuk' miturut GDPR EU"

msgid "プライバシーポリシーの文字列"
msgstr "Tèks kabijakan privasi"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Mangga atur URL kanggo kabijakan privasi ing kene."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Mangga tambahi ing ngandhap iki ing Kebijakan Privasi."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Kanggo ndeteksi aktivitas penipuan, identifikasi kaya alamat IP disimpen ing cookie lan basis data. Data sing disimpen bakal diilangi miturut kaputusan administrator."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Supaya gambar dikirim kanthi bener mung nalika proteksi gambar diaktifake, kita nyimpen data hashed sing ngemot alamat IP lan jeneng file gambar ing basis data nganti 60 menit."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Yen sampeyan nyetel Syarat Panggunaan, priksa manawa sampeyan nyakup pranala menyang syarat kasebut ing Kebijakan Privasi sampeyan."

msgid "利用規約の文字列"
msgstr "Tèks syarat panggunaan"

msgid "利用規約のページ"
msgstr "Kaca Syarat lan Ketentuan"

msgid "ページ選択なし"
msgstr "Ora ana kaca sing dipilih"

msgid "検索エンジン等のURL"
msgstr "URL kanggo mesin telusur, lsp."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Atur URL kanggo mesin telusur lan situs sing padha sing ngarahake pangguna nalika persetujuan ora diwenehake."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "Mode debug, pesen peringatan ing konsol"

msgid "右クリックの警告メッセージ"
msgstr "Pesen peringatan klik-tengen"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Pesen peringatan babagan nyithak lan nyimpen minangka PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Pesen peringatan ing tangkapan layar"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Pesen peringatan babagan tangkapan layar sing diduga"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Pesen peringatan nalika kabeh teks dipilih"

msgid "ページ保存の警告メッセージ"
msgstr "Pesen peringatan babagan nyimpen kaca"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Pesen sing ditampilake nalika nyalin utawa motong"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Pesen sing bakal ditampilake nalika ndeleng sumber HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Pesen sing ditampilake ing ndhuwur kode sumber nalika ngabur utawa nglindhungi HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Pesen sing bakal ditampilake yen token otentikasi sak-sepisan ora sah nalika proteksi HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Pesen sing bakal ditampilake yen cookie utawa JavaScript dinonaktifake"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Sejatine, iki mung ditampilake nalika JavaScript dipatèni."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Nalika gambar dilindhungi, gambar kasebut diundhuh lan pesen bakal ditampilake ing gambar kasebut"

msgid "HTML難読化 (圧縮)"
msgstr "Pengaburan HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Iki kompresi HTML standar; ana uga situs web sing bisa mbalèkaké kodené."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Nggaktèkaké pilihan iki ngidini sampeyan njupuk log sumber tampilan."

msgid "HTML保護"
msgstr "Proteksi HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Iki mung ngasilake HTML sing paling minimal—malah luwih sithik tinimbang nalika nggunakake kompresi HTML—lan isi ing tag BODY ora ditampilake babar pisan."

msgid "Firefoxに対しては無効です"
msgstr "Iki ora ditrapake kanggo Firefox"

msgid "SEOに著しく影響があります"
msgstr "Iki nduwèni pangaruh sing wigati marang SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Ngasilake HTML nganggo JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Supaya bisa ngliwati watesan Firefox, kita nampilake HTML nganggo JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Ngaktifake rendering JavaScript bakal nyuda kacepetan muat situs web kanthi signifikan."

msgid "画像の保護"
msgstr "Pelindhung gambar"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Lindhungi gambar saben tag img diundang"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Lindhungi kabèh gambar sing diunggah menyang WordPress ing saindenging output HTML."

msgid "画像をダウンロードから保護します"
msgstr "Ngamanake gambar supaya ora bisa diundhuh"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Nalika data gambar dilindhungi, kita nyegah meh kabèh undhuhan, ngasilaké URL sak-sepisan sing unik, ngotentikasi nganggo token sing disimpen ing sesi, lan nampilaké gambar liwat PHP; iki sacara efektif nyegah meh kabèh kasus nyolong gambar."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Nalika data gambar dilindhungi, caching ora bisa digunakake, sing tegese situs bakal muat luwih alon nalika dikunjungi maneh, saéngga mengaruhi SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Ngamanake data gambar bisa nambah beban ing basis data."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Yen sampeyan milih 'Lindhungi gambar saben tag img diundang', sistem bakal nggunakake add_filter kanggo nerapake saringan nalika tag img digawe; nanging, iki bisa uga ora bisa digunakake kanthi bener karo sawetara tema."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Yen sampeyan milih 'Ngamanake kabeh gambar sing diunggah menyang WordPress ing saindenging output HTML', plugin iki bakal nyekel meh kabeh operasi WordPress lan ngolah saben tag img ing konten. Mangga dicathet yen iki bisa uga ora bisa digunakake kanthi bener karo sawetara tema."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Mangga dipun mangertosi menawa gambar sing ditetepake minangka gambar unggulan bakal dibagi minangka data OGP lan ora bisa dilindhungi. Yen pancen sampeyan kudu nglindhungi, mangga ganti setelan kanggo output tag HEAD ing setelan canggih nalika ngaktifake proteksi HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Fungsi screenshot sing kalebu standar ing sistem operasi ora bisa dilindhungi."

msgid "画像URLの保護"
msgstr "Ngamanake URL gambar"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Iki kudu digunakake bareng karo proteksi gambar; yen dhewekan, ora ana gunane."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Amarga dimuat liwat JavaScript, iki mengaruhi SEO."

msgid "画像のウォーターマーク"
msgstr "Airmark gambar"

msgid "右下"
msgstr "Ngisor tengen"

msgid "ランダム位置"
msgstr "Posisi acak"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Digunakake bareng karo proteksi gambar, watermark dinamis kanthi cetha nuduhake kepemilikan hak cipta lan menehi kesan marang pamirsa yen dheweke lagi diawasi, saéngga dadi panghalang."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Mung format JPG, PNG, lan WebP sing didhukung."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Nggaktèkaké iki bakal nambah beban ing server."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Ngasilake seni ASCII saka kode sumber HTML nalika ngaburake lan nglindhungi HTML"

msgid "表示なし"
msgstr "Ora ana tampilan"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Nampilake seni ASCII sing menehi tandha peringatan nalika ndeleng sumber HTML nganggo 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Tampilake desain nalika tumindak target wis rampung"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Desain dhasar sing nampilake teks ireng ing latar kuning"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Desain gaya horor sing nampilake teks abang ing latar ireng"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Desain sing nampilake teks abang padhang ing latar ireng"

msgid "対象アクションを起こした時のBGM"
msgstr "Musik latar sing muni nalika tumindak target ditindakake"

msgid "サウンドなし"
msgstr "Ora ana swara"

