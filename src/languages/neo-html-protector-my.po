msgid "設定"
msgstr "ဆက်တင်များ"

msgid "IPログリーダー"
msgstr "IP မှတ်တမ်းဖတ်စက်"

msgid "IPアドレスログ"
msgstr "IP လိပ်စာ မှတ်တမ်း"

msgid "全クリア"
msgstr "အဆင့်အားလုံးကို ပြီးမြောက်ပါ"

msgid "IPログが全て削除されました"
msgstr "IP မှတ်တမ်းအားလုံး ဖျက်ပစ်ပြီးပါပြီ။"

msgid "ID"
msgstr "အိုင်ဒီ"

msgid "タイムスタンプ"
msgstr "အချိန်တံဆိပ်"

msgid "IPアドレス"
msgstr "IP လိပ်စာ"

msgid "ユーザーエージェント"
msgstr "အသုံးပြုသူ ကိုယ်စားလှယ်"

msgid "イベント"
msgstr "ပွဲ"

msgid "IPアドレスのデータはありません"
msgstr "IP လိပ်စာအတွက် ဒေတာမရှိပါ။"

msgid "EU GDPR対応"
msgstr "EU GDPR နှင့် ကိုက်ညီခြင်း"

msgid "無効"
msgstr "မမှန်ကန်ပါ"

msgid "有効"
msgstr "မှန်ကန်သော"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "သင်သည် ဥရောပသမဂ္ဂအတွင်းတွင် WordPress ကို အသုံးပြုနေပါက သို့မဟုတ် သင့်ဝက်ဘ်ဆိုဒ်သည် ဥရောပသမဂ္ဂအတွင်းရှိ အသုံးပြုသူများကို ရည်ရွယ်ထားပါက ဤအင်္ဂါရပ်ကို ဖွင့်ထားကြောင်း သေချာစေပါ။"

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "'Confirm' ခလုတ်သည် 'Agree' သို့မဟုတ် 'Disagree' အဖြစ် ပြောင်းလဲသွားမည်ဖြစ်ပြီး လုပ်ဆောင်ပုံလည်း အနည်းငယ် ပြောင်းလဲသွားမည်။"

msgid "同意画面の色"
msgstr "သဘောတူခွင့်ပေး မျက်နှာပြင်၏ အရောင်"

msgid "自動"
msgstr "အလိုအလျောက်"

msgid "ライトモード"
msgstr "အလင်းမုဒ်"

msgid "ダークモード"
msgstr "အမှောင်မုဒ်"

msgid "同意画面表示中の配色を設定します"
msgstr "သဘောတူခွင့်ပေးမည့် မျက်နှာပြင်အတွက် အရောင်စနစ်ကို သတ်မှတ်ပါ။"

msgid "同意画面中のコンテンツのぼかし"
msgstr "သဘောတူခွင့်ပေးမည့် မျက်နှာပြင်ပေါ်တွင် အကြောင်းအရာ မှိုကွက်ခြင်း"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "သဘောတူခွင့်ပေးမည့် မျက်နှာပြင်ပေါ်တွင် ပြသမည့် အကြောင်းအရာများအတွက် မှုန်ကွဲမှု အဆင့်ကို သတ်မှတ်ပါ။"

msgid "同意画面の透過"
msgstr "သဘောတူခွင့်ပေး မျက်နှာပြင်၏ ထင်ရှားမှု"

msgid "透過なし"
msgstr "ရှင်းလင်းမြင်သာမှုမရှိခြင်း"

msgid "同意画面の透過具合を設定します"
msgstr "သဘောတူခွင့်ပေးမည့် မျက်နှာပြင်၏ ပွင့်လင်းမြင်သာမှု အဆင့်ကို သတ်မှတ်ပါ။"

msgid "お知らせの1行目"
msgstr "ကြေညာချက်၏ ပထမဆုံးကြောင်း"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "ဤစာသားကို စာမျက်နှာကို ပထမဆုံး တင်လိုက်သောအခါ အမြဲပြသသည်။"

msgid "お知らせの2行目"
msgstr "ကြေညာချက်၏ ဒုတိယကြောင်း"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "ဤစာသားကို EU GDPR အကျုံးဝင်နေစဉ်တွင်သာ ပထမဆုံးပြသမှုတွင် အမြဲတမ်း မြင်တွေ့ရမည်။"

msgid "お知らせの3行目"
msgstr "ကြေညာချက်၏ တတိယကြောင်း"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "၎င်းသည် ကိုယ်ရေးကိုယ်တာမူဝါဒလင့်ခ်၏ ညာဘက်တွင် ပေါ်လာမည်။"

msgid "非EU向け確認の文字列"
msgstr "EU မဟုတ်သော နိုင်ငံများအတွက် အတည်ပြုစာသား"

msgid "EU GDPR向け同意するの文字列"
msgstr "EU GDPR အတွက် သဘောတူစာသား"

msgid "EU GDPR向け同意しないの文字列"
msgstr "EU GDPR အောက်တွင် 'သဘောမတူပါ' ဟုရေးသားထားသော စာသား"

msgid "プライバシーポリシーの文字列"
msgstr "ကိုယ်ရေးကိုယ်တာ သတင်းအချက်အလက် ကာကွယ်ရေး မူဝါဒ စာသား"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "ကျေးဇူးပြု၍ ကိုယ်ရေးအချက်အလက်ကာကွယ်ရေးမူဝါဒ၏ URL ကို ဤနေရာတွင် သတ်မှတ်ပါ။"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "ကျေးဇူးပြု၍ အောက်ပါအချက်များကို ကိုယ်ရေးအချက်အလက်ကာကွယ်ရေးမူဝါဒတွင် ထည့်သွင်းပါ။"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "လိမ်လည်မှု လှုပ်ရှားမှုများကို ရှာဖွေရန် IP လိပ်စာကဲ့သို့ အထူးသတ်မှတ်ကိန်းများကို ကွကီးများနှင့် ဒေတာဘေ့စ်တွင် သိမ်းဆည်းထားသည်။ သိမ်းဆည်းထားသော ဒေတာများကို အုပ်ချုပ်သူ၏ ဆုံးဖြတ်ချက်အရ ဖျက်ပစ်သည်။"

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "ပုံကာကွယ်မှု ဖွင့်ထားသည့်အခါမှသာ ပုံများကို မှန်ကန်စွာ ပို့ဆောင်နိုင်ရန်၊ IP လိပ်စာနှင့် ပုံဖိုင်အမည် ပါဝင်သည့် ဟက်ရှ်ဒေတာကို ဒေတာဘေ့စ်တွင် ၆၀ မိနစ်အထိ သိမ်းဆည်းထားပါသည်။"

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "အသုံးပြုခွင့်စည်းမျဉ်းများကို သတ်မှတ်နေပါက၊ သင့်၏ ကိုယ်ရေးအချက်အလက်ကာကွယ်ရေးမူဝါဒတွင် ထိုစည်းမျဉ်းများသို့ ချိတ်ဆက်ချက်တစ်ခု ထည့်သွင်းထားကြောင်း သေချာစေပါ။"

msgid "利用規約の文字列"
msgstr "အသုံးပြုမှု စည်းမျဉ်းများ၏ စာသား"

msgid "利用規約のページ"
msgstr "စည်းမျဉ်းနှင့် သတ်မှတ်ချက်များ စာမျက်နှာ"

msgid "ページ選択なし"
msgstr "ရွေးထားသော စာမျက်နှာ မရှိပါ"

msgid "検索エンジン等のURL"
msgstr "ရှာဖွေရေးအင်ဂျင်များအတွက် URL များ စသည်"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "သဘောတူညီချက် မပေးပါက အသုံးပြုသူများကို ပြန်လည်ညွှန်ပြသည့် ရှာဖွေရေးအင်ဂျင်များနှင့် ဆင်တူဆိုဒ်များအတွက် URL ကို သတ်မှတ်ပါ။"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "အမှားရှာဖွေရေးမုဒ်၊ ကွန်ဆိုးလ် သတိပေးစာများ"

msgid "右クリックの警告メッセージ"
msgstr "ညာဘက်ကလစ်ဖြင့် သတိပေးစာ"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "PDF အဖြစ် ပုံနှိပ်ခြင်းနှင့် သိမ်းဆည်းခြင်းဆိုင်ရာ သတိပေးစာ"

msgid "スクリーンショットの警告メッセージ"
msgstr "စကရင်ရှော့တွင် သတိပေးစာသား"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "သံသယရှိသော screenshot များနှင့်ပတ်သက်သည့် သတိပေးစာ"

msgid "テキスト全選択時の警告メッセージ"
msgstr "စာသားအားလုံးကိုရွေးချယ်ထားသောအခါ သတိပေးစာသား"

msgid "ページ保存の警告メッセージ"
msgstr "စာမျက်နှာ သိမ်းဆည်းခြင်းနှင့် ပတ်သက်သည့် သတိပေးစာ"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "ကူးယူခြင်း သို့မဟုတ် ဖြတ်ထုတ်ခြင်း ပြုလုပ်သောအခါ ပြသသည့် စာသား"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "HTML မူရင်းကုဒ်ကြည့်ရှုနေစဉ် ပြသမည့် စာတို"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "HTML ကို မှိုကွယ်ခြင်း သို့မဟုတ် ကာကွယ်ခြင်း ပြုလုပ်သောအခါ အရင်းအမြစ်ကုဒ်၏ ထိပ်ဆုံးတွင် ပြသမည့် စာသား"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "HTML ကာကွယ်မှုအတွင်း တစ်ကြိမ်သုံး အတည်ပြုကုဒ် မမှန်ကန်ပါက ပြသရန် မက်ဆေ့ခ်ျ"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "ကွကီများ သို့မဟုတ် JavaScript ကို ပိတ်ထားပါက ပြသမည့် သတင်းစကား"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "အမှန်တော့ JavaScript ကို ပိတ်ထားတဲ့အခါမှသာ ဒီကို ပြသပါသည်။"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "ပုံတစ်ပုံကိုကာကွယ်ထားလျှင်၊ ၎င်းကိုဒေါင်းလုဒ်ဆွဲပြီး၊ အဲဒီပုံပေါ်တွင်စာတစ်စောင်ပြသမည်"

msgid "HTML難読化 (圧縮)"
msgstr "HTML ဖျောက်ဖျက်ခြင်း"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "ဒါက စံ HTML ဖိသိပ်ခြင်းဖြစ်ပြီး၊ ၎င်းကို ပြန်ဖော်ပေးနိုင်တဲ့ ဝက်ဘ်ဆိုဒ်များလည်း ရှိသည်။"

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "ဤရွေးချယ်စရာကို ဖွင့်ထားခြင်းဖြင့် view-source မှတ်တမ်းများကို ပြန်လည်ရယူနိုင်ပါသည်။"

msgid "HTML保護"
msgstr "HTML ကာကွယ်မှု"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "ဤသည် HTML ကို အနည်းဆုံးလိုအပ်သမျှသာ ထုတ်ပေးပြီး HTML ဖိသိပ်ခြင်းအသုံးပြုသည့်အခါထက်ပိုနည်းပါးကာ BODY တက်အတွင်းရှိ အကြောင်းအရာများကို လုံးဝ မထုတ်ပေးပါ။"

msgid "Firefoxに対しては無効です"
msgstr "ဤသည် Firefox အတွက် မသက်ဆိုင်ပါ။"

msgid "SEOに著しく影響があります"
msgstr "ဤသည် SEO အပေါ် အရေးကြီးသော သက်ရောက်မှု ရှိသည်။"

msgid "HTMLをJavaScriptで描画"
msgstr "JavaScript ဖြင့် HTML ဖော်ပြခြင်း"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Firefox ကိုကျော်လွှားရန်အတွက် ကျွန်ုပ်တို့သည် JavaScript ဖြင့် HTML ကို ဖော်ပြသည်။"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "JavaScript rendering ကို ဖွင့်ထားခြင်းက ဝက်ဘ်ဆိုဒ်ဖွင့်ချိန်ကို အလွန်နှေးကွေးစေပါလိမ့်မည်။"

msgid "画像の保護"
msgstr "ပုံကာကွယ်ခြင်း"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Img tag ကို ခေါ်တိုင်း ပုံကို ကာကွယ်ပါ။"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "WordPress သို့ တင်ထားသော ပုံအားလုံးကို HTML ထွက်စာတန်းတစ်ခုလုံးအတွင်း ကာကွယ်ပါ။"

msgid "画像をダウンロードから保護します"
msgstr "ပုံများကို ဒေါင်းလုဒ်ဆွဲခြင်းမှ ကာကွယ်ပေးသည်။"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
