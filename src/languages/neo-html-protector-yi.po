msgid "設定"
msgstr "איינשטעלונגען"

msgid "IPログリーダー"
msgstr "IP לאָג לייענער"

msgid "IPアドレスログ"
msgstr "לאָג פֿון IP-אַדרעסן"

msgid "全クリア"
msgstr "פֿאַרענדיק אַלע לעוועלס"

msgid "IPログが全て削除されました"
msgstr "אַלע IP־לאָגס זענען אויסגעמעקט געוואָרן."

msgid "ID"
msgstr "אידענטיפיקאַציע"

msgid "タイムスタンプ"
msgstr "צײַט־שטעמפּל"

msgid "IPアドレス"
msgstr "IP-אַדרעס"

msgid "ユーザーエージェント"
msgstr "באַניצער־אַגענט"

msgid "イベント"
msgstr "געשעעניש"

msgid "IPアドレスのデータはありません"
msgstr "עס זענען נישט קיין דאַטן פֿאַר דער IP-אַדרעס."

msgid "EU GDPR対応"
msgstr "איינהאַלטונג פֿון דער אי״יו גאָדפּי"

msgid "無効"
msgstr "ניט גילטיק"

msgid "有効"
msgstr "גילטיק"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "אויב איר ניצט WordPress אינעם אייראפעישן פאראייניקונג, אָדער אויב אייער וועבזייטל ריכט זיך צו באַניצער אינעם אייראפעישן פאראייניקונג, ביטע זייט זיכער אַז דאָס איז אַקטיוו."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "דער באַשטעטיקן-קנעפּל וועט זיך טוישן צו איינשטימען אָדער נישט איינשטימען, און די אויפֿפֿירונג וועט זיך אַ ביסל טוישן."

msgid "同意画面の色"
msgstr "פֿאַרב פֿונעם צוזימונג־עקראַן"

msgid "自動"
msgstr "אױטאָמאַטיש"

msgid "ライトモード"
msgstr "ליכטיקער מאָדע"

msgid "ダークモード"
msgstr "טונעלקער מאָדע"

msgid "同意画面表示中の配色を設定します"
msgstr "שטעלט די קאָליר־סכעמע פֿאַרן צוזימונג־עקראַן"

msgid "同意画面中のコンテンツのぼかし"
msgstr "פֿאַרווישן פֿון אינהאַלט אויפֿן הסכּמה־עקראַן"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "שטעלט אײַן די מדרגה פֿון פֿאַרוואַסערונג פֿאַר דעם אינהאַלט וואָס ווערט געוויזן אויפֿן צוזימונג־עקראַן"

msgid "同意画面の透過"
msgstr "טראַנספּאַרענץ פֿונעם צוזימונג־עקראַן"

msgid "透過なし"
msgstr "קיין דורכזיכטיקייט"

msgid "同意画面の透過具合を設定します"
msgstr "שטעלט די דורכזיכטיקייט פֿונעם הסכּמה־עקראַן"

msgid "お知らせの1行目"
msgstr "ערשטע שורה פֿון דער מעלדונג"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "די אָנזאָג ווערט שטענדיק געוויזן דעם ערשטן מאָל ווען די זײַט לאָדירט ווערט."

msgid "お知らせの2行目"
msgstr "די צווייטע שורה פֿון דער מעלדונג"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "די אָנזאָג וועט שטענדיק דערשייַנען אויף דער ערשטער אַרויסווייַזונג נאָר ווען די EU GDPR איז אין קראַפֿט."

msgid "お知らせの3行目"
msgstr "די דריטע שורה פֿון דער מעלדונג"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "עס וועט דערשייַנען רעכטס פֿון דעם לינק צו דער פּריוואַטקייט־פּאָליטיק."

msgid "非EU向け確認の文字列"
msgstr "באַשטעטיקונג־טעקסט פֿאַר ניט־אי״יו לענדער"

msgid "EU GDPR向け同意するの文字列"
msgstr "צוזימונג־טעקסט פֿאַר דער אי״יו ג.ד.פּ.אַר."

msgid "EU GDPR向け同意しないの文字列"
msgstr "טעקסט פֿאַר ניט מסכים אונטער דעם אייראָפּעיִשן GDPR"

msgid "プライバシーポリシーの文字列"
msgstr "פּריוואַטקייט־פּאָליטיק טעקסט"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "ביטע שטעלן דאָ די URL פֿאַר דער פּריוואַטקייט־פּאָליטיק."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "ביטע לייגט די פאלגנדיקע צו דער פּריוואַטקייט־פּאָליטיק."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "צו אַנטדעקטן פראָדזשענטע אַקטיוויטעטן, ווערן אידענטיפיערס ווי IP-אַדרעסן געשפּייַכט אין קוקיס און אין דער דאַטאַבייס. די געשפּייַכטע דאַטן ווערן אויסגעמעקט לויט דער באַשלוס פונעם אַדמיניסטראַטאָר."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "כדי צו פֿאַרזיכערן אַז בילדער ווערן ריכטיק איבערגעגעבן ווען בילדער־שוץ איז אַקטיוו, שפּייַכן מיר האַשט־דאַטן וואָס אַרײַננעמען דעם IP־אַדרעס און דעם בילד־טעקע־נאָמען אין אַ דאַטאַבייס פֿאַר ביז 60 מינוט."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "אויב איר שטעלט אויף באַניץ־באַדינגונגען, ביטע זייט זיכער אַז איר אַרײַננעמט אַ לינק צו זיי אין אייער פּריוואַטקייט־פּאָליטיק."

msgid "利用規約の文字列"
msgstr "טעקסט פֿון די באַניץ־באַדינגונגען"

msgid "利用規約のページ"
msgstr "תּנאָים און באַדינגונגען זײַט"

msgid "ページ選択なし"
msgstr "קיין זײַט איז נישט אויסגעקליבן"

msgid "検索エンジン等のURL"
msgstr "URLs פֿאַר זוך־מאַשינען, אאז״וו."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "שטעלט דעם URL פֿאַר זוך־מאָטאָרן און ענלעכע וועבזײַטן וואָס ווײַזן אויף אַן אַנדער זײַט ווען מען גיט נישט קיין צוזימונג."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "דיבאַג־מאָדוס, קאָנסאָלע־וואָרענונג־מעסעדזשעס"

msgid "右クリックの警告メッセージ"
msgstr "רעכט־קליק אזהרה־מעסעדזש"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "וואָרענונג־מעלדונג וועגן דרוקן און אויפֿהיטן ווי PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "וואָרענונגס־מעסעדזש אין דעם סקרינשאָט"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "וואָרענונג־מעלדונג וועגן פֿאַרדעכטיקטע סקרינשאַטס"

msgid "テキスト全選択時の警告メッセージ"
msgstr "וואָרענונגס־מעסעדזש ווען דער גאַנצער טעקסט איז אויסגעקליבן"

msgid "ページ保存の警告メッセージ"
msgstr "וואָרענונג וועגן שפּאַרן דעם בלאַט"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "מעסעדזש וואָס ווערט געוויזן בײַם קאָפּירן אָדער אויסשנײַדן"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "מעסעדזש צו ווײַזן ווען מען קוקט דעם HTML־מקור"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "מעסעדזש צו ווײַזן אויבן אין דעם מקור־קאָד ווען מען אָפּפֿאַסט אָדער באַשיצט HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "מעסעדזש צו ווײַזן אויב דער איין־מאָליקער אויטענטיפֿיקאַציע־טאָקען איז אומגילטיק בעת HTML־שוץ"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "מעסעדזש צו ווײַזן אויב קוקיס אָדער דזשאַוואַסקריפּט זענען אויסגעשאַלטן"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "למעשה, דאָס ווערט געוויזן נאָר ווען דזשאַוואַסקריפּט איז אויסגעשאַלטן."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "ווען אַ בילד איז באַשיצט, ווערט עס אַראָפּגעלאָדן, און אַ אָנזאָג ווערט אויפֿן בילד געוויזן"

msgid "HTML難読化 (圧縮)"
msgstr "HTML פֿאַרפֿלייצונג"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "דאָס איז סטאַנדאַרטע HTML־קאָמפּרעסיע; עס זענען אויך וועבזײַטן וואָס קענען עס דעקאָדירן."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "דאָס אַקטיווירן דער אָפּציע דערלויבט אײַך צו באַקומען דעם view-source לאָג."

msgid "HTML保護"
msgstr "HTML שוץ"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "עס גיט אויס בלויז דעם נייטיקסטן מינימום פֿון HTML — אַפֿילו ווייניקער ווי בײַם ניצן פֿון HTML־קאָמפּרעסיע — און דער אינהאַלט אינעם BODY־טאַג וועט בכלל נישט אויסגעגעבן ווערן."

msgid "Firefoxに対しては無効です"
msgstr "דאָס גייט נישט אָן אויף פֿײַערפֿאָקס."

msgid "SEOに著しく影響があります"
msgstr "דאָס האָט אַ באַטײַטנדיקע השפּעה אויף SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "רענדערן HTML מיט JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "כּדי אַרומצוגיין Firefox, רענדערן מיר די HTML מיט JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "די אַקטיווירונג פֿון דזשאַוואַסקריפּט־רענדערינג וועט באַטייטיק פֿאַרלאַנגזאַמען די לאָדונג־גיכקייט פֿון דער וועבזײַט."

msgid "画像の保護"
msgstr "בילד־שוץ"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "באַשיצן דעם בילד יעדעס מאָל ווען דער img-טאַג ווערט גערופֿן"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "שוץ אַלע בילדער וואָס ווערן אַרויפֿגעלאָדן אין WordPress אינעם גאַנצן HTML־אויסגאַנג."

msgid "画像をダウンロードから保護します"
msgstr "שוץ בילדער פֿון אַראָפּלאָדן"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "ווען בילד־דאַטן זענען באַשיצט, פאַרמיידן מיר כּמעט אַלע אַראָפּלאָדונגען, געבן יינציקע איין־מאָל URLס, אויטענטיפֿיצירן מיט טאָקענס וואָס ווערן געשפּייכערט אין דער סעסיע, און ווײַזן די בילדער דורך PHP; דאָס פאַרמיידט כּמעט אַלע פאַלן פֿון בילד־גנבֿה."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "ווען בילד־דאַטן זענען באַשיצט, קעש־לאַגירונג אַרבעט נישט, וואָס מיינט אַז די זייטל וועט זיך לאָדן פּאַמעלעכער בײַ די ווייַטערדיקע באַזוכן, און דאָס ווירקט זיך אויף SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "דער שוץ פֿון בילד־דאַטן קען פֿאַרגרעסערן די לאַסט אויף דער דאַטאַבאַזע."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "אויב איר אויסקלײַבט באַשיצן בילדער יעדעס מאָל ווען אַן img־טאַג ווערט גערופֿן, ניצט דער סיסטעם add_filter צו אָנווענדן פֿילטרירונג ווען דער img־טאַג ווערט גענערירט; אָבער דאָס קען נישט אַרבעטן ריכטיק מיט עטלעכע טעמעס."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "אויב איר קלייבט אויס שוץ אַלע בילדער וואָס ווערן אַרויפֿגעלאָדן אין WordPress אינעם גאַנצן HTML־אויסגאַנג, וועט דער פּלאַגין כּמעט אַלע WordPress־אָפּעראַציעס אָפּכאַפּן און פּראַסעסירן יעדן img־טאַג אינעם אינהאַלט. ביטע באַמערקט אַז דאָס קען נישט אַרבעטן ריכטיק מיט עטלעכע טעמעס."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
