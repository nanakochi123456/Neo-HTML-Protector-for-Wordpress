msgid "設定"
msgstr "הגדרות"

msgid "IPログリーダー"
msgstr "קורא יומני IP"

msgid "IPアドレスログ"
msgstr "יומן כתובות IP"

msgid "全クリア"
msgstr "השלים את כל השלבים"

msgid "IPログが全て削除されました"
msgstr "כל יומני ה-IP נמחקו"

msgid "ID"
msgstr "מספר זיהוי"

msgid "タイムスタンプ"
msgstr "חותמת זמן"

msgid "IPアドレス"
msgstr "כתובת IP"

msgid "ユーザーエージェント"
msgstr "סוכן המשתמש"

msgid "イベント"
msgstr "אירוע"

msgid "IPアドレスのデータはありません"
msgstr "אין נתונים עבור כתובת ה-IP הזו"

msgid "EU GDPR対応"
msgstr "עמידה בתקנות ה-GDPR של האיחוד האירופי"

msgid "無効"
msgstr "לא חוקי"

msgid "有効"
msgstr "תקף"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "אם אתם משתמשים בוורדפרס בתוך האיחוד האירופי, או אם האתר שלכם פונה למשתמשים בתוך האיחוד האירופי, אנא ודאו שהאפשרות הזו מופעלת."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "הכפתור 'אשר' ישתנה ל'מסכים' או 'לא מסכים', וההתנהגות תשתנה מעט"

msgid "同意画面の色"
msgstr "צבע מסך האישור"

msgid "自動"
msgstr "אוטומטי"

msgid "ライトモード"
msgstr "מצב בהיר"

msgid "ダークモード"
msgstr "מצב כהה"

msgid "同意画面表示中の配色を設定します"
msgstr "הגדר את ערכת הצבעים של מסך ההסכמה"

msgid "同意画面中のコンテンツのぼかし"
msgstr "טשטוש התוכן במסך ההסכמה"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "הגדר את רמת הטשטוש של התוכן המוצג במסך ההסכמה"

msgid "同意画面の透過"
msgstr "שקיפות מסך ההסכמה"

msgid "透過なし"
msgstr "אין שקיפות"

msgid "同意画面の透過具合を設定します"
msgstr "הגדר את רמת השקיפות של מסך ההסכמה"

msgid "お知らせの1行目"
msgstr "השורה הראשונה בהודעה"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "הודעה זו מוצגת תמיד בפעם הראשונה שהדף נטען"

msgid "お知らせの2行目"
msgstr "השורה השנייה בהודעה"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "הודעה זו תופיע תמיד רק במסך הראשון, כל עוד תקנות ה-GDPR של האיחוד האירופי בתוקף."

msgid "お知らせの3行目"
msgstr "השורה השלישית בהודעה"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "הוא יופיע מימין לקישור למדיניות הפרטיות"

msgid "非EU向け確認の文字列"
msgstr "טקסט אישור עבור מדינות שאינן חברות באיחוד האירופי"

msgid "EU GDPR向け同意するの文字列"
msgstr "נוסח הסכמת המשתמש בהתאם לתקנות ה-GDPR של האיחוד האירופי"

msgid "EU GDPR向け同意しないの文字列"
msgstr "הטקסט המופיע תחת הכותרת אל תסכים בהתאם לתקנת ה-GDPR של האיחוד האירופי"

msgid "プライバシーポリシーの文字列"
msgstr "טקסט מדיניות הפרטיות"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "אנא הזן כאן את כתובת ה-URL של מדיניות הפרטיות"

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "אנא הוסף את הדברים הבאים למדיניות הפרטיות"

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "כדי לאתר פעילות הונאה, מזהים כגון כתובות IP נשמרים בקובצי Cookie ובמאגר הנתונים. הנתונים השמורים נמחקים לפי שיקול דעתו של המנהל."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "כדי להבטיח שהתמונות יועברו כהלכה רק כאשר הגנת התמונות מופעלת, אנו שומרים נתונים מוצפנים הכוללים את כתובת ה-IP ואת שם קובץ התמונה במסד הנתונים למשך עד 60 דקות."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "אם אתם מגדירים תנאי שימוש, אנא הקפידו לכלול קישור אליהם במדיניות הפרטיות שלכם."

msgid "利用規約の文字列"
msgstr "נוסח תנאי השימוש"

msgid "利用規約のページ"
msgstr "דף התנאים וההגבלות"

msgid "ページ選択なし"
msgstr "לא נבחרה דף"

msgid "検索エンジン等のURL"
msgstr "כתובות URL למנועי חיפוש וכדומה"

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "הגדר את כתובת ה-URL עבור מנועי חיפוש ואתרים דומים, המפנים לדף אחר כאשר לא ניתנה הסכמה"

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "מצב ניפוי באגים, הודעות אזהרה במסוף"

msgid "右クリックの警告メッセージ"
msgstr "הודעת אזהרה בלחיצה ימנית"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "הודעת אזהרה בנוגע להדפסה ולשמירה כקובץ PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "הודעת אזהרה בצילום המסך"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "הודעת אזהרה בנוגע לצילומי מסך חשודים"

msgid "テキスト全選択時の警告メッセージ"
msgstr "הודעת אזהרה כאשר כל הטקסט נבחר"

msgid "ページ保存の警告メッセージ"
msgstr "הודעת אזהרה בנוגע לשמירת הדף"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "הודעה המוצגת בעת העתקה או גזירה"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "הודעה שתוצג בעת הצגת קוד המקור של HTML"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "הודעה שתוצג בראש קוד המקור בעת טשטוש או הגנה על HTML"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "הודעה שתוצג אם אסימון האימות החד-פעמי אינו תקף במהלך הגנת HTML"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "הודעה שתוצג אם קובצי Cookie או JavaScript מושבתים"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "למעשה, זה מוצג רק כאשר JavaScript מושבת"

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "כאשר תמונה מוגנת, היא יורדת, והודעה מוצגת על גבי התמונה"

msgid "HTML難読化 (圧縮)"
msgstr "הסתרת קוד HTML"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "זוהי דחיסת HTML סטנדרטית; ישנם גם אתרי אינטרנט שיכולים לפענח אותה."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "הפעלת אפשרות זו מאפשרת לך להציג את יומן ה-view-source"

msgid "HTML保護"
msgstr "הגנה על HTML"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "הוא מפיק רק את המינימום ההכרחי של HTML — אפילו פחות מאשר בשימוש בדחיסת HTML — והתוכן שבתגית BODY אינו מוצג כלל."

msgid "Firefoxに対しては無効です"
msgstr "זה לא חל על Firefox"

msgid "SEOに著しく影響があります"
msgstr "לכך יש השפעה משמעותית על קידום אתרים"

msgid "HTMLをJavaScriptで描画"
msgstr "הצגת HTML באמצעות JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "כדי לעקוף את Firefox, אנו מציגים את ה-HTML באמצעות JavaScript"

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "הפעלת עיבוד JavaScript תאט באופן משמעותי את מהירות הטעינה של האתר"

msgid "画像の保護"
msgstr "הגנה על תמונות"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "יש להגן על התמונה בכל פעם שמתבצע קריאה לתגית img"

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "הגן על כל התמונות שהועלו לוורדפרס בכל פלט ה-HTML"

msgid "画像をダウンロードから保護します"
msgstr "מונע הורדת תמונות"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "כאשר נתוני התמונות מוגנים, אנו מונעים כמעט את כל ההורדות, מנפיקים כתובות URL חד-פעמיות ייחודיות, מבצעים אימות באמצעות אסימונים המאוחסנים בהפעלה, ומציגים את התמונות באמצעות PHP; דבר זה מונע ביעילות כמעט את כל מקרי גניבת התמונות."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "כאשר נתוני התמונה מוגנים, המטמון אינו פועל, מה שאומר שהאתר ייטען לאט יותר בביקורים הבאים, ובכך ישפיע על קידום האתר במנועי חיפוש"

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "הגנה על נתוני תמונות עלולה להגדיל את העומס על מסד הנתונים"

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "אם תבחר באפשרות הגן על תמונות בכל פעם שמתבצע קריאה לתגית img, המערכת תשתמש ב-add_filter כדי להחיל סינון בעת יצירת תגית ה-img; עם זאת, ייתכן שהדבר לא יפעל כראוי עם ערכות עיצוב מסוימות."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "אם תבחרו באפשרות הגן על כל התמונות שהועלו לוורדפרס בכל פלט ה-HTML, התוסף יתעד כמעט את כל פעולות וורדפרס ויעבד כל תגית img בתוך התוכן. שימו לב כי ייתכן שהאפשרות הזו לא תפעל כראוי עם ערכות עיצוב מסוימות."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "שימו לב: תמונות שסומנו כתמונות מובילות ישותפו כנתוני OGP ולא ניתן להגן עליהן. אם אתם חייבים להגן עליהן, אנא שנו את ההגדרה של פלט תגיות HEAD בהגדרות המתקדמות בעת הפעלת הגנת HTML."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "לא ניתן להגן על פונקציית צילום המסך המובנית כברירת מחדל במערכת ההפעלה"

msgid "画像URLの保護"
msgstr "הגנה על כתובות URL של תמונות"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "יש להשתמש בזה בשילוב עם הגנה על תמונות; כשלעצמו, אין לזה כל תועלת."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "מכיוון שהדף נטען באופן מושהה באמצעות JavaScript, הדבר משפיע על קידום האתר במנועי חיפוש"

msgid "画像のウォーターマーク"
msgstr "סימן מים בתמונה"

msgid "右下"
msgstr "בפינה הימנית התחתונה"

msgid "ランダム位置"
msgstr "מיקום אקראי"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "בשימוש בשילוב עם הגנה על תמונות, סימני מים דינמיים מציינים בבירור את בעלות זכויות היוצרים, תוך שהם מעניקים לצופים את הרושם שהם נמצאים תחת מעקב, ובכך משמשים כאמצעי הרתעה."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "נתמכים רק הפורמטים JPG, PNG ו-WebP"

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "הפעלת אפשרות זו תגביר את העומס על השרת"

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "הפקת אמנות ASCII מקוד מקור HTML במהלך טשטוש והגנה על HTML"

msgid "表示なし"
msgstr "אין תצוגה"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "מציג אמנות ASCII המציינת אזהרה בעת הצגת קוד המקור של ה-HTML באמצעות 'view-source'"

msgid "対象アクションを起こした時の表示デザイン"
msgstr "הצג עיצוב כאשר הפעולה המיועדת מבוצעת"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "עיצוב בסיסי הכולל טקסט שחור על רקע צהוב"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "עיצוב בסגנון אימה הכולל טקסט אדום על רקע שחור"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "עיצוב הכולל טקסט אדום זוהר על רקע שחור"

msgid "対象アクションを起こした時のBGM"
msgstr "מוזיקת רקע המושמעת בעת ביצוע הפעולה המיועדת"

msgid "サウンドなし"
msgstr "אין צליל"

msgid "戦闘＆戦闘勝利 - 1分16.3秒 - 630,056bytes - 64kbps - ライセンス：CC2.1 or later"
msgstr "קרב וניצחון - 1 דקה ו-16.3 שניות - 630,056 בתים - 64 קילובית לשנייה - רישיון: CC 2.1 או גרסה מאוחרת יותר"

msgid "おやじ ショート - 3.8秒 - 32,364bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Dad Short - 3.8 שניות - 32,364 בתים - 64 kbps - רישיון: GPL 2.0 או גרסה מאוחרת יותר"

msgid "おやじ ロング - 23.5秒 - 195,578bytes - 64kbps - ライセンス GPL2.0 or later (C)EJ"
msgstr "Oyaji Long - 23.5 שניות - 195,578 בתים - 64 קילובית לשנייה - רישיון: GPL 2.0 או גרסה מאוחרת יותר"

msgid "ショパン エチュード Op.10-5 黒鍵 打ち込み版 高速版 - 1分0.0秒 - 369,778bytes - 48kbps - ライセンス：CC BY-ND 4.0 or later"
msgstr "אטיוד מס' 5 מתוך אופוס 10 מאת שופן"

msgid "ショパン エチュード Op.10-12 革命 打ち込み版 高速版 - 1分57.6秒 - 724,457bytes - 48kbps -  ライセンス：CC BY-ND 4.0 or later"
msgstr "אטיוד מס' 12 מתוך אופוס 10 של שופן, המהפכה – גרסה שנוצרה במחשב, במהירות גבוהה – 1 דקה ו-57.6 שניות – 724,457 בתים – 48 קילובית לשנייה – רישיון: CC BY-ND 4.0 או גרסה מאוחרת יותר"

