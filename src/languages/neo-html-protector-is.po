msgstr "Retro-stíl hátíðarsveifla – 2,2 sekúndur – 10.536 bæti – 32 kbps – Leyfi: Almannaréttur"

msgid "レトロ風オープン - 42.1秒 - 179,138bytes - 32kbps - ライセンス：パブリックドメイン"
msgstr "Retro-stíls inngangur – 42,1 sekúndur – 179.138 bæti – 32 kbps – Leyfi: Almannasafn"

msgid "警告 by ChatGPT - 3.8秒 - 109,700bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Viðvörun frá ChatGPT - 3,8 sekúndur - 109.700 bæti - 256 kbps - Leyfi: Almenningseign"

msgid "マルウェア検出みたいな緊急感の高い音 その１ by ChatGPT - 3.3秒 - 102,850bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Hljóð af mikilli forgangi sem hljómar eins og viðvörun um spilliforrit – 1. hluti eftir ChatGPT – 3,3 sekúndur – 102.850 bætir – 256 kbps – Leyfi: Almannasafn"

msgid "マルウェア検出みたいな緊急感の高い音 その２ by ChatGPT - 3.3秒 - 103,122bytes - 256kbps - ライセンス：パブリックドメイン"
msgstr "Háttskyndur hljómur sem hljómar eins og viðvörun um spilliforrit, 2. hluti eftir ChatGPT - 3,3 sekúndur - 103.122 bæti - 256 kbps - Leyfi: Almenningseign"

msgid "MRI風サウンド by ChatGPT - 1分14.9秒 - 3,340,392bytes - 320kbps - ライセンス：パブリックドメイン"
msgstr "MRI-stíll hljóð eftir ChatGPT – 1 mínúta 14,9 sekúndur – 3.340.392 bæti – 320 kbps – Leyfi: Almenningseign"

msgid "警告表示中のBGMを選択します"
msgstr "Veldu bakgrunnstónlist sem á að spila á meðan varaun er í gangi."

msgid "びっくりするような雰囲気を作ります"
msgstr "Það skapar óvænt andrúmsloft"

msgid "Firefoxでは音声ブロックされます"
msgstr "Hljóð er lokað í Firefox"

msgid "対象アクションを起こした時のビープ音"
msgstr "Píp þegar tilgreind aðgerð er framkvæmd"

msgid "有効 音量小さ目"
msgstr "Á, hljóðstyrkur lágur"

msgid "有効 音量大き目"
msgstr "Í gangi, hljóðstyrkur stilltur á hátt"

msgid "警告表示中にすべてのキー・マウスイベントでビープ音を鳴らします"
msgstr "Píp hljómar fyrir öll lyklaborðs- og músaratburði á meðan viðvörun er sýnd."

msgid "警告表示中に端末が暴走したかのような雰囲気を作ります"
msgstr "Það gefur til kynna að tækið hafi farið úr böndunum á meðan viðvörunin er sýnd."

msgid "対象アクションを起こした時のマウスカーソルの消去"
msgstr "Fela músbendilinn þegar tilteknum aðgerð er framkvæmd"

msgid "警告表示中にブラウザのエリアのマウスカーソルを消去します"
msgstr "Fylkir músvísarann í vafrasvæðinu á meðan viðvörun er sýnd"

msgid "デバッグモード"
msgstr "V villuleitarhamur"

msgid "妨害＋記録のみ"
msgstr "Truflun + Plötur einungis"

msgid "妨害＋記録＋表示＋リダイレクト"
msgstr "Truflun + Skráning + Skjá birting + Endurbeining"

