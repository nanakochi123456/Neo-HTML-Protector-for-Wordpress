msgstr "Auðkenni"

msgid "タイムスタンプ"
msgstr "Tímastimpill"

msgid "IPアドレス"
msgstr "IP-tala"

msgid "ユーザーエージェント"
msgstr "Notendaboði"

msgid "イベント"
msgstr "Viðburður"

msgid "IPアドレスのデータはありません"
msgstr "Engin gögn eru til fyrir þessa IP-tölu."

msgid "EU GDPR対応"
msgstr "Samræmi við GDPR ESB"

msgid "無効"
msgstr "Ógilt"

msgid "有効"
msgstr "Gildur"

msgid "EU圏内でWordpressを使用する場合、並びにEU圏内も対象とするには必ず有効にしてください"
msgstr "Ef þú notar WordPress innan ESB, eða ef vefsíðan þín beinist að notendum innan ESB, vinsamlegast vertu viss um að þetta sé virkjað."

msgid "確認のボタンが同意する、同意しないのボタンになり、少し動作が変わります"
msgstr "Hnappurinn Staðfesta mun breytast í Samþykkja eða Synja, og hegðunin mun breytast örlítið."

msgid "同意画面の色"
msgstr "Litur samþykkisskjásins"

msgid "自動"
msgstr "Sjálfvirkur"

msgid "ライトモード"
msgstr "Léttur hamur"

msgid "ダークモード"
msgstr "Dimmur hamur"

msgid "同意画面表示中の配色を設定します"
msgstr "Settu litaskemað fyrir samþykkisskjalið"

msgid "同意画面中のコンテンツのぼかし"
msgstr "Óskýrleiki efnis á samþykkisskjánum"

msgid "同意画面表示中のコンテンツのぼかし具合を設定します"
msgstr "Stilla óskýrleika stigs fyrir efni sem birtist á samþykkisskjánum"

msgid "同意画面の透過"
msgstr "Gagnsæi samþykkisskjásins"

msgid "透過なし"
msgstr "Engin gagnsæi"

msgid "同意画面の透過具合を設定します"
msgstr "Stilla gagnsæi samþykkisskjárins"

msgid "お知らせの1行目"
msgstr "Fyrsta lína tilkynningarinnar"

msgid "初回表示で必ず表示されるメッセージです"
msgstr "Þessi skilaboð birtast alltaf í fyrsta sinn sem síðunni er hlaðið."

msgid "お知らせの2行目"
msgstr "Önnur línan í tilkynningunni"

msgid "EU GDPRが有効の際のみ初回表示で必ず表示されるメッセージです"
msgstr "Þessi skilaboð munu alltaf birtast á fyrstu skjánum aðeins þegar GDPR ESB er í gildi."

msgid "お知らせの3行目"
msgstr "Þriðja línan í tilkynningunni"

msgid "プライバシーポリシーのリンクの右側に表示されます"
msgstr "Það mun birtast til hægri við hlekkinn á persónuverndarstefnuna."

msgid "非EU向け確認の文字列"
msgstr "Staðfestingartexti fyrir lönd utan ESB"

msgid "EU GDPR向け同意するの文字列"
msgstr "Samþykkistexti fyrir ESB persónuverndarreglugerðina"

msgid "EU GDPR向け同意しないの文字列"
msgstr "Texti fyrir Ekki veita samþykki samkvæmt GDPR ESB"

msgid "プライバシーポリシーの文字列"
msgstr "Texti persónuverndarstefnu"

msgid "プライバシーポリシーのURLはこちらから設定して下さい"
msgstr "Settu hér vefslóð persónuverndarstefnunnar."

msgid "プライバシーポリシーには以下の内容を追加して下さい"
msgstr "Vinsamlegast bætið eftirfarandi við persónuverndarstefnuna."

msgid "不正操作検知のため、CookieおよびデータベースにIPアドレス等の識別子を保存する。保存されたデータは、管理者の任意のタイミングで削除を行う。"
msgstr "Til að greina sviksamlega starfsemi eru auðkenni, svo sem IP-tölur, vistuð í smákökum og gagnagrunnum. Geymd gögn eru eytt eftir hentisemi stjórnanda."

msgid "画像保護が有効な場合のみ、画像を正常に配信するため、IPアドレスと画像ファイル名をハッシュ化したデータをデータベースに最大60分間保存する。"
msgstr "Til að tryggja að myndir séu afhentar rétt aðeins þegar myndavörn er virk, geymum við hashuð gögn sem innihalda IP-tölu og myndaskránaverknafn í gagnagrunninum í allt að 60 mínútur."

msgid "利用規約を設定する場合、必ずプライバシーポリシーに利用規約のリンクを設置して下さい"
msgstr "Ef þú ert að setja upp notkunarskilmála, vinsamlegast tryggðu að þú bætir við hlekk á þá í persónuverndarstefnu þinni."

msgid "利用規約の文字列"
msgstr "Texti notkunarskilmála"

msgid "利用規約のページ"
msgstr "Skilmálar og skilyrði síða"

msgid "ページ選択なし"
msgstr "Engin síða valin"

msgid "検索エンジン等のURL"
msgstr "URL-slóðir fyrir leitarvélar o.s.frv."

msgid "同意しなかった時に画面遷移する検索エンジンなどのURLを設定します"
msgstr "Settu slóðina fyrir leitarvélar og svipuð vefsvæði sem vísa notendum áfram þegar samþykki er ekki veitt."

msgid "デバッグモード、コンソールの警告メッセージ"
msgstr "V villuleitarhamur, viðvörunarboð á konsólunni"

msgid "右クリックの警告メッセージ"
msgstr "Hægri-smelltu viðvörunarboðskap"

msgid "印刷、PDF保存の警告メッセージ"
msgstr "Viðvörunarboð um prentun og vistun sem PDF"

msgid "スクリーンショットの警告メッセージ"
msgstr "Viðvörunarboðskapur í skjámyndinni"

msgid "スクリーンショットの疑いの警告メッセージ"
msgstr "Viðvörunarboð um grunsamleg skjámyndir"

msgid "テキスト全選択時の警告メッセージ"
msgstr "Viðvörunarboðskapur þegar allt textinn er valið"

msgid "ページ保存の警告メッセージ"
msgstr "Viðvörunarboð um síðusparnað"

msgid "コピー・カットした時に表示するメッセージ"
msgstr "Skilaboð sem birtast þegar afritað er eða skorið"

msgid "HTMLソース表示時に表示するメッセージ"
msgstr "Skilaboð sem birtast þegar skoðað er HTML-uppspretta"

msgid "HTML難読化・保護時にソースの先頭に表示するメッセージ"
msgstr "Skilaboð sem birtast efst í upphafskóðanum þegar HTML er þokað eða verndað"

msgid "HTML保護時に一度限りの認証トークンが異常の場合に表示するメッセージ"
msgstr "Skilaboð sem birtast ef einnota auðkennislykillinn er ógildur við HTML-vernd"

msgid "CookieやJavascriptが有効でない場合に表示するメッセージ"
msgstr "Skilaboð sem birtast ef vafrakökur eða JavaScript eru óvirk"

msgid "実際にはJavascriptが無効時のみ表示されます"
msgstr "Reyndar er þetta aðeins sýnt þegar JavaScript er óvirkjað."

msgid "画像保護時に画像がダウンロードされ、その画像に表示するメッセージ 英語のみ"
msgstr "Þegar mynd er vernduð er hún sótt og skilaboð birt á myndinni"

msgid "HTML難読化 (圧縮)"
msgstr "HTML-óskýrleiki"

msgid "一般的なHTML圧縮です、難読化解除のサイトもあります"
msgstr "Þetta er staðlað HTML-þjöppun; það eru líka vefsíður sem geta afkóðað hana."

msgid "このオプションを有効にするとview-sourceのログが取得できます"
msgstr "Með því að virkja þessa valkost leyfirðu þér að sækja view-source-skráningar."

msgid "HTML保護"
msgstr "HTML-vernd"

msgid "HTML圧縮以上に最小限のHTMLしか出力せず、BODYタグ内の内容が全く出力されなくなります"
msgstr "Það framleiðir aðeins hið allra nauðsynlegasta af HTML—jafnvel minna en þegar HTML-þjöppun er notuð—og efnið innan BODY-merkisins verður alls ekki birt."

msgid "Firefoxに対しては無効です"
msgstr "Þetta á ekki við um Firefox."

msgid "SEOに著しく影響があります"
msgstr "Þetta hefur veruleg áhrif á SEO."

msgid "HTMLをJavaScriptで描画"
msgstr "Sýna HTML með JavaScript"

msgid "Firefox対策としてHTMLをJavaScriptで描画をします"
msgstr "Til að komast hjá Firefox rennum við HTML-ið með JavaScript."

msgid "JavaScript描画で有効にするとウェブサイトの表示速度が著しく遅くなります"
msgstr "Að virkja JavaScript-sýningu mun verulega hægja á hleðsluhraða vefsíðunnar."

msgid "画像の保護"
msgstr "Myndavernd"

msgid "imgタグが呼び出されるごとに画像を保護"
msgstr "Verndaðu myndina í hvert sinn sem img-merkið er kallað."

msgid "出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護"
msgstr "Verndaðu allar myndir sem hlaðnar eru upp í WordPress innan alls HTML-útputsins."

msgid "画像をダウンロードから保護します"
msgstr "Verndar myndir gegn niðurhali"

msgid "画像データを保護した時にはほぼ完全なるダウンロードを阻止し、完全なるワンタイムURLを発行し、セッションに保存されたトークンで認証し、phpから画像を表示します、その為ほぼ完全な画像盗用を防ぎます"
msgstr "Þegar myndagögn eru vernduð hindrum við nánast allar niðurhal, útveguðum einstakar einnota vefslóðir, auðkennum með tokenum sem eru geymd í lotunni og birtum myndirnar í gegnum PHP; þetta kemur í raun í veg fyrir nánast alla myndastuld."

msgid "画像データを保護した時には画像のキャッシュが効かないため、次回訪問時にサイトの読み込みが遅くなるため、SEOに影響があります"
msgstr "Þegar myndagögn eru vernduð virkar skyndiminni ekki, sem þýðir að vefsvæðið hleðst hægar við endurkomur og hefur þar með áhrif á SEO."

msgid "画像データを保護した時には、データベースの負荷が高くなる可能性があります"
msgstr "Verndun myndagagna getur aukið álagið á gagnagrunninn."

msgid "「imgタグが呼び出されるごとに画像を保護」の場合は、add_filterを使用し、imgタグの発行時にフィルタリングを行います、テーマによっては正しく動作しません"
msgstr "Ef þú velur 'Verndar myndir hvenær sem img-merki er kallað', notar kerfið add_filter til að beita síun þegar img-merki er búið til; þó gæti þetta ekki virkað rétt með sumum þemum."

msgid "「出力される全HTMLのうち、Wordpressにアップロードされた画像をすべて保護」の場合は、Wordpressのほぼすべての動作をキャプチャし、コンテンツ内のimgタグについてすべて処理します。テーマによっては正しく動作しません"
msgstr "Ef þú velur 'Verndar allar myndir sem hlaðnar eru inn í WordPress í allri HTML-útgáfu', mun viðbótin fanga nánast allar WordPress-aðgerðir og vinna úr hverri img-tagg innan efnisins. Vinsamlegast athugið að þetta gæti ekki virkað rétt með sumum þemum."

msgid "なお、アイキャッチに指定した画像はOGPとして拡散されますので保護できません。どうしても保護すべき場合は高度な設定でHTML保護時のHEADタグの出力の選択を変更してください"
msgstr "Vinsamlegast athugið að myndir sem merktar eru sem aðalmyndir verða deilt sem OGP-gögn og er ekki hægt að vernda þær. Ef þið verðið endilega að vernda þær, breyttu stillingunni fyrir HEAD-merki í háþróuðum stillingum þegar HTML-vernd er virkjuð."

msgid "OS標準搭載のスクリーンショット機能を保護することはできません"
msgstr "Skjámyndatökuaðgerðin sem er innifalin sem staðalbúnaður í stýrikerfinu er ekki hægt að vernda."

msgid "画像URLの保護"
msgstr "Verndun mynda-URL-slóða"

msgid "画像の保護と組み合わせて使用します、単体では意味がありません"
msgstr "Þetta skal nota í samspili við myndavörn; eitt og sér hefur það engan tilgang."

msgid "JavaScriptにより遅延読まれますのでSEOに影響があります"
msgstr "Þar sem það er hlaðið letilega í gegnum JavaScript, hefur þetta áhrif á SEO."

msgid "画像のウォーターマーク"
msgstr "Myndvatnsmerki"

msgid "右下"
msgstr "Neðst til hægri"

msgid "ランダム位置"
msgstr "Handahófskennd staða"

msgid "画像の保護と組み合わせて使用します、動的な透かしで著作権を明示しつつ、閲覧者に監視されている印象を与え抑止力を高めます"
msgstr "Þegar notaðar eru í tengslum við myndavörn sýna hreyfanleg vatnsmerki skýrt hver hefur höfundarréttinn og gefa áhorfendum til kynna að verið sé að fylgjast með þeim, sem hefur fælingarhrif."

msgid "JPG形式、PNG形式、WebP形式のみ対応します"
msgstr "Aðeins JPG-, PNG- og WebP-snið eru studd."

msgid "有効にするとサーバーの負荷が高くなります"
msgstr "Að virkja þetta mun auka álagið á netþjóninum."

msgid "HTML難読化・保護時のHTMLソースコードのアスキーアートの出力"
msgstr "Úttak ASCII-listar úr HTML-upphafskóða við HTML-óskýringu og verndun"

msgid "表示なし"
msgstr "Engin skjástilling"

msgid "view-sourceでHTMLソース表示をした時に警告の意思を示すアスキーアートを表示します"
msgstr "Sýnir ASCII-list sem gefur til kynna viðvörun þegar skoðað er HTML-uppspretta með 'view-source'."

msgid "対象アクションを起こした時の表示デザイン"
msgstr "Sýna hönnun þegar markaðar aðgerðar er framkvæmt"

msgid "黄色の背景の黒文字のベーシックデザイン"
msgstr "Grunnleg hönnun með svörtum texta á gulum bakgrunni"

msgid "黒色の背景の赤文字のホラー風デザイン"
msgstr "Hrollvekjandi hönnun með rauðum stöfum á svörtum bakgrunni"

msgid "黒色の背景の赤文字の光る文字のデザイン"
msgstr "Hönnun með glóandi rauðum texta á svörtum bakgrunni"

msgid "対象アクションを起こした時のBGM"
msgstr "Bakgrunnstónlist sem spilar þegar markaða aðgerðin er framkvæmd"

msgid "サウンドなし"
msgstr "Enginn hljómur"

